{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    background: {{ section.settings.section_background_gradient_start }};
    {% if section.settings.enable_gradient %}
      background: linear-gradient(
        {{ section.settings.gradient_angle }}deg,
        {{ section.settings.section_background_gradient_start }} 0%,
        {{ section.settings.section_background_gradient_end }} 100%
      );
    {% endif %}
  }

  .ai-faq-container-{{ ai_gen_id }} {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    padding-left: {{ section.settings.container_padding_horizontal }}px;
    padding-right: {{ section.settings.container_padding_horizontal }}px;
  }

  .ai-faq-header-{{ ai_gen_id }} {
    text-align: {{ section.settings.header_text_align }};
    margin-bottom: {{ section.settings.header_margin_bottom }}px;
  }

  .ai-faq-eyebrow-{{ ai_gen_id }} {
    font-size: {{ section.settings.eyebrow_font_size }}px;
    font-weight: {{ section.settings.eyebrow_font_weight }};
    text-transform: {{ section.settings.eyebrow_text_transform }};
    letter-spacing: {{ section.settings.eyebrow_letter_spacing }};
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: {{ section.settings.eyebrow_margin_bottom }}px;
    line-height: {{ section.settings.eyebrow_line_height }};
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    font-size: {{ section.settings.heading_font_size }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    color: {{ section.settings.heading_color }};
    line-height: {{ section.settings.heading_line_height }};
    letter-spacing: {{ section.settings.heading_letter_spacing }};
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
  }

  .ai-faq-accordion-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.accordion_item_spacing }}px;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    background-color: {{ section.settings.item_background_color }};
    border: {{ section.settings.item_border_width }}px {{ section.settings.item_border_style }} {{ section.settings.item_border_color }};
    border-radius: {{ section.settings.item_border_radius }}px;
    padding-left: {{ section.settings.item_padding_horizontal }}px;
    padding-right: {{ section.settings.item_padding_horizontal }}px;
    box-shadow: {{ section.settings.item_shadow_x }}px {{ section.settings.item_shadow_y }}px {{ section.settings.item_shadow_blur }}px {{ section.settings.item_shadow_spread }}px {{ section.settings.item_shadow_color }};
    overflow: hidden;
  }

  .ai-faq-question-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-align: left;
    background: none;
    border: none;
    padding-top: {{ section.settings.question_padding_vertical }}px;
    padding-bottom: {{ section.settings.question_padding_vertical }}px;
    cursor: pointer;
    font-size: {{ section.settings.question_font_size }}px;
    font-weight: {{ section.settings.question_font_weight }};
    color: {{ section.settings.question_color }};
    line-height: 1.2;
    transition: color 0.3s ease;
  }

  .ai-faq-question-{{ ai_gen_id }}:hover {
    color: {{ section.settings.question_hover_color }};
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    flex: 1;
    padding-right: 16px;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ section.settings.icon_color }};
    stroke-width: {{ section.settings.icon_stroke_width }};
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: rotate({{ section.settings.icon_rotation_active }}deg);
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    font-size: {{ section.settings.answer_font_size }}px;
    color: {{ section.settings.answer_color }};
    line-height: 1.5;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    overflow: hidden;
    padding-bottom: 0;
    transition: padding-bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    grid-template-rows: 1fr;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-content-{{ ai_gen_id }} {
    padding-bottom: {{ section.settings.answer_padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-section-{{ ai_gen_id }} {
      padding-top: {{ section.settings.section_padding_top_mobile }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_mobile }}px;
    }
    .ai-faq-container-{{ ai_gen_id }} {
      padding-left: {{ section.settings.container_padding_horizontal_mobile }}px;
      padding-right: {{ section.settings.container_padding_horizontal_mobile }}px;
    }
  }
{% endstyle %}

<div id="FAQ-{{ ai_gen_id }}" class="ai-faq-section-{{ ai_gen_id }}" {{ section.shopify_attributes }}>
  <div class="ai-faq-container-{{ ai_gen_id }}">
    <div class="ai-faq-header-{{ ai_gen_id }}">
      {% if section.settings.eyebrow_text != blank %}
        <p class="ai-faq-eyebrow-{{ ai_gen_id }}">{{ section.settings.eyebrow_text }}</p>
      {% endif %}
      {% if section.settings.heading_text != blank %}
        <h2 class="ai-faq-heading-{{ ai_gen_id }}">{{ section.settings.heading_text }}</h2>
      {% endif %}
    </div>

    <div class="ai-faq-accordion-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% assign question_key = 'faq_question_' | append: i %}
        {% assign answer_key = 'faq_answer_' | append: i %}
        {% assign question = section.settings[question_key] %}
        {% assign answer = section.settings[answer_key] %}

        {% if question != blank and answer != blank %}
          <div class="ai-faq-item-{{ ai_gen_id }}" data-faq-item>
            <button class="ai-faq-question-{{ ai_gen_id }}" aria-expanded="false" data-faq-trigger>
              <span class="ai-faq-question-text-{{ ai_gen_id }}">{{ question }}</span>
              <span class="ai-faq-icon-{{ ai_gen_id }}">
                {% if section.settings.icon_style == 'plus' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% elsif section.settings.icon_style == 'chevron' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <polyline points="6 9 12 15 18 9" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% elsif section.settings.icon_style == 'arrow' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="19 12 12 19 5 12" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% endif %}
              </span>
            </button>
            <div class="ai-faq-answer-{{ ai_gen_id }}" data-faq-content>
              <div class="ai-faq-answer-content-{{ ai_gen_id }}">
                {{ answer }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    const initFaq = () => {
      const container = document.querySelector('#FAQ-{{ ai_gen_id }}');
      if (!container) return;

      const items = container.querySelectorAll('[data-faq-item]');
      
      items.forEach((item, index) => {
        const trigger = item.querySelector('[data-faq-trigger]');
        
        trigger.addEventListener('click', () => {
          const isActive = item.classList.contains('active');

          {% unless section.settings.allow_multiple_open %}
            items.forEach((otherItem) => {
              if (otherItem !== item) {
                otherItem.classList.remove('active');
                otherItem.querySelector('[data-faq-trigger]').setAttribute('aria-expanded', 'false');
              }
            });
          {% endunless %}

          if (isActive) {
            item.classList.remove('active');
            trigger.setAttribute('aria-expanded', 'false');
          } else {
            item.classList.add('active');
            trigger.setAttribute('aria-expanded', 'true');
          }
        });

        {% if section.settings.open_first_item %}
          if (index === 0) {
            item.classList.add('active');
            trigger.setAttribute('aria-expanded', 'true');
          }
        {% endif %}
      });
    };

    initFaq();
    document.addEventListener('shopify:section:load', (e) => {
      if (e.detail.sectionId === '{{ section.id }}') initFaq();
    });
  })();
</script>

