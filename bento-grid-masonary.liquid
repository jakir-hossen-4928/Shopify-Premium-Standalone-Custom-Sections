{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mb }}px;
    padding-bottom: {{ section.settings.padding_bottom_mb }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Header Styling */
  .gallery-header-{{ section.id }} {
    text-align: {{ section.settings.header_align }};
    margin-bottom: {{ section.settings.header_margin }}px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 15px;
  }

  .gallery-title-{{ section.id }} {
    margin: 0 0 10px 0;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_mb }}px;
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.2;
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
  }

  .gallery-subtitle-{{ section.id }} {
    margin: 0;
    color: {{ section.settings.sub_color }};
    font-size: {{ section.settings.sub_size_mb }}px;
    font-weight: {{ section.settings.sub_weight }};
    line-height: 1.5;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
  }

  @media screen and (min-width: 750px) {
    .gallery-title-{{ section.id }} {
      font-size: {{ section.settings.title_size_dt }}px;
    }
    .gallery-subtitle-{{ section.id }} {
      font-size: {{ section.settings.sub_size_dt }}px;
    }
  }

  /* Bento Grid Engine */
  .gallery-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .gallery-grid-{{ section.id }} {
    display: grid;
    gap: {{ section.settings.gap_mb }}px;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: {{ section.settings.row_height_mb }}px;
  }

  @media screen and (max-width: 749px) {
    .gallery-item-{{ section.id }}:nth-child(3n) {
      grid-column: span 2;
    }
  }

  @media screen and (min-width: 750px) {
    .gallery-grid-{{ section.id }} {
      gap: {{ section.settings.gap_dt }}px;
      grid-template-columns: repeat({{ section.settings.cols_desktop }}, 1fr);
      grid-auto-rows: {{ section.settings.row_height_dt }}px;
      grid-auto-flow: dense;
    }

    /* Auto Bento Pattern (Perfectly Balanced 8-Item Repeating Pattern) */
    .gallery-item-{{ section.id }}:nth-child(8n + 1) {
      grid-column: span 2;
      grid-row: span 2;
    }
    .gallery-item-{{ section.id }}:nth-child(8n + 2) {
      grid-column: span 1;
      grid-row: span 1;
    }
    .gallery-item-{{ section.id }}:nth-child(8n + 3) {
      grid-column: span 1;
      grid-row: span 1;
    }
    .gallery-item-{{ section.id }}:nth-child(8n + 4) {
      grid-column: span 2;
      grid-row: span 1;
    }
    .gallery-item-{{ section.id }}:nth-child(8n + 5) {
      grid-column: span 1;
      grid-row: span 1;
    }
    .gallery-item-{{ section.id }}:nth-child(8n + 6) {
      grid-column: span 1;
      grid-row: span 1;
    }
    .gallery-item-{{ section.id }}:nth-child(8n + 7) {
      grid-column: span 2;
      grid-row: span 2;
    }
    .gallery-item-{{ section.id }}:nth-child(8n + 8) {
      grid-column: span 2;
      grid-row: span 1;
    }
  }

  .gallery-item-{{ section.id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    background: #f0f0f0;
  }

  .gallery-item-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .gallery-item-{{ section.id }}:hover img {
    transform: scale({{ section.settings.hover_zoom }});
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
    <div class="gallery-header-{{ section.id }}">
      {%- if section.settings.title != blank -%}
        <h2 class="gallery-title-{{ section.id }}">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="gallery-subtitle-{{ section.id }}">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="gallery-container-{{ section.id }}">
    <div class="gallery-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="gallery-item-{{ section.id }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag:
              loading: 'lazy',
              widths: '375, 550, 750, 1100, 1200',
              alt: block.settings.image.alt | escape
            }}
          {%- else -%}
             {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

