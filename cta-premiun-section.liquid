{% comment %}
  ============================================================
  WO PREMIUM CTA SECTION - Fully Customizable Refactor
  ============================================================
{% endcomment %}

{%- liquid
  assign font_title = section.settings.font_title
  assign font_eyebrow = section.settings.font_eyebrow
  assign font_text = section.settings.font_text
  assign font_btn = section.settings.font_btn
-%}

<style>
  {{ font_title | font_face: display: 'swap' }}
  {{ font_eyebrow | font_face: display: 'swap' }}
  {{ font_text | font_face: display: 'swap' }}
  {{ font_btn | font_face: display: 'swap' }}

  #shopify-section-{{ section.id }} {
    --wo-cta-bg: {{ section.settings.bg_color }};
    --wo-cta-title: {{ section.settings.title_color }};
    --wo-cta-text: {{ section.settings.text_color }};
    --wo-cta-accent: {{ section.settings.accent_color }};

    --wo-cta-btn-bg: {{ section.settings.btn_bg_color }};
    --wo-cta-btn-text: {{ section.settings.btn_text_color }};
    --wo-cta-btn-glow: {{ section.settings.btn_glow_color }};

    --wo-cta-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --wo-cta-overlay-color: {{ section.settings.overlay_color }};

    --wo-cta-section-overlay: {{ section.settings.section_overlay_opacity | divided_by: 100.0 }};
    --wo-cta-section-overlay-color: {{ section.settings.section_overlay_color }};

    --wo-cta-title-desk: {{ section.settings.title_size_desk }}px;
    --wo-cta-text-desk: {{ section.settings.text_size_desk }}px;
    --wo-cta-label-desk: {{ section.settings.label_size_desk }}px;

    --wo-cta-title-mob: {{ section.settings.title_size_mob }}px;
    --wo-cta-text-mob: {{ section.settings.text_size_mob }}px;

    --wo-cta-pad-top-desk: {{ section.settings.pad_top_desk }}px;
    --wo-cta-pad-bot-desk: {{ section.settings.pad_bot_desk }}px;
    --wo-cta-pad-top-mob: {{ section.settings.pad_top_mob }}px;
    --wo-cta-pad-bot-mob: {{ section.settings.pad_bot_mob }}px;

    --wo-cta-gap: {{ section.settings.col_gap }}px;
    --wo-cta-radius: {{ section.settings.section_radius }}px;
    --wo-cta-inner-radius: {{ section.settings.inner_radius }}px;
    --wo-cta-container-max-width: {{ section.settings.container_max_width }}px;

    --font-family-title: {{ font_title.family }}, {{ font_title.fallback_families }};
    --font-family-eyebrow: {{ font_eyebrow.family }}, {{ font_eyebrow.fallback_families }};
    --font-family-text: {{ font_text.family }}, {{ font_text.fallback_families }};
    --font-family-btn: {{ font_btn.family }}, {{ font_btn.fallback_families }};
  }

  .wo-cta-section {
    position: relative;
    background-color: var(--wo-cta-bg);
    padding: var(--wo-cta-pad-top-desk) clamp(20px, 5vw, 80px) var(--wo-cta-pad-bot-desk);
    overflow: hidden;
    border-radius: var(--wo-cta-radius);
  }

  .wo-cta-section-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .wo-cta-section-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1.04);
    transition: transform 12s ease-in-out;
  }

  .wo-cta-section.is-visible .wo-cta-section-bg img {
    transform: scale(1);
  }

  .wo-cta-section-bg-overlay {
    position: absolute;
    inset: 0;
    background-color: var(--wo-cta-section-overlay-color);
    opacity: var(--wo-cta-section-overlay);
    z-index: 1;
  }

  .wo-cta-section-bg-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(0,0,0,{{ section.settings.gradient_opacity_1 | divided_by: 100.0 }}) 0%,
      rgba(0,0,0,{{ section.settings.gradient_opacity_2 | divided_by: 100.0 }}) 50%,
      rgba(0,0,0,{{ section.settings.gradient_opacity_3 | divided_by: 100.0 }}) 100%
    );
    z-index: 2;
  }

  .wo-cta-section-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    opacity: 0.35;
    z-index: 3;
  }

  .wo-cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--wo-cta-gap);
    align-items: center;
    max-width: var(--wo-cta-container-max-width);
    margin: 0 auto;
    position: relative;
    z-index: 4;
  }

  .wo-cta-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .wo-cta-label {
    font-family: var(--font-family-eyebrow);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: var(--wo-cta-label-desk);
    font-weight: {{ section.settings.font_weight_eyebrow }};
    letter-spacing: {{ section.settings.letter_spacing_eyebrow | divided_by: 10.0 }}px;
    text-transform: {{ section.settings.text_transform_eyebrow }};
    color: var(--wo-cta-accent);
    margin-bottom: 20px;
  }

  .wo-cta-label::before {
    {% if section.settings.show_eyebrow_line %}content: '';{% endif %}
    display: inline-block;
    width: 28px;
    height: 2px;
    background-color: var(--wo-cta-accent);
    border-radius: 2px;
  }

  .wo-cta-heading {
    font-family: var(--font-family-title);
    font-size: var(--wo-cta-title-desk);
    font-weight: {{ section.settings.font_weight_title }};
    color: var(--wo-cta-title);
    line-height: {{ section.settings.line_height_title }};
    letter-spacing: {{ section.settings.letter_spacing_title | divided_by: 10.0 }}px;
    margin: 0 0 24px 0;
    text-transform: {{ section.settings.text_transform_title }};
  }

  .wo-cta-heading em {
    font-style: normal;
    color: var(--wo-cta-accent);
    position: relative;
    display: inline-block;
  }

  .wo-cta-heading em::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0; right: 0;
    height: 3px;
    background: var(--wo-cta-accent);
    border-radius: 2px;
    opacity: 0.4;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1) 0.9s;
  }

  .wo-cta-section.is-visible .wo-cta-heading em::after {
    transform: scaleX(1);
  }

  .wo-cta-desc {
    font-family: var(--font-family-text);
    font-size: var(--wo-cta-text-desk);
    color: var(--wo-cta-text);
    line-height: {{ section.settings.line_height_text }};
    font-weight: {{ section.settings.font_weight_text }};
    margin: 0 0 40px 0;
    max-width: {{ section.settings.desc_max_width }}px;
  }

  .wo-cta-stats {
    display: flex;
    gap: 36px;
    flex-wrap: wrap;
  }

  .wo-cta-stat {
    display: flex;
    flex-direction: column;
  }

  .wo-cta-stat-num {
    font-size: {{ section.settings.stat_num_size }}px;
    font-weight: 800;
    color: var(--wo-cta-title);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .wo-cta-stat-num span {
    color: var(--wo-cta-accent);
  }

  .wo-cta-stat-label {
    font-size: {{ section.settings.stat_label_size }}px;
    color: var(--wo-cta-text);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-top: 6px;
    font-weight: 500;
  }

  .wo-cta-stat + .wo-cta-stat {
    padding-left: 36px;
    border-left: 1px solid rgba(255,255,255,0.12);
  }

  .wo-cta-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    gap: 32px;
  }

  .wo-cta-img-card {
    position: relative;
    width: 100%;
    border-radius: var(--wo-cta-inner-radius);
    overflow: hidden;
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
  }

  .wo-cta-img-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .wo-cta-img-card:hover img {
    transform: scale(1.05);
  }

  .wo-cta-img-overlay {
    position: absolute;
    inset: 0;
    background-color: var(--wo-cta-overlay-color);
    opacity: var(--wo-cta-overlay);
    z-index: 1;
    pointer-events: none;
  }

  .wo-cta-img-overlay-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0,0,0,0.35) 0%,
      transparent 60%,
      rgba(0,0,0,0.2) 100%
    );
    z-index: 2;
    pointer-events: none;
  }

  .wo-cta-live-dot {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px;
    padding: 6px 12px 6px 10px;
  }

  .wo-cta-live-dot-circle {
    width: 8px;
    height: 8px;
    background: {{ section.settings.live_badge_color }};
    border-radius: 50%;
    animation: wo-live-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes wo-live-pulse {
    0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 {{ section.settings.live_badge_color | color_modify: 'alpha', 0.5 }}; }
    50%       { opacity: 0.8; transform: scale(1.15); box-shadow: 0 0 0 5px {{ section.settings.live_badge_color | color_modify: 'alpha', 0 }}; }
  }

  .wo-cta-live-dot-text {
    font-size: 10px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .wo-cta-img-badge {
    position: absolute;
    bottom: 18px;
    left: 18px;
    z-index: 3;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 10px 16px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .wo-cta-img-badge-title {
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.05em;
  }

  .wo-cta-img-badge-sub {
    font-size: 10px;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .wo-cta-btn-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .wo-cta-btn-wrap {
    position: relative;
    display: inline-block;
    z-index: 2;
    width: 100%;
  }

  .wo-cta-btn {
    font-family: var(--font-family-btn);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: {{ section.settings.btn_padding_vertical }}px {{ section.settings.btn_padding_horizontal }}px;
    background-color: var(--wo-cta-btn-bg);
    color: var(--wo-cta-btn-text);
    font-size: {{ section.settings.btn_font_size }}px;
    font-weight: {{ section.settings.btn_font_weight }};
    letter-spacing: {{ section.settings.btn_letter_spacing | divided_by: 10.0 }}px;
    text-transform: {{ section.settings.btn_text_transform }};
    text-decoration: none;
    border-radius: {{ section.settings.btn_border_radius }}px;
    position: relative;
    z-index: 2;
    width: 100%;
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.3s ease;
    will-change: transform;
  }

  .wo-cta-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.28), transparent);
    transform: skewX(-20deg);
    transition: left 0.65s ease;
    pointer-events: none;
  }

  .wo-cta-btn:hover::before {
    left: 150%;
  }

  .wo-cta-btn-arrow {
    display: inline-flex;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .wo-cta-btn:hover .wo-cta-btn-arrow {
    transform: translateX(5px);
  }

  .wo-cta-btn-wrap::after {
    {% if section.settings.enable_btn_glow %}content: '';{% endif %}
    position: absolute;
    top: 15%; left: 5%; right: 5%; bottom: -15%;
    background: var(--wo-cta-btn-glow);
    filter: blur(28px);
    opacity: 0.45;
    z-index: 1;
    border-radius: 12px;
    animation: wo-pulse-glow 3s ease-in-out infinite alternate;
    transition: opacity 0.4s ease, filter 0.4s ease;
  }

  @keyframes wo-pulse-glow {
    0%   { transform: scale(0.92); opacity: 0.35; }
    100% { transform: scale(1.08); opacity: 0.65; }
  }

  .wo-cta-btn-wrap:hover .wo-cta-btn {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.35);
  }

  .wo-cta-btn-wrap:hover::after {
    opacity: 0.85;
    filter: blur(34px);
    animation-play-state: paused;
  }

  .wo-cta-btn-wrap:active .wo-cta-btn {
    transform: scale(0.97) translateY(0);
  }

  .wo-cta-secondary-link {
    font-family: var(--font-family-btn);
    font-size: 12px;
    color: var(--wo-cta-text);
    text-decoration: none;
    letter-spacing: 0.08em;
    opacity: 0.7;
    transition: opacity 0.2s ease, color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .wo-cta-secondary-link:hover {
    opacity: 1;
    color: var(--wo-cta-title);
  }

  .wo-cta-trust {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .wo-cta-trust-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    color: var(--wo-cta-text);
    opacity: 0.65;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .wo-cta-trust-sep {
    width: 3px;
    height: 3px;
    background: var(--wo-cta-text);
    border-radius: 50%;
    opacity: 0.3;
  }

  .wo-cta-right.no-image {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: var(--wo-cta-inner-radius);
    padding: 48px 40px;
  }

  .wo-anim-reveal {
    opacity: 0;
    transform: translateY(28px) scale(0.98);
    filter: blur(6px);
    transition:
      opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.85s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.85s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity, filter;
  }

  .wo-anim-reveal-right {
    opacity: 0;
    transform: translateX(28px) scale(0.98);
    filter: blur(6px);
    transition:
      opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.85s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.85s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity, filter;
  }

  .wo-cta-section.is-visible .wo-anim-reveal,
  .wo-anim-reveal-right {
    opacity: 1;
    transform: translateY(0) translateX(0) scale(1);
    filter: blur(0);
  }

  .wo-cta-left .wo-anim-reveal:nth-child(1) { transition-delay: 0.05s; }
  .wo-cta-left .wo-anim-reveal:nth-child(2) { transition-delay: 0.18s; }
  .wo-cta-left .wo-anim-reveal:nth-child(3) { transition-delay: 0.30s; }
  .wo-cta-left .wo-anim-reveal:nth-child(4) { transition-delay: 0.42s; }

  .wo-cta-right .wo-anim-reveal-right:nth-child(1) { transition-delay: 0.25s; }
  .wo-cta-right .wo-anim-reveal-right:nth-child(2) { transition-delay: 0.40s; }
  .wo-cta-right .wo-anim-reveal-right:nth-child(3) { transition-delay: 0.52s; }

  @media (max-width: 900px) {
    .wo-cta-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .wo-cta-right { order: {{ section.settings.mobile_order }}; }
    .wo-cta-right.no-image { order: 1; padding: 36px 24px; }
    .wo-anim-reveal-right { transform: translateY(28px) scale(0.98); }
  }

  @media (max-width: 768px) {
    .wo-cta-section { padding: var(--wo-cta-pad-top-mob) 20px var(--wo-cta-pad-bot-mob); }
    .wo-cta-heading { font-size: var(--wo-cta-title-mob); margin-bottom: 18px; }
    .wo-cta-desc { font-size: var(--wo-cta-text-mob); margin-bottom: 32px; }
    .wo-cta-btn { padding: 18px 28px; font-size: 11px; }
    .wo-cta-stats { gap: 20px; }
    .wo-cta-stat + .wo-cta-stat { padding-left: 20px; }
    .wo-cta-stat-num { font-size: 22px; }
    .wo-cta-img-card { aspect-ratio: {{ section.settings.image_aspect_ratio_mobile }}; }
    .wo-cta-section-bg-grad {
      background: linear-gradient(
        180deg,
        rgba(0,0,0,{{ section.settings.gradient_opacity_1 }}) 0%,
        rgba(0,0,0,{{ section.settings.gradient_opacity_3 }}) 100%
      );
    }
  }
</style>

{%- liquid
  assign has_card_image = false
  assign has_section_bg = false
  if section.settings.bg_image != blank
    assign has_card_image = true
  endif
  if section.settings.section_bg_image != blank
    assign has_section_bg = true
  endif
-%}

<section class="wo-cta-section" id="wo-cta-{{ section.id }}">

  {%- if has_section_bg -%}
    <div class="wo-cta-section-bg">
      {{- section.settings.section_bg_image
          | image_url: width: 2000
          | image_tag:
              loading: 'lazy',
              widths: '800, 1200, 1600, 2000',
              alt: section.settings.section_bg_alt -}}
    </div>
    <div class="wo-cta-section-bg-overlay"></div>
    {%- if section.settings.section_bg_grad -%}
      <div class="wo-cta-section-bg-grad"></div>
    {%- endif -%}
  {%- endif -%}

  <div class="wo-cta-section-noise"></div>

  <div class="wo-cta-grid">

    <!-- LEFT — CONTENT -->
    <div class="wo-cta-left">

      {%- if section.settings.eyebrow != blank -%}
        <div class="wo-cta-label wo-anim-reveal">{{ section.settings.eyebrow }}</div>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="wo-cta-heading wo-anim-reveal">{{ section.settings.title | newline_to_br }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p class="wo-cta-desc wo-anim-reveal">{{ section.settings.text | newline_to_br }}</p>
      {%- endif -%}

      {%- assign stat_blocks = section.blocks | where: 'type', 'stat' -%}
      {%- if stat_blocks.size > 0 -%}
        <div class="wo-cta-stats wo-anim-reveal">
          {%- for block in stat_blocks -%}
            <div class="wo-cta-stat" {{ block.shopify_attributes }}>
              <div class="wo-cta-stat-num">
                {{ block.settings.number }}<span>{{ block.settings.suffix }}</span>
              </div>
              <div class="wo-cta-stat-label">{{ block.settings.label }}</div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>

    <!-- RIGHT — IMAGE + BUTTON -->
    <div class="wo-cta-right{% unless has_card_image %} no-image{% endunless %}">

      {%- if has_card_image -%}
        <div class="wo-cta-img-card wo-anim-reveal-right">
          {{- section.settings.bg_image
              | image_url: width: 900
              | image_tag:
                  loading: 'lazy',
                  widths: '400, 600, 900',
                  alt: section.settings.img_alt -}}

          <div class="wo-cta-img-overlay"></div>
          <div class="wo-cta-img-overlay-grad"></div>

          {%- if section.settings.show_live_badge -%}
            <div class="wo-cta-live-dot">
              <div class="wo-cta-live-dot-circle"></div>
              <span class="wo-cta-live-dot-text">
                {{ section.settings.live_badge_text }}
              </span>
            </div>
          {%- endif -%}

          {%- if section.settings.img_badge_title != blank -%}
            <div class="wo-cta-img-badge">
              <div class="wo-cta-img-badge-title">{{ section.settings.img_badge_title }}</div>
              {%- if section.settings.img_badge_sub != blank -%}
                <div class="wo-cta-img-badge-sub">{{ section.settings.img_badge_sub }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="wo-cta-btn-group wo-anim-reveal-right">
        {%- if section.settings.btn_text != blank and section.settings.btn_url != blank -%}
          <div class="wo-cta-btn-wrap" id="wo-magnetic-{{ section.id }}">
            <a href="{{ section.settings.btn_url }}" class="wo-cta-btn">
              {{ section.settings.btn_text }}
              {%- if section.settings.show_btn_icon -%}
                <span class="wo-cta-btn-arrow">
                  {{ section.settings.btn_icon_svg | default: '<svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>' }}
                </span>
              {%- endif -%}
            </a>
          </div>
        {%- endif -%}

        {%- assign trust_blocks = section.blocks | where: 'type', 'trust' -%}
        {%- if trust_blocks.size > 0 -%}
          <div class="wo-cta-trust">
            {%- for block in trust_blocks -%}
              <div class="wo-cta-trust-item" {{ block.shopify_attributes }}>
                {%- if block.settings.svg != blank -%}
                  {{ block.settings.svg }}
                {%- else -%}
                  <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                  </svg>
                {%- endif -%}
                {{ block.settings.text }}
              </div>
              {%- unless forloop.last -%}
                <div class="wo-cta-trust-sep"></div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.secondary_text != blank and section.settings.secondary_url != blank -%}
          <a href="{{ section.settings.secondary_url }}" class="wo-cta-secondary-link">
            {{ section.settings.secondary_text }}
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

    </div>

  </div>
</section>

<script>
(function () {
  const section = document.getElementById('wo-cta-{{ section.id }}');
  if (!section) return;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        section.classList.add('is-visible');
        observer.unobserve(section);
      }
    });
  }, { threshold: 0.2 });

  observer.observe(section);

  {% if section.settings.enable_magnetic %}
  const btnWrap = document.getElementById('wo-magnetic-{{ section.id }}');
  const btn     = btnWrap ? btnWrap.querySelector('.wo-cta-btn') : null;

  if (btnWrap && btn) {
    let raf;
    btnWrap.addEventListener('mousemove', (e) => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const rect = btnWrap.getBoundingClientRect();
        const x    = e.clientX - rect.left  - rect.width  / 2;
        const y    = e.clientY - rect.top   - rect.height / 2;
        btn.style.transform = `translate(${x * 0.18}px, ${y * 0.18}px) scale(1.02)`;
      });
    });
    btnWrap.addEventListener('mouseleave', () => {
      cancelAnimationFrame(raf);
      btn.style.transform = '';
    });
  }
  {% endif %}

  {% if section.settings.enable_counter %}
  const statNums = section.querySelectorAll('.wo-cta-stat-num');
  if (statNums.length) {
    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el         = entry.target;
        const suffix     = el.querySelector('span');
        const suffixTxt  = suffix ? suffix.textContent : '';
        const rawText    = el.childNodes[0].textContent.trim();
        const target     = parseFloat(rawText);
        if (isNaN(target)) return;
        const isFloat   = rawText.includes('.');
        const duration  = 1600;
        const start     = performance.now();
        function tick(now) {
          const progress = Math.min((now - start) / duration, 1);
          const eased    = 1 - Math.pow(1 - progress, 4);
          const current  = target * eased;
          el.childNodes[0].textContent = isFloat ? current.toFixed(1) : Math.round(current);
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        countObserver.unobserve(el);
      });
    }, { threshold: 0.6 });
    statNums.forEach(n => countObserver.observe(n));
  }
  {% endif %}
})();
</script>

