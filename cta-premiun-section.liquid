<script>
(function () {
  const section = document.getElementById('wo-cta-{{ section.id }}');
  if (!section) return;

  /* 1 — Scroll Reveal */
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        section.classList.add('is-visible');
        observer.unobserve(section);
      }
    });
  }, { threshold: 0.2 });

  observer.observe(section);

  /* 2 — Magnetic Button */
  const btnWrap = document.getElementById('wo-magnetic-{{ section.id }}');
  const btn     = btnWrap ? btnWrap.querySelector('.wo-cta-btn') : null;

  if (btnWrap && btn) {
    let raf;

    btnWrap.addEventListener('mousemove', (e) => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const rect = btnWrap.getBoundingClientRect();
        const x    = e.clientX - rect.left  - rect.width  / 2;
        const y    = e.clientY - rect.top   - rect.height / 2;
        btn.style.transform = `translate(${x * 0.18}px, ${y * 0.18}px) scale(1.02)`;
      });
    });

    btnWrap.addEventListener('mouseleave', () => {
      cancelAnimationFrame(raf);
      btn.style.transform = '';
    });
  }

  /* 3 — Counter Animation */
  const statNums = section.querySelectorAll('.wo-cta-stat-num');

  if (statNums.length) {
    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;

        const el         = entry.target;
        const suffix     = el.querySelector('span');
        const suffixTxt  = suffix ? suffix.textContent : '';
        const rawText    = el.childNodes[0].textContent.trim();
        const target     = parseFloat(rawText);

        if (isNaN(target)) return;

        const isFloat   = rawText.includes('.');
        const duration  = 1600;
        const start     = performance.now();

        function tick(now) {
          const progress = Math.min((now - start) / duration, 1);
          const eased    = 1 - Math.pow(1 - progress, 4);
          const current  = target * eased;
          el.childNodes[0].textContent = isFloat
            ? current.toFixed(1)
            : Math.round(current);
          if (progress < 1) requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
        countObserver.unobserve(el);
      });
    }, { threshold: 0.6 });

    statNums.forEach(n => countObserver.observe(n));
  }
})();
</script>

