{%- comment -%}
  Dynamic CSS generated from section settings.
  Uses CSS variables to ensure zero hardcoding and full responsiveness.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    /* Colors */
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --accent-color: {{ section.settings.accent_color }};
    --border-color: {{ section.settings.border_color }};
    
    /* Layout Configurations */
    --container-width: {{ section.settings.container_width }}px;
    --container-width-mobile: {{ section.settings.container_width_mobile }}px;
    --item-gap-desktop: {{ section.settings.item_gap_desktop }}px;
    --item-gap-mobile: {{ section.settings.item_gap_mobile }}px;

    /* Desktop Spacing */
    --padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --margin-top-desktop: {{ section.settings.margin_top_desktop }}px;
    --margin-bottom-desktop: {{ section.settings.margin_bottom_desktop }}px;
    
    /* Mobile Spacing */
    --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --margin-top-mobile: {{ section.settings.margin_top_mobile }}px;
    --margin-bottom-mobile: {{ section.settings.margin_bottom_mobile }}px;

    /* Desktop Typography Sizes & Weights */
    --pre-heading-size-desktop: {{ section.settings.pre_heading_size_desktop }}px;
    --pre-heading-weight: {{ section.settings.pre_heading_weight }};
    --heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --heading-weight: {{ section.settings.heading_weight }};
    --subheading-size-desktop: {{ section.settings.subheading_size_desktop }}px;
    --subheading-weight: {{ section.settings.subheading_weight }};
    --item-title-size-desktop: {{ section.settings.item_title_size_desktop }}px;
    --item-title-weight: {{ section.settings.item_title_weight }};
    --item-subtitle-size-desktop: {{ section.settings.item_subtitle_size_desktop }}px;

    /* Mobile Typography Sizes */
    --pre-heading-size-mobile: {{ section.settings.pre_heading_size_mobile }}px;
    --heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --subheading-size-mobile: {{ section.settings.subheading_size_mobile }}px;
    --item-title-size-mobile: {{ section.settings.item_title_size_mobile }}px;
    --item-subtitle-size-mobile: {{ section.settings.item_subtitle_size_mobile }}px;

    /* Line Heights */
    --line-height-desktop: {{ section.settings.line_height_desktop }};
    --line-height-mobile: {{ section.settings.line_height_mobile }};

    /* Images */
    --image-size-desktop: {{ section.settings.image_size_desktop }}px;
    --image-size-mobile: {{ section.settings.image_size_mobile }}px;
    --image-border-radius: {{ section.settings.image_border_radius }}%;
    --image-border-width: {{ section.settings.image_border_width }}px;
    --image-border-style: {{ section.settings.image_border_style }};
  }

  .sbo-wrapper {
    background-color: var(--bg-color);
    padding: var(--padding-top-desktop) 20px var(--padding-bottom-desktop) 20px;
    margin-top: var(--margin-top-desktop);
    margin-bottom: var(--margin-bottom-desktop);
    line-height: var(--line-height-desktop);
  }

  .sbo-container {
    max-width: var(--container-width);
    margin: 0 auto;
    text-align: center;
  }

  .sbo-header {
    margin-bottom: 40px;
    color: var(--text-color);
  }

  .sbo-pre-heading {
    font-size: var(--pre-heading-size-desktop);
    font-weight: var(--pre-heading-weight);
    color: var(--accent-color);
    margin-bottom: 8px;
    letter-spacing: 0px;
    text-transform: none;
  }

  .sbo-heading {
    font-size: var(--heading-size-desktop);
    font-weight: var(--heading-weight);
    margin-bottom: 12px;
    color: var(--text-color);
  }

  .sbo-subheading {
    font-size: var(--subheading-size-desktop);
    font-weight: var(--subheading-weight);
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto;
  }

    /* Desktop Grid Configuration (Automatically scales depending on content) */
  .sbo-items-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--item-gap-desktop);
  }

  /* Desktop-only configurations (applied above mobile breakpoint) */
  @media screen and (min-width: 769px) {
    .sbo-items-grid {
      grid-template-columns: repeat({{ section.blocks.size | default: 6 | at_most: 6 }}, minmax(0, 1fr));
    }
    
    /* Apply lift animation ONLY on hoverable desktop screens */
    .sbo-item:hover {
      transform: translateY(-5px);
    }
  }

  .sbo-item {
    text-decoration: none;
    color: var(--text-color);
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: transform 0.3s ease;
  }



  .sbo-image-wrapper {
    width: var(--image-size-desktop);
    height: var(--image-size-desktop);
    border-radius: var(--image-border-radius);
    border: var(--image-border-width) var(--image-border-style) var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 20px;
    background-color: #fff;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  .sbo-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .sbo-image-wrapper svg {
    width: 50%;
    height: 50%;
    fill: #ccc;
  }

  .sbo-item-title {
    font-size: var(--item-title-size-desktop);
    font-weight: var(--item-title-weight);
    margin-bottom: 5px;
  }

  .sbo-item-subtitle {
    font-size: var(--item-subtitle-size-desktop);
    opacity: 0.6;
    margin: 0;
  }

  /* Mobile Breakpoint Customizations */
  @media screen and (max-width: 768px) {
    .sbo-wrapper {
      padding-top: var(--padding-top-mobile);
      padding-bottom: var(--padding-bottom-mobile);
      margin-top: var(--margin-top-mobile);
      margin-bottom: var(--margin-bottom-mobile);
      line-height: var(--line-height-mobile);
    }

    .sbo-container {
      max-width: var(--container-width-mobile);
    }

    .sbo-pre-heading { font-size: var(--pre-heading-size-mobile); }
    .sbo-heading { font-size: var(--heading-size-mobile); }
    .sbo-subheading { font-size: var(--subheading-size-mobile); }
    .sbo-item-title { font-size: var(--item-title-size-mobile); }
    .sbo-item-subtitle { font-size: var(--item-subtitle-size-mobile); }
    
    .sbo-image-wrapper {
      width: var(--image-size-mobile);
      height: var(--image-size-mobile);
    }

    /* Condition 1: Horizontal Scroll View Mode */
    {% if section.settings.mobile_layout == 'scroll' %}
      .sbo-items-grid {
        display: flex;
        gap: var(--item-gap-mobile);
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scroll-behavior: smooth;
        padding-bottom: 10px;
        scrollbar-width: none; /* Hides scrollbar on Firefox */
      }

      /* Hide webkit browser scrollbars completely */
      .sbo-items-grid::-webkit-scrollbar {
        display: none;
        height: 0px;
        background: transparent;
      }


      .sbo-item {
    scroll-snap-align: start;
    flex: auto;
    width: calc(var(--image-size-mobile) + 30px);
      }

    /* Condition 2: Clean Uniform Grid Mode */
    {% else %}
      .sbo-items-grid {
        display: grid;
        grid-template-columns: repeat({{ section.settings.mobile_columns }}, 1fr);
        gap: var(--item-gap-mobile);
      }
      .sbo-item {
        width: 100%;
      }
    {% endif %}
  }
</style>

<div class="sbo-wrapper">
  <div class="sbo-container">
    
    <div class="sbo-header">
      {% if section.settings.pre_heading != blank %}
        <div class="sbo-pre-heading">{{ section.settings.pre_heading }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="sbo-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="sbo-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="sbo-items-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="sbo-item" {{ block.shopify_attributes }}>
          <div class="sbo-image-wrapper">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | img_url: '500x500' }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {% else %}
              {{ 'image' | placeholder_svg_tag }}
            {% endif %}
          </div>
          <div class="sbo-item-title">{{ block.settings.title }}</div>
          <div class="sbo-item-subtitle">{{ block.settings.subtitle }}</div>
        </a>
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Shop By Occasion",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
