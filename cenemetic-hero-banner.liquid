    { "type": "range", "id": "padding_bottom_desktop", "min": 0, "max": 120, "step": 10, "unit": "px", "label": "Desktop Padding Bottom", "default": 20 },
    { "type": "range", "id": "padding_top_mobile",      "min": 0, "max": 100, "step": 10, "unit": "px", "label": "Mobile Padding Top",  "default": 0 },
    { "type": "range", "id": "padding_bottom_mobile",   "min": 0, "max": 100, "step": 10, "unit": "px", "label": "Mobile Padding Bottom", "default": 30 }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Card",
      "limit": 5,
      "settings": [
        { "type": "textarea", "id": "custom_svg", "label": "Custom SVG Icon" },
        { "type": "text", "id": "value", "label": "Number / Value", "default": "€95,000+" },
        { "type": "text", "id": "label", "label": "Label Text", "default": "Average Offshore Salary" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cinematic Hero Pro",
      "blocks": [
        { "type": "stat", "settings": { "value": "€95,000+", "label": "Average Offshore Salary" } },
        { "type": "stat", "settings": { "value": "2/4", "label": "Work Rotation (2 Weeks On, 4 Off)" } },
        { "type": "stat", "settings": { "value": "12,500+", "label": "Offshore Jobs Available" } },
        { "type": "stat", "settings": { "value": "4.9/5", "label": "From 2,000+ Success Stories" } },
        { "type": "stat", "settings": { "value": "90+", "label": "Countries Hiring" } }
      ]
    }
  ]
}
{% endschema %}
