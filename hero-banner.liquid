{% comment %}
  Hero Banner section converted from a standalone HTML template.
  This section includes dynamic settings for badge text, headings, description,
  buttons, image, statistics, progress, rating, and certificate count.
{% endcomment %}

<section id="hero-banner-{{ section.id }}" class="hero-banner" aria-label="{{ section.settings.heading_line1 }} {{ section.settings.heading_line2 }}">
  <style>
    #hero-banner-{{ section.id }} *,
    #hero-banner-{{ section.id }} *::before,
    #hero-banner-{{ section.id }} *::after {
      box-sizing: border-box;
    }

    #hero-banner-{{ section.id }} {
      --hero-section-bg: {{ section.settings.section_bg_color }};
      --hero-heading-color: {{ section.settings.heading_color }};
      --hero-heading-gradient-start: {{ section.settings.heading_gradient_start }};
      --hero-heading-gradient-end: {{ section.settings.heading_gradient_end }};
      --hero-body-color: {{ section.settings.body_color }};
      --hero-badge-bg: {{ section.settings.badge_bg_color }};
      --hero-badge-text: {{ section.settings.badge_text_color }};
      --hero-badge-border: {{ section.settings.badge_border_color }};
      --hero-badge-radius: {{ section.settings.badge_border_radius }}px;
      --hero-badge-padding-vertical: {{ section.settings.badge_padding_vertical }}px;
      --hero-badge-padding-horizontal: {{ section.settings.badge_padding_horizontal }}px;
      --hero-badge-font-size: {{ section.settings.badge_font_size_desktop }}px;
      --hero-btn-primary-bg: {{ section.settings.primary_button_bg }};
      --hero-btn-primary-hover: {{ section.settings.primary_button_hover }};
      --hero-btn-primary-color: {{ section.settings.primary_button_text_color }};
      --hero-btn-secondary-bg: {{ section.settings.secondary_button_bg }};
      --hero-btn-secondary-color: {{ section.settings.secondary_button_text_color }};
      --hero-btn-secondary-border-color: {{ section.settings.secondary_button_border_color }};
      --hero-btn-secondary-border-width: {{ section.settings.secondary_button_border_width }}px;
      --hero-btn-border-radius: {{ section.settings.button_border_radius }}px;
      --hero-btn-padding-vertical: {{ section.settings.button_padding_vertical_desktop }}px;
      --hero-btn-padding-horizontal: {{ section.settings.button_padding_horizontal_desktop }}px;
      --hero-btn-font-size: {{ section.settings.button_font_size_desktop }}px;
      --hero-btn-gap: {{ section.settings.button_gap_desktop }}px;
      --hero-btn-wrap: {{ section.settings.button_wrap_desktop }};
      --hero-content-gap: {{ section.settings.content_gap_desktop }}px;
      --hero-section-padding-top: {{ section.settings.section_padding_top_desktop }}px;
      --hero-section-padding-bottom: {{ section.settings.section_padding_bottom_desktop }}px;
      --hero-container-padding: clamp(20px, 5vw, {{ section.settings.container_padding_desktop }}px);
      --hero-grid-gap: {{ section.settings.grid_gap_desktop }}px;
      --hero-grid-columns: {{ section.settings.layout_desktop }};
      --hero-heading-size: {{ section.settings.heading_size_desktop }}px;
      --hero-description-size: {{ section.settings.description_size_desktop }}px;
      --hero-stat-size: {{ section.settings.stat_text_size_desktop }}px;
      --hero-image-max-width: {{ section.settings.image_max_width_desktop }}px;
      --hero-image-aspect: {{ section.settings.image_aspect_ratio_width }} / {{ section.settings.image_aspect_ratio_height }};
      --hero-image-border-radius: {{ section.settings.image_border_radius }}px;
      --hero-card-bg: {{ section.settings.card_bg_color }};
      --hero-card-border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
      --hero-card-radius: {{ section.settings.card_border_radius }}px;
      --hero-card-shadow: {{ section.settings.card_box_shadow }};
      --hero-card-gap: {{ section.settings.card_gap }}px;
      --hero-blob-1: {{ section.settings.blob_1_color }};
      --hero-blob-2: {{ section.settings.blob_2_color }};
      --hero-blob-3: {{ section.settings.blob_3_color }};
      --hero-shape-dots: {{ section.settings.shape_dots_color }};
      --hero-shape-circle: {{ section.settings.shape_circle_color }};
      --hero-shape-ring: {{ section.settings.shape_ring_color }};
      background: var(--hero-section-bg);
      overflow: hidden;
      font-family: inherit;
      display: block;
    }

    .hero-banner {
      position: relative;
      width: 100%;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      padding: var(--hero-section-padding-top) 0 var(--hero-section-padding-bottom);
    }

    .hero-banner__bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .hero-banner__blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0;
      animation: blobReveal 1.2s ease forwards, blobDrift 12s ease-in-out infinite alternate;
    }

    .hero-banner__blob--1 {
      width: 600px;
      height: 600px;
      top: -200px;
      right: -100px;
      background: var(--hero-blob-1);
      animation-delay: 0.3s, 2s;
    }

    .hero-banner__blob--2 {
      width: 400px;
      height: 400px;
      bottom: -150px;
      left: -80px;
      background: var(--hero-blob-2);
      animation-delay: 0.5s, 2s;
      animation-direction: alternate-reverse;
    }

    .hero-banner__blob--3 {
      width: 300px;
      height: 300px;
      top: 50%;
      left: 40%;
      transform: translateY(-50%);
      background: var(--hero-blob-3);
      animation-delay: 0.7s, 2s;
    }

    .hero-banner__shape {
      position: absolute;
      opacity: 0;
      animation: shapeReveal 0.8s ease forwards;
    }

    .hero-banner__shape--dots {
      width: 120px;
      height: 120px;
      top: 15%;
      right: 8%;
      background-image: radial-gradient(var(--hero-shape-dots) 2.5px, transparent 2.5px);
      background-size: 20px 20px;
      animation-delay: 1.2s;
    }

    .hero-banner__shape--circle {
      width: 12px;
      height: 12px;
      background: var(--hero-shape-circle);
      border-radius: 50%;
      top: 20%;
      right: 35%;
      animation-delay: 1.4s;
    }

    .hero-banner__shape--ring {
      width: 40px;
      height: 40px;
      border: 3px solid var(--hero-shape-ring);
      border-radius: 50%;
      top: 60%;
      right: 15%;
      animation-delay: 1.6s;
    }

    .hero-banner__container {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 var(--hero-container-padding);
      position: relative;
      z-index: 1;
    }

    .hero-banner__grid {
      display: grid;
      grid-template-columns: var(--hero-grid-columns);
      gap: var(--hero-grid-gap);
      align-items: center;
    }

    .hero-banner__content {
      display: flex;
      flex-direction: column;
      gap: var(--hero-content-gap);
      opacity: 0;
      transform: translateX(-50px);
      animation: slideInLeft 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    }

    .hero-banner__badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: var(--hero-badge-padding-vertical) var(--hero-badge-padding-horizontal);
      border-radius: var(--hero-badge-radius);
      background: var(--hero-badge-bg);
      color: var(--hero-badge-text);
      font-size: var(--hero-badge-font-size);
      font-weight: 600;
      letter-spacing: 0.02em;
      width: fit-content;
      backdrop-filter: blur(6px);
      box-shadow: 0 2px 16px rgba(0,0,0,0.06);
      border: 1px solid var(--hero-badge-border);
      opacity: 0;
      transform: translateY(10px);
      animation: fadeUp 0.6s ease 0.4s forwards;
    }

    .hero-banner__badge-icon {
      font-size: 1em;
    }

    .hero-banner__heading {
      margin: 0;
      line-height: 1.12;
      letter-spacing: -0.03em;
      font-weight: 800;
      font-size: var(--hero-heading-size);
      color: var(--hero-heading-color);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .hero-banner__heading-line {
      display: block;
      opacity: 0;
      transform: translateY(30px);
      animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .hero-banner__heading-line:nth-child(1) { animation-delay: 0.5s; }
    .hero-banner__heading-line:nth-child(2) { animation-delay: 0.65s; }

    .hero-banner__heading-gradient {
      background: linear-gradient(135deg, var(--color-accent-purple), var(--color-accent-orange));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-banner__description {
      line-height: 1.7;
      font-size: var(--hero-description-size);
      color: var(--hero-body-color);
      max-width: 480px;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.7s ease 0.8s forwards;
    }

    .hero-banner__buttons {
      display: flex;
      flex-wrap: var(--hero-btn-wrap);
      gap: var(--hero-btn-gap);
      align-items: center;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.7s ease 0.95s forwards;
    }

    .hero-banner__btn {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: var(--hero-btn-padding-vertical) var(--hero-btn-padding-horizontal);
      font-size: var(--hero-btn-font-size);
      font-weight: 600;
      text-decoration: none;
      border-radius: var(--hero-btn-border-radius);
      transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
      white-space: nowrap;
      overflow: hidden;
      border: none;
      cursor: pointer;
    }

    .hero-banner__btn--primary {
      background: var(--hero-btn-primary-bg);
      color: var(--hero-btn-primary-color);
      box-shadow: 0 4px 20px rgba(91,33,182,0.35);
    }

    .hero-banner__btn--primary::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transform: translateX(-100%);
      transition: transform 0.6s ease;
    }

    .hero-banner__btn--primary:hover {
      background: var(--hero-btn-primary-hover);
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(91,33,182,0.45);
    }

    .hero-banner__btn--primary:hover::before {
      transform: translateX(100%);
    }

    .hero-banner__btn-arrow {
      transition: transform 0.2s ease;
    }

    .hero-banner__btn--secondary {
      background: var(--hero-btn-secondary-bg);
      color: var(--hero-btn-secondary-color);
      border: var(--hero-btn-secondary-border-width) solid var(--hero-btn-secondary-border-color);
    }

    .hero-banner__btn--secondary:hover {
      background: rgba(91,33,182,0.08);
      border-color: var(--hero-btn-primary-bg);
      color: var(--hero-btn-primary-bg);
      transform: translateY(-2px);
    }

    .hero-banner__play-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: rgba(91,33,182,0.1);
      flex-shrink: 0;
      transition: var(--transition-smooth);
    }

    .hero-banner__btn--secondary:hover .hero-banner__play-icon {
      background: rgba(91,33,182,0.18);
      transform: scale(1.1);
    }

    .hero-banner__stats {
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      align-items: center;
      padding: 18px 24px;
      background: var(--color-stat-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: var(--radius-card);
      border: 1px solid rgba(255,255,255,0.6);
      box-shadow: 0 8px 32px rgba(0,0,0,0.06);
      width: fit-content;
      max-width: 100%;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.7s ease 1.1s forwards;
    }

    .hero-banner__stat {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
      padding: 0 20px;
      position: relative;
    }

    .hero-banner__stat-icon {
      font-size: 1.4rem;
      line-height: 1;
      margin-bottom: 2px;
    }

    .hero-banner__stat-number {
      font-size: clamp(1.1rem, 1.8vw, 1.5rem);
      font-weight: 800;
      line-height: 1.1;
      color: var(--hero-heading-color);
    }

    .hero-banner__stat-label {
      font-size: 0.75rem;
      color: var(--color-text-muted);
      font-weight: 500;
      white-space: nowrap;
    }

    .hero-banner__stat-divider {
      width: 1px;
      height: 36px;
      background: rgba(0,0,0,0.1);
      flex-shrink: 0;
    }

    .hero-banner__image-wrap {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      opacity: 0;
      transform: translateX(50px);
      animation: slideInRight 1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
    }

    .hero-banner__image-frame {
      position: relative;
      width: 90%;
      max-width: var(--hero-image-max-width);
      border-radius: var(--hero-image-border-radius);
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(91,33,182,0.15);
      transition: transform 0.4s ease;
      aspect-ratio: var(--hero-image-aspect);
    }

    .hero-banner__image-frame:hover {
      transform: translateY(-4px);
    }

    .hero-banner__img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      transition: transform 0.6s ease;
    }

    .hero-banner__image-frame:hover .hero-banner__img {
      transform: scale(1.03);
    }

    .hero-banner__float-card {
      position: absolute;
      padding: 14px 18px;
      border-radius: var(--hero-card-radius);
      background: var(--hero-card-bg);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      box-shadow: var(--hero-card-shadow);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--hero-card-gap);
      min-width: 110px;
      z-index: 5;
      opacity: 0;
      transform: scale(0.8);
      animation: cardPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      border: var(--hero-card-border);
    }

    .hero-banner__float-card--progress {
      top: 12%;
      left: -5%;
      animation-delay: 1.3s;
    }

    .hero-banner__float-card--rating {
      top: 8%;
      right: -2%;
      animation-delay: 1.5s;
    }

    .hero-banner__float-card--achievement {
      bottom: 8%;
      left: -4%;
      animation-delay: 1.7s;
    }

    .hero-banner__float-card--progress,
    .hero-banner__float-card--achievement,
    .hero-banner__float-card--rating {
      animation: cardPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
                 float 4s ease-in-out infinite;
    }

    .hero-banner__card-label {
      margin: 0;
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--hero-body-color);
      text-align: center;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .hero-banner__progress-ring {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .hero-banner__ring-bg {
      fill: none;
      stroke: #e2e8f0;
      stroke-width: 6;
    }

    .hero-banner__ring-fill {
      fill: none;
      stroke-width: 6;
      stroke-linecap: round;
      transform: rotate(-90deg);
      transform-origin: center;
      stroke-dasharray: 213.6;
      stroke-dashoffset: 213.6;
      transition: stroke-dashoffset 1.5s cubic-bezier(0.4,0,0.2,1);
      stroke: var(--hero-btn-primary-bg);
    }

    .hero-banner__ring-text {
      position: absolute;
      font-size: 0.9rem;
      font-weight: 800;
      color: var(--hero-heading-color);
    }

    .hero-banner__rating-value {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--color-text-dark);
      line-height: 1;
    }

    .hero-banner__stars {
      display: flex;
      gap: 2px;
    }

    .hero-banner__review-count {
      margin: 0;
      font-size: 0.7rem;
      color: var(--color-text-light);
    }

    .hero-banner__card-icon {
      font-size: 1.4rem;
      line-height: 1;
    }

    .hero-banner__achieve-count {
      font-size: 1.3rem;
      font-weight: 800;
      color: var(--color-text-dark);
      line-height: 1;
    }

    .hero-banner__achieve-label {
      font-size: 0.7rem;
      color: var(--color-text-light);
      margin: 0;
    }

    @keyframes blobReveal {
      from { opacity: 0; transform: scale(0.8); }
      to { opacity: 0.35; transform: scale(1); }
    }

    @keyframes blobDrift {
      0% { transform: translate(0, 0) scale(1); }
      100% { transform: translate(40px, -30px) scale(1.1); }
    }

    @keyframes shapeReveal {
      from { opacity: 0; transform: scale(0); }
      to { opacity: 0.18; transform: scale(1); }
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes slideInLeft {
      from { opacity: 0; transform: translateX(-50px); }
      to { opacity: 1; transform: translateX(0); }
    }

    @keyframes slideInRight {
      from { opacity: 0; transform: translateX(50px); }
      to { opacity: 1; transform: translateX(0); }
    }

    @keyframes cardPop {
      from { opacity: 0; transform: scale(0.8); }
      to { opacity: 1; transform: scale(1); }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
    }

    @keyframes ripple {
      to { transform: scale(4); opacity: 0; }
    }

    @media (max-width: 1023px) {
      .hero-banner {
        padding: 60px 0;
        min-height: auto;
      }

      .hero-banner__grid {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 48px;
      }

      .hero-banner__content {
        align-items: center;
        order: 2;
      }

      .hero-banner__description {
        max-width: 70ch;
        margin: 0 auto;
      }

      .hero-banner__buttons {
        justify-content: center;
      }

      .hero-banner__stats {
        margin: 0 auto;
      }

      .hero-banner__image-wrap {
        order: 1;
        max-width: 500px;
        margin: 0 auto;
      }

      .hero-banner__float-card--progress { left: 2%; }
      .hero-banner__float-card--achievement { left: 2%; }
      .hero-banner__float-card--rating { right: 2%; }
    }

    @media (max-width: 767px) {
      .hero-banner {
        padding: 40px 0;
      }

      .hero-banner__float-card {
        transform: scale(0.85);
      }

      .hero-banner__float-card--progress {
        display: none;
      }

      .hero-banner__stats {
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
        padding: 14px 18px;
      }

      .hero-banner__stat {
        min-width: 70px;
        padding: 0 12px;
      }

      .hero-banner__stat-divider {
        display: none;
      }

      .hero-banner__stat:not(:last-child)::after {
        content: '';
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 1px;
        height: 30px;
        background: rgba(0,0,0,0.08);
      }

      .hero-banner__heading {
        font-size: 2.2rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #hero-banner-{{ section.id }} *,
      #hero-banner-{{ section.id }} *::before,
      #hero-banner-{{ section.id }} *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>

  <div class="hero-banner__bg" aria-hidden="true">
    <div class="hero-banner__blob hero-banner__blob--1"></div>
    <div class="hero-banner__blob hero-banner__blob--2"></div>
    <div class="hero-banner__blob hero-banner__blob--3"></div>
    <div class="hero-banner__shape hero-banner__shape--dots"></div>
    <div class="hero-banner__shape hero-banner__shape--circle"></div>
    <div class="hero-banner__shape hero-banner__shape--ring"></div>
  </div>

  <div class="hero-banner__container">
    <div class="hero-banner__grid">
      <div class="hero-banner__content">
        <div class="hero-banner__badge">
          <span class="hero-banner__badge-icon">%</span>
          <span>{{ section.settings.badge_text }}</span>
        </div>

        <h1 class="hero-banner__heading">
          <span class="hero-banner__heading-line">{{ section.settings.heading_line1 }}</span>
          <span class="hero-banner__heading-line hero-banner__heading-gradient">{{ section.settings.heading_line2 }}</span>
        </h1>

        <div class="hero-banner__description">
          <p>{{ section.settings.description }}</p>
        </div>

        <div class="hero-banner__buttons">
          <a href="{{ section.settings.primary_button_link }}" class="hero-banner__btn hero-banner__btn--primary" aria-label="{{ section.settings.primary_button_label }}">
            {{ section.settings.primary_button_label }}
            <span class="hero-banner__btn-arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
          <a href="{{ section.settings.secondary_button_link }}" class="hero-banner__btn hero-banner__btn--secondary" aria-label="{{ section.settings.secondary_button_label }}">
            <span class="hero-banner__play-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
            </span>
            {{ section.settings.secondary_button_label }}
          </a>
        </div>

        <div class="hero-banner__stats">
          <div class="hero-banner__stat">
            <span class="hero-banner__stat-icon" aria-hidden="true">{{ section.settings.stat1_icon }}</span>
            <strong class="hero-banner__stat-number" data-target="{{ section.settings.stat1_value }}" data-suffix="{{ section.settings.stat1_suffix }}">{{ section.settings.stat1_value }}{{ section.settings.stat1_suffix }}</strong>
            <span class="hero-banner__stat-label">{{ section.settings.stat1_label }}</span>
          </div>
          <div class="hero-banner__stat-divider" aria-hidden="true"></div>
          <div class="hero-banner__stat">
            <span class="hero-banner__stat-icon" aria-hidden="true">{{ section.settings.stat2_icon }}</span>
            <strong class="hero-banner__stat-number" data-target="{{ section.settings.stat2_value }}" data-suffix="{{ section.settings.stat2_suffix }}">{{ section.settings.stat2_value }}{{ section.settings.stat2_suffix }}</strong>
            <span class="hero-banner__stat-label">{{ section.settings.stat2_label }}</span>
          </div>
          <div class="hero-banner__stat-divider" aria-hidden="true"></div>
          <div class="hero-banner__stat">
            <span class="hero-banner__stat-icon" aria-hidden="true">{{ section.settings.stat3_icon }}</span>
            <strong class="hero-banner__stat-number" data-target="{{ section.settings.stat3_value }}" data-suffix="{{ section.settings.stat3_suffix }}">{{ section.settings.stat3_value }}{{ section.settings.stat3_suffix }}</strong>
            <span class="hero-banner__stat-label">{{ section.settings.stat3_label }}</span>
          </div>
          <div class="hero-banner__stat-divider" aria-hidden="true"></div>
          <div class="hero-banner__stat">
            <span class="hero-banner__stat-icon" aria-hidden="true">{{ section.settings.stat4_icon }}</span>
            <strong class="hero-banner__stat-number" data-target="{{ section.settings.stat4_value }}" data-suffix="{{ section.settings.stat4_suffix }}">{{ section.settings.stat4_value }}{{ section.settings.stat4_suffix }}</strong>
            <span class="hero-banner__stat-label">{{ section.settings.stat4_label }}</span>
          </div>
        </div>
      </div>

      <div class="hero-banner__image-wrap">
        <div class="hero-banner__image-frame">
          {% if section.settings.hero_image != blank %}
            <img src="{{ section.settings.hero_image | img_url: '2048x' }}" alt="{{ section.settings.hero_image_alt | escape }}" class="hero-banner__img" width="800" height="600" loading="eager">
          {% else %}
            <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=800&h=600&fit=crop&crop=faces" alt="{{ section.settings.hero_image_alt | default: 'Student learning online with headphones and laptop' | escape }}" class="hero-banner__img" width="800" height="600" loading="eager">
          {% endif %}
        </div>

        <div class="hero-banner__float-card hero-banner__float-card--progress" aria-label="Your Progress: {{ section.settings.progress_percent }}%">
          <p class="hero-banner__card-label">Your Progress</p>
          <div class="hero-banner__progress-ring" role="progressbar" aria-valuenow="{{ section.settings.progress_percent }}" aria-valuemin="0" aria-valuemax="100">
            <svg viewBox="0 0 80 80" width="72" height="72" aria-hidden="true">
              <circle class="hero-banner__ring-bg" cx="40" cy="40" r="34"/>
              <circle class="hero-banner__ring-fill" cx="40" cy="40" r="34" stroke-width="6" data-progress="{{ section.settings.progress_percent }}"/>
            </svg>
            <span class="hero-banner__ring-text">{{ section.settings.progress_percent }}%</span>
          </div>
        </div>

        <div class="hero-banner__float-card hero-banner__float-card--rating" aria-label="Rating: {{ section.settings.review_rating }} out of 5 from {{ section.settings.review_count }}">
          <span class="hero-banner__rating-value">{{ section.settings.review_rating }}</span>
          <div class="hero-banner__stars" aria-hidden="true">
            {% for i in (1..5) %}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            {% endfor %}
          </div>
          <p class="hero-banner__review-count">({{ section.settings.review_count }})</p>
        </div>

        <div class="hero-banner__float-card hero-banner__float-card--achievement" aria-label="Certificates Earned: {{ section.settings.certificates_count }}">
          <span class="hero-banner__card-icon" aria-hidden="true">🏆</span>
          <strong class="hero-banner__achieve-count">{{ section.settings.certificates_count }}</strong>
          <p class="hero-banner__achieve-label">Certificates Earned</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      const container = document.querySelector('#hero-banner-{{ section.id }}');
      if (!container) return;

      const rings = container.querySelectorAll('.hero-banner__ring-fill');
      rings.forEach((ring) => {
        const progress = parseFloat(ring.dataset.progress) || 75;
        const radius = 34;
        const circumference = 2 * Math.PI * radius;
        const offset = circumference - (progress / 100) * circumference;
        ring.style.strokeDasharray = circumference;
        ring.style.strokeDashoffset = circumference;
        setTimeout(() => {
          ring.style.strokeDashoffset = offset;
        }, 500);
      });

      const stats = container.querySelectorAll('.hero-banner__stat-number');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const target = parseFloat(el.dataset.target) || 0;
          const suffix = el.dataset.suffix || '';
          const duration = 1400;
          const start = performance.now();
          function tick(now) {
            const elapsed = Math.min(now - start, duration);
            const progress = elapsed / duration;
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = Math.floor(target * eased);
            el.textContent = current + suffix;
            if (elapsed < duration) requestAnimationFrame(tick);
            else el.textContent = target + suffix;
          }
          requestAnimationFrame(tick);
          observer.unobserve(el);
        });
      }, { threshold: 0.4 });
      stats.forEach(stat => observer.observe(stat));

      container.querySelectorAll('.hero-banner__btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
          const rect = this.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const ripple = document.createElement('span');
          ripple.style.cssText = 'position:absolute; background:rgba(255,255,255,0.3); border-radius:50%; transform:scale(0); animation:ripple 0.6s linear; pointer-events:none; width:100px; height:100px; left:' + x + 'px; top:' + y + 'px; margin-left:-50px; margin-top:-50px;';
          this.appendChild(ripple);
          setTimeout(() => ripple.remove(), 600);
        });
      });
    })();
  </script>
</section>

