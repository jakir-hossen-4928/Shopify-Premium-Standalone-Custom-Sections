{%- style -%}
  /* Section Spacing & Background */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mb }}px;
    padding-bottom: {{ section.settings.padding_bottom_mb }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Header Styling */
  .gallery-header-{{ section.id }} {
    text-align: {{ section.settings.header_align }};
    margin-bottom: {{ section.settings.header_margin }}px;
    max-width: {{ section.settings.container_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 20px;
  }
 
  .gallery-header-{{ section.id }} h2 {
    margin: 0;
    line-height: 1.2;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_mb }}px;
  }

  @media screen and (min-width: 750px) {
    .gallery-header-{{ section.id }} h2 {
      font-size: {{ section.settings.title_size_dt }}px;
    }
  }

  /* Container & Grid Engine */
  .gallery-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .gallery-grid-{{ section.id }} {
    display: grid;
    gap: {{ section.settings.gap_mb }}px;
    grid-template-columns: 1fr; /* Force 1 column on mobile */
    grid-auto-rows: {{ section.settings.row_height_mb }}px;
  }

  @media screen and (min-width: 750px) {
    .gallery-grid-{{ section.id }} {
      gap: {{ section.settings.gap_dt }}px;
      grid-template-columns: repeat({{ section.settings.cols_desktop }}, 1fr);
      grid-auto-rows: {{ section.settings.row_height_dt }}px;
      grid-auto-flow: dense;
    }
    
    .gallery-item-{{ section.id }}.span-large { grid-column: span 2; grid-row: span 2; }
    .gallery-item-{{ section.id }}.span-wide { grid-column: span 2; }
    .gallery-item-{{ section.id }}.span-tall { grid-row: span 2; }
  }

  /* Card & Image Styling */
  .gallery-item-{{ section.id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    display: flex;
    background: #f0f0f0;
  }

  .gallery-item-{{ section.id }} .image-wrap {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 1;
  }

  .gallery-item-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  /* Block-specific Styles */
  {%- for block in section.blocks -%}
    .item-{{ block.id }} img {
      object-position: {{ block.settings.img_focal }};
      transform: scale({{ block.settings.img_scale }});
    }
    .item-{{ block.id }}:hover img {
      transform: scale(calc({{ block.settings.img_scale }} * {{ section.settings.hover_zoom }}));
    }
    .btn-{{ block.id }} {
      background-color: {{ block.settings.btn_bg_color }} !important;
      color: {{ block.settings.btn_text_color }} !important;
      border-color: {{ block.settings.btn_border_color }} !important;
      font-size: {{ block.settings.btn_size_mb }}px !important;
    }
    .item-{{ block.id }} .card-title-{{ section.id }} {
      font-size: {{ block.settings.font_size_mb }}px;
      color: {{ block.settings.text_color }};
    }
    @media screen and (min-width: 750px) {
      .btn-{{ block.id }} {
        font-size: {{ block.settings.btn_size_dt }}px !important;
      }
      .item-{{ block.id }} .card-title-{{ section.id }} {
        font-size: {{ block.settings.font_size }}px;
      }
    }
  {%- endfor -%}

  .gallery-content-{{ section.id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    padding: 25px;
    display: flex;
    flex-direction: column;
    background: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0) 50%, rgba(0,0,0,0.4) 100%);
  }

  .align-top-left { justify-content: flex-start; align-items: flex-start; text-align: left; }
  .align-center { justify-content: center; align-items: center; text-align: center; }
  .align-bottom-left { justify-content: flex-end; align-items: flex-start; text-align: left; }

  .card-title-{{ section.id }} {
    margin: 0 0 15px 0;
    line-height: 1.1;
    font-weight: 700;
  }

  .card-action-{{ section.id }} .button {
    display: inline-block;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: var(--btn-3-font-family);
    font-weight: var(--btn-3-font-weight);
    text-transform: var(--btn-3-text-transform);
    border-radius: var(--btn-3-border-radius);
    border-style: var(--btn-3-border-style);
    border-width: var(--btn-3-border-width);
    padding: var(--btn-3-padding-top) 25px var(--btn-3-padding-bottom) 25px;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  {%- if section.settings.title != blank -%}
    <div class="gallery-header-{{ section.id }}">
      <h2>{{ section.settings.title }}</h2>
    </div>
  {%- endif -%}

  <div class="gallery-container-{{ section.id }}">
    <div class="gallery-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="gallery-item-{{ section.id }} item-{{ block.id }} span-{{ block.settings.block_size }}" {{ block.shopify_attributes }}>
          <div class="image-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          <div class="gallery-content-{{ section.id }} align-{{ block.settings.content_position }}">
            {%- if block.settings.title != blank -%}
              <h3 class="card-title-{{ section.id }}">
                {{ block.settings.title }}
              </h3>
            {%- endif -%}
            
            {%- if block.settings.btn_label != blank -%}
              <div class="card-action-{{ section.id }}">
                <a href="{{ block.settings.link }}" class="button btn-{{ block.id }}">{{ block.settings.btn_label }}</a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bento Marketing Grid",
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 800,
      "max": 1800,
      "step": 10,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1470
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Main Heading Settings"
    },
    { "type": "text", "id": "title", "label": "Main Heading", "default": "Reflections & Experiences" },
    { "type": "color", "id": "title_color", "label": "Heading Color", "default": "#121212" },
    { "type": "range", "id": "title_size_dt", "min": 20, "max": 80, "step": 2, "unit": "px", "label": "Size (Desktop)", "default": 40 },
    { "type": "range", "id": "title_size_mb", "min": 16, "max": 50, "step": 2, "unit": "px", "label": "Size (Mobile)", "default": 28 },
    { "type": "select", "id": "header_align", "label": "Alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }], "default": "center" },
    { "type": "range", "id": "header_margin", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Space Below Header", "default": 30 },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    { "type": "range", "id": "cols_desktop", "min": 2, "max": 6, "step": 1, "label": "Columns (Desktop)", "default": 3 },
    { "type": "range", "id": "row_height_dt", "min": 100, "max": 800, "step": 10, "unit": "px", "label": "Row Height (Desktop)", "default": 350 },
    { "type": "range", "id": "row_height_mb", "min": 100, "max": 600, "step": 10, "unit": "px", "label": "Row Height (Mobile)", "default": 300 },
    { "type": "range", "id": "gap_dt", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Gap (Desktop)", "default": 20 },
    { "type": "range", "id": "gap_mb", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Gap (Mobile)", "default": 16 },
    { "type": "range", "id": "border_radius", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Corner Radius", "default": 12 },
    { "type": "range", "id": "hover_zoom", "min": 1.0, "max": 1.3, "step": 0.1, "label": "Hover Zoom Intensity", "default": 1.1 },
    {
      "type": "header",
      "content": "Padding"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "default": 40, "label": "Top (DT)" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "default": 40, "label": "Bottom (DT)" },
    { "type": "range", "id": "padding_top_mb", "min": 0, "max": 100, "step": 5, "default": 20, "label": "Top (MB)" },
    { "type": "range", "id": "padding_bottom_mb", "min": 0, "max": 100, "step": 5, "default": 20, "label": "Bottom (MB)" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Promo Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "select", "id": "img_focal", "label": "Image Focal Point", "options": [
            { "value": "top", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "bottom", "label": "Bottom" }
          ], "default": "center" 
        },
        { "type": "range", "id": "img_scale", "min": 1.0, "max": 2.0, "step": 0.1, "label": "Image Base Scale", "default": 1.0 },
        { "type": "select", "id": "block_size", "label": "Desktop Span", "options": [
            { "value": "standard", "label": "Standard (1x1)" },
            { "value": "wide", "label": "Wide (2x1)" },
            { "value": "tall", "label": "Tall (1x2)" },
            { "value": "large", "label": "Large (2x2)" }
          ], "default": "standard" 
        },
        { "type": "header", "content": "Typography" },
        { "type": "text", "id": "title", "label": "Card Heading", "default": "Bundle and Save" },
        { "type": "color", "id": "text_color", "label": "Heading Color", "default": "#ffffff" },
        { "type": "range", "id": "font_size", "min": 12, "max": 60, "step": 1, "default": 24, "label": "Heading Size (Desktop)" },
        { "type": "range", "id": "font_size_mb", "min": 12, "max": 40, "step": 1, "default": 20, "label": "Heading Size (Mobile)" },
        { "type": "select", "id": "content_position", "label": "Content Position", "options": [
            { "value": "top-left", "label": "Top Left" },
            { "value": "center", "label": "Center" },
            { "value": "bottom-left", "label": "Bottom Left" }
          ], "default": "top-left" 
        },
        { "type": "header", "content": "Button" },
        { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Discover" },
        { "type": "url", "id": "link", "label": "Button Link" },
        { "type": "range", "id": "btn_size_dt", "min": 10, "max": 30, "step": 1, "default": 14, "label": "Button Font Size (Desktop)" },
        { "type": "range", "id": "btn_size_mb", "min": 10, "max": 24, "step": 1, "default": 12, "label": "Button Font Size (Mobile)" },
        { "type": "color", "id": "btn_bg_color", "label": "Button Background", "default": "#e60023" },
        { "type": "color", "id": "btn_text_color", "label": "Button Text", "default": "#ffffff" },
        { "type": "color", "id": "btn_border_color", "label": "Button Border", "default": "transparent" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bento Marketing Grid",
      "blocks": [
        { "type": "image", "settings": { "block_size": "wide" } },
        { "type": "image", "settings": { "block_size": "standard" } },
        { "type": "image", "settings": { "block_size": "standard" } },
        { "type": "image", "settings": { "block_size": "wide" } }
      ]
    }
  ]
}
{% endschema %}