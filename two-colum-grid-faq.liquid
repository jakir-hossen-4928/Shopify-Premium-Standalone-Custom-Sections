{% comment %}
  ============================================================
  WORK OFFSHORE — FAQ / ACCORDION SECTION
  2-Column Grid | Background Image + Overlay | Auto-Close Siblings
  ============================================================
{% endcomment %}

<style>
/* ============================================================
   CSS VARIABLES
============================================================ */
#shopify-section-{{ section.id }} {
  --wo-faq-accent:      {{ section.settings.accent_color }};
  --wo-faq-title:       {{ section.settings.title_color }};
  --wo-faq-q:           {{ section.settings.question_color }};
  --wo-faq-a:           {{ section.settings.answer_color }};
  --wo-faq-item-bg:     {{ section.settings.item_bg_color }};
  --wo-faq-item-border: {{ section.settings.item_border_color }};
  --wo-faq-btn-bg:      {{ section.settings.btn_bg_color }};
  --wo-faq-btn-text:    {{ section.settings.btn_text_color }};
  --wo-faq-btn-border:  {{ section.settings.btn_border_color }};
  --wo-faq-overlay:     {{ section.settings.overlay_color }};
  --wo-faq-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};

  --wo-faq-title-desk:  {{ section.settings.title_size_desktop }}px;
  --wo-faq-q-desk:      {{ section.settings.q_size_desktop }}px;
  --wo-faq-a-desk:      {{ section.settings.a_size_desktop }}px;
  --wo-faq-title-mob:   {{ section.settings.title_size_mobile }}px;
  --wo-faq-q-mob:       {{ section.settings.q_size_mobile }}px;
  --wo-faq-a-mob:       {{ section.settings.a_size_mobile }}px;

  --wo-faq-pad-top-desk: {{ section.settings.pad_top_desktop }}px;
  --wo-faq-pad-bot-desk: {{ section.settings.pad_bot_desktop }}px;
  --wo-faq-pad-top-mob:  {{ section.settings.pad_top_mobile }}px;
  --wo-faq-pad-bot-mob:  {{ section.settings.pad_bot_mobile }}px;
}

/* ============================================================
   SECTION WRAPPER — background image + overlay
============================================================ */
.wo-faq-section {
  position: relative;
  padding: var(--wo-faq-pad-top-desk) 20px var(--wo-faq-pad-bot-desk);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  overflow: hidden;
}

/* Background image layer */
.wo-faq-bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  z-index: 0;
}

/* Overlay layer — color + opacity controlled from theme editor */
.wo-faq-overlay {
  position: absolute;
  inset: 0;
  background-color: var(--wo-faq-overlay);
  opacity: var(--wo-faq-overlay-opacity);
  z-index: 1;
}

/* Content sits above overlay */
.wo-faq-inner {
  position: relative;
  z-index: 2;
  max-width: 1560px;
  margin: 0 auto;
}

/* ============================================================
   HEADER
============================================================ */
.wo-faq-header {
  text-align: center;
  margin-bottom: 36px;
}

.wo-faq-title {
  font-size: var(--wo-faq-title-desk);
  font-weight: 800;
  letter-spacing: -0.01em;
  color: var(--wo-faq-title);
  margin: 0;
}

/* ============================================================
   2-COLUMN GRID
============================================================ */
.wo-faq-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 12px;
}

.wo-faq-col {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ============================================================
   FAQ ITEM
============================================================ */
.wo-faq-item {
  background-color: var(--wo-faq-item-bg);
  border: 1px solid var(--wo-faq-item-border);
  border-radius: 6px;
  overflow: hidden;
  transition: background-color 0.25s ease;
}

.wo-faq-item:hover {
  background-color: rgba(18,18,18,0.67);
}

/* ============================================================
   TRIGGER / QUESTION ROW
============================================================ */
.wo-faq-trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 20px;
  background: transparent;
  border: none;
  cursor: pointer;
  text-align: left;
  font-family: inherit;
  -webkit-tap-highlight-color: transparent;
}

.wo-faq-trigger:focus-visible {
  outline: 2px solid var(--wo-faq-accent);
  outline-offset: -2px;
  border-radius: 6px;
}

.wo-faq-q-text {
  font-size: var(--wo-faq-q-desk);
  font-weight: 600;
  color: var(--wo-faq-q);
  padding-right: 16px;
  line-height: 1.4;
  transition: color 0.25s ease;
}

.wo-faq-item.is-open .wo-faq-q-text {
  color: #ffffff;
}

/* ============================================================
   PLUS / MINUS ICON
============================================================ */
.wo-faq-icon {
  position: relative;
  width: 14px;
  height: 14px;
  flex-shrink: 0;
}

.wo-faq-icon::before,
.wo-faq-icon::after {
  content: '';
  position: absolute;
  background-color: var(--wo-faq-accent);
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
  border-radius: 2px;
}

.wo-faq-icon::before {
  top: 50%; left: 0;
  width: 100%; height: 2px;
  margin-top: -1px;
}

.wo-faq-icon::after {
  top: 0; left: 50%;
  width: 2px; height: 100%;
  margin-left: -1px;
}

.wo-faq-item.is-open .wo-faq-icon::after {
  transform: rotate(90deg);
  opacity: 0;
}

/* ============================================================
   SMOOTH ACCORDION CONTENT (CSS GRID TRICK)
============================================================ */
.wo-faq-content-wrap {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.38s cubic-bezier(0.16, 1, 0.3, 1);
}

.wo-faq-item.is-open .wo-faq-content-wrap {
  grid-template-rows: 1fr;
}

.wo-faq-content-inner {
  overflow: hidden;
}

.wo-faq-a-text {
  padding: 0 20px 20px;
  font-size: var(--wo-faq-a-desk);
  color: var(--wo-faq-a);
  line-height: 1.65;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.28s ease, transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

.wo-faq-item.is-open .wo-faq-a-text {
  opacity: 1;
  transform: translateY(0);
  transition-delay: 0.08s;
}

.wo-faq-a-text a {
  color: var(--wo-faq-accent);
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* ============================================================
   VIEW ALL BUTTON
============================================================ */
.wo-faq-footer {
  text-align: center;
  margin-top: 32px;
}

.wo-faq-btn {
  display: inline-block;
  padding: 14px 40px;
  background-color: var(--wo-faq-btn-bg);
  color: var(--wo-faq-btn-text);
  border: 1px solid var(--wo-faq-btn-border);
  border-radius: 4px;
  font-family: inherit;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  transition: background-color 0.2s ease, color 0.2s ease;
}

.wo-faq-btn:hover {
  background-color: var(--wo-faq-accent);
  border-color: var(--wo-faq-accent);
  color: #000;
}

/* ============================================================
   RESPONSIVE
============================================================ */
@media (max-width: 768px) {
  .wo-faq-section {
    padding: var(--wo-faq-pad-top-mob) 16px var(--wo-faq-pad-bot-mob);
  }
  .wo-faq-header {
    margin-bottom: 24px;
  }
  .wo-faq-title {
    font-size: var(--wo-faq-title-mob);
  }
  /* Stack to single column on mobile */
  .wo-faq-grid {
    grid-template-columns: 1fr;
    gap: 0;
  }
  .wo-faq-col {
    gap: 6px;
    margin-bottom: 6px;
  }
  .wo-faq-q-text {
    font-size: var(--wo-faq-q-mob);
  }
  .wo-faq-a-text {
    font-size: var(--wo-faq-a-mob);
    padding: 0 16px 18px;
  }
  .wo-faq-trigger {
    padding: 16px;
  }
}
</style>

<section class="wo-faq-section">

  <!-- Background Image -->
  {%- if section.settings.bg_image != blank -%}
    <div class="wo-faq-bg" style="background-image: url('{{ section.settings.bg_image | image_url: width: 1600 }}');"></div>
  {%- else -%}
    <div class="wo-faq-bg" style="background-color: {{ section.settings.fallback_bg_color }};"></div>
  {%- endif -%}

  <!-- Overlay -->
  <div class="wo-faq-overlay"></div>

  <div class="wo-faq-inner">

    <!-- Header -->
    <div class="wo-faq-header">
      {%- if section.settings.title != blank -%}
        <h2 class="wo-faq-title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <!-- 2-Column FAQ Grid — each column is an independent accordion group -->
    <div class="wo-faq-grid">

      <!-- LEFT COLUMN (odd blocks: 1, 3, 5 …) -->
      <div class="wo-faq-col" data-col="left">
        {%- for block in section.blocks -%}
          {%- if forloop.index0 == 0 or forloop.index0 == 2 or forloop.index0 == 4 or forloop.index0 == 6 or forloop.index0 == 8 -%}
            <div class="wo-faq-item" {{ block.shopify_attributes }}>
              <button class="wo-faq-trigger"
                      aria-expanded="false"
                      aria-controls="faq-content-{{ block.id }}">
                <span class="wo-faq-q-text">{{ block.settings.question }}</span>
                <span class="wo-faq-icon" aria-hidden="true"></span>
              </button>
              <div class="wo-faq-content-wrap" id="faq-content-{{ block.id }}">
                <div class="wo-faq-content-inner">
                  <div class="wo-faq-a-text">{{ block.settings.answer }}</div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- RIGHT COLUMN (even blocks: 2, 4, 6 …) -->
      <div class="wo-faq-col" data-col="right">
        {%- for block in section.blocks -%}
          {%- if forloop.index0 == 1 or forloop.index0 == 3 or forloop.index0 == 5 or forloop.index0 == 7 or forloop.index0 == 9 -%}
            <div class="wo-faq-item" {{ block.shopify_attributes }}>
              <button class="wo-faq-trigger"
                      aria-expanded="false"
                      aria-controls="faq-content-{{ block.id }}">
                <span class="wo-faq-q-text">{{ block.settings.question }}</span>
                <span class="wo-faq-icon" aria-hidden="true"></span>
              </button>
              <div class="wo-faq-content-wrap" id="faq-content-{{ block.id }}">
                <div class="wo-faq-content-inner">
                  <div class="wo-faq-a-text">{{ block.settings.answer }}</div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

    <!-- View All Button -->
    {%- if section.settings.show_btn and section.settings.btn_label != blank -%}
      <div class="wo-faq-footer">
        <a href="{{ section.settings.btn_url }}" class="wo-faq-btn">
          {{ section.settings.btn_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<!-- ============================================================
     JAVASCRIPT: EXCLUSIVE ACCORDION (AUTO-CLOSE SIBLINGS)
============================================================ -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  const sectionEl = document.getElementById('shopify-section-{{ section.id }}');
  if (!sectionEl) return;

  sectionEl.querySelectorAll('.wo-faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const currentItem = btn.closest('.wo-faq-item');
      const parentCol  = btn.closest('.wo-faq-col');
      const isOpen     = currentItem.classList.contains('is-open');

      // Close all items ONLY within the same column
      parentCol.querySelectorAll('.wo-faq-item').forEach(item => {
        item.classList.remove('is-open');
        item.querySelector('.wo-faq-trigger').setAttribute('aria-expanded', 'false');
      });

      // If clicked item was closed, open it (toggle: if it was open it stays closed)
      if (!isOpen) {
        currentItem.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ── Default: প্রতিটি column এর প্রথম item auto-open ──
  sectionEl.querySelectorAll('.wo-faq-col').forEach(col => {
    const firstItem = col.querySelector('.wo-faq-item');
    if (firstItem) {
      firstItem.classList.add('is-open');
      firstItem.querySelector('.wo-faq-trigger').setAttribute('aria-expanded', 'true');
    }
  });
});
</script>

