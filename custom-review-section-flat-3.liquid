{% comment %}
  ============================================================
  PRO GRID SLIDER REVIEW SECTION
  Refactored for full customization from Theme Editor
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign title_font = section.settings.title_font
  assign body_font = section.settings.body_font
  assign meta_font = section.settings.meta_font

  assign title_font_bold = title_font | font_modify: 'weight', 'bold'
  assign title_font_italic = title_font | font_modify: 'style', 'italic'
  assign title_font_bold_italic = title_font_bold | font_modify: 'style', 'italic'

  assign body_font_bold = body_font | font_modify: 'weight', 'bold'
  assign body_font_italic = body_font | font_modify: 'style', 'italic'
  assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
-%}

<style>
  {{ title_font | font_face: font_display: 'swap' }}
  {{ title_font_bold | font_face: font_display: 'swap' }}
  {{ title_font_italic | font_face: font_display: 'swap' }}
  {{ title_font_bold_italic | font_face: font_display: 'swap' }}

  {{ body_font | font_face: font_display: 'swap' }}
  {{ body_font_bold | font_face: font_display: 'swap' }}
  {{ body_font_italic | font_face: font_display: 'swap' }}
  {{ body_font_bold_italic | font_face: font_display: 'swap' }}

  {{ meta_font | font_face: font_display: 'swap' }}

  #shopify-section-{{ section_id }} {
    /* Colors */
    --wo-bg: {{ section.settings.bg_color }};
    --wo-card-bg: {{ section.settings.card_bg }};
    --wo-border: {{ section.settings.border_color }};
    --wo-accent: {{ section.settings.accent_color }};
    --wo-text-main: {{ section.settings.text_color_main }};
    --wo-text-sub: {{ section.settings.text_color_sub }};
    --wo-dot-color: {{ section.settings.dot_color | default: section.settings.border_color }};
    --wo-dot-active: {{ section.settings.dot_active_color | default: section.settings.accent_color }};

    /* Typography - Header */
    --wo-title-font: {{ title_font.family }}, {{ title_font.fallback_families }};
    --wo-title-weight: {{ section.settings.title_weight | default: title_font.weight }};
    --wo-title-ls: {{ section.settings.title_ls | divided_by: 100.0 }}em;
    --wo-title-lh: {{ section.settings.title_lh | divided_by: 10.0 }};
    --wo-title-transform: {{ section.settings.title_transform }};

    --wo-sub-font: {{ meta_font.family }}, {{ meta_font.fallback_families }};
    --wo-sub-size: {{ section.settings.sub_size }}px;
    --wo-sub-weight: {{ section.settings.sub_weight }};
    --wo-sub-ls: {{ section.settings.sub_ls | divided_by: 100.0 }}em;
    --wo-sub-transform: {{ section.settings.sub_transform }};

    /* Typography - Card */
    --wo-quote-font: {{ body_font.family }}, {{ body_font.fallback_families }};
    --wo-quote-weight: {{ section.settings.quote_weight | default: body_font.weight }};
    --wo-quote-lh: {{ section.settings.quote_lh | divided_by: 10.0 }};

    --wo-name-font: {{ meta_font.family }}, {{ meta_font.fallback_families }};
    --wo-name-size: {{ section.settings.name_size }}px;
    --wo-name-weight: {{ section.settings.name_weight }};

    --wo-job-font: {{ meta_font.family }}, {{ meta_font.fallback_families }};
    --wo-job-size: {{ section.settings.job_size }}px;
    --wo-job-weight: {{ section.settings.job_weight }};

    /* Sizes */
    --wo-container-width: {{ section.settings.container_width }}px;
    --wo-title-desk: {{ section.settings.title_size_desktop }}px;
    --wo-text-desk: {{ section.settings.text_size_desktop }}px;
    --wo-title-mob: {{ section.settings.title_size_mobile }}px;
    --wo-text-mob: {{ section.settings.text_size_mobile }}px;

    /* Spacing */
    --wo-pad-top-desk: {{ section.settings.pad_top_desktop }}px;
    --wo-pad-bot-desk: {{ section.settings.pad_bot_desktop }}px;
    --wo-pad-top-mob: {{ section.settings.pad_top_mobile }}px;
    --wo-pad-bot-mob: {{ section.settings.pad_bot_mobile }}px;
    --wo-card-gap: {{ section.settings.card_gap }}px;
    --wo-card-padding: {{ section.settings.card_padding_v }}px {{ section.settings.card_padding_h }}px;

    /* Effects */
    --wo-card-radius: {{ section.settings.card_radius }}px;
    --wo-img-radius: {{ section.settings.img_radius }}%;
    --wo-shadow: {{ section.settings.card_shadow }};
    --wo-shadow-hover: {{ section.settings.card_shadow_hover }};
  }

  .wo-rev-sec {
    background: var(--wo-bg);
    padding: var(--wo-pad-top-desk) 0 var(--wo-pad-bot-desk);
    font-family: var(--wo-quote-font);
    overflow: hidden;
  }

  .wo-rev-wrap {
    max-width: var(--wo-container-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── Header ── */
  .wo-rev-header {
    text-align: {{ section.settings.header_align }};
    margin-bottom: {{ section.settings.header_margin_bottom }}px;
  }

  .wo-rev-subtitle {
    display: block;
    color: var(--wo-accent);
    font-family: var(--wo-sub-font);
    font-size: var(--wo-sub-size);
    font-weight: var(--wo-sub-weight);
    letter-spacing: var(--wo-sub-ls);
    text-transform: var(--wo-sub-transform);
    margin-bottom: 12px;
  }

  .wo-rev-title {
    font-family: var(--wo-title-font);
    font-size: var(--wo-title-desk);
    font-weight: var(--wo-title-weight);
    line-height: var(--wo-title-lh);
    letter-spacing: var(--wo-title-ls);
    text-transform: var(--wo-title-transform);
    color: var(--wo-text-main);
    margin: 0;
  }

  /* ── Slider ── */
  .wo-slider-outer {
    overflow: hidden;
    cursor: grab;
    -webkit-user-select: none;
    user-select: none;
    position: relative;
  }

  .wo-slider-outer.is-dragging {
    cursor: grabbing;
  }

  .wo-slider-track {
    display: flex;
    width: 100%;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .wo-slider-track.no-transition {
    transition: none !important;
  }

  /* Each slide is 100% width of outer */
  .wo-slide {
    min-width: 100%;
    width: 100%;
    display: grid;
    gap: var(--wo-card-gap);
    padding: 4px 2px 8px;
    align-items: stretch;
  }

  /* Grid columns set by JS data attribute */
  .wo-slide[data-cols="2"] { grid-template-columns: repeat(2, 1fr); }
  .wo-slide[data-cols="3"] { grid-template-columns: repeat(3, 1fr); }
  .wo-slide[data-cols="4"] { grid-template-columns: repeat(4, 1fr); }

  /* ── Card ── */
  .wo-rev-card {
    background: var(--wo-card-bg);
    border: 1px solid var(--wo-border);
    border-radius: var(--wo-card-radius);
    padding: var(--wo-card-padding);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    pointer-events: none;
    box-shadow: var(--wo-shadow);
  }

  .wo-slider-outer:not(.is-dragging) .wo-rev-card {
    pointer-events: auto;
  }

  .wo-rev-card:hover {
    box-shadow: var(--wo-shadow-hover);
    transform: translateY(-4px);
  }

  .wo-rev-quote-icon {
    display: {{ section.settings.show_quote_icon | liquid_if_true: 'block', 'none' }};
    color: var(--wo-accent);
    font-size: {{ section.settings.quote_icon_size }}px;
    line-height: 0.8;
    font-family: Georgia, serif;
    font-weight: 900;
    margin-bottom: 20px;
  }

  .wo-rev-quote {
    font-family: var(--wo-quote-font);
    font-size: var(--wo-text-desk);
    font-weight: var(--wo-quote-weight);
    color: var(--wo-text-sub);
    line-height: var(--wo-quote-lh);
    margin: 0;
    flex-grow: 1;
  }

  .wo-rev-profile {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--wo-border);
  }

  .wo-rev-img {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: var(--wo-img-radius);
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--wo-border);
    display: block;
    pointer-events: none;
  }

  .wo-rev-initial {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: var(--wo-img-radius);
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.12 }};
    color: var(--wo-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: calc({{ section.settings.avatar_size }}px * 0.4);
    font-weight: 800;
    flex-shrink: 0;
    border: 2px solid var(--wo-border);
  }

  .wo-rev-meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .wo-rev-name {
    font-family: var(--wo-name-font);
    font-size: var(--wo-name-size);
    font-weight: var(--wo-name-weight);
    color: var(--wo-text-main);
    margin: 0;
  }

  .wo-rev-job {
    font-family: var(--wo-job-font);
    font-size: var(--wo-job-size);
    font-weight: var(--wo-job-weight);
    color: var(--wo-accent);
    margin: 0;
  }

  /* ── Dots ── */
  .wo-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 36px;
    min-height: 20px;
  }

  .wo-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--wo-dot-color);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, transform 0.3s ease;
    outline: none;
    display: block;
    flex-shrink: 0;
  }

  .wo-dot.is-active {
    background: var(--wo-dot-active);
    transform: scale(1.4);
  }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .wo-rev-sec {
      padding: var(--wo-pad-top-mob) 0 var(--wo-pad-bot-mob);
    }
    .wo-rev-wrap {
      padding: 0 16px;
    }
    .wo-rev-title {
      font-size: var(--wo-title-mob);
    }
    .wo-rev-quote {
      font-size: var(--wo-text-mob);
    }
    .wo-slide {
      gap: 16px;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .wo-rev-wrap {
      padding: 0 24px;
    }
  }
</style>

<!-- Hidden data store for JS -->
<div
  id="wo-data-{{ section_id }}"
  style="display:none"
  data-cols="{{ section.settings.columns_desktop }}"
>
  {%- for block in section.blocks -%}
    <div
      class="wo-block-data"
      data-name="{{ block.settings.name | escape }}"
      data-job="{{ block.settings.job | escape }}"
      data-quote="{{ block.settings.quote | escape }}"
      data-image="{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 120 }}{%- endif -%}"
      data-initial="{{ block.settings.name | slice: 0 | upcase | escape }}"
    ></div>
  {%- endfor -%}
</div>

<section class="wo-rev-sec" id="wo-sec-{{ section_id }}">
  <div class="wo-rev-wrap">

    <!-- Header -->
    <div class="wo-rev-header">
      {%- if section.settings.subtitle != blank -%}
        <span class="wo-rev-subtitle">{{ section.settings.subtitle }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="wo-rev-title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <!-- Slider — built by JS -->
    <div class="wo-slider-outer" id="wo-outer-{{ section_id }}">
      <div class="wo-slider-track" id="wo-track-{{ section_id }}"></div>
    </div>

    <!-- Dots — built by JS -->
    <div class="wo-dots" id="wo-dots-{{ section_id }}"></div>

  </div>
</section>

<script>
(function () {
  'use strict';

  function initSection() {
    var sid     = '{{ section_id }}';
    var dataEl  = document.getElementById('wo-data-' + sid);
    var outer   = document.getElementById('wo-outer-' + sid);
    var track   = document.getElementById('wo-track-' + sid);
    var dotsEl  = document.getElementById('wo-dots-' + sid);

    if (!dataEl || !outer || !track || !dotsEl) return;

    /* ── Read block data from DOM ── */
    var blockEls = dataEl.querySelectorAll('.wo-block-data');
    var blocks   = [];
    blockEls.forEach(function (el) {
      blocks.push({
        name:    el.getAttribute('data-name')    || '',
        job:     el.getAttribute('data-job')     || '',
        quote:   el.getAttribute('data-quote')   || '',
        image:   el.getAttribute('data-image')   || '',
        initial: el.getAttribute('data-initial') || '?'
      });
    });

    if (blocks.length === 0) {
      track.innerHTML = '';
      dotsEl.innerHTML = '';
      return;
    }

    /* ── Responsive columns ── */
    var colsSetting = parseInt(dataEl.getAttribute('data-cols'), 10) || 3;

    function getActiveCols() {
      var w = window.innerWidth;
      if (w < 768)  return 1;
      if (w < 1024) return Math.min(2, colsSetting);
      return colsSetting;
    }

    /* ── Build card HTML ── */
    function buildCard(block) {
      var avatar = block.image
        ? '<img class="wo-rev-img" src="' + block.image + '" alt="' + block.name + '" loading="lazy" width="50" height="50">'
        : '<div class="wo-rev-initial">' + block.initial + '</div>';

      var quoteIcon = {{ section.settings.show_quote_icon | json }} 
        ? '<span class="wo-rev-quote-icon">\u201C</span>' 
        : '';

      return (
        '<div class="wo-rev-card">' +
          quoteIcon +
          '<p class="wo-rev-quote">' + block.quote + '</p>' +
          '<div class="wo-rev-profile">' +
            avatar +
            '<div class="wo-rev-meta">' +
              '<h3 class="wo-rev-name">' + block.name + '</h3>' +
              '<p class="wo-rev-job">' + block.job + '</p>' +
            '</div>' +
          '</div>' +
        '</div>'
      );
    }

    /* ── Chunk array into pages ── */
    function chunk(arr, size) {
      var pages = [];
      for (var i = 0; i < arr.length; i += size) {
        pages.push(arr.slice(i, i + size));
      }
      return pages;
    }

    /* ── State ── */
    var current  = 0;
    var pages    = [];
    var numPages = 0;

    /* ── Render slides ── */
    function render() {
      var cols  = getActiveCols();
      pages     = chunk(blocks, cols);
      numPages  = pages.length;
      current   = Math.min(current, numPages - 1);

      /* Build track HTML */
      var html = '';
      pages.forEach(function (page) {
        html += '<div class="wo-slide" data-cols="' + cols + '">';
        page.forEach(function (block) {
          html += buildCard(block);
        });
        html += '</div>';
      });
      track.innerHTML = html;

      /* Build dots */
      if (numPages <= 1) {
        dotsEl.innerHTML = '';
      } else {
        var dotsHtml = '';
        for (var i = 0; i < numPages; i++) {
          dotsHtml += '<button class="wo-dot' + (i === current ? ' is-active' : '') + '" data-idx="' + i + '" aria-label="Page ' + (i + 1) + '"></button>';
        }
        dotsEl.innerHTML = dotsHtml;

        dotsEl.querySelectorAll('.wo-dot').forEach(function (btn) {
          btn.addEventListener('click', function () {
            goTo(parseInt(this.getAttribute('data-idx'), 10));
          });
        });
      }

      /* Snap to current without animation */
      track.classList.add('no-transition');
      track.style.transform = 'translateX(' + (-current * 100) + '%)';
      /* Force reflow then re-enable transition */
      track.offsetHeight;
      track.classList.remove('no-transition');
    }

    /* ── Navigate ── */
    function goTo(index) {
      current = Math.max(0, Math.min(index, numPages - 1));
      track.style.transform = 'translateX(' + (-current * 100) + '%)';

      dotsEl.querySelectorAll('.wo-dot').forEach(function (d, i) {
        d.classList.toggle('is-active', i === current);
      });
    }

    /* ── Drag / Swipe ── */
    var dragStartX  = 0;
    var dragStartY  = 0;
    var dragCurrent = 0;
    var dragging    = false;
    var lockAxis    = null;
    var THRESHOLD   = 50;

    function dragStart(x, y) {
      dragStartX  = x;
      dragStartY  = y;
      dragCurrent = 0;
      dragging    = true;
      lockAxis    = null;
      track.classList.add('no-transition');
      outer.classList.add('is-dragging');
    }

    function dragMove(x, y) {
      if (!dragging) return;

      var dx = x - dragStartX;
      var dy = y - dragStartY;

      /* Lock axis on first meaningful movement */
      if (!lockAxis && (Math.abs(dx) > 6 || Math.abs(dy) > 6)) {
        lockAxis = Math.abs(dx) >= Math.abs(dy) ? 'x' : 'y';
      }

      if (lockAxis !== 'x') return;

      dragCurrent = dx;

      /* Resistance at edges */
      var resistance = 1;
      if ((current === 0 && dx > 0) || (current === numPages - 1 && dx < 0)) {
        resistance = 0.25;
      }

      var pct = (-current * 100) + ((dx * resistance) / outer.offsetWidth * 100);
      track.style.transform = 'translateX(' + pct + '%)';
    }

    function dragEnd() {
      if (!dragging) return;
      dragging = false;
      track.classList.remove('no-transition');
      outer.classList.remove('is-dragging');

      if (lockAxis === 'x') {
        if (dragCurrent < -THRESHOLD && current < numPages - 1) {
          goTo(current + 1);
        } else if (dragCurrent > THRESHOLD && current > 0) {
          goTo(current - 1);
        } else {
          goTo(current); /* snap back */
        }
      }

      lockAxis    = null;
      dragCurrent = 0;
    }

    /* Mouse */
    outer.addEventListener('mousedown', function (e) {
      if (e.button !== 0) return;
      e.preventDefault();
      dragStart(e.clientX, e.clientY);
    });

    document.addEventListener('mousemove', function (e) {
      dragMove(e.clientX, e.clientY);
    });

    document.addEventListener('mouseup', function () {
      dragEnd();
    });

    /* Touch */
    outer.addEventListener('touchstart', function (e) {
      dragStart(e.touches[0].clientX, e.touches[0].clientY);
    }, { passive: true });

    outer.addEventListener('touchmove', function (e) {
      if (lockAxis === 'x' && e.cancelable) e.preventDefault();
      dragMove(e.touches[0].clientX, e.touches[0].clientY);
    }, { passive: false });

    outer.addEventListener('touchend', function () {
      dragEnd();
    });

    /* Prevent browser drag on images */
    outer.addEventListener('dragstart', function (e) {
      e.preventDefault();
    });

    /* ── Resize ── */
    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(render, 200);
    });

    /* ── Init ── */
    render();
  }

  // Handle Shopify Theme Editor events
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail.sectionId === '{{ section_id }}') initSection();
  });

  initSection();

})();
</script>

{% schema %}
{
  "name": "PRO Grid Reviews",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "━━ Content ━━"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "SUCCESS STORIES"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Real People. Real Results."
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "━━ Layout ━━"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1400
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Cards Per Page (Desktop)",
      "options": [
        { "value": "2", "label": "2 Cards" },
        { "value": "3", "label": "3 Cards" },
        { "value": "4", "label": "4 Cards" }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Gap Between Cards",
      "default": 24
    },
    {
      "type": "header",
      "content": "━━ Card Style ━━"
    },
    {
      "type": "checkbox",
      "id": "show_quote_icon",
      "label": "Show Quote Icon",
      "default": true
    },
    {
      "type": "range",
      "id": "quote_icon_size",
      "min": 30,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Quote Icon Size",
      "default": 52
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card Border Radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding_v",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Card Vertical Padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_padding_h",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Card Horizontal Padding",
      "default": 28
    },
    {
      "type": "text",
      "id": "card_shadow",
      "label": "Card Shadow (CSS)",
      "default": "0 4px 12px rgba(0,0,0,0.05)",
      "info": "Example: 0 4px 12px rgba(0,0,0,0.05)"
    },
    {
      "type": "text",
      "id": "card_shadow_hover",
      "label": "Card Shadow Hover (CSS)",
      "default": "0 12px 40px rgba(0,0,0,0.10)"
    },
    {
      "type": "header",
      "content": "━━ Avatar Style ━━"
    },
    {
      "type": "range",
      "id": "avatar_size",
      "min": 30,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Avatar Size",
      "default": 50
    },
    {
