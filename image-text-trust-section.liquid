      "default": "Real people.\nReal jobs.\nReal freedom.",
      "info": "Use Enter for line breaks."
    },
    {
      "type": "header",
      "content": "Trust Bar (Bottom of Card)"
    },
    {
      "type": "checkbox", "id": "show_trust_bar", "label": "Show Trust Bar", "default": true
    },
    {
      "type": "image_picker", "id": "avatar_1", "label": "Avatar 1"
    },
    {
      "type": "image_picker", "id": "avatar_2", "label": "Avatar 2"
    },
    {
      "type": "image_picker", "id": "avatar_3", "label": "Avatar 3"
    },
    {
      "type": "text", "id": "trust_text_bold", "label": "Main Text",
      "default": "Join thousands who changed their life"
    },
    {
      "type": "text", "id": "trust_text_sub", "label": "Sub Text",
      "default": "with an offshore career"
    },
    {
      "type": "text", "id": "rating_score", "label": "Rating Score",
      "default": "4.9/5"
    },
    {
      "type": "text", "id": "review_count_text", "label": "Review Count Text",
      "default": "From 1,000+ reviews"
    },
    {
      "type": "header",
      "content": "Typography - Desktop"
    },
    {
      "type": "range", "id": "title_size_desk", "min": 24, "max": 64, "step": 2, "unit": "px",
      "label": "Heading Size", "default": 42
    },
    {
      "type": "range", "id": "subtitle_size_desk", "min": 10, "max": 24, "step": 1, "unit": "px",
      "label": "Subtitle Size", "default": 14
