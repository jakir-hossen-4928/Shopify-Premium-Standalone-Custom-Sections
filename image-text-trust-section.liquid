{% comment %}
  ============================================================
  PRO IMAGE & TRUST TEXT SECTION
  Refactored for full customization from Theme Editor
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign title_font = section.settings.title_font
  assign body_font = section.settings.body_font
  assign accent_font = section.settings.accent_font
  assign hand_font = section.settings.hand_font
-%}

<style>
  {{ title_font | font_face: font_display: 'swap' }}
  {{ body_font | font_face: font_display: 'swap' }}
  {{ accent_font | font_face: font_display: 'swap' }}
  {{ hand_font | font_face: font_display: 'swap' }}

  #ImageTrustSection-{{ section_id }} {
    /* Section Padding */
    --padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --max-width: {{ section.settings.max_width }}px;

    /* Typography - Header */
    --title-font: {{ title_font.family }}, {{ title_font.fallback_families }};
    --title-size-desk: {{ section.settings.title_size_desk }}px;
    --title-size-mob: {{ section.settings.title_size_mob }}px;
    --title-weight: {{ section.settings.title_weight | default: title_font.weight }};
    --title-lh: {{ section.settings.title_lh }};
    --title-ls: {{ section.settings.title_ls }}em;
    --title-transform: {{ section.settings.title_transform }};

    --subtitle-font: {{ accent_font.family }}, {{ accent_font.fallback_families }};
    --subtitle-size-desk: {{ section.settings.subtitle_size_desk }}px;
    --subtitle-size-mob: {{ section.settings.subtitle_size_mob }}px;
    --subtitle-weight: {{ section.settings.subtitle_weight | default: accent_font.weight }};
    --subtitle-ls: {{ section.settings.subtitle_ls }}em;
    --subtitle-transform: {{ section.settings.subtitle_transform }};

    /* Typography - Body */
    --text-font: {{ body_font.family }}, {{ body_font.fallback_families }};
    --text-size-desk: {{ section.settings.text_size_desk }}px;
    --text-size-mob: {{ section.settings.text_size_mob }}px;
    --text-weight: {{ section.settings.text_weight | default: body_font.weight }};
    --text-lh: {{ section.settings.text_lh }};

    /* Typography - Hand */
    --hand-font: {{ hand_font.family }}, {{ hand_font.fallback_families }};
    --handwriting-size-desk: {{ section.settings.handwriting_size_desk }}px;
    --handwriting-size-mob: {{ section.settings.handwriting_size_mob }}px;
    --handwriting-weight: {{ section.settings.hand_weight | default: hand_font.weight }};

    /* Colors */
    --bg-color: {{ section.settings.bg_color }};
    --title-color: {{ section.settings.title_color }};
    --text-color: {{ section.settings.text_color }};
    --highlight-color: {{ section.settings.highlight_color }};
    
    --btn-bg: {{ section.settings.btn_bg }};
    --btn-text-color: {{ section.settings.btn_text_color }};
    --btn-radius: {{ section.settings.btn_radius }}px;
    
    --feature-bg: {{ section.settings.feature_bg }};
    --feature-border: {{ section.settings.feature_border }};
    --feature-radius: {{ section.settings.feature_radius }}px;
    
    --card-bg: {{ section.settings.card_bg }};
    --card-radius: {{ section.settings.card_radius }}px;
  }

  #ImageTrustSection-{{ section_id }} {
    background-color: var(--bg-color);
    padding-top: var(--padding-top-desktop);
    padding-bottom: var(--padding-bottom-desktop);
    overflow: hidden;
  }

  #ImageTrustSection-{{ section_id }} * { box-sizing: border-box; }

  .itt-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: {{ section.settings.column_gap }}px;
    align-items: center;
  }

  /* Animations */
  .itt-animate {
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.25, 0.8, 0.25, 1), transform 1.2s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  
  .itt-animate.slide-left { transform: translateX(-80px); }
  .itt-animate.slide-right { transform: translateX(80px); }
  .itt-animate.itt-visible { opacity: 1; transform: translateX(0); }

  /* Left Column */
  .itt-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    text-align: {{ section.settings.text_align }};
    align-items: {{ section.settings.text_align | replace: 'left', 'flex-start' | replace: 'right', 'flex-end' }};
    order: {{ section.settings.media_position | liquid_if_true: '2', '1' }};
  }

  .itt-subtitle {
    font-family: var(--subtitle-font);
    font-size: var(--subtitle-size-desk);
    color: var(--highlight-color);
    font-weight: var(--subtitle-weight);
    text-transform: var(--subtitle-transform);
    letter-spacing: var(--subtitle-ls);
    margin: 0;
  }

  .itt-title {
    font-family: var(--title-font);
    font-size: var(--title-size-desk);
    color: var(--title-color);
    line-height: var(--title-lh);
    letter-spacing: var(--title-ls);
    text-transform: var(--title-transform);
    font-weight: var(--title-weight);
    margin: 0;
  }

  .itt-text {
    font-family: var(--text-font);
    font-size: var(--text-size-desk);
    font-weight: var(--text-weight);
    color: var(--text-color);
    line-height: var(--text-lh);
    margin: 0;
  }

  .itt-text p { margin: 0 0 10px 0; }
  .itt-text p:last-child { margin: 0; }

  .itt-features {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 10px;
    justify-content: {{ section.settings.text_align | replace: 'left', 'flex-start' | replace: 'right', 'flex-end' }};
  }

  .itt-feature-tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--feature-bg);
    border: 1px solid var(--feature-border);
    padding: 8px 14px;
    border-radius: var(--feature-radius);
    font-size: 12px;
    font-weight: 600;
    color: var(--title-color);
  }

  .itt-feature-tag svg { width: 16px; height: 16px; color: var(--highlight-color); flex-shrink: 0; }

  .itt-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: var(--btn-bg);
    color: var(--btn-text-color);
    padding: 16px 28px;
    border-radius: var(--btn-radius);
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .itt-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.15); }
  .itt-btn svg { width: 14px; height: 14px; }

  /* Right Column */
  .itt-media-card {
    background: var(--card-bg);
    border-radius: var(--card-radius);
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    position: relative;
    order: {{ section.settings.media_position | liquid_if_true: '1', '2' }};
  }

  .itt-image-wrap {
    position: relative;
    width: 100%;
    padding-bottom: 60%;
    border-radius: var(--card-radius) var(--card-radius) 0 0;
    overflow: hidden;
  }

  .itt-image-wrap img, .itt-image-wrap video {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  }

  .itt-image-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 50%, rgba(0,0,0,0.4) 100%);
  }

  .itt-handwriting-wrap {
    position: absolute;
    top: {{ section.settings.hand_pos_v }}%;
    left: {{ section.settings.hand_pos_h }}%;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: rotate({{ section.settings.hand_rotation }}deg);
  }

  .itt-handwriting {
    font-family: var(--hand-font);
    font-size: var(--handwriting-size-desk);
    font-weight: var(--handwriting-weight);
    color: #fff;
    line-height: 1.2;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    white-space: pre-line;
  }

  .itt-arrow-svg {
    width: {{ section.settings.arrow_size }}px;
    height: auto;
    margin-top: 5px;
    stroke: #fff;
    filter: drop-shadow(0 2px 2px rgba(0,0,0,0.5));
    display: {{ section.settings.show_arrow | liquid_if_true: 'block', 'none' }};
  }

  .itt-play-btn {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 70px; height: 70px;
    background: #fff; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    z-index: 2; cursor: pointer;
    box-shadow: 0 0 0 8px rgba(255,255,255,0.2), 0 10px 20px rgba(0,0,0,0.2);
    transition: transform 0.3s ease;
  }

  .itt-play-btn:hover { transform: translate(-50%, -50%) scale(1.05); }
  .itt-play-btn svg { width: 24px; height: 24px; fill: #000; margin-left: 4px; }

  /* Trust Bar */
  .itt-trust-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    background: var(--card-bg);
    border-radius: 0 0 var(--card-radius) var(--card-radius);
    flex-wrap: wrap;
    gap: 16px;
  }

  .itt-trust-left, .itt-trust-right { display: flex; align-items: center; gap: 12px; }
  .itt-avatars { display: flex; align-items: center; }
  .itt-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    border: 2px solid var(--card-bg); object-fit: cover;
    margin-left: -12px; background-color: #eee;
  }
  .itt-avatar:first-child { margin-left: 0; }

  .itt-trust-text { font-size: 13px; font-weight: 600; color: var(--title-color); line-height: 1.3; }
  .itt-trust-text span { display: block; font-weight: 400; color: var(--text-color); font-size: 12px; }

  .itt-rating-box {
    border: 1px solid var(--feature-border);
    padding: 4px 10px; border-radius: 20px;
    font-weight: 700; font-size: 16px; color: var(--title-color);
  }

  .itt-stars-wrap { display: flex; flex-direction: column; gap: 2px; }
  .itt-stars { display: flex; gap: 2px; color: var(--highlight-color); }
  .itt-stars svg { width: 14px; height: 14px; fill: currentColor; }
  .itt-reviews-count { font-size: 11px; color: var(--highlight-color); font-weight: 500; }

  /* Modal */
  .itt-video-modal {
    position: fixed; inset: 0; z-index: 99999;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.4s ease;
  }
  .itt-video-modal.active { opacity: 1; pointer-events: auto; }
  .itt-modal-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(5px); }
  .itt-modal-content { position: relative; width: 90%; max-width: 1000px; z-index: 2; transform: scale(0.95); transition: transform 0.4s ease; }
  .itt-video-modal.active .itt-modal-content { transform: scale(1); }
  .itt-video-modal video { width: 100%; border-radius: 12px; }
  .itt-close-btn { position: absolute; top: -45px; right: 0; color: #fff; background: none; border: none; font-size: 32px; cursor: pointer; }

  /* Mobile */
  @media screen and (max-width: 990px) {
    #ImageTrustSection-{{ section_id }} { padding-top: var(--padding-top-mobile); padding-bottom: var(--padding-bottom-mobile); }
    .itt-container { grid-template-columns: 1fr; gap: 40px; }
    .itt-animate.slide-left, .itt-animate.slide-right { transform: translateY(40px); }
    .itt-animate.itt-visible { transform: translateY(0); }
    .itt-title { font-size: var(--title-size-mob); }
    .itt-subtitle { font-size: var(--subtitle-size-mob); }
    .itt-text { font-size: var(--text-size-mob); }
    .itt-handwriting { font-size: var(--handwriting-size-mob); }
    .itt-content { align-items: center; text-align: center; order: 2; }
    .itt-media-card { order: 1; }
    .itt-btn { width: 100%; }
    .itt-image-wrap { padding-bottom: 75%; }
    .itt-trust-bar { flex-direction: column; text-align: center; padding: 20px; }
    .itt-trust-left { flex-direction: column; }
    .itt-trust-right { justify-content: center; }
  }
</style>

<section id="ImageTrustSection-{{ section_id }}">
  <div class="itt-container">
    
    <div class="itt-content itt-animate slide-left">
      {% if section.settings.subtitle != blank %}
        <h4 class="itt-subtitle">{{ section.settings.subtitle }}</h4>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="itt-title">{{ section.settings.title }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="itt-text">{{ section.settings.text }}</div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="itt-features">
          {% for block in section.blocks %}
            <div class="itt-feature-tag" {{ block.shopify_attributes }}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
              {{ block.settings.title }}
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.btn_text != blank %}
        <a href="{{ section.settings.btn_link }}" class="itt-btn">
          {{ section.settings.btn_text }}
          <svg viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {% endif %}
    </div>

    <div class="itt-media-card itt-animate slide-right">
      <div class="itt-image-wrap">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
        
        <div class="itt-image-overlay"></div>

        {% if section.settings.handwriting_text != blank %}
          <div class="itt-handwriting-wrap">
            <div class="itt-handwriting">{{ section.settings.handwriting_text }}</div>
            <svg class="itt-arrow-svg" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 20 Q 30 70, 80 80" stroke-width="4" stroke-linecap="round" fill="transparent"/>
              <path d="M60 70 L 80 80 L 70 95" stroke-width="4" stroke-linecap="round" fill="transparent"/>
            </svg>
          </div>
        {% endif %}

        {% if section.settings.hosted_video != blank %}
          <div class="itt-play-btn" role="button" aria-label="Play video">
            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div>
        {% endif %}
      </div>

      {% if section.settings.show_trust_bar %}
        <div class="itt-trust-bar">
          <div class="itt-trust-left">
            <div class="itt-avatars">
              {% if section.settings.avatar_1 != blank %}
                {{ section.settings.avatar_1 | image_url: width: 80 | image_tag: class: 'itt-avatar' }}
              {% endif %}
              {% if section.settings.avatar_2 != blank %}
                {{ section.settings.avatar_2 | image_url: width: 80 | image_tag: class: 'itt-avatar' }}
              {% endif %}
              {% if section.settings.avatar_3 != blank %}
                {{ section.settings.avatar_3 | image_url: width: 80 | image_tag: class: 'itt-avatar' }}
              {% endif %}
            </div>
            <div class="itt-trust-text">
              {{ section.settings.trust_text_bold }}
              <span>{{ section.settings.trust_text_sub }}</span>
            </div>
          </div>

          <div class="itt-trust-right">
            <div class="itt-rating-box">{{ section.settings.rating_score }}</div>
            <div class="itt-stars-wrap">
              <div class="itt-stars">
                {%- for i in (1..5) -%}
                  <svg viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/></svg>
                {%- endfor -%}
              </div>
              <div class="itt-reviews-count">{{ section.settings.review_count_text }}</div>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  {% if section.settings.hosted_video != blank %}
    <div class="itt-video-modal" role="dialog" aria-modal="true" aria-label="Video Player">
      <div class="itt-modal-overlay"></div>
      <div class="itt-modal-content">
        <button class="itt-close-btn" aria-label="Close video">&times;</button>
        {{ section.settings.hosted_video | video_tag: controls: true, autoplay: false, loop: false, width: '100%' }}
      </div>
    </div>
  {% endif %}
</section>

<script>
  (function() {
    function initSection() {
      const section = document.querySelector("#ImageTrustSection-{{ section_id }}");
      if (!section) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('itt-visible');
          }
        });
      }, { threshold: 0.15 });

      section.querySelectorAll('.itt-animate').forEach(el => observer.observe(el));

      const playBtn = section.querySelector('.itt-play-btn');
      const modal = section.querySelector('.itt-video-modal');
      
      if (playBtn && modal) {
        const closeBtn = modal.querySelector('.itt-close-btn');
        const overlay = modal.querySelector('.itt-modal-overlay');
        const videoEl = modal.querySelector('video');

        playBtn.addEventListener('click', () => { modal.classList.add('active'); videoEl?.play(); });
        [closeBtn, overlay].forEach(el => el.addEventListener('click', () => { modal.classList.remove('active'); videoEl?.pause(); }));
      }
    }

    document.addEventListener("DOMContentLoaded", initSection);
    if (Shopify.designMode) {
      document.addEventListener('shopify:section:load', e => { if (e.detail.sectionId === '{{ section_id }}') initSection(); });
    }
  })();
</script>

{% schema %}
{
  "name": "PRO Image & Trust Text",
  "settings": [
    {
      "type": "header",
      "content": "━━ Layout ━━"
    },
    {
      "type": "range", "id": "max_width", "min": 800, "max": 1800, "step": 20, "unit": "px", "label": "Container Width", "default": 1300
    },
    {
      "type": "range", "id": "column_gap", "min": 20, "max": 120, "step": 5, "unit": "px", "label": "Column Gap", "default": 60
    },
    {
      "type": "select", "id": "media_position", "label": "Media Position",
      "options": [
        { "value": "false", "label": "Right" },
        { "value": "true", "label": "Left" }
      ],
      "default": "false"
    },
    {
      "type": "select", "id": "text_align", "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "━━ Content ━━"
    },
    {
      "type": "text", "id": "subtitle", "label": "Subtitle", "default": "YOUR FUTURE IS OFFSHORE"
    },
    {
      "type": "textarea", "id": "title", "label": "Heading", "default": "We Help You Get Hired in the Norwegian Offshore Industry"
    },
    {
      "type": "richtext", "id": "text", "label": "Paragraph", "default": "<p>Work Offshore is your trusted guide to enter the offshore oil and gas industry in Norway. We provide step-by-step guidance, professional CV services and career resources that help you stand out and get hired faster.</p>"
    },
    {
      "type": "text", "id": "btn_text", "label": "Button Text", "default": "LEARN MORE ABOUT US"
    },
    {
      "type": "url", "id": "btn_link", "label": "Button Link"
    },
    {
      "type": "header",
      "content": "━━ Media & Effects ━━"
    },
    {
      "type": "image_picker", "id": "image", "label": "Cover Image"
    },
    {
      "type": "video", "id": "hosted_video", "label": "Upload Video"
    },
    {
      "type": "textarea", "id": "handwriting_text", "label": "Handwritten Text", "default": "Real people.\nReal jobs.\nReal freedom."
    },
    {
      "type": "checkbox", "id": "show_arrow", "label": "Show Arrow Icon", "default": true
    },
    {
      "type": "range", "id": "arrow_size", "min": 20, "max": 100, "step": 2, "unit": "px", "label": "Arrow Size", "default": 40
    },
    {
      "type": "range", "id": "hand_pos_v", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Handwriting Position V", "default": 15
    },
    {
      "type": "range", "id": "hand_pos_h", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Handwriting Position H", "default": 6
    },
    {
      "type": "range", "id": "hand_rotation", "min": -45, "max": 45, "step": 1, "unit": "deg", "label": "Handwriting Rotation", "default": 0
    },
    {
      "type": "header",
      "content": "━━ Trust Bar ━━"
    },
    {
      "type": "checkbox", "id": "show_trust_bar", "label": "Show Trust Bar", "default": true
    },
    {
      "type": "image_picker", "id": "avatar_1", "label": "Avatar 1"
    },
    {
      "type": "image_picker", "id": "avatar_2", "label": "Avatar 2"
    },
    {
      "type": "image_picker", "id": "avatar_3", "label": "Avatar 3"
    },
    {
      "type": "text", "id": "trust_text_bold", "label": "Main Text", "default": "Join thousands who changed their life"
    },
    {
      "type": "text", "id": "trust_text_sub", "label": "Sub Text", "default": "with an offshore career"
    },
    {
      "type": "text", "id": "rating_score", "label": "Rating Score", "default": "4.9/5"
    },
    {
      "type": "text", "id": "review_count_text", "label": "Review Count Text", "default": "From 1,000+ reviews"
    },
    {
      "type": "header",
      "content": "━━ Typography Header ━━"
    },
    {
      "type": "font_picker", "id": "title_font", "label": "Heading Font", "default": "assistant_n8"
    },
    {
      "type": "range", "id": "title_size_desk", "min": 20, "max": 80, "step": 2, "unit": "px", "label": "Heading Size Desktop", "default": 42
    },
    {
      "type": "range", "id": "title_size_mob", "min": 18, "max": 50, "step": 2, "unit": "px", "label": "Heading Size Mobile", "default": 32
    },
    {
      "type": "select", "id": "title_weight", "label": "Heading Weight",
      "options": [
        { "value": "400", "label": "Regular" },
