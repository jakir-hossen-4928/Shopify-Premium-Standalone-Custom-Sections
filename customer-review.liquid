{%- liquid
  assign heading_size_class = 'heading--medium'
  if section.settings.heading_size == 'large'
    assign heading_size_class = 'heading--large'
  endif

  assign text_align_class = 'text-align--' | append: section.settings.text_alignment

  assign container_class = 'container--default'
  if section.settings.container_type == 'full_width'
    assign container_class = 'container--full-width'
  elsif section.settings.container_type == 'container_box'
    assign container_class = 'container--box'
  endif

  assign animation_class = ''
  if section.settings.animation != 'inherit'
    assign animation_class = 'animate--' | append: section.settings.animation
  endif
-%}

<style>
  #shopify-section-{{ section.id }} {
    /* Container Widths */
    --container-max-width-desktop: {{ section.settings.container_max_width_desktop }}px;
    --container-max-width-mobile: {{ section.settings.container_max_width_mobile }}px;

    /* Stars */
    --stars-color: {{ section.settings.stars_color }};
    --star-size: {{ section.settings.star_size }}px;
    --star-spacing: {{ section.settings.star_spacing }}px;

    /* Paddings */
    --pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    
    /* Card Padding */
    --card-padding-desktop: {{ section.settings.card_padding_desktop }};
    --card-padding-mobile: {{ section.settings.card_padding_mobile }};

    /* Card Layout & Colors */
    --card-bg-color: {{ section.settings.card_bg_color }};
    --card-border-color: {{ section.settings.card_border_color }};
    --card-border-width: {{ section.settings.card_border_width }}px;
    --card-border-radius: {{ section.settings.card_border_radius }}px;
    --card-width-desktop: {{ section.settings.card_width_desktop }};
    --card-width-mobile: {{ section.settings.card_width_mobile }};
    --card-min-height-desktop: {{ section.settings.card_min_height_desktop }}px;
    --card-min-height-mobile: {{ section.settings.card_min_height_mobile }}px;

    /* Typography Colors */
    --heading-color: {{ section.settings.heading_color }};
    --subheading-color: {{ section.settings.subheading_color }};
    --desc-color: {{ section.settings.desc_color }};
    --quote-color: {{ section.settings.quote_color }};
    --author-name-color: {{ section.settings.author_name_color }};
    --author-location-color: {{ section.settings.author_location_color }};

    /* Typography Font Sizes - Desktop */
    --desktop-heading-size: {{ section.settings.desktop_heading_size }}px;
    --desktop-subheading-size: {{ section.settings.desktop_subheading_size }}px;
    --desktop-desc-size: {{ section.settings.desktop_desc_size }}px;
    --desktop-quote-size: {{ section.settings.desktop_quote_size }}px;
    --desktop-author-size: {{ section.settings.desktop_author_size }}px;
    --desktop-location-size: {{ section.settings.desktop_location_size }}px;

    /* Typography Font Sizes - Mobile */
    --mobile-heading-size: {{ section.settings.mobile_heading_size }}px;
    --mobile-subheading-size: {{ section.settings.mobile_subheading_size }}px;
    --mobile-desc-size: {{ section.settings.mobile_desc_size }}px;
    --mobile-quote-size: {{ section.settings.mobile_quote_size }}px;
    --mobile-author-size: {{ section.settings.mobile_author_size }}px;
    --mobile-location-size: {{ section.settings.mobile_location_size }}px;

    /* Author Avatar Size */
    --avatar-size-desktop: {{ section.settings.avatar_size_desktop }}px;
    --avatar-size-mobile: {{ section.settings.avatar_size_mobile }}px;
    --avatar-border-radius: {{ section.settings.avatar_border_radius }}px;

    /* Nav Button custom variables */
    --nav-btn-size: {{ section.settings.nav_btn_size }}px;
    --nav-btn-radius: {{ section.settings.nav_btn_radius }}px;
    --nav-btn-color: {{ section.settings.nav_btn_color }};
    --nav-btn-bg-color: {{ section.settings.nav_btn_bg_color }};
    --nav-btn-border-color: {{ section.settings.nav_btn_border_color }};
    --nav-btn-hover-color: {{ section.settings.nav_btn_hover_color }};
    --nav-btn-hover-bg-color: {{ section.settings.nav_btn_hover_bg_color }};
  }

  .testi-{{ section.id }} {
    padding-top: var(--pt-desktop);
    padding-bottom: var(--pb-desktop);
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  /* Container types */
  .testi-{{ section.id }} .container--default   { max-width: var(--container-max-width-desktop); margin: 0 auto; padding: 0 20px; }
  .testi-{{ section.id }} .container--full-width { max-width: 100%; padding: 0 20px; }
  .testi-{{ section.id }} .container--box       { max-width: var(--container-max-width-desktop); margin: 0 auto; padding: 0 48px; }

  @media (max-width: 768px) {
    .testi-{{ section.id }} {
      padding-top: var(--pt-mobile);
      padding-bottom: var(--pb-mobile);
    }
    .testi-{{ section.id }} .container--default   { max-width: var(--container-max-width-mobile); }
    .testi-{{ section.id }} .container--box       { max-width: var(--container-max-width-mobile); padding: 0 20px; }
  }

  /* Header */
  .testi-{{ section.id }} .section-header { padding: 0 20px; margin-bottom: 20px; }
  .testi-{{ section.id }} .text-align--left   { text-align: left; }
  .testi-{{ section.id }} .text-align--center { text-align: center; }

  .testi-{{ section.id }} .section-heading {
    color: var(--heading-color); line-height: 1.15; font-weight: 400; margin: 0 0 12px;
    font-size: var(--desktop-heading-size);
  }
  .testi-{{ section.id }} .section-heading .highlight { color: #C17A36; font-style: italic; }

  .testi-{{ section.id }} .section-subheading {
    font-size: var(--desktop-subheading-size); font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--subheading-color); margin-bottom: 14px;
  }
  .testi-{{ section.id }} .section-description {
    font-size: var(--desktop-desc-size); color: var(--desc-color); line-height: 1.7;
    margin-top: 14px; max-width: 560px;
  }
  .testi-{{ section.id }} .text-align--center .section-description { margin-left: auto; margin-right: auto; }

  /* Carousel */
  .testi-{{ section.id }} .carousel-outer { position: relative; }

  .testi-{{ section.id }} .carousel-viewport {
    overflow: hidden; cursor: grab;
    user-select: none; -webkit-user-select: none;
  }
  .testi-{{ section.id }} .carousel-viewport:active { cursor: grabbing; }

  .testi-{{ section.id }} .carousel-track {
    display: flex;
    will-change: transform;
  }

  .testi-{{ section.id }} .layout--slider {
    gap: {{ section.settings.slider_gap_desktop }}px;
    padding: 20px 0 28px;
  }

  .testi-{{ section.id }} .layout--grid {
    display: grid !important;
    grid-template-columns: repeat({{ section.settings.grid_cols_desktop }}, 1fr) !important;
    gap: {{ section.settings.grid_gap_desktop }}px !important;
    padding: 20px 0 28px !important;
    flex-wrap: wrap !important;
  }

  /* Cards */
  .testi-{{ section.id }} .testimonial-card {
    background: var(--card-bg-color);
    border: var(--card-border-width) solid var(--card-border-color);
    border-radius: var(--card-border-radius);
    padding: var(--card-padding-desktop);
    transition: transform 0.4s ease, opacity 0.4s ease, box-shadow 0.4s ease;
    flex-shrink: 0;
    min-height: var(--card-min-height-desktop);
    box-sizing: border-box;
  }

  .testi-{{ section.id }} .layout--slider .testimonial-card {
    flex: 0 0 var(--card-width-desktop);
    opacity: 0.5;
    transform: scale(0.96);
  }

  .testi-{{ section.id }} .layout--slider .testimonial-card.is-active {
    opacity: 1;
    transform: scale(1);
    box-shadow: 0 4px 24px -4px hsla(150, 30%, 12%, 0.06);
  }

  .testi-{{ section.id }} .layout--slider .testimonial-card.is-near {
    opacity: 0.82;
    transform: scale(0.98);
  }

  .testi-{{ section.id }} .layout--grid .testimonial-card {
    width: 100%;
    opacity: 1 !important;
    transform: none !important;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }

  /* Stars */
  .testi-{{ section.id }} .card-stars {
    display: flex;
    gap: var(--star-spacing);
    margin-bottom: 20px;
    justify-content: {{ section.settings.stars_alignment }};
  }
  .testi-{{ section.id }} .star-icon  { width: var(--star-size); height: var(--star-size); fill: var(--stars-color); }
  .testi-{{ section.id }} .star-icon.dim { fill: rgba(193,122,54,0.2); }

  /* Quote */
  .testi-{{ section.id }} .card-quote {
    font-size: var(--desktop-quote-size); line-height: 1.4; color: var(--quote-color);
    font-weight: 300; margin-bottom: 28px; min-height: 90px;
  }

  /* Author & Avatar */
  .testi-{{ section.id }} .card-author {
    border-top: 1px solid rgba(0,0,0,0.07);
    padding-top: 20px;
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .testi-{{ section.id }} .author-avatar-wrapper {
    width: var(--avatar-size-desktop);
    height: var(--avatar-size-desktop);
    border-radius: var(--avatar-border-radius);
    overflow: hidden;
    flex-shrink: 0;
  }
  .testi-{{ section.id }} .author-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .testi-{{ section.id }} .author-meta {
    display: flex;
    flex-direction: column;
  }

  .testi-{{ section.id }} .author-name {
    font-style: italic; font-size: var(--desktop-author-size); color: var(--author-name-color); margin-bottom: 3px;
  }
  .testi-{{ section.id }} .author-location {
    font-size: var(--desktop-location-size); font-weight: 600; letter-spacing: 0.05em;
    color: var(--author-location-color); text-transform: uppercase;
  }

  /* Nav Controls */
  .testi-{{ section.id }} .carousel-nav {
    display: flex; align-items: center; justify-content: center;
    gap: 16px; margin-top: 36px;
  }
  .testi-{{ section.id }} .nav-btn {
    width: var(--nav-btn-size); height: var(--nav-btn-size); border-radius: var(--nav-btn-radius);
    border: 1.5px solid var(--nav-btn-border-color); background: var(--nav-btn-bg-color);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background 0.25s, border-color 0.25s, transform 0.2s;
    color: var(--nav-btn-color);
  }
  .testi-{{ section.id }} .nav-btn:hover {
    background: var(--nav-btn-hover-bg-color); color: var(--nav-btn-hover-color); border-color: var(--nav-btn-hover-bg-color); transform: scale(1.08);
  }
  .testi-{{ section.id }} .nav-btn svg {
    width: 18px; height: 18px; stroke: currentColor; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }

  /* Pagination */
  .testi-{{ section.id }} .carousel-pagination {
    display: flex; align-items: center; gap: 8px;
    justify-content: center; margin-top: 24px;
  }
  .testi-{{ section.id }} .pagination-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: rgba(193,122,54,0.25); cursor: pointer; border: none;
    transition: background 0.25s, transform 0.25s; padding: 0;
  }
  .testi-{{ section.id }} .pagination-dot.is-active { background: #C17A36; transform: scale(1.4); }

  /* Animations */
  .animate--fade-in       { opacity:0; animation: tmFadeIn      0.7s ease forwards; }
  .animate--fade-in-up    { opacity:0; animation: tmFadeInUp    0.7s ease forwards; }
  .animate--fade-in-left  { opacity:0; animation: tmFadeInLeft  0.7s ease forwards; }
  .animate--fade-in-right { opacity:0; animation: tmFadeInRight 0.7s ease forwards; }
  @keyframes tmFadeIn      { to { opacity:1; transform:none; } }
  @keyframes tmFadeInUp    { from { transform:translateY(30px); } to { opacity:1; transform:none; } }
  @keyframes tmFadeInLeft  { from { transform:translateX(-30px); } to { opacity:1; transform:none; } }
  @keyframes tmFadeInRight { from { transform:translateX(30px); } to { opacity:1; transform:none; } }

  @media (max-width: 768px) {
    .testi-{{ section.id }} .section-heading { font-size: var(--mobile-heading-size); }
    .testi-{{ section.id }} .section-subheading { font-size: var(--mobile-subheading-size); }
    .testi-{{ section.id }} .section-description { font-size: var(--mobile-desc-size); }
    .testi-{{ section.id }} .card-quote { font-size: var(--mobile-quote-size); }
    .testi-{{ section.id }} .author-name { font-size: var(--mobile-author-size); }
    .testi-{{ section.id }} .author-location { font-size: var(--mobile-location-size); }
    
    .testi-{{ section.id }} .section-header { padding: 0; }
    
    /* Slider layout mobile behavior */
    .testi-{{ section.id }} .layout--slider {
      gap: {{ section.settings.slider_gap_mobile }}px;
      padding: 15px 0 20px;
    }
    /* Grid layout mobile behavior */
    .testi-{{ section.id }} .layout--grid {
      grid-template-columns: repeat({{ section.settings.grid_cols_mobile }}, 1fr) !important;
      gap: {{ section.settings.grid_gap_mobile }}px !important;
    }
    .testi-{{ section.id }} .carousel-viewport { max-width: 100%; margin: 0 auto; }
    .testi-{{ section.id }} .layout--slider .testimonial-card { flex: 0 0 var(--card-width-mobile); opacity: 1; transform: none; }
    
    .testi-{{ section.id }} .carousel-nav { padding: 0; }
  }

  {% if section.settings.custom_css != blank %}{{ section.settings.custom_css }}{% endif %}
</style>

<section
  id="shopify-section-testi-{{ section.id }}"
  class="testi-{{ section.id }} {{ section.settings.custom_classes }} {{ animation_class }}"
  data-section-id="{{ section.id }}"
  {% if section.settings.custom_attributes != blank %}{{ section.settings.custom_attributes }}{% endif %}
>
  <div class="{{ container_class }}">

    {%- comment -%}── Section Header ──{%- endcomment -%}
    <div class="section-header {{ text_align_class }}">
      {%- if section.settings.subheading != blank -%}
        <p class="section-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-heading {{ heading_size_class }}">{{- section.settings.heading -}}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="section-description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- comment -%}── Carousel ──{%- endcomment -%}
    <div
      class="carousel-outer"
      data-autoplay="{{ section.settings.auto_rotate }}"
      data-autoplay-speed="4000"
      data-section="{{ section.id }}"
    >
      <div class="carousel-viewport" id="testi-vp-{{ section.id }}">
        <div class="carousel-track layout--{{ section.settings.layout_mode }}" id="testi-track-{{ section.id }}">

          <script type="application/json" id="testi-data-{{ section.id }}">
            [
              {%- assign first_item = true -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'testimonial' -%}
                  {%- unless first_item -%},{%- endunless -%}
                  {%- assign first_item = false -%}
                  {
                    "rating": {{ block.settings.rating | default: 5 }},
                    "quote":  {{ block.settings.quote    | json }},
                    "author": {{ block.settings.author   | json }},
                    "location": {{ block.settings.location | json }},
                    "show_stars": {{ section.settings.show_stars }},
                    "avatar": {% if block.settings.avatar != blank %}{{ block.settings.avatar | image_url: width: 200, height: 200 | json }}{% else %}null{% endif %}
                  }
                {%- endif -%}
              {%- endfor -%}
            ]
          </script>

        </div>
      </div>

      {%- if section.settings.layout_mode == 'slider' -%}
        {%- if section.settings.show_navigation -%}
          <div class="carousel-nav">
            <button class="nav-btn nav-prev-{{ section.id }}" aria-label="Previous testimonial">
              <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="nav-btn nav-next-{{ section.id }}" aria-label="Next testimonial">
              <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        {%- endif -%}

        {%- if section.settings.show_pagination -%}
          <div class="carousel-pagination" id="testi-pag-{{ section.id }}" role="tablist"></div>
        {%- endif -%}
      {%- endif -%}

    </div>

  </div>
</section>

<script>
(function () {
  'use strict';

  var SID     = '{{ section.id }}';
  var CLONES  = 3;

  /* ── Grab elements ── */
  var dataEl  = document.getElementById('testi-data-' + SID);
  var track   = document.getElementById('testi-track-' + SID);
  var viewport= document.getElementById('testi-vp-' + SID);
  var pagEl   = document.getElementById('testi-pag-' + SID);
  var prevBtn = document.querySelector('.nav-prev-' + SID);
  var nextBtn = document.querySelector('.nav-next-' + SID);

  if (!track || !viewport || !dataEl) return;

  var DATA = JSON.parse(dataEl.textContent);
  var N    = DATA.length;
  if (N === 0) return;

  /* ── State ── */
  var currentExt   = CLONES;
  var realIdx      = 0;
  var isAnimating  = false;
  var isDragging   = false;
  var dragStartX   = 0;
  var dragCurrentX = 0;
  var startTx      = 0;
  var autoTimer    = null;
  var autoplay     = track.closest('[data-autoplay]').dataset.autoplay === 'true';
  var autoSpeed    = parseInt(track.closest('[data-autoplay]').dataset.autoplaySpeed, 10) || 4000;

  /* ── Build one card DOM node ── */
  function makeCard(item) {
    var stars = '';
    if (item.show_stars) {
      for (var i = 1; i <= 5; i++) {
        stars += '<svg class="star-icon' + (i > item.rating ? ' dim' : '') + '" viewBox="0 0 20 20" aria-hidden="true">' +
          '<path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.62l5.34-.78z"' +
          (i > item.rating ? ' opacity="0.2"' : '') + '/></svg>';
      }
    }
    var avatarHtml = '';
    if (item.avatar) {
      avatarHtml = '<div class="author-avatar-wrapper">' +
        '<img class="author-avatar" src="' + item.avatar + '" alt="' + (item.author || '') + '" loading="lazy" />' +
        '</div>';
    }
    var el = document.createElement('div');
    el.className = 'testimonial-card';
    el.innerHTML =
      (stars ? '<div class="card-stars">' + stars + '</div>' : '') +
      '<p class="card-quote">' + item.quote + '</p>' +
      '<div class="card-author' + (item.avatar ? ' has-avatar' : '') + '">' +
        avatarHtml +
        '<div class="author-meta">' +
          (item.author   ? '<div class="author-name">'     + item.author   + '</div>' : '') +
          (item.location ? '<div class="author-location">' + item.location + '</div>' : '') +
        '</div>' +
      '</div>';
    return el;
  }

  /* ── Populate track with clones + reals + clones ── */
  function buildTrack() {
    if (dataEl && dataEl.parentNode === track) track.removeChild(dataEl);
    track.innerHTML = '';
    var frag = document.createDocumentFragment();
    for (var c = N - CLONES; c < N; c++)   frag.appendChild(makeCard(DATA[c]));
    for (var r = 0; r < N; r++)            frag.appendChild(makeCard(DATA[r]));
    for (var t = 0; t < CLONES; t++)       frag.appendChild(makeCard(DATA[t]));
    track.appendChild(frag);
  }

  /* ── Pagination ── */
  function buildPagination() {
    if (!pagEl) return;
    pagEl.innerHTML = '';
    for (var i = 0; i < N; i++) {
      var dot = document.createElement('button');
      dot.className = 'pagination-dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('role', 'tab');
      dot.setAttribute('aria-label', 'Testimonial ' + (i + 1));
      dot.setAttribute('data-ri', i);
      pagEl.appendChild(dot);
    }
    pagEl.addEventListener('click', function (e) {
      var dot = e.target.closest('.pagination-dot');
      if (!dot) return;
      jumpToReal(parseInt(dot.getAttribute('data-ri'), 10), true);
      resetAuto();
    });
  }

  /* ── Measure helpers ── */
  function cw()  { var c = track.querySelector('.testimonial-card'); return c ? c.getBoundingClientRect().width : 320; }
  function cgap(){ return parseFloat(window.getComputedStyle(track).columnGap) || {{ section.settings.slider_gap_desktop }}; }

  /* ── Translate for an extended index — centres card in viewport ── */
  function txFor(extIdx) {
    var pos = extIdx * (cw() + cgap()) - viewport.getBoundingClientRect().width / 2 + cw() / 2;
    return -pos;
  }

  /* ── Instant snap ── */
  function snapTo(extIdx) {
    track.style.transition = 'none';
    track.style.transform  = 'translateX(' + txFor(extIdx) + 'px)';
    track.offsetHeight;
  }

  /* ── Animated slide ── */
  function slideTo(extIdx, cb) {
    isAnimating = true;
    track.style.transition = 'transform 0.55s cubic-bezier(0.25,0.46,0.45,0.94)';
    track.style.transform  = 'translateX(' + txFor(extIdx) + 'px)';
    function done(ev) {
      if (ev && ev.propertyName !== 'transform') return;
      track.removeEventListener('transitionend', done);
      isAnimating = false;
      if (cb) cb();
    }
    track.addEventListener('transitionend', done);
  }

  /* ── Extended → real index ── */
  function e2r(ext) { return ((ext - CLONES) % N + N) % N; }

  /* ── Refresh card classes ── */
  function refreshCards(centerExt) {
    var cards = track.querySelectorAll('.testimonial-card');
    cards.forEach(function (card, i) {
      card.classList.remove('is-active', 'is-near');
      var d = Math.abs(i - centerExt);
      if (d === 0)      card.classList.add('is-active');
      else if (d === 1) card.classList.add('is-near');
    });
  }

  /* ── Refresh dots ── */
  function refreshPag(ri) {
    if (!pagEl) return;
    pagEl.querySelectorAll('.pagination-dot').forEach(function (dot, i) {
      var on = i === ri;
      dot.classList.toggle('is-active', on);
      dot.setAttribute('aria-selected', on ? 'true' : 'false');
    });
  }

  /* ── Step ±1 with seamless loop ── */
  function step(dir) {
    if (isAnimating) return;
    var targetExt  = currentExt + dir;
    var targetReal = e2r(targetExt);
    refreshCards(targetExt);
    refreshPag(targetReal);
    slideTo(targetExt, function () {
      var inCloneZone = targetExt < CLONES || targetExt >= CLONES + N;
      if (inCloneZone) {
        var jumpExt = CLONES + targetReal;
        snapTo(jumpExt);
        refreshCards(jumpExt);
        currentExt = jumpExt;
      } else {
        currentExt = targetExt;
      }
      realIdx = e2r(currentExt);
      refreshPag(realIdx);
    });
  }

  /* ── Jump to real index (e.g. from pagination) ── */
  function jumpToReal(ri, animated) {
    realIdx    = ri;
    currentExt = CLONES + ri;
    refreshCards(currentExt);
    refreshPag(realIdx);
    if (animated) slideTo(currentExt, null);
    else          snapTo(currentExt);
  }

  /* ── Auto-rotate ── */
  function startAuto() { if (!autoplay) return; autoTimer = setInterval(function () { step(1); }, autoSpeed); }
  function stopAuto()  { clearInterval(autoTimer); }
  function resetAuto() { stopAuto(); startAuto(); }

  /* ── Drag / touch ── */
  function onStart(e) {
    if (isAnimating) return;
    isDragging = true;
    track.style.transition = 'none';
    dragStartX   = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
    dragCurrentX = dragStartX;
    var m = new DOMMatrix(window.getComputedStyle(track).transform);
    startTx = m.m41;
    stopAuto();
  }
  function onMove(e) {
    if (!isDragging) return;
    dragCurrentX = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
    track.style.transform = 'translateX(' + (startTx + dragCurrentX - dragStartX) + 'px)';
    if (e.type === 'touchmove') e.preventDefault();
  }
  function onEnd() {
    if (!isDragging) return;
    isDragging = false;
    var diff = dragCurrentX - dragStartX;
    var thr  = cw() * 0.22;
    if      (diff < -thr) step(1);
    else if (diff >  thr) step(-1);
    else          slideTo(currentExt, null);
    resetAuto();
  }

  /* ── Init ── */
  var isGrid = '{{ section.settings.layout_mode }}' === 'grid';
  if (isGrid) {
    buildStaticGrid();
  } else {
    buildTrack();
    buildPagination();
    snapTo(currentExt);
    refreshCards(currentExt);
    refreshPag(realIdx);
    startAuto();

    viewport.addEventListener('mousedown',  onStart, { passive: true });
    window.addEventListener  ('mousemove',  onMove,  { passive: true });
    window.addEventListener  ('mouseup',    onEnd,   { passive: true });
    viewport.addEventListener('touchstart', onStart, { passive: true });
    viewport.addEventListener('touchmove',  onMove,  { passive: false });
    viewport.addEventListener('touchend',   onEnd,   { passive: true });

    if (prevBtn) prevBtn.addEventListener('click', function () { step(-1); resetAuto(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { step(1);  resetAuto(); });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft')  { step(-1); resetAuto(); }
      if (e.key === 'ArrowRight') { step(1);  resetAuto(); }
    });

    var rzTimer;
    window.addEventListener('resize', function () {
      clearTimeout(rzTimer);
      rzTimer = setTimeout(function () { snapTo(currentExt); }, 150);
    });
  }

  function buildStaticGrid() {
    if (dataEl && dataEl.parentNode === track) track.removeChild(dataEl);
    track.innerHTML = '';
    var frag = document.createDocumentFragment();
    for (var r = 0; r < N; r++) {
      frag.appendChild(makeCard(DATA[r]));
    }
    track.appendChild(frag);
  }

})();
</script>

