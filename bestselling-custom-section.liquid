{%- style -%}
  :root {
    --fg-bs-bg: {{ section.settings.bg_color }};
    {% if section.settings.bg_gradient != blank %}
      --fg-bs-bg-gradient: {{ section.settings.bg_gradient }};
    {% endif %}
    --fg-bs-max-width: {{ section.settings.max_width }}px;
    
    --fg-bs-pad-top-de: {{ section.settings.pad_top_desktop }}px;
    --fg-bs-pad-btm-de: {{ section.settings.pad_btm_desktop }}px;
    --fg-bs-pad-top-mo: {{ section.settings.pad_top_mobile }}px;
    --fg-bs-pad-btm-mo: {{ section.settings.pad_btm_mobile }}px;
    
    --fg-bs-col-gap-de: {{ section.settings.col_gap_desktop }}px;
    --fg-bs-col-gap-mo: {{ section.settings.col_gap_mobile }}px;
    --fg-bs-card-gap-de: {{ section.settings.card_gap_desktop }}px;
    --fg-bs-card-gap-mo: {{ section.settings.card_gap_mobile }}px;
    
    --fg-bs-radius: {{ section.settings.border_radius }}px;
    --fg-bs-border-width: {{ section.settings.border_width }}px;
    --fg-bs-border-style: {{ section.settings.border_style }};
    --fg-bs-border-color: {{ section.settings.border_color }};
    
    --fg-bs-title-size-de: {{ section.settings.title_size_desktop }}px;
    --fg-bs-title-size-mo: {{ section.settings.title_size_mobile }}px;
    --fg-bs-title-weight: {{ section.settings.title_weight }};
    --fg-bs-title-color: {{ section.settings.title_color }};
    
    --fg-bs-sub-size-de: {{ section.settings.sub_size_desktop }}px;
    --fg-bs-sub-size-mo: {{ section.settings.sub_size_mobile }}px;
    --fg-bs-sub-color: {{ section.settings.sub_color }};
    --fg-bs-sub-lh: {{ section.settings.sub_line_height | default: 1.5 | plus: 0 }};
    
    --fg-bs-card-bg: {{ section.settings.card_bg }};
    --fg-bs-card-pad: {{ section.settings.card_pad }}px;
    --fg-bs-card-radius: {{ section.settings.card_radius }}px;
    --fg-bs-card-border-w: {{ section.settings.card_border_w }}px;
    --fg-bs-card-border-c: {{ section.settings.card_border_c }};
    --fg-bs-card-shadow: {{ section.settings.card_shadow }};
    --fg-bs-card-shadow-h: {{ section.settings.card_shadow_h }};
    --fg-bs-card-hover-y: {% if section.settings.enable_card_hover %}-{{ section.settings.card_hover_lift }}px{% else %}0px{% endif %};
    
    --fg-bs-img-ratio: {{ section.settings.img_ratio }};
    --fg-bs-img-fit: {{ section.settings.img_fit }};
    --fg-bs-img-radius: {{ section.settings.img_radius }}px;
    --fg-bs-img-w: {{ section.settings.img_w }}px;
    
    --fg-bs-promo-bg-c: {{ section.settings.promo_bg_c }};
    --fg-bs-promo-radius: {{ section.settings.promo_radius }}px;
    --fg-bs-promo-h-de: {{ section.settings.promo_h_desktop }}px;
    --fg-bs-promo-h-mo: {{ section.settings.promo_h_mobile }}px;
    --fg-bs-promo-overlay: {{ section.settings.promo_overlay_c | color_modify: 'alpha', section.settings.promo_overlay_o }};
    --fg-bs-promo-align-v: {{ section.settings.promo_align_v }};
    --fg-bs-promo-align-h: {{ section.settings.promo_align_h }};
    
    --fg-bs-p-title-de: {{ section.settings.promo_title_de }}px;
    --fg-bs-p-title-mo: {{ section.settings.promo_title_mo }}px;
    --fg-bs-p-title-w: {{ section.settings.promo_title_w }};
    --fg-bs-p-title-c: {{ section.settings.promo_title_c }};
    --fg-bs-p-title-lh: {{ section.settings.promo_title_lh }};
    
    --fg-bs-p-desc-de: {{ section.settings.promo_desc_de }}px;
    --fg-bs-p-desc-mo: {{ section.settings.promo_desc_mo }}px;
    --fg-bs-p-desc-c: {{ section.settings.promo_desc_c }};
    --fg-bs-p-desc-lh: {{ section.settings.promo_desc_lh }};
    
    --fg-bs-btn-bg: {{ section.settings.btn_bg }};
    --fg-bs-btn-bg-h: {{ section.settings.btn_bg_h }};
    --fg-bs-btn-text: {{ section.settings.btn_text_c }};
    --fg-bs-btn-text-h: {{ section.settings.btn_text_c_h }};
    --fg-bs-btn-radius: {{ section.settings.btn_radius }}px;
    --fg-bs-btn-pad: {{ section.settings.btn_pad }};
    --fg-bs-btn-size-de: {{ section.settings.btn_size_de }}px;
    --fg-bs-btn-size-mo: {{ section.settings.btn_size_mo }}px;
    
    --fg-bs-col-w-left: {{ section.settings.col_w_left }}%;
    --fg-bs-col-w-center: {{ section.settings.col_w_center }}%;
    --fg-bs-col-w-right: {{ section.settings.col_w_right }}%;
    --fg-bs-valign: {{ section.settings.valign }};
    
    --fg-bs-mo-slide-w: {{ section.settings.mo_slide_w }}px;
  }

  .fg-bs-section {
    background: var(--fg-bs-bg-gradient, var(--fg-bs-bg));
    {% if section.settings.bg_img != blank %}
      background-image: url('{{ section.settings.bg_img | image_url }}');
      background-repeat: {{ section.settings.bg_repeat }};
      background-size: {{ section.settings.bg_size }};
      background-position: center;
    {% endif %}
    padding-top: var(--fg-bs-pad-top-mo);
    padding-bottom: var(--fg-bs-pad-btm-mo);
    border: var(--fg-bs-border-width) var(--fg-bs-border-style) var(--fg-bs-border-color);
    border-radius: var(--fg-bs-radius);
    overflow: hidden;
  }

  .fg-bs-inner {
    max-width: var(--fg-bs-max-width);
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
  }

  .fg-bs-head {
    text-align: {{ section.settings.head_align }};
    margin-bottom: var(--fg-bs-card-gap-mo);
  }

  .fg-bs-title {
    font-size: var(--fg-bs-title-size-mo);
    font-weight: var(--fg-bs-title-weight);
    color: var(--fg-bs-title-color);
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .fg-bs-sub {
    font-size: var(--fg-bs-sub-size-mo);
    color: var(--fg-bs-sub-color);
    line-height: var(--fg-bs-sub-lh);
    margin: 0;
  }

  .fg-bs-grid {
    display: flex;
    flex-direction: column;
    gap: var(--fg-bs-col-gap-mo);
  }

  .fg-bs-col {
    display: flex;
    flex-direction: column;
    gap: var(--fg-bs-card-gap-mo);
    width: 100%;
  }

  .fg-bs-col-side {
    {% if section.settings.mo_scroll %}
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: {% if section.settings.mo_snap %}x mandatory{% else %}none{% endif %};
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 8px;
    {% endif %}
  }
  
  .fg-bs-col-side::-webkit-scrollbar {
    display: none;
  }

  .fg-bs-card {
    background: var(--fg-bs-card-bg);
    border-radius: var(--fg-bs-card-radius);
    padding: var(--fg-bs-card-pad);
    border: var(--fg-bs-card-border-w) solid var(--fg-bs-card-border-c);
    box-shadow: var(--fg-bs-card-shadow);
    display: grid;
    grid-template-columns: var(--fg-bs-img-w) 1fr;
    gap: {{ section.settings.card_inner_gap }}px;
    align-items: center;
    transition: transform .3s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow .3s ease;
    text-decoration: none;
    color: inherit;
    {% if section.settings.mo_scroll %}
      flex: 0 0 var(--fg-bs-mo-slide-w);
      scroll-snap-align: start;
    {% endif %}
  }

  .fg-bs-card:hover {
    transform: translateY(var(--fg-bs-card-hover-y));
    box-shadow: var(--fg-bs-card-shadow-h);
  }

  .fg-bs-card-img {
    width: var(--fg-bs-img-w);
    aspect-ratio: var(--fg-bs-img-ratio);
    border-radius: var(--fg-bs-img-radius);
    overflow: hidden;
    position: relative;
    background: #f5f5f5;
  }

  .fg-bs-card-img img {
    width: 100%;
    height: 100%;
    object-fit: var(--fg-bs-img-fit);
    transition: opacity .4s ease;
  }

  .fg-bs-card-img img.secondary-img {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  .fg-bs-card:hover .fg-bs-card-img img.secondary-img {
    opacity: 1;
  }

  .fg-bs-card-body {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.card_body_gap }}px;
    min-width: 0;
  }

  .fg-bs-card-cat {
    font-size: {{ section.settings.cat_font_size }}px;
    text-transform: {{ section.settings.cat_transform }};
    letter-spacing: {{ section.settings.cat_letter_spacing }}em;
    opacity: {{ section.settings.cat_opacity }};
    font-weight: {{ section.settings.cat_weight }};
    color: {{ section.settings.cat_color }};
  }

  .fg-bs-card-name {
    font-size: {{ section.settings.title_font_size }}px;
    font-weight: {{ section.settings.title_font_weight }};
    margin: 0;
    line-height: {{ section.settings.title_line_height }};
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: {{ section.settings.title_lines }};
    -webkit-box-orient: vertical;
    color: {{ section.settings.title_card_color }};
  }

  .fg-bs-card-weight {
    font-size: {{ section.settings.weight_font_size }}px;
    opacity: {{ section.settings.weight_opacity }};
    color: {{ section.settings.weight_color }};
  }

  .fg-bs-card-price {
    margin-top: {{ section.settings.price_margin_top }}px;
    font-size: {{ section.settings.price_font_size }}px;
    font-weight: {{ section.settings.price_weight }};
    color: {{ section.settings.price_color }};
  }

  .fg-bs-card-price s {
    opacity: {{ section.settings.original_price_opacity }};
    font-weight: {{ section.settings.original_price_weight }};
    margin-right: {{ section.settings.original_price_margin }}px;
    color: {{ section.settings.original_price_color }};
  }

  .fg-bs-card-price .sale-price {
    color: {{ section.settings.sale_color }};
    font-weight: {{ section.settings.sale_price_weight }};
  }

  .fg-bs-promo {
    position: relative;
    border-radius: var(--fg-bs-promo-radius);
    overflow: hidden;
    min-height: var(--fg-bs-promo-h-mo);
    display: flex;
    flex-direction: column;
    justify-content: var(--fg-bs-promo-align-v);
    align-items: var(--fg-bs-promo-align-h);
    padding: {{ section.settings.promo_padding_mobile }};
    background: var(--fg-bs-promo-bg-c);
    text-align: {{ section.settings.promo_text_align }};
  }

  .fg-bs-promo-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .fg-bs-promo-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fg-bs-promo-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--fg-bs-promo-overlay);
  }

  .fg-bs-promo-content {
    position: relative;
    z-index: 1;
    max-width: {{ section.settings.promo_content_max_w }}%;
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.promo_text_align }};
    gap: {{ section.settings.promo_content_gap }}px;
  }

  .fg-bs-p-label {
    font-size: {{ section.settings.promo_label_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ section.settings.promo_label_spacing }}em;
    color: var(--fg-bs-p-title-c);
    opacity: {{ section.settings.promo_label_opacity }};
    margin-bottom: 0;
    font-weight: {{ section.settings.promo_label_weight }};
  }

  .fg-bs-promo-title {
    font-size: var(--fg-bs-p-title-mo);
    font-weight: var(--fg-bs-p-title-w);
    color: var(--fg-bs-p-title-c);
    margin: 0;
    line-height: var(--fg-bs-p-title-lh);
  }

  .fg-bs-promo-desc {
    font-size: var(--fg-bs-p-desc-mo);
    color: var(--fg-bs-p-desc-c);
    margin: 0;
    line-height: var(--fg-bs-p-desc-lh);
  }

  .fg-bs-promo-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--fg-bs-btn-bg);
    color: var(--fg-bs-btn-text);
    padding: var(--fg-bs-btn-pad);
    border-radius: var(--fg-bs-btn-radius);
    font-size: var(--fg-bs-btn-size-mo);
    font-weight: {{ section.settings.btn_weight }};
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background .25s ease, transform .25s ease, color .25s ease;
    gap: {{ section.settings.btn_icon_gap }}px;
    {% if section.settings.mo_full_btn %}
      width: 100%;
    {% else %}
      width: max-content;
    {% endif %}
  }

  .fg-bs-promo-btn:hover {
    background: var(--fg-bs-btn-bg-h);
    color: var(--fg-bs-btn-text-h);
    transform: translateY({{ section.settings.btn_hover_lift }}px);
  }

  /* Mobile Center Promo Fix */
  @media (max-width: 1023px) {
    .fg-bs-order-banner { 
      order: 1; 
      margin-bottom: var(--fg-bs-card-gap-mo);
    }
    .fg-bs-order-left { order: 2; }
    .fg-bs-order-right { order: 3; }
  }

  @media (min-width: 768px) {
    .fg-bs-section {
      padding-top: var(--fg-bs-pad-top-de);
      padding-bottom: var(--fg-bs-pad-btm-de);
    }
    .fg-bs-head {
      margin-bottom: var(--fg-bs-col-gap-de);
    }
    .fg-bs-title {
      font-size: var(--fg-bs-title-size-de);
    }
    .fg-bs-sub {
      font-size: var(--fg-bs-sub-size-de);
    }
    .fg-bs-promo {
      min-height: var(--fg-bs-promo-h-de);
      padding: {{ section.settings.promo_padding_desktop }};
    }
    .fg-bs-promo-title {
      font-size: var(--fg-bs-p-title-de);
    }
    .fg-bs-promo-desc {
      font-size: var(--fg-bs-p-desc-de);
    }
    .fg-bs-promo-btn {
      font-size: var(--fg-bs-btn-size-de);
      width: max-content;
    }
  }

  @media (min-width: 1024px) {
    .fg-bs-grid {
      display: flex;
      flex-direction: row;
      gap: var(--fg-bs-col-gap-de);
      align-items: var(--fg-bs-valign);
      {% if section.settings.reverse_layout %}
        flex-direction: row-reverse;
      {% endif %}
    }
    .fg-bs-col-left {
      width: var(--fg-bs-col-w-left);
      display: {% if section.settings.hide_left %}none{% else %}flex{% endif %};
    }
    .fg-bs-col-center {
      width: var(--fg-bs-col-w-center);
    }
    .fg-bs-col-right {
      width: var(--fg-bs-col-w-right);
      display: {% if section.settings.hide_right %}none{% else %}flex{% endif %};
    }
    .fg-bs-col-side {
      flex-direction: column;
      overflow-x: visible;
      scroll-snap-type: none;
      padding-bottom: 0;
    }
    .fg-bs-card {
      flex: none;
    }
    .fg-bs-promo {
      min-height: 100%;
      height: 100%;
    }
    .fg-bs-order-banner, .fg-bs-order-left, .fg-bs-order-right { 
      order: unset; 
      margin-bottom: 0;
    }
  }
{%- endstyle -%}

<section class="fg-bs-section" id="fg-bs-{{ section.id }}">
  <div class="fg-bs-inner">
    
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="fg-bs-head">
        {%- if section.settings.heading != blank -%}
          <h2 class="fg-bs-title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="fg-bs-sub">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="fg-bs-grid">
      
      <!-- Left Column -->
      <div class="fg-bs-col fg-bs-col-left fg-bs-col-side fg-bs-order-left">
        {%- for block in section.blocks -%}
          {%- if block.type == 'left_product' -%}
            {%- assign p = all_products[block.settings.product] -%}
            {%- assign c = collections[block.settings.collection] -%}
            
            {%- assign card_url = "#" -%}
            {%- assign card_title = block.settings.custom_title -%}
            {%- assign card_cat = block.settings.custom_cat -%}
            {%- assign card_weight = block.settings.custom_weight -%}
            {%- assign card_price = block.settings.custom_price -%}
            {%- assign card_was = block.settings.custom_was_price -%}
            {%- assign main_img = block.settings.custom_img -%}
            {%- assign second_img = block.settings.custom_img_hover -%}

            {%- if block.settings.mode == 'product' and p != blank -%}
              {%- assign card_url = p.url -%}
              {%- assign card_title = card_title | default: p.title -%}
              {%- assign card_cat = card_cat | default: p.vendor -%}
              {%- assign card_weight = card_weight | default: p.metafields.custom.weight -%}
              {%- if main_img == blank -%}{%- assign main_img = p.featured_image -%}{%- endif -%}
              {%- if second_img == blank and p.images.size > 1 -%}
                {%- assign second_img = p.images[1] -%}
              {%- endif -%}
              {%- capture price_html -%}
                {%- if p.compare_at_price_min > p.price_min -%}
                  <s>{{ p.compare_at_price_min | money }}</s>
                  <span class="sale-price">{{ p.price_min | money }}</span>
                {%- else -%}
                  {%- if p.price_varies -%}
                    {{ p.price_min | money }} – {{ p.price_max | money }}
                  {%- else -%}
                    {{ p.price | money }}
                  {%- endif -%}
                {%- endif -%}
              {%- endcapture -%}
            {%- elsif block.settings.mode == 'collection' and c != blank -%}
              {%- assign card_url = c.url -%}
              {%- assign card_title = card_title | default: c.title -%}
              {%- assign card_cat = card_cat | default: "Collection" -%}
              {%- if main_img == blank -%}
                {%- assign main_img = c.image | default: c.products.first.featured_image -%}
              {%- endif -%}
              {%- capture price_html -%}{{ c.all_products_count }} products{%- endcapture -%}
            {%- elsif block.settings.mode == 'manual' -%}
              {%- capture price_html -%}
                {%- if card_was != blank -%}<s>{{ card_was | escape }}</s>{%- endif -%}
                {%- if card_price != blank -%}
                  <span class="{% if card_was != blank %}sale-price{% endif %}">{{ card_price | escape }}</span>
                {%- endif -%}
              {%- endcapture -%}
            {%- endif -%}

            {%- if block.settings.mode == 'manual' or p != blank or c != blank -%}
              <a href="{{ card_url }}" class="fg-bs-card" {{ block.shopify_attributes }}>
                <div class="fg-bs-card-img">
                  {%- if main_img != blank -%}
                    <img src="{{ main_img | image_url: width: 300 }}" alt="{{ card_title | escape }}" loading="lazy" width="150" height="150">
                    {%- if second_img != blank and section.settings.enable_card_hover -%}
                      <img src="{{ second_img | image_url: width: 300 }}" alt="{{ card_title | escape }}" class="secondary-img" loading="lazy" width="150" height="150">
                    {%- endif -%}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag }}
                  {%- endif -%}
                </div>
                <div class="fg-bs-card-body">
                  {%- if card_cat != blank -%}
                    <span class="fg-bs-card-cat">{{ card_cat | escape }}</span>
                  {%- endif -%}
                  <h3 class="fg-bs-card-name">{{ card_title | escape }}</h3>
                  {%- if card_weight != blank -%}
                    <span class="fg-bs-card-weight">{{ card_weight | escape }}</span>
                  {%- endif -%}
                  <div class="fg-bs-card-price">{{ price_html }}</div>
                </div>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Center Banner -->
      <div class="fg-bs-col fg-bs-col-center fg-bs-order-banner">
        <div class="fg-bs-promo">
          {%- if section.settings.promo_img != blank and section.settings.overwrite_promo_img -%}
            <div class="fg-bs-promo-bg">
              <img 
                src="{{ section.settings.promo_img | image_url: width: 1000 }}" 
                alt="{{ section.settings.promo_heading | escape }}" 
                loading="lazy"
                width="800"
                height="1000"
              >
            </div>
          {%- endif -%}
          
          <div class="fg-bs-promo-content">
            {%- if section.settings.promo_label != blank -%}
              <span class="fg-bs-p-label">{{ section.settings.promo_label | escape }}</span>
            {%- endif -%}
            {%- if section.settings.promo_heading != blank -%}
              <h3 class="fg-bs-promo-title">{{ section.settings.promo_heading | escape }}</h3>
            {%- endif -%}
            {%- if section.settings.promo_desc != blank -%}
              <p class="fg-bs-promo-desc">{{ section.settings.promo_desc | escape }}</p>
            {%- endif -%}
            {%- if section.settings.promo_btn_text != blank -%}
              <a href="{{ section.settings.promo_btn_url | default: '#' }}" class="fg-bs-promo-btn">
                {%- if section.settings.btn_icon != blank -%}
                  <span class="btn-icon">{{ section.settings.btn_icon }}</span>
                {%- endif -%}
                {{ section.settings.promo_btn_text | escape }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- Right Column -->
      <div class="fg-bs-col fg-bs-col-right fg-bs-col-side fg-bs-order-right">
        {%- for block in section.blocks -%}
          {%- if block.type == 'right_product' -%}
            {%- assign p = all_products[block.settings.product] -%}
            {%- assign c = collections[block.settings.collection] -%}
            
            {%- assign card_url = "#" -%}
            {%- assign card_title = block.settings.custom_title -%}
            {%- assign card_cat = block.settings.custom_cat -%}
            {%- assign card_weight = block.settings.custom_weight -%}
            {%- assign card_price = block.settings.custom_price -%}
            {%- assign card_was = block.settings.custom_was_price -%}
            {%- assign main_img = block.settings.custom_img -%}
            {%- assign second_img = block.settings.custom_img_hover -%}

            {%- if block.settings.mode == 'product' and p != blank -%}
              {%- assign card_url = p.url -%}
              {%- assign card_title = card_title | default: p.title -%}
              {%- assign card_cat = card_cat | default: p.vendor -%}
              {%- assign card_weight = card_weight | default: p.metafields.custom.weight -%}
              {%- if main_img == blank -%}{%- assign main_img = p.featured_image -%}{%- endif -%}
              {%- if second_img == blank and p.images.size > 1 -%}
                {%- assign second_img = p.images[1] -%}
              {%- endif -%}
              {%- capture price_html -%}
                {%- if p.compare_at_price_min > p.price_min -%}
                  <s>{{ p.compare_at_price_min | money }}</s>
                  <span class="sale-price">{{ p.price_min | money }}</span>
                {%- else -%}
                  {%- if p.price_varies -%}
                    {{ p.price_min | money }} – {{ p.price_max | money }}
                  {%- else -%}
                    {{ p.price | money }}
                  {%- endif -%}
                {%- endif -%}
              {%- endcapture -%}
            {%- elsif block.settings.mode == 'collection' and c != blank -%}
              {%- assign card_url = c.url -%}
              {%- assign card_title = card_title | default: c.title -%}
              {%- assign card_cat = card_cat | default: "Collection" -%}
              {%- if main_img == blank -%}
                {%- assign main_img = c.image | default: c.products.first.featured_image -%}
              {%- endif -%}
              {%- capture price_html -%}{{ c.all_products_count }} products{%- endcapture -%}
            {%- elsif block.settings.mode == 'manual' -%}
              {%- capture price_html -%}
                {%- if card_was != blank -%}<s>{{ card_was | escape }}</s>{%- endif -%}
                {%- if card_price != blank -%}
                  <span class="{% if card_was != blank %}sale-price{% endif %}">{{ card_price | escape }}</span>
                {%- endif -%}
              {%- endcapture -%}
            {%- endif -%}

            {%- if block.settings.mode == 'manual' or p != blank or c != blank -%}
              <a href="{{ card_url }}" class="fg-bs-card" {{ block.shopify_attributes }}>
                <div class="fg-bs-card-img">
                  {%- if main_img != blank -%}
                    <img src="{{ main_img | image_url: width: 300 }}" alt="{{ card_title | escape }}" loading="lazy" width="150" height="150">
                    {%- if second_img != blank and section.settings.enable_card_hover -%}
                      <img src="{{ second_img | image_url: width: 300 }}" alt="{{ card_title | escape }}" class="secondary-img" loading="lazy" width="150" height="150">
                    {%- endif -%}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag }}
                  {%- endif -%}
                </div>
                <div class="fg-bs-card-body">
                  {%- if card_cat != blank -%}
                    <span class="fg-bs-card-cat">{{ card_cat | escape }}</span>
                  {%- endif -%}
                  <h3 class="fg-bs-card-name">{{ card_title | escape }}</h3>
                  {%- if card_weight != blank -%}
                    <span class="fg-bs-card-weight">{{ card_weight | escape }}</span>
                  {%- endif -%}
                  <div class="fg-bs-card-price">{{ price_html }}</div>
                </div>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

