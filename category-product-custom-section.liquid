{%- style -%}
  /* --- Base Dynamic Styles --- */
  .fg-cat-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  .fg-cat-{{ section.id }} .fg-cat-inner {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding_mobile }}px;
  }
  .fg-cat-{{ section.id }} .fg-cat-head {
    text-align: center;
    margin-bottom: {{ section.settings.head_margin_bottom_mobile }}px;
  }
  .fg-cat-{{ section.id }} .fg-cat-title {
    font-weight: {{ section.settings.heading_weight }};
    font-size: {{ section.settings.heading_size_mobile }}px;
    line-height: {{ section.settings.heading_line_height }};
    letter-spacing: -0.02em;
    margin: 0;
    color: {{ section.settings.heading_color }};
  }
  .fg-cat-{{ section.id }} .fg-cat-title em {
    font-style: italic;
    color: {{ section.settings.accent_color }};
  }

  /* --- Grid System --- */
  .fg-cat-{{ section.id }} .fg-cat-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: {{ section.settings.grid_gap_mobile }}px;
  }
  .fg-cat-{{ section.id }} .fg-cat-card {
    position: relative;
    aspect-ratio: {{ section.settings.card_aspect_ratio_mobile }};
    border-radius: {{ section.settings.card_radius }}px;
    border: {{ section.settings.card_border_width }}px {{ section.settings.card_border_style }} {{ section.settings.card_border_color }};
    overflow: hidden;
    background: {{ section.settings.card_bg_color }};
    text-decoration: none;
    color: {{ section.settings.card_text_color }};
    cursor: pointer;
    transition: transform {{ section.settings.card_hover_transition }}s ease;
  }
  .fg-cat-{{ section.id }} .fg-cat-card:hover {
    transform: translateY({{ section.settings.card_hover_offset }}px);
  }
  .fg-cat-{{ section.id }} .fg-cat-card.fg-tall {
    grid-row: span {{ section.settings.tall_row_span }};
    aspect-ratio: {{ section.settings.tall_aspect_ratio_mobile }};
  }
  .fg-cat-{{ section.id }} .fg-cat-card img,
  .fg-cat-{{ section.id }} .fg-cat-card .fg-placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform {{ section.settings.image_hover_transition }}s ease;
  }
  .fg-cat-{{ section.id }} .fg-cat-card:hover img {
    transform: scale({{ section.settings.image_scale_on_hover }});
  }
  .fg-cat-{{ section.id }} .fg-cat-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient({{ section.settings.overlay_direction }}, {{ section.settings.overlay_start_color }} {{ section.settings.overlay_start_position }}%, {{ section.settings.overlay_end_color }} {{ section.settings.overlay_end_position }}%);
    pointer-events: none;
    opacity: {{ section.settings.overlay_opacity }};
  }
  .fg-cat-{{ section.id }} .fg-cat-meta {
    position: absolute;
    left: {{ section.settings.meta_padding }}px;
    right: {{ section.settings.meta_padding }}px;
    bottom: {{ section.settings.meta_padding }}px;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .fg-cat-{{ section.id }} .fg-cat-meta-title {
    font-size: {{ section.settings.card_title_size_mobile }}rem;
    font-weight: {{ section.settings.card_title_weight }};
    margin: 0;
    letter-spacing: -0.01em;
    color: {{ section.settings.card_text_color }};
  }
  /* --- Arrow Button Styles --- */
  .fg-cat-{{ section.id }} .fg-cat-arrow {
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    border-radius: {{ section.settings.arrow_border_radius }}px;
    background: {{ section.settings.arrow_bg_color }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background {{ section.settings.button_transition }}s ease;
  }
  .fg-cat-{{ section.id }} .fg-cat-arrow svg {
    width: {{ section.settings.arrow_icon_size }}px;
    height: {{ section.settings.arrow_icon_size }}px;
    stroke: {{ section.settings.arrow_icon_color }};
    stroke-width: {{ section.settings.arrow_stroke_width }};
    fill: none;
  }
  .fg-cat-{{ section.id }} .fg-cat-card:hover .fg-cat-arrow {
    background: {{ section.settings.arrow_hover_bg_color }};
  }
  .fg-cat-{{ section.id }} .fg-cat-card:hover .fg-cat-arrow svg {
    stroke: {{ section.settings.arrow_hover_icon_color }};
  }

  /* --- Responsive Breakpoints --- */
  @media (min-width: 768px) {
    .fg-cat-{{ section.id }} .fg-cat-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: {{ section.settings.grid_gap_desktop }}px;
    }
    .fg-cat-{{ section.id }} .fg-cat-card {
      aspect-ratio: {{ section.settings.card_aspect_ratio_desktop }};
    }
    .fg-cat-{{ section.id }} .fg-cat-card.fg-tall {
      aspect-ratio: {{ section.settings.tall_aspect_ratio_desktop }};
    }
    .fg-cat-{{ section.id }} .fg-cat-meta-title {
      font-size: {{ section.settings.card_title_size_desktop }}rem;
    }
  }

  @media (min-width: 992px) {
    .fg-cat-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
    .fg-cat-{{ section.id }} .fg-cat-inner {
      padding: 0 {{ section.settings.side_padding_desktop }}px;
    }
    .fg-cat-{{ section.id }} .fg-cat-head {
      margin-bottom: {{ section.settings.head_margin_bottom_desktop }}px;
    }
    .fg-cat-{{ section.id }} .fg-cat-title {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }
  }
{%- endstyle -%}

<section class="fg-cat-{{ section.id }}" id="categories-{{ section.id }}">
  <div class="fg-cat-inner">
    <div class="fg-cat-head">
      {%- if section.settings.heading_text != blank -%}
        <h2 class="fg-cat-title">{{ section.settings.heading_text }}</h2>
      {%- endif -%}
    </div>

    <div class="fg-cat-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- assign collection_link = block.settings.collection -%}
          {%- assign card_url = block.settings.custom_link -%}
          {%- if collection_link != blank -%}
            {%- assign card_url = collection_link.url -%}
          {%- endif -%}
          <a href="{{ card_url | default: '#' }}" class="fg-cat-card{% if block.settings.tall %} fg-tall{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1600 | image_tag: 
                loading: 'lazy', 
                sizes: '(min-width: 992px) 25vw, (min-width: 768px) 50vw, 100vw',
                widths: '300, 600, 900, 1200, 1600',
                class: 'fg-card-image'
              }}
            {%- else -%}
              <div class="fg-placeholder-svg">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
            
            <div class="fg-cat-meta">
              <h3 class="fg-cat-meta-title">{{ block.settings.title | default: collection_link.title | escape }}</h3>
              <span class="fg-cat-arrow">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7 17L17 7M9 7H17V15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

