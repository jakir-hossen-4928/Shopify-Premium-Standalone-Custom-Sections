{% comment %}
  Parallax Arched & Stacked Section
  Fully standalone, highly customizable, and responsive.
  No external CSS or JS connections. Compatible with any Shopify theme.
{% endcomment %}

<div id="yv-images-grid-section-{{ section.id }}" 
     class="yv-images-grid-section-root"
     data-parallax="{{ section.settings.parallax_effect }}"
     data-parallax-speed="{{ section.settings.parallax_speed | times: 0.1 }}">

  
  <div class="container sm-container">
    <div class="yv-images-grid-container-custom position-{{ section.settings.content_position }} {% if section.settings.mobile_layout == 'text_first' %}mobile-stack-text-first{% else %}mobile-stack-images-first{% endif %} {% if section.settings.show_separator %}has-separator{% endif %} {% if section.settings.show_separator_mobile %}has-separator-mobile{% endif %}">
      
      <!-- Content Column -->
      {%- if section.settings.show_heading or section.settings.show_description or section.settings.show_btn -%}
        <div class="yv-images-grid-content-wrapper-custom">
          <div class="yv-images-grid-content-custom">
            
            {%- if section.settings.show_heading and section.settings.heading != blank -%}
              {%- assign highlight_class = 'yv-highlight-custom' -%}
              {%- if section.settings.highlight_font == 'body' -%}
                {%- assign highlight_class = highlight_class | append: ' body-font' -%}
              {%- elsif section.settings.highlight_font == 'heading' -%}
                {%- assign highlight_class = highlight_class | append: ' heading-font' -%}
              {%- else -%}
                {%- assign highlight_class = highlight_class | append: ' accent-font' -%}
              {%- endif -%}
              {%- assign open_tag = '<span class="' | append: highlight_class | append: '">' -%}
              
              <{{ section.settings.seo_heading }} class="yv-images-grid-content-heading-custom">
                {{ section.settings.heading | replace: "<strong>", open_tag | replace: "</strong>", '</span>' }}
              </{{ section.settings.seo_heading }}>
            {%- endif -%}

            {%- if section.settings.show_description and section.settings.description != blank -%}
              <div class="yv-images-grid-content-text-custom">
                {{ section.settings.description }}
              </div>
            {%- endif -%}

            {%- if section.settings.show_btn and section.settings.btn_text != blank and section.settings.btn_link != blank -%}
              <div class="yv-images-grid-buttons-custom">
                <a href="{{ section.settings.btn_link }}" class="yv-images-grid-btn-custom yv-images-grid-btn-{{ section.settings.btn_style }}-custom">
                  {{ section.settings.btn_text }}
                </a>
              </div>
            {%- endif -%}
            
          </div>
        </div>
      {%- endif -%}

      <div class="yv-grid-separator-custom"></div>

      <!-- Image Column -->
      <div class="yv-images-grid-image-wrapper-custom">
        <div class="yv-images-grid-image-body-custom">
          {%- if section.settings.images_display_type == 'arched' -%}
            <div class="yv-images-arched-layout-custom">
              {%- assign total_blocks = section.blocks.size -%}
              {%- assign second_to_last_index = total_blocks | minus: 2 -%} 
              {%- assign last_index = total_blocks | minus: 1 -%}
              
              {%- for block in section.blocks -%}
                {%- assign current_index = forloop.index0 -%}
              
                {%- if current_index == second_to_last_index -%}
                  {{ '<div class="yv-arched-flex-row-custom">' }}
                {%- endif -%}
              
                {%- capture block_aspect_ratio_desktop -%}
                  {%- if block.settings.aspect_ratio_select_desktop == 'custom' -%}
                    {{ block.settings.aspect_ratio_desktop | default: section.settings.img_aspect_ratio_desktop | default: '120' }}
                  {%- elsif block.settings.aspect_ratio_select_desktop != blank and block.settings.aspect_ratio_select_desktop != 'inherit' -%}
                    {{ block.settings.aspect_ratio_select_desktop }}
                  {%- else -%}
                    {%- if section.settings.img_aspect_ratio_select_desktop == 'custom' -%}
                      {{ section.settings.img_aspect_ratio_desktop | default: '120' }}
                    {%- else -%}
                      {{ section.settings.img_aspect_ratio_select_desktop | default: '120' }}
                    {%- endif -%}
                  {%- endif -%}
                {%- endcapture -%}
                {%- capture block_aspect_ratio_mobile -%}
                  {%- if block.settings.aspect_ratio_select_mobile == 'custom' -%}
                    {{ block.settings.aspect_ratio_mobile | default: section.settings.img_aspect_ratio_mobile | default: '120' }}
                  {%- elsif block.settings.aspect_ratio_select_mobile != blank and block.settings.aspect_ratio_select_mobile != 'inherit' -%}
                    {{ block.settings.aspect_ratio_select_mobile }}
                  {%- else -%}
                    {%- if section.settings.img_aspect_ratio_select_mobile == 'custom' -%}
                      {{ section.settings.img_aspect_ratio_mobile | default: '120' }}
                    {%- else -%}
                      {{ section.settings.img_aspect_ratio_select_mobile | default: '120' }}
                    {%- endif -%}
                  {%- endif -%}
                {%- endcapture -%}
                {%- capture block_border_radius -%}
                  {%- if block.settings.border_radius > 0 -%}{{ block.settings.border_radius }}{%- else -%}{{ section.settings.img_radius_standard }}{%- endif -%}
                {%- endcapture -%}
                {%- capture block_border_width -%}
                  {%- if block.settings.border_width > 0 -%}{{ block.settings.border_width }}{%- else -%}{{ section.settings.img_border_width }}{%- endif -%}
                {%- endcapture -%}
                {%- capture block_border_style -%}
                  {%- if block.settings.border_style != 'none' -%}{{ block.settings.border_style }}{%- else -%}{{ section.settings.img_border_style }}{%- endif -%}
                {%- endcapture -%}
                {%- capture block_border_color -%}
                  {%- if block.settings.border_color != blank -%}{{ block.settings.border_color }}{%- else -%}{{ section.settings.img_border_color }}{%- endif -%}
                {%- endcapture -%}

                <div class="yv-arched-item-custom {% if section.settings.parallax_effect %}scene-parallax{% endif %}" 
                     style="--block-aspect-ratio-desktop: {{ block_aspect_ratio_desktop | strip }}%;
                            --block-aspect-ratio-mobile: {{ block_aspect_ratio_mobile | strip }}%;
                            --block-border-radius: {{ block_border_radius | strip }}px;
                            --block-border-color: {{ block_border_color | strip }};
                            --block-border-width: {{ block_border_width | strip }}px;
                            --block-border-style: {{ block_border_style | strip }};"
                     {{ block.shopify_attributes }}>
                  <div class="yv-img-wrapper-custom">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 1200 | image_tag: 
                        loading: 'lazy', 
                        sizes: '(min-width: 992px) 33vw, 100vw',
                        class: 'yv-grid-img-custom'
                      }}
                    {%- else -%}
                      {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                    <div class="yv-img-overlay-custom"></div>
                  </div>
                </div>
              
                {%- if current_index == last_index -%}
                  {{ '</div>' }}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- else -%}
            <!-- Stacked Layout -->
            <div class="yv-images-stacked-layout-custom {% if section.settings.stacked_layout_mode == 'auto' %}layout-auto-collage{% endif %}">
              {%- for block in section.blocks -%}
                {%- capture block_aspect_ratio_desktop -%}
                  {%- if block.settings.aspect_ratio_select_desktop == 'custom' -%}
                    {{ block.settings.aspect_ratio_desktop | default: section.settings.img_aspect_ratio_desktop | default: '120' }}
                  {%- elsif block.settings.aspect_ratio_select_desktop != blank and block.settings.aspect_ratio_select_desktop != 'inherit' -%}
                    {{ block.settings.aspect_ratio_select_desktop }}
                  {%- else -%}
                    {%- if section.settings.img_aspect_ratio_select_desktop == 'custom' -%}
                      {{ section.settings.img_aspect_ratio_desktop | default: '120' }}
                    {%- else -%}
                      {{ section.settings.img_aspect_ratio_select_desktop | default: '120' }}
                    {%- endif -%}
                  {%- endif -%}
                {%- endcapture -%}
                {%- capture block_aspect_ratio_mobile -%}
                  {%- if block.settings.aspect_ratio_select_mobile == 'custom' -%}
                    {{ block.settings.aspect_ratio_mobile | default: section.settings.img_aspect_ratio_mobile | default: '120' }}
                  {%- elsif block.settings.aspect_ratio_select_mobile != blank and block.settings.aspect_ratio_select_mobile != 'inherit' -%}
                    {{ block.settings.aspect_ratio_select_mobile }}
                  {%- else -%}
                    {%- if section.settings.img_aspect_ratio_select_mobile == 'custom' -%}
                      {{ section.settings.img_aspect_ratio_mobile | default: '120' }}
                    {%- else -%}
                      {{ section.settings.img_aspect_ratio_select_mobile | default: '120' }}
                    {%- endif -%}
                  {%- endif -%}
                {%- endcapture -%}
                {%- capture block_border_radius -%}
                  {%- if block.settings.border_radius > 0 -%}{{ block.settings.border_radius }}{%- else -%}{{ section.settings.img_radius_standard }}{%- endif -%}
                {%- endcapture -%}
                {%- capture block_border_width -%}
                  {%- if block.settings.border_width > 0 -%}{{ block.settings.border_width }}{%- else -%}{{ section.settings.img_border_width }}{%- endif -%}
                {%- endcapture -%}
                {%- capture block_border_style -%}
                  {%- if block.settings.border_style != 'none' -%}{{ block.settings.border_style }}{%- else -%}{{ section.settings.img_border_style }}{%- endif -%}
                {%- endcapture -%}
                {%- capture block_border_color -%}
                  {%- if block.settings.border_color != blank -%}{{ block.settings.border_color }}{%- else -%}{{ section.settings.img_border_color }}{%- endif -%}
                {%- endcapture -%}

                <div class="yv-stacked-item-custom {% if section.settings.parallax_effect %}scene-parallax{% endif %} block-{{ block.id }}" 
                     style="
                       --desktop-width: {{ block.settings.desktop_width }}%;
                       --mobile-width: {{ block.settings.mobile_width }}%;
                       --desktop-offset-x: {{ block.settings.desktop_offset_x }}%;
                       --desktop-offset-y: {{ block.settings.desktop_offset_y }}%;
                       --mobile-offset-x: {{ block.settings.mobile_offset_x }}%;
                       --mobile-offset-y: {{ block.settings.mobile_offset_y }}%;
                       --desktop-rotate: {{ block.settings.desktop_rotate }}deg;
                       --mobile-rotate: {{ block.settings.mobile_rotate }}deg;
                       --z-index: {{ block.settings.z_index }};
                       --block-aspect-ratio-desktop: {{ block_aspect_ratio_desktop | strip }}%;
                       --block-aspect-ratio-mobile: {{ block_aspect_ratio_mobile | strip }}%;
                       --block-border-radius: {{ block_border_radius | strip }}px;
                       --block-border-color: {{ block_border_color | strip }};
                       --block-border-width: {{ block_border_width | strip }}px;
                       --block-border-style: {{ block_border_style | strip }};
                     "
                     {{ block.shopify_attributes }}>
                  <div class="yv-img-wrapper-custom">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 1200 | image_tag: 
                        loading: 'lazy', 
                        sizes: '(min-width: 992px) 33vw, 100vw',
                        class: 'yv-grid-img-custom'
                      }}
                    {%- else -%}
                      {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                    <div class="yv-img-overlay-custom"></div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</div>

<style>
#yv-images-grid-section-{{ section.id }} {
  --section-bg-color: {{ section.settings.bg_color }};
  --section-bg-gradient: {{ section.settings.bg_gradient }};
  
  /* Desktop Spacing */
  --padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
  --padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
  --padding-left-desktop: {{ section.settings.padding_left_desktop }}px;
  --padding-right-desktop: {{ section.settings.padding_right_desktop }}px;
  --margin-top-desktop: {{ section.settings.margin_top_desktop }}px;
  --margin-bottom-desktop: {{ section.settings.margin_bottom_desktop }}px;

  /* Mobile Spacing */
  --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  --padding-left-mobile: {{ section.settings.padding_left_mobile }}px;
  --padding-right-mobile: {{ section.settings.padding_right_mobile }}px;
  --margin-top-mobile: {{ section.settings.margin_top_mobile }}px;
  --margin-bottom-mobile: {{ section.settings.margin_bottom_mobile }}px;

  /* Sizing */
  --container-max-width-desktop: {{ section.settings.container_max_width_desktop }}px;
  --container-max-width-mobile: 100%;

  /* Alignment */
  --content-alignment-desktop: {{ section.settings.content_alignment_desktop }};
  --content-alignment-mobile: {{ section.settings.content_alignment_mobile }};

  /* Font Families */
  --heading-font-family: {{ section.settings.heading_font_family }};
  --desc-font-family: {{ section.settings.desc_font_family }};
  --btn-font-family: {{ section.settings.btn_font_family }};

  /* Typography Desktop */
  --heading-font-size-desktop: {{ section.settings.heading_font_size_desktop }}px;
  --heading-line-height-desktop: {{ section.settings.heading_line_height_desktop }};
  --heading-letter-spacing-desktop: {{ section.settings.heading_letter_spacing_desktop }}px;
  --heading-font-weight: {{ section.settings.heading_font_weight }};
  --heading-color: {{ section.settings.heading_color }};
  --heading-margin-bottom-desktop: {{ section.settings.heading_margin_bottom_desktop }}px;

  --desc-font-size-desktop: {{ section.settings.desc_font_size_desktop }}px;
  --desc-line-height-desktop: {{ section.settings.desc_line_height_desktop }};
  --desc-letter-spacing-desktop: {{ section.settings.desc_letter_spacing_desktop }}px;
  --desc-font-weight: {{ section.settings.desc_font_weight }};
  --desc-color: {{ section.settings.desc_color }};
  --desc-margin-bottom-desktop: {{ section.settings.desc_margin_bottom_desktop }}px;

  /* Typography Mobile */
  --heading-font-size-mobile: {{ section.settings.heading_font_size_mobile }}px;
  --heading-line-height-mobile: {{ section.settings.heading_line_height_mobile }};
  --heading-letter-spacing-mobile: {{ section.settings.heading_letter_spacing_mobile }}px;
  --heading-margin-bottom-mobile: {{ section.settings.heading_margin_bottom_mobile }}px;

  --desc-font-size-mobile: {{ section.settings.desc_font_size_mobile }}px;
  --desc-line-height-mobile: {{ section.settings.desc_line_height_mobile }};
  --desc-letter-spacing-mobile: {{ section.settings.desc_letter_spacing_mobile }}px;
  --desc-margin-bottom-mobile: {{ section.settings.desc_margin_bottom_mobile }}px;

  /* Highlight Settings */
  --highlight-color: {{ section.settings.highlight_color }};
  --highlight-font-weight: {{ section.settings.highlight_font_weight }};
  --highlight-font-style: {{ section.settings.highlight_font_style }};
  --highlight-bg-color: {{ section.settings.highlight_bg_color }};
  --highlight-padding: {{ section.settings.highlight_padding }};
  --highlight-radius: {{ section.settings.highlight_radius }}px;

  /* Button Desktop */
  --btn-font-size-desktop: {{ section.settings.btn_font_size_desktop }}px;
  --btn-padding-tb-desktop: {{ section.settings.btn_padding_tb_desktop }}px;
  --btn-padding-lr-desktop: {{ section.settings.btn_padding_lr_desktop }}px;
  --btn-bg-color: {{ section.settings.btn_bg_color }};
  --btn-text-color: {{ section.settings.btn_text_color }};
  --btn-border-color: {{ section.settings.btn_border_color }};
  --btn-border-width: {{ section.settings.btn_border_width }}px;
  --btn-border-style: {{ section.settings.btn_border_style }};
  --btn-radius: {{ section.settings.btn_radius }}px;
  --btn-shadow: {{ section.settings.btn_shadow }};

  --btn-hover-bg-color: {{ section.settings.btn_hover_bg_color }};
  --btn-hover-text-color: {{ section.settings.btn_hover_text_color }};
  --btn-hover-border-color: {{ section.settings.btn_hover_border_color }};
  --btn-hover-translate-y: {{ section.settings.btn_hover_translate_y }};
  --btn-hover-shadow: {{ section.settings.btn_hover_shadow }};

  /* Button Mobile */
  --btn-font-size-mobile: {{ section.settings.btn_font_size_mobile }}px;
  --btn-padding-tb-mobile: {{ section.settings.btn_padding_tb_mobile }}px;
  --btn-padding-lr-mobile: {{ section.settings.btn_padding_lr_mobile }}px;
  --btn-align-desktop: {% if section.settings.btn_alignment_desktop == 'left' %}flex-start{% elsif section.settings.btn_alignment_desktop == 'center' %}center{% else %}flex-end{% endif %};
  --btn-align-mobile: {% if section.settings.btn_alignment_mobile == 'left' %}flex-start{% elsif section.settings.btn_alignment_mobile == 'center' %}center{% else %}flex-end{% endif %};
  --btn-width-mobile: {% if section.settings.btn_full_width_mobile %}100%{% else %}auto{% endif %};
  --btn-font-weight: {{ section.settings.btn_font_weight }};
  --btn-letter-spacing: {{ section.settings.btn_letter_spacing }}px;

  /* Grid Layout Spacings & Widths */
  --grid-gap-desktop: {{ section.settings.grid_gap_desktop }}px;
  --grid-gap-mobile: {{ section.settings.grid_gap_mobile }}px;

  --content-width-desktop: {% if section.settings.desktop_layout_split == '50_50' %}calc(50% - (var(--grid-gap-desktop) / 2)){%
    elsif section.settings.desktop_layout_split == '40_60' %}calc(40% - (var(--grid-gap-desktop) * 0.6)){%
    elsif section.settings.desktop_layout_split == '60_40' %}calc(60% - (var(--grid-gap-desktop) * 0.4)){%
    elsif section.settings.desktop_layout_split == '35_65' %}calc(35% - (var(--grid-gap-desktop) * 0.65)){%
    elsif section.settings.desktop_layout_split == '65_35' %}calc(65% - (var(--grid-gap-desktop) * 0.35)){%
    endif %};
  --image-width-desktop: {% if section.settings.desktop_layout_split == '50_50' %}calc(50% - (var(--grid-gap-desktop) / 2)){%
    elsif section.settings.desktop_layout_split == '40_60' %}calc(60% - (var(--grid-gap-desktop) * 0.4)){%
    elsif section.settings.desktop_layout_split == '60_40' %}calc(40% - (var(--grid-gap-desktop) * 0.6)){%
    elsif section.settings.desktop_layout_split == '35_65' %}calc(65% - (var(--grid-gap-desktop) * 0.35)){%
    elsif section.settings.desktop_layout_split == '65_35' %}calc(35% - (var(--grid-gap-desktop) * 0.65)){%
    endif %};

  /* Image Visuals */
  --img-border-width: {{ section.settings.img_border_width }}px;
  --img-border-style: {{ section.settings.img_border_style }};
  --img-border-color: {{ section.settings.img_border_color }};
  --img-radius-standard: {{ section.settings.img_radius_standard }}px;
  --img-radius-arch-top: {{ section.settings.img_radius_arch_top }}px;
  --img-aspect-ratio-desktop: {{ section.settings.img_aspect_ratio_desktop }}%;
  --img-aspect-ratio-mobile: {{ section.settings.img_aspect_ratio_mobile }}%;
  --img-object-fit: {{ section.settings.img_object_fit }};
  --img-box-shadow: {{ section.settings.img_box_shadow }};
  --img-opacity: {{ section.settings.img_opacity | times: 0.01 }};

  --img-overlay-color: {{ section.settings.img_overlay_color }};
  --img-overlay-opacity: {{ section.settings.img_overlay_opacity | times: 0.01 }};

  --stacked-container-height-desktop: {{ section.settings.stacked_height_desktop }}%;
  --stacked-container-height-mobile: {{ section.settings.stacked_height_mobile }}%;
  --separator-color: {{ section.settings.separator_color }};
  --separator-width: {{ section.settings.separator_width }}px;
}

/* Base styles for portability */
.yv-images-grid-section-root {
  background-color: var(--section-bg-color);
  background-image: var(--section-bg-gradient);
  padding-top: var(--padding-top-mobile);
  padding-bottom: var(--padding-bottom-mobile);
  padding-left: var(--padding-left-mobile);
  padding-right: var(--padding-right-mobile);
  margin-top: var(--margin-top-mobile);
  margin-bottom: var(--margin-bottom-mobile);
  display: block;
  overflow: hidden;
  box-sizing: border-box;
}

@media only screen and (min-width: 992px) {
  .yv-images-grid-section-root {
    padding-top: var(--padding-top-desktop);
    padding-bottom: var(--padding-bottom-desktop);
    padding-left: var(--padding-left-desktop);
    padding-right: var(--padding-right-desktop);
    margin-top: var(--margin-top-desktop);
    margin-bottom: var(--margin-bottom-desktop);
  }
}

/* Flexbox layout container - 100% vertically centered */
.yv-images-grid-container-custom {
  max-width: var(--container-max-width-mobile);
  margin-left: auto;
  margin-right: auto;
  display: flex !important;
  flex-direction: column !important;
  gap: var(--grid-gap-mobile) !important;
  align-items: center !important;
  justify-content: center !important;
  box-sizing: border-box;
  width: 100% !important;
}

@media only screen and (min-width: 992px) {
  .yv-images-grid-container-custom {
    max-width: var(--container-max-width-desktop);
    flex-direction: row !important;
    gap: var(--grid-gap-desktop) !important;
    align-items: center !important;
    justify-content: center !important;
  }
}

/* Desktop alignment/order depending on position settings */
@media only screen and (min-width: 992px) {
  .yv-images-grid-container-custom.position-left {
    flex-direction: row !important;
  }
  .yv-images-grid-container-custom.position-right {
    flex-direction: row-reverse !important;
  }
  .yv-images-grid-container-custom.position-top {
    flex-direction: column !important;
  }
  .yv-images-grid-container-custom.position-bottom {
    flex-direction: column-reverse !important;
  }
}

/* Mobile Stacking Orders */
@media only screen and (max-width: 991px) {
  .yv-images-grid-container-custom.mobile-stack-text-first {
    flex-direction: column !important;
  }
  .yv-images-grid-container-custom.mobile-stack-images-first {
    flex-direction: column-reverse !important;
  }
}

/* Content wrapper style - 100% vertically centered */
.yv-images-grid-content-wrapper-custom {
  display: flex !important;
  flex-direction: column !important;
  justify-content: center !important;
  align-items: var(--content-alignment-mobile) !important;
  text-align: var(--content-alignment-mobile) !important;
  box-sizing: border-box;
  width: 100% !important;
  flex: 0 0 100% !important;
}

@media only screen and (min-width: 992px) {
  .yv-images-grid-content-wrapper-custom {
    align-items: var(--content-alignment-desktop) !important;
    text-align: var(--content-alignment-desktop) !important;
    width: var(--content-width-desktop) !important;
    flex: 0 0 var(--content-width-desktop) !important;
  }
}

.yv-images-grid-content-custom {
  width: 100%;
}

.yv-images-grid-content-heading-custom {
  font-family: var(--heading-font-family), inherit !important;
  font-size: var(--heading-font-size-mobile) !important;
  line-height: var(--heading-line-height-mobile) !important;
  letter-spacing: var(--heading-letter-spacing-mobile) !important;
  font-weight: var(--heading-font-weight) !important;
  color: var(--heading-color) !important;
  margin-top: 0 !important;
  margin-bottom: var(--heading-margin-bottom-mobile) !important;
}

@media only screen and (min-width: 992px) {
  .yv-images-grid-content-heading-custom {
    font-size: var(--heading-font-size-desktop) !important;
    line-height: var(--heading-line-height-desktop) !important;
    letter-spacing: var(--heading-letter-spacing-desktop) !important;
    margin-bottom: var(--heading-margin-bottom-desktop) !important;
  }
}

.yv-images-grid-content-text-custom {
  font-family: var(--desc-font-family), inherit !important;
  font-size: var(--desc-font-size-mobile) !important;
  line-height: var(--desc-line-height-mobile) !important;
  letter-spacing: var(--desc-letter-spacing-mobile) !important;
  font-weight: var(--desc-font-weight) !important;
  color: var(--desc-color) !important;
  margin-bottom: var(--desc-margin-bottom-mobile) !important;
}

@media only screen and (min-width: 992px) {
  .yv-images-grid-content-text-custom {
