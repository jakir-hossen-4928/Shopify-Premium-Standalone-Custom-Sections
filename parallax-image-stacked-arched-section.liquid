<script>
(function() {
  const initSection = () => {
    const section = document.getElementById("yv-images-grid-section-{{ section.id }}");
    if (!section) return;
    
    const parallaxEnabled = section.getAttribute("data-parallax") === "true";
    if (!parallaxEnabled) return;

    const elements = section.querySelectorAll(".scene-parallax");
    if (elements.length === 0) return;

    const speed = parseFloat(section.getAttribute("data-parallax-speed")) || 0.4;
    
    let scrollY = window.scrollY;
    let ticking = false;

    const onScroll = () => {
      scrollY = window.scrollY;
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateParallax();
          ticking = false;
        });
        ticking = true;
      }
    };

    const updateParallax = () => {
      const rect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight;
      
      if (rect.top < viewportHeight && rect.bottom > 0) {
        const sectionCenter = rect.top + rect.height / 2;
        const viewportCenter = viewportHeight / 2;
        const offset = (sectionCenter - viewportCenter) * speed * 0.15;

        elements.forEach((el, index) => {
          const elementSpeedFactor = 1 + (index * 0.2); 
          const translateValue = offset * elementSpeedFactor;
          el.style.transform = `translateY(${translateValue}px) rotate(var(--desktop-rotate, var(--mobile-rotate, 0deg)))`;
        });
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            window.addEventListener("scroll", onScroll, { passive: true });
            updateParallax();
          } else {
            window.removeEventListener("scroll", onScroll);
          }
        });
      },
      { threshold: 0.01 }
    );

    observer.observe(section);
  };

  document.addEventListener("DOMContentLoaded", initSection);
  document.addEventListener("shopify:section:load", function(e) {
    if (e.detail.sectionId === "{{ section.id }}") {
      initSection();
    }
  });
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initSection();
  }
})();
</script>

