{% comment %} SilVet Active Ingredients Section {% endcomment %}

<style>
  .sv-section {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_sides }}px {{ section.settings.padding_bottom }}px;
  }

  .sv-title {
    font-size: {{ section.settings.title_font_size }}px;
    font-weight: 600;
    line-height: 1.3;
    color: {{ section.settings.title_color }};
    text-align: center;
    margin: 0 0 20px;
  }

  .sv-description {
    max-width: {{ section.settings.desc_max_width }}px;
    margin: 0 auto {{ section.settings.desc_margin_bottom }}px;
    font-size: {{ section.settings.desc_font_size }}px;
    line-height: 26px;
    color: {{ section.settings.desc_color }};
    text-align: {{ section.settings.desc_alignment }};
  }

  /* ── TABLE (desktop) ── */
  .sv-table-wrapper {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .sv-table {
    width: 100%;
    min-width: 900px;
    border-collapse: collapse;
    background: {{ section.settings.table_bg }};
    border: 1px solid {{ section.settings.border_color }};
  }

  .sv-table thead th {
    background: {{ section.settings.header_bg }};
    color: {{ section.settings.header_text_color }};
    font-size: {{ section.settings.header_font_size }}px;
    font-weight: 600;
    padding: 18px 20px;
    text-align: left;
    border: 1px solid {{ section.settings.header_bg }};
  }

  .sv-table tbody td {
    padding: 20px;
    border: 1px solid {{ section.settings.border_color }};
    vertical-align: top;
    font-size: {{ section.settings.cell_font_size }}px;
    line-height: 26px;
    color: {{ section.settings.cell_text_color }};
  }

  .sv-table tbody tr:nth-child(even) {
    background: {{ section.settings.row_even_bg }};
  }

  .sv-table tbody tr:hover {
    background: {{ section.settings.row_hover_bg }};
  }

  .sv-table tbody td:first-child {
    width: 20%;
    color: {{ section.settings.ingredient_color }};
    font-weight: 600;
  }

  .sv-table tbody td:nth-child(2) {
    width: 25%;
    font-weight: 600;
  }

  .sv-table tbody td:nth-child(3) {
    width: 55%;
  }

  /* ── CARDS (mobile) ── */
  .sv-cards {
    display: none;
    gap: {{ section.settings.card_gap }}px;
    flex-direction: column;
  }

  .sv-card {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
  }

  .sv-card__header {
    background: {{ section.settings.header_bg }};
    padding: 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: center;
  }

  .sv-card__ingredient {
    font-size: {{ section.settings.card_ingredient_size }}px;
    font-weight: 700;
    color: {{ section.settings.card_ingredient_color }};
    line-height: 1.2;
  }

  .sv-card__action {
    font-size: {{ section.settings.card_action_size }}px;
    font-weight: 600;
    color: {{ section.settings.header_text_color }};
    line-height: 1.3;
    opacity: 0.9;
  }

  .sv-card__body {
    padding: 14px 18px;
  }

  .sv-card__desc {
    font-size: {{ section.settings.card_desc_size }}px;
    line-height: 24px;
    color: {{ section.settings.cell_text_color }};
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .sv-section {
      padding: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_padding_sides }}px {{ section.settings.mobile_padding_bottom }}px;
    }

    .sv-title {
      font-size: {{ section.settings.mobile_title_size }}px;
      margin-bottom: 15px;
    }

    .sv-description {
      font-size: 16px;
      line-height: 26px;
      margin-bottom: 30px;
    }

    .sv-table-wrapper {
      display: none;
    }

    .sv-table-wrapper.sv-table-mobile-show {
      display: block;
    }

    .sv-cards-hide {
      display: none !important;
    }

    .sv-cards {
      display: flex;
    }
  }
</style>

<section class="sv-section" id="sv-section-{{ section.id }}">

  {% if section.settings.title != blank %}
    <h2 class="sv-title">{{ section.settings.title }}</h2>
  {% endif %}

  {% if section.settings.description != blank %}
    <div class="sv-description">{{ section.settings.description }}</div>
  {% endif %}

  {% comment %} ── DESKTOP TABLE ── {% endcomment %}
  <div class="sv-table-wrapper{% if section.settings.show_table_mobile %} sv-table-mobile-show{% endif %}">
    <table class="sv-table">
      <thead>
        <tr>
          <th>{{ section.settings.col1_label }}</th>
          <th>{{ section.settings.col2_label }}</th>
          <th>{{ section.settings.col3_label }}</th>
        </tr>
      </thead>
      <tbody>
        {% for block in section.blocks %}
          <tr {{ block.shopify_attributes }}>
            <td>{{ block.settings.ingredient }}</td>
            <td>{{ block.settings.action }}</td>
            <td>{{ block.settings.description }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% comment %} ── MOBILE CARDS ── {% endcomment %}
  <div class="sv-cards{% if section.settings.show_table_mobile %} sv-cards-hide{% endif %}">
    {% for block in section.blocks %}
      <div class="sv-card" {{ block.shopify_attributes }}>
        <div class="sv-card__header">
          <span class="sv-card__ingredient">{{ block.settings.ingredient }}</span>
          <span class="sv-card__action">{{ block.settings.action }}</span>
        </div>
        <div class="sv-card__body">
          <p class="sv-card__desc">{{ block.settings.description }}</p>
        </div>
      </div>
    {% endfor %}
  </div>

</section>

{% schema %}
{
  "name": "SilVet Info Table",
  "tag": "section",
  "class": "silvet-info-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "SilVet™ Active Ingredients & Their Function"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Section Description",
      "default": "<p>SilVet™ is based on <strong>SilverStream® Solution</strong> that has been authorized by the US FDA and another 23 countries for the treatment of all types of wounds and burns.</p>"
    },
    {
      "type": "header",
      "content": "Table Column Labels"
    },
    {
      "type": "text",
      "id": "col1_label",
      "label": "Column 1 Label",
      "default": "Ingredient"
    },
    {
      "type": "text",
      "id": "col2_label",
      "label": "Column 2 Label",
      "default": "Action"
    },
    {
      "type": "text",
      "id": "col3_label",
      "label": "Column 3 Label",
      "default": "Description"
    },
    {
      "type": "header",
      "content": "Layout & Spacing"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "min": 800,
      "max": 1800,
      "step": 10,
      "default": 1570
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Desktop Padding Top (px)",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Desktop Padding Bottom (px)",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_sides",
      "label": "Desktop Padding Sides (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 10
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 45
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 45
    },
    {
      "type": "range",
      "id": "mobile_padding_sides",
      "label": "Mobile Padding Sides (px)",
      "min": 0,
      "max": 60,
      "step": 5,
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "show_table_mobile",
      "label": "Show table on mobile",
      "default": false,
      "info": "Adds horizontal scrolling for the table on mobile devices"
    },
    {
      "type": "range",
      "id": "desc_max_width",
      "label": "Description Max Width (px)",
      "min": 400,
      "max": 1200,
      "step": 10,
      "default": 900
    },
    {
      "type": "select",
      "id": "desc_alignment",
      "label": "Description Text Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "desc_margin_bottom",
      "label": "Description Margin Bottom (px)",
      "min": 10,
      "max": 80,
      "step": 5,
      "default": 45
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title Font Size (px)",
      "min": 20,
      "max": 60,
      "step": 1,
      "default": 36
    },
    {
      "type": "range",
      "id": "mobile_title_size",
      "label": "Mobile Title Font Size (px)",
      "min": 16,
      "max": 40,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "desc_font_size",
      "label": "Description Font Size (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "header_font_size",
      "label": "Table Header Font Size (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "cell_font_size",
      "label": "Table Cell Font Size (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors — Text"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description Color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "ingredient_color",
      "label": "Ingredient Column Color",
      "default": "#F16B23"
    },
    {
      "type": "color",
      "id": "cell_text_color",
      "label": "Cell Text Color",
      "default": "#444444"
    },
    {
      "type": "header",
      "content": "Colors — Table"
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "Header Background",
      "default": "#F16B23"
    },
    {
      "type": "color",
      "id": "header_text_color",
      "label": "Header Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "table_bg",
      "label": "Table Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#ececec"
    },
    {
      "type": "color",
      "id": "row_even_bg",
      "label": "Even Row Background",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "row_hover_bg",
      "label": "Row Hover Background",
      "default": "#fff7f1"
    },
    {
      "type": "header",
      "content": "Colors — Mobile Cards"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "#ececec"
    },
    {
      "type": "color",
      "id": "card_ingredient_color",
      "label": "Card Ingredient Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius (px)",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card Gap (px)",
      "min": 8,
      "max": 32,
      "step": 2,
      "default": 14
    },
    {
      "type": "range",
      "id": "card_ingredient_size",
      "label": "Card Ingredient Font Size (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "card_action_size",
      "label": "Card Action Font Size (px)",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "card_desc_size",
      "label": "Card Description Font Size (px)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 15
    }
  ],
  "blocks": [
    {
      "type": "ingredient_row",
      "name": "Ingredient Row",
      "settings": [
        {
          "type": "text",
          "id": "ingredient",
          "label": "Ingredient",
          "default": "Ag NO₃"
        },
        {
          "type": "text",
          "id": "action",
          "label": "Action",
          "default": "Preservative & Anti-microbial Agent"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Ionic silver kills on contact and inhibits the growth of bacteria, yeast, and fungi."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SilVet Info Table",
      "blocks": [
        {
          "type": "ingredient_row",
          "settings": {
            "ingredient": "Ag NO₃",
            "action": "Preservative & Anti-microbial Agent",
            "description": "Ionic silver kills on contact and inhibits the growth of bacteria, yeast, and fungi."
          }
        },
        {
          "type": "ingredient_row",
          "settings": {
            "ingredient": "Menthol",
            "action": "Penetration Enhancer, Growth Promoter, Pain Reliever, Odor Fighter",
            "description": "Enhances ionic silver antimicrobial activities, fights wound odor, and promotes granulation tissue growth through vasodilatation."
          }
        },
        {
          "type": "ingredient_row",
          "settings": {
            "ingredient": "Tween 20",
            "action": "Surfactant & Detergent",
            "description": "Enhances solution penetration into the biofilm and acts as a wound cleansing detergent."
          }
        },
        {
          "type": "ingredient_row",
          "settings": {
            "ingredient": "Glycerol",
            "action": "Hypertonic Aqueous Solution & Soothing Agent",
            "description": "Prevents macerations, aids the mechanical removal of exudates and microorganisms, and creates a hydrogel function by absorbing water molecules."
          }
        },
        {
          "type": "ingredient_row",
          "settings": {
            "ingredient": "Tris Buffer",
            "action": "Buffered Neutral pH",
            "description": "Biocompatible to physiological pH."
          }
        }
      ]
    }
  ]
}
{% endschema %}
