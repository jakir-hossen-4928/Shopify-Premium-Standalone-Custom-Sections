    { "type": "color", "id": "text_color", "label": "Body Text", "default": "#4A4A4A" },
    { "type": "color", "id": "border_color", "label": "Image Borders/Accents", "default": "#2D3B2D" },
    { "type": "header", "content": "Images" },
