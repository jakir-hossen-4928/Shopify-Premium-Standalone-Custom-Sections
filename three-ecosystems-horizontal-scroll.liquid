{% comment %}
  TGCD Studios / Collection Cards Section
  Compatible with: Shopify Impulse Theme
  Features: Eyebrow, 2-col header, 3 image cards with overlay text + CTA
  CSS prefix: tgcd-studios__
  MOBILE: Horizontal scroll option via theme editor toggle
{% endcomment %}

<style>
  /* ============================================
   THREE ECOSYSTEMS SECTION
   ============================================ */

.three-ecosystems {
  background-color: var(--section-bg, #f5f0eb);
  width: 100%;
}

.ecosystems-container {
  max-width: 1420px;
  margin: 0 auto;
  padding: 0 20px;
}

/* ============================================
   HEADER AREA
   ============================================ */

.ecosystems-header {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: flex-end;
  margin-bottom: 50px;
}

.ecosystems-header__left {
  max-width: 680px;
}

.ecosystems-header__right {
  display: flex;
  align-items: flex-end;
  padding-bottom: 8px;
}

/* Eyebrow */
.ecosystems-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--subheading-color, #8B4A2E);
  margin: 0 0 18px 0;
  font-family: inherit;
}

.eyebrow-line {
  display: inline-block;
  width: 28px;
  height: 1.5px;
  background-color: var(--subheading-color, #8B4A2E);
  flex-shrink: 0;
}

/* Main Heading */
.ecosystems-heading {
  font-size: clamp(36px, 4.5vw, 62px);
  font-weight: 800;
  line-height: 1.1;
  color: var(--heading-color, #0f0f0f);
  margin: 0;
  letter-spacing: -0.02em;
  font-family: inherit;
  white-space: pre-line;
}

/* Header Description */
.ecosystems-header-desc {
  font-size: 15px;
  line-height: 1.65;
  color: var(--desc-color, #3a3a3a);
  margin: 0;
  max-width: 380px;
  font-family: inherit;
}

/* ============================================
   CARDS GRID
   ============================================ */

.ecosystems-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

/* ============================================
   SINGLE CARD
   ============================================ */

.ecosystem-card {
  position: relative;
  border-radius: 6px;
  overflow: hidden;
  cursor: pointer;
  aspect-ratio: 3 / 4;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: #1a1a1a;

  /* Animation base */
  transform: translateY(0);
  transition:
    transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94),
    box-shadow 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.ecosystem-card:hover {
  transform: translateY(-8px);
  box-shadow:
    0 30px 60px rgba(0, 0, 0, 0.25),
    0 10px 20px rgba(0, 0, 0, 0.15);
}

/* ---- Background Image ---- */
.card-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
}

.card-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transform: scale(1);
  transition: transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.ecosystem-card:hover .card-bg img {
  transform: scale(1.06);
}

.card-bg-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 100%);
}

/* ---- Overlay ---- */
.card-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.15) 0%,
    rgba(0, 0, 0, 0.05) 30%,
    rgba(0, 0, 0, 0.55) 65%,
    rgba(0, 0, 0, 0.82) 100%
  );
  transition: background 0.45s ease;
}

.ecosystem-card:hover .card-overlay {
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.2) 0%,
    rgba(0, 0, 0, 0.1) 25%,
    rgba(0, 0, 0, 0.6) 60%,
    rgba(0, 0, 0, 0.88) 100%
  );
}

/* ---- Top Bar (Number + Arrow) ---- */
.card-top {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22px 22px 0 22px;
}

.card-number-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.85);
  font-family: inherit;
}

.card-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background-color: var(--arrow-bg, rgba(255, 255, 255, 0.15));
  color: var(--arrow-color, #ffffff);
  text-decoration: none;
  border: 1px solid rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  transition:
    background-color 0.3s ease,
    transform 0.3s ease,
    border-color 0.3s ease;
  flex-shrink: 0;
}

.card-arrow:hover,
.ecosystem-card:hover .card-arrow {
  background-color: rgba(255, 255, 255, 0.25);
  border-color: rgba(255, 255, 255, 0.5);
  transform: rotate(45deg) scale(1.05);
}

.card-arrow svg {
  transition: transform 0.3s ease;
}

/* ---- Bottom Content ---- */
.card-content {
  position: relative;
  z-index: 2;
  padding: 0 22px 26px 22px;
  transform: translateY(0);
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.ecosystem-card:hover .card-content {
  transform: translateY(-4px);
}

.card-title {
  font-size: clamp(20px, 2.2vw, 28px);
  font-weight: 800;
  line-height: 1.2;
  color: #ffffff;
  margin: 0 0 12px 0;
  letter-spacing: -0.01em;
  font-family: inherit;
}

.card-desc {
  font-size: 14px;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
  margin: 0 0 18px 0;
  font-family: inherit;

  /* Animate in on hover */
  opacity: 0.85;
  transform: translateY(0);
  transition:
    opacity 0.4s ease,
    transform 0.4s ease;
}

.ecosystem-card:hover .card-desc {
  opacity: 1;
  transform: translateY(-2px);
}

/* CTA Link */
.card-cta {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--card-accent, #c0392b);
  text-decoration: none;
  position: relative;
  font-family: inherit;
  transition: 
    color 0.3s ease,
    letter-spacing 0.3s ease;
}

.card-cta:hover{
   color: #f38d43;
}

.card-cta::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 0;
  height: 1.5px;
  background-color: var(--card-accent, #c0392b);
  transition: width 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.ecosystem-card:hover .card-cta::after {
  width: 100%;
}

.ecosystem-card:hover .card-cta {
  letter-spacing: 0.18em;
}

/* ============================================
   ENTER ANIMATION (Scroll Reveal)
   ============================================ */

@keyframes fadeUpIn {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.ecosystem-card {
  animation: fadeUpIn 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}

.ecosystem-card:nth-child(1) { animation-delay: 0.1s; }
.ecosystem-card:nth-child(2) { animation-delay: 0.22s; }
.ecosystem-card:nth-child(3) { animation-delay: 0.34s; }
.ecosystem-card:nth-child(4) { animation-delay: 0.46s; }
.ecosystem-card:nth-child(5) { animation-delay: 0.58s; }
.ecosystem-card:nth-child(6) { animation-delay: 0.70s; }

/* ============================================
   RESPONSIVE — TABLET (max 1024px)
   ============================================ */

@media screen and (max-width: 1024px) {
  .ecosystems-header {
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 40px;
  }

  .ecosystems-header__right {
    align-items: flex-start;
    padding-bottom: 0;
  }

  .ecosystems-header-desc {
    max-width: 560px;
  }

  .ecosystems-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .ecosystem-card {
    aspect-ratio: 4 / 5;
  }
}

/* ============================================
   RESPONSIVE — MOBILE (max 768px)
   ============================================ */

@media screen and (max-width: 768px) {
  .ecosystems-container {
    padding: 0 16px;
  }

  .ecosystems-header {
    margin-bottom: 30px;
  }

  .ecosystems-heading {
    font-size: clamp(28px, 8vw, 42px);
  }

  /* Default mobile: stacked single column */
  .ecosystems-grid {
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .ecosystem-card {
    aspect-ratio: 4 / 3.2;
  }

  .card-top {
    padding: 18px 18px 0 18px;
  }

  .card-content {
    padding: 0 18px 22px 18px;
  }

  .card-title {
    font-size: 22px;
  }

  /* Disable hover lift on touch devices */
  .ecosystem-card:hover {
    transform: none;
    box-shadow: none;
  }

  .ecosystem-card:hover .card-bg img {
    transform: scale(1);
  }

  .ecosystem-card:hover .card-content {
    transform: none;
  }
}

/* ============================================
   MOBILE HORIZONTAL SCROLL (when enabled)
   ============================================ */

@media screen and (max-width: 768px) {
  .ecosystems-grid--scroll {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    gap: 12px;
    padding-bottom: 16px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE 10+ */
    scroll-snap-type: x mandatory;
    scroll-padding-left: 16px;
    scroll-padding-right: 16px;
  }

  .ecosystems-grid--scroll::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  .ecosystems-grid--scroll .ecosystem-card {
    flex: 0 0 auto;
    width: 78vw;
    max-width: 320px;
    aspect-ratio: 3 / 4;
    scroll-snap-align: start;
    margin-right: 4px;
  }

  .ecosystems-grid--scroll .ecosystem-card:last-child {
    margin-right: 16px;
  }

  /* Scroll indicator dots */
  .ecosystems-scroll-indicator {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 16px;
    padding-bottom: 8px;
  }

  .scroll-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: rgba(0, 0, 0, 0.2);
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .scroll-dot.active {
    background-color: var(--subheading-color, #8B4A2E);
    transform: scale(1.3);
  }
}

/* ============================================
   RESPONSIVE — SMALL MOBILE (max 480px)
   ============================================ */

@media screen and (max-width: 480px) {
  .ecosystem-card {
    aspect-ratio: 3 / 2.5;
  }

  .ecosystems-grid--scroll .ecosystem-card {
    aspect-ratio: 3 / 4;
  }

  .ecosystems-eyebrow {
    font-size: 11px;
  }

  .card-number-label {
    font-size: 10px;
  }

  .card-arrow {
    width: 34px;
    height: 34px;
  }
}
</style>

{{ 'three-ecosystems.css' | asset_url | stylesheet_tag }}

<section class="three-ecosystems" style="
  --section-bg: {{ section.settings.section_bg }};
  --heading-color: {{ section.settings.heading_color }};
  --subheading-color: {{ section.settings.subheading_color }};
  --desc-color: {{ section.settings.desc_color }};
  --label-color: {{ section.settings.label_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
">
  <div class="ecosystems-container">

    <!-- Top Header Area -->
    <div class="ecosystems-header">
      <div class="ecosystems-header__left">
        {% if section.settings.eyebrow != blank %}
          <p class="ecosystems-eyebrow">
            <span class="eyebrow-line"></span>
            {{ section.settings.eyebrow }}
          </p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="ecosystems-heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
      <div class="ecosystems-header__right">
        {% if section.settings.header_desc != blank %}
          <p class="ecosystems-header-desc">{{ section.settings.header_desc }}</p>
        {% endif %}
      </div>
    </div>

    <!-- Cards Grid -->
    <div class="ecosystems-grid {% if section.settings.enable_mobile_scroll %}ecosystems-grid--scroll{% endif %}">
      {% for block in section.blocks %}
        {% if block.type == 'card' %}
          <div class="ecosystem-card" {{ block.shopify_attributes }}
            style="
              --card-accent: {{ block.settings.accent_color }};
              --arrow-bg: {{ block.settings.arrow_bg }};
              --arrow-color: {{ block.settings.arrow_icon_color }};
            ">

            <!-- Background Image -->
            <div class="card-bg">
              {% if block.settings.image != blank %}
                <img 
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.title }}"
                  loading="lazy"
                  width="800"
                  height="600"
                >
              {% else %}
                <div class="card-bg-placeholder"></div>
              {% endif %}
            </div>

            <!-- Overlay -->
            <div class="card-overlay"></div>

            <!-- Top Bar -->
            <div class="card-top">
              <span class="card-number-label">
                {{ block.settings.number_label }}
              </span>
              <a 
                href="{{ block.settings.card_link }}" 
                class="card-arrow"
                aria-label="Go to {{ block.settings.title }}"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 13L13 3M13 3H5M13 3V11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>

            <!-- Bottom Content -->
            <div class="card-content">
              {% if block.settings.title != blank %}
                <h3 class="card-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <p class="card-desc">{{ block.settings.description }}</p>
              {% endif %}
              {% if block.settings.link_text != blank %}
                <a href="{{ block.settings.card_link }}" class="card-cta">
                  {{ block.settings.link_text }} &rarr;
                </a>
              {% endif %}
            </div>

          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.enable_mobile_scroll and section.blocks.size > 0 %}
      <div class="ecosystems-scroll-indicator">
        {% for block in section.blocks %}
          {% if block.type == 'card' %}
            <span class="scroll-dot {% if forloop.first %}active{% endif %}"></span>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

{% if section.settings.enable_mobile_scroll %}
<script>
  (function() {
    var grid = document.querySelector('.ecosystems-grid--scroll');
    if (!grid) return;
    var dots = document.querySelectorAll('.scroll-dot');
    var cards = grid.querySelectorAll('.ecosystem-card');
    if (!dots.length || !cards.length) return;

    function updateDots() {
      var scrollLeft = grid.scrollLeft;
      var cardWidth = cards[0].offsetWidth + 12; // width + gap
      var index = Math.round(scrollLeft / cardWidth);
      if (index >= dots.length) index = dots.length - 1;
      if (index < 0) index = 0;
      dots.forEach(function(dot, i) {
        dot.classList.toggle('active', i === index);
      });
    }

    grid.addEventListener('scroll', updateDots, { passive: true });
  })();
</script>
{% endif %}

