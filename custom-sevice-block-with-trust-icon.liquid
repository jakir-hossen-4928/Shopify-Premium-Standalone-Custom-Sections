{% style %}
  .service-trust-section {
    display: block;
    width: 100%;
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    background-color: {{ section.settings.section_bg_color }};
  }

  .service-trust-container {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    padding-left: {{ section.settings.container_padding_desktop }}px;
    padding-right: {{ section.settings.container_padding_desktop }}px;
    display: grid;
    gap: 24px;
  }

  {% if section.settings.full_width %}
    .service-trust-container {
      max-width: 100%;
    }
  {% endif %}

  .service-trust-header {
    text-align: {{ section.settings.heading_alignment_desktop }};
    margin-bottom: {{ section.settings.header_margin_bottom_desktop }}px;
    display: grid;
    justify-items: center;
  }

  .service-trust-heading {
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
    line-height: {{ section.settings.heading_line_height }};
  }

  .service-trust-description {
    font-size: {{ section.settings.description_font_size_desktop }}px;
    color: {{ section.settings.description_color }};
    margin: 0;
    line-height: {{ section.settings.description_line_height }};
  }

  .service-trust-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.desktop_columns }}, minmax(0, 1fr));
    gap: {{ section.settings.gap_desktop }}px;
    justify-content: center;
    align-items: stretch;
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .service-trust-card {
    background-color: {{ section.settings.card_bg_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: {{ section.settings.card_padding_desktop }}px;
    text-align: {{ section.settings.card_content_alignment_desktop }};
    justify-self: center;
    border: {{ section.settings.card_border_width }}px {{ section.settings.card_border_style }} {{ section.settings.card_border_color }};
    box-shadow: {{ section.settings.card_shadow_x }}px {{ section.settings.card_shadow_y }}px {{ section.settings.card_shadow_blur }}px {{ section.settings.card_shadow_spread }}px {{ section.settings.card_shadow_color }};
    transition: transform {{ section.settings.hover_transition_speed }}s ease, box-shadow {{ section.settings.hover_transition_speed }}s ease;
    min-width: {{ section.settings.card_min_width_desktop }}px;
    max-width: {{ section.settings.card_max_width_desktop }}px;
    width: 100%;
    {% if section.settings.card_height_desktop > 0 %}
      min-height: {{ section.settings.card_height_desktop }}px;
    {% endif %}
  }

  {% if section.settings.enable_card_hover %}
    .service-trust-card:hover {
      transform: translateY(-{{ section.settings.card_hover_lift }}px);
      box-shadow: {{ section.settings.card_hover_shadow_x }}px {{ section.settings.card_hover_shadow_y }}px {{ section.settings.card_hover_shadow_blur }}px {{ section.settings.card_hover_shadow_spread }}px {{ section.settings.card_hover_shadow_color }};
    }
  {% endif %}

  .service-trust-image-wrapper {
    margin-bottom: {{ section.settings.image_margin_bottom_desktop }}px;
    display: flex;
    justify-content: {{ section.settings.card_content_alignment_desktop }};
  }

  .service-trust-image {
    width: {{ section.settings.image_width_desktop }}px;
    height: {{ section.settings.image_height_desktop }}px;
    object-fit: {{ section.settings.image_object_fit }};
    border-radius: {{ section.settings.image_border_radius }}px;
    background-color: {{ section.settings.image_bg_color }};
    padding: {{ section.settings.image_padding }}px;
    transition: transform {{ section.settings.hover_transition_speed }}s ease;
  }

  {% if section.settings.enable_image_hover %}
    .service-trust-card:hover .service-trust-image {
      transform: scale({{ section.settings.image_hover_scale }});
    }
  {% endif %}

  .service-trust-card-title {
    font-size: {{ section.settings.card_title_font_size_desktop }}px;
    font-weight: {{ section.settings.card_title_font_weight }};
    color: {{ section.settings.card_title_color }};
    margin: 0 0 {{ section.settings.card_title_margin_bottom }}px;
    line-height: {{ section.settings.card_title_line_height }};
  }

  .service-trust-card-description {
    font-size: {{ section.settings.card_description_font_size_desktop }}px;
    color: {{ section.settings.card_description_color }};
    margin: 0;
    line-height: {{ section.settings.card_description_line_height }};
  }

  @media screen and (max-width: 989px) and (min-width: 750px) {
    .service-trust-section {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }

    .service-trust-container {
      padding-left: {{ section.settings.container_padding_tablet }}px;
      padding-right: {{ section.settings.container_padding_tablet }}px;
    }

    .service-trust-header {
      text-align: {{ section.settings.heading_alignment_tablet }};
      margin-bottom: {{ section.settings.header_margin_bottom_tablet }}px;
    }

    .service-trust-heading {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }

    .service-trust-description {
      font-size: {{ section.settings.description_font_size_tablet }}px;
    }

    .service-trust-grid {
      grid-template-columns: repeat({{ section.settings.tablet_columns }}, minmax(0, 1fr));
      gap: {{ section.settings.gap_tablet }}px;
      justify-content: center;
      align-items: stretch;
      width: 100%;
    }

    .service-trust-card {
      padding: {{ section.settings.card_padding_tablet }}px;
      text-align: {{ section.settings.card_content_alignment_tablet }};
      {% if section.settings.card_height_tablet > 0 %}
        min-height: {{ section.settings.card_height_tablet }}px;
      {% endif %}
    }

    .service-trust-image-wrapper {
      margin-bottom: {{ section.settings.image_margin_bottom_tablet }}px;
      justify-content: {{ section.settings.card_content_alignment_tablet }};
    }

    .service-trust-image {
      width: {{ section.settings.image_width_tablet }}px;
      height: {{ section.settings.image_height_tablet }}px;
    }

    .service-trust-card-title {
      font-size: {{ section.settings.card_title_font_size_tablet }}px;
    }

    .service-trust-card-description {
      font-size: {{ section.settings.card_description_font_size_tablet }}px;
    }
  }

@media screen and (max-width: 749px) {
  .service-trust-section {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  .service-trust-container {
    padding-left: {{ section.settings.container_padding_mobile }}px;
    padding-right: {{ section.settings.container_padding_mobile }}px;
  }

  .service-trust-header {
    text-align: {{ section.settings.heading_alignment_mobile }};
    margin-bottom: {{ section.settings.header_margin_bottom_mobile }}px;
  }

  .service-trust-heading {
    font-size: {{ section.settings.heading_font_size_mobile }}px;
  }

  .service-trust-description {
    font-size: {{ section.settings.description_font_size_mobile }}px;
  }

  {% if section.settings.enable_mobile_carousel %}
    .service-trust-grid {
      display: grid;
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: minmax(min(260px, 100%), {{ section.settings.mobile_card_width_percent }}%);
      gap: {{ section.settings.gap_mobile }}px;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: {{ section.settings.mobile_edge_padding }}px;
      padding-left: {{ section.settings.mobile_edge_padding }}px;
      padding-right: {{ section.settings.mobile_edge_padding }}px;
      margin-left: 0;
      margin-right: 0;
      touch-action: pan-x;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: {% if section.settings.hide_scrollbar %}none{% else %}thin{% endif %};
      justify-content: start;
      align-items: stretch;
      box-sizing: border-box;
    }

    .service-trust-grid::-webkit-scrollbar {
      {% if section.settings.hide_scrollbar %}
        display: none;
      {% else %}
        height: 6px;
      {% endif %}
    }

    .service-trust-card {
      width: 100%;
      min-width: 0;
      max-width: none;
      box-sizing: border-box;
      scroll-snap-align: start;
      padding: {{ section.settings.card_padding_mobile }}px;
      text-align: {{ section.settings.card_content_alignment_mobile }};
      {% if section.settings.card_height_mobile > 0 %}
        min-height: {{ section.settings.card_height_mobile }}px;
      {% endif %}
    }

    {% if section.settings.enable_mobile_hover %}
      .service-trust-card:active {
        transform: translateY(-{{ section.settings.mobile_hover_lift }}px);
        box-shadow: {{ section.settings.mobile_hover_shadow_x }}px {{ section.settings.mobile_hover_shadow_y }}px {{ section.settings.mobile_hover_shadow_blur }}px {{ section.settings.mobile_hover_shadow_spread }}px {{ section.settings.mobile_hover_shadow_color }};
      }
    {% endif %}
  {% else %}
    .service-trust-grid {
      grid-template-columns: 1fr;
      gap: {{ section.settings.gap_mobile }}px;
      justify-content: {{ section.settings.mobile_alignment }};
    }

    .service-trust-card {
      padding: {{ section.settings.card_padding_mobile }}px;
      text-align: {{ section.settings.card_content_alignment_mobile }};
      {% if section.settings.card_height_mobile > 0 %}
        min-height: {{ section.settings.card_height_mobile }}px;
      {% endif %}
    }
  {% endif %}

  .service-trust-image-wrapper {
    margin-bottom: {{ section.settings.image_margin_bottom_mobile }}px;
    justify-content: {{ section.settings.card_content_alignment_mobile }};
  }

  .service-trust-image {
    width: {{ section.settings.image_width_mobile }}px;
    height: {{ section.settings.image_height_mobile }}px;
  }

  {% if section.settings.enable_mobile_image_hover %}
    .service-trust-card:active .service-trust-image {
      transform: scale({{ section.settings.mobile_image_hover_scale }});
    }
  {% endif %}

  .service-trust-card-title {
    font-size: {{ section.settings.card_title_font_size_mobile }}px;
    overflow-wrap: break-word;
  }

  .service-trust-card-description {
    font-size: {{ section.settings.card_description_font_size_mobile }}px;
    overflow-wrap: break-word;
  }
}

{% endstyle %}

<div class="service-trust-section" {{ section.shopify_attributes }}>
  <div class="service-trust-container">
    {% if section.settings.heading != blank or section.settings.description != blank %}
      <div class="service-trust-header">
        {% if section.settings.heading != blank %}
          <h2 class="service-trust-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="service-trust-description">{{ section.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="service-trust-grid">
      {% for i in (1..4) %}
        {% assign title_key = 'service_' | append: i | append: '_title' %}
        {% assign image_key = 'service_' | append: i | append: '_image' %}
        {% assign description_key = 'service_' | append: i | append: '_description' %}
        
        {% if section.settings[title_key] != blank %}
          <div class="service-trust-card">
            {% if section.settings[image_key] != blank %}
              <div class="service-trust-image-wrapper">
                <img
                  src="{{ section.settings[image_key] | image_url: width: 400 }}"
                  alt="{{ section.settings[image_key].alt | escape }}"
                  class="service-trust-image"
                  loading="lazy"
                  width="{{ section.settings.image_width_desktop }}"
                  height="{{ section.settings.image_height_desktop }}"
                >
              </div>
            {% endif %}
            <h3 class="service-trust-card-title">{{ section.settings[title_key] }}</h3>
            {% if section.settings[description_key] != blank %}
              <p class="service-trust-card-description">{{ section.settings[description_key] }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    class ServiceTrustCarousel extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const carousel = document.querySelector('.service-trust-grid');
        if (!carousel) return;

        if (window.innerWidth <= 749 && {{ section.settings.enable_mobile_carousel | json }}) {
          this.initCarousel(carousel);
        }
      }

      initCarousel(carousel) {
        let isDown = false;
        let startX;
        let scrollLeft;

        carousel.addEventListener('mousedown', (e) => {
          isDown = true;
          carousel.style.cursor = 'grabbing';
          startX = e.pageX - carousel.offsetLeft;
          scrollLeft = carousel.scrollLeft;
        });

        carousel.addEventListener('mouseleave', () => {
          isDown = false;
          carousel.style.cursor = 'grab';
        });

        carousel.addEventListener('mouseup', () => {
          isDown = false;
          carousel.style.cursor = 'grab';
        });

        carousel.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - carousel.offsetLeft;
          const walk = (x - startX) * {{ section.settings.swipe_sensitivity }};
          carousel.scrollLeft = scrollLeft - walk;
        });

        carousel.addEventListener('touchstart', (e) => {
          startX = e.touches[0].pageX - carousel.offsetLeft;
          scrollLeft = carousel.scrollLeft;
        });

        carousel.addEventListener('touchmove', (e) => {
          if (!startX) return;
          const x = e.touches[0].pageX - carousel.offsetLeft;
          const walk = (x - startX) * {{ section.settings.swipe_sensitivity }};
          carousel.scrollLeft = scrollLeft - walk;
        });

        carousel.addEventListener('touchend', () => {
          startX = null;
        });
      }
    }

    customElements.define('service-trust-carousel', ServiceTrustCarousel);
  })();
</script>

