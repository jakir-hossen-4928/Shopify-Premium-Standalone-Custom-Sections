{% comment %}
  ============================================================
  PRO PREMIUM HEADER
  Refactored for full customization from Theme Editor
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign menu = section.settings.menu
  assign show_cta = section.settings.show_cta_button
  assign cta_text = section.settings.cta_button_text
  assign cta_url = section.settings.cta_button_url
  assign show_cart_count = section.settings.show_cart_count

  assign logo_font = section.settings.logo_font
  assign nav_font = section.settings.nav_font
  assign cta_font = section.settings.cta_font
-%}

<style>
  {{ logo_font | font_face: font_display: 'swap' }}
  {{ nav_font | font_face: font_display: 'swap' }}
  {{ cta_font | font_face: font_display: 'swap' }}

  :root {
    --wo-h-desk: {{ section.settings.header_height_desktop }}px;
    --wo-h-mob: {{ section.settings.header_height_mobile }}px;
    --wo-pad-desk: {{ section.settings.desktop_padding }}px;
    --wo-pad-mob: {{ section.settings.mobile_padding }}px;
    
    --wo-logo-w-desk: {{ section.settings.logo_width_desktop }}px;
    --wo-logo-w-mob: {{ section.settings.logo_width_mobile }}px;
    --wo-logo-h-desk: calc(var(--wo-h-desk) - {{ section.settings.logo_vertical_padding }}px);
    --wo-logo-h-mob: calc(var(--wo-h-mob) - {{ section.settings.logo_vertical_padding_mobile }}px);
    
    --wo-header-bg: {{ section.settings.header_bg_color }};
    --wo-header-border: {{ section.settings.header_border_color }};
    
    /* Logo Typography */
    --wo-logo-font: {{ logo_font.family }}, {{ logo_font.fallback_families }};
    --wo-logo-color: {{ section.settings.logo_text_color }};
    --wo-logo-size: {{ section.settings.logo_font_size }}px;
    --wo-logo-weight: {{ section.settings.logo_font_weight | default: logo_font.weight }};
    --wo-logo-ls: {{ section.settings.logo_letter_spacing | divided_by: 100.0 }}em;
    --wo-logo-transform: {{ section.settings.logo_text_transform }};

    /* Nav Typography */
    --wo-nav-font: {{ nav_font.family }}, {{ nav_font.fallback_families }};
    --wo-nav-color: {{ section.settings.nav_text_color }};
    --wo-nav-hover: {{ section.settings.nav_hover_color }};
    --wo-nav-active: {{ section.settings.nav_active_color }};
    --wo-nav-size: {{ section.settings.nav_font_size }}px;
    --wo-nav-weight: {{ section.settings.nav_font_weight | default: nav_font.weight }};
    --wo-nav-gap: {{ section.settings.nav_spacing }}px;
    --wo-nav-tracking: {{ section.settings.nav_letter_spacing | divided_by: 100.0 }}em;
    --wo-nav-transform: {{ section.settings.nav_text_transform }};

    /* Cart Icon & Badge */
    --wo-cart-color: {{ section.settings.cart_icon_color }};
    --wo-cart-size: {{ section.settings.cart_icon_size }}px;
    --wo-count-bg: {{ section.settings.cart_count_bg }};
    --wo-count-color: {{ section.settings.cart_count_color }};

    /* CTA Typography */
    --wo-cta-font: {{ cta_font.family }}, {{ cta_font.fallback_families }};
    --wo-cta-bg: {{ section.settings.cta_bg_color }};
    --wo-cta-color: {{ section.settings.cta_text_color }};
    --wo-cta-hover: {{ section.settings.cta_hover_bg }};
    --wo-cta-radius: {{ section.settings.cta_border_radius }}px;
    --wo-cta-border: {{ section.settings.cta_border_color }};
    --wo-cta-weight: {{ section.settings.cta_font_weight | default: cta_font.weight }};
    --wo-cta-ls: {{ section.settings.cta_letter_spacing | divided_by: 100.0 }}em;
    --wo-cta-transform: {{ section.settings.cta_text_transform }};

    /* Drawer & Mobile Menu */
    --wo-mob-bg: {{ section.settings.mobile_menu_bg }};
    --wo-drawer-bg: {{ section.settings.drawer_bg }};
    --wo-overlay-op: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --wo-speed: {{ section.settings.animation_speed }}ms;
    --wo-ease: cubic-bezier(0.16, 1, 0.3, 1);
    --wo-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .wo-header *, .wo-header *::before, .wo-header *::after,
  .wo-cart-drawer *, .wo-cart-drawer *::before, .wo-cart-drawer *::after,
  .wo-mobile-menu *, .wo-mobile-menu *::before, .wo-mobile-menu *::after,
  .wo-overlay { box-sizing: border-box; margin: 0; padding: 0; }

  body { padding-top: var(--wo-h-desk); }
  @media (max-width: 768px) { body { padding-top: var(--wo-h-mob); } }

  .wo-header {
    position: {{ section.settings.sticky_behavior | liquid_if_true: 'fixed', 'relative' }};
    top: 0; left: 0; right: 0;
    z-index: 9990;
    width: 100%;
    height: var(--wo-h-desk);
    background: var(--wo-header-bg);
    border-bottom: 1px solid var(--wo-header-border);
    display: flex;
    align-items: center;
    transition: background var(--wo-speed) var(--wo-ease), border-color var(--wo-speed) var(--wo-ease);
  }

  .wo-header.is-menu-open {
    background: var(--wo-mob-bg);
    border-bottom-color: transparent;
  }

  .wo-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 var(--wo-pad-desk);
    height: 100%;
    position: relative;
    gap: 20px;
  }

  /* Logo */
  .wo-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    z-index: 2;
    position: relative;
    padding: 0;
    order: {{ section.settings.logo_position | liquid_if_true: '1', '2' }};
  }

  .wo-logo__img {
    display: block;
    width: var(--wo-logo-w-desk);
    max-width: 100%;
    height: var(--wo-logo-h-desk);
    max-height: var(--wo-logo-h-desk);
    object-fit: contain;
    object-position: {{ section.settings.header_align | liquid_if_true: 'left', 'center' }};
    transition: opacity var(--wo-speed) var(--wo-ease), transform var(--wo-speed) var(--wo-ease);
  }

  .wo-logo:hover .wo-logo__img { opacity: 0.8; transform: scale(0.975); }

  .wo-logo__text-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    height: 100%;
  }

  .wo-logo__name {
    font-family: var(--wo-logo-font);
    font-size: var(--wo-logo-size);
    font-weight: var(--wo-logo-weight);
    letter-spacing: var(--wo-logo-ls);
    text-transform: var(--wo-logo-transform);
    color: var(--wo-logo-color);
    line-height: 1;
    white-space: nowrap;
  }

  /* Nav */
  .wo-nav-wrap {
    flex-grow: 1;
    display: flex;
    justify-content: {{ section.settings.header_align }};
    order: 2;
  }

  .wo-nav {
    display: flex;
    align-items: center;
    gap: var(--wo-nav-gap);
    list-style: none;
    padding: 0; margin: 0;
  }

  .wo-nav__link {
    display: inline-block;
    font-family: var(--wo-nav-font);
    font-size: var(--wo-nav-size);
    font-weight: var(--wo-nav-weight);
    letter-spacing: var(--wo-nav-tracking);
    text-transform: var(--wo-nav-transform);
    color: var(--wo-nav-color);
    text-decoration: none;
    padding: 8px 0;
    position: relative;
    transition: color var(--wo-speed) var(--wo-ease);
  }

  .wo-nav__link::after {
    content: '';
    position: absolute;
    bottom: 2px; left: 0;
    width: 100%; height: 1.5px;
    background: var(--wo-nav-hover);
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform calc(var(--wo-speed) * 0.7) var(--wo-ease);
  }

  .wo-nav__link:hover { color: var(--wo-nav-hover); }
  .wo-nav__link:hover::after { transform: scaleX(1); transform-origin: left center; }
  .wo-nav__link.wo-active { color: var(--wo-nav-active); }
  .wo-nav__link.wo-active::after { background: var(--wo-nav-active); transform: scaleX(1); }

  /* Actions */
  .wo-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    order: 3;
    z-index: 2;
  }

  .wo-cart-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px; height: 42px;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: 10px;
    transition: background var(--wo-speed) var(--wo-ease), transform calc(var(--wo-speed) * 0.5) var(--wo-spring);
  }

  .wo-cart-btn:hover { background: rgba(255,255,255,0.06); transform: scale(1.06); }
  .wo-cart-btn:active { transform: scale(0.93); }
  .wo-cart-btn svg {
    width: var(--wo-cart-size); height: var(--wo-cart-size);
    stroke: var(--wo-cart-color);
    fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round;
  }

  .wo-badge {
    position: absolute;
    top: 4px; right: 4px;
    min-width: 16px; height: 16px;
    background: var(--wo-count-bg);
    color: var(--wo-count-color);
    border-radius: 50%;
    font-size: 9px; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    padding: 0 3px; opacity: 0; transform: scale(0);
    transition: opacity 0.28s var(--wo-spring), transform 0.32s var(--wo-spring);
  }

  .wo-badge.is-visible { opacity: 1; transform: scale(1); }

  .wo-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 22px;
    height: 38px;
    background: var(--wo-cta-bg);
    color: var(--wo-cta-color);
    border: 1px solid var(--wo-cta-border);
    border-radius: var(--wo-cta-radius);
    font-family: var(--wo-cta-font);
    font-size: 11.5px;
    font-weight: var(--wo-cta-weight);
    letter-spacing: var(--wo-cta-ls);
    text-transform: var(--wo-cta-transform);
    text-decoration: none;
    cursor: pointer;
    transition: background var(--wo-speed) var(--wo-ease), box-shadow var(--wo-speed) var(--wo-ease);
  }

  .wo-cta:hover { background: var(--wo-cta-hover); box-shadow: 0 6px 22px rgba(0,0,0,0.28); }

  .wo-hamburger {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 42px; height: 42px;
    background: transparent; border: none; cursor: pointer; gap: 6px;
  }

  .wo-hamburger__bar {
    display: block; height: 1.5px;
    background: var(--wo-nav-color);
    border-radius: 2px;
    transition: transform 0.44s var(--wo-ease), opacity 0.3s var(--wo-ease), width 0.34s var(--wo-ease);
  }

  .wo-hamburger__bar:nth-child(1) { width: 22px; }
  .wo-hamburger__bar:nth-child(2) { width: 14px; margin-right: 8px; align-self: flex-end; }

  .wo-hamburger.is-open .wo-hamburger__bar:nth-child(1) { transform: translateY(3.75px) rotate(42deg); }
  .wo-hamburger.is-open .wo-hamburger__bar:nth-child(2) { transform: translateY(-4.75px) rotate(-41deg); width: 22px; margin-right: 10px; }

  /* Mobile Menu */
  .wo-mobile-menu {
    position: fixed; inset: 0; z-index: 9989;
    background: var(--wo-mob-bg);
    display: flex; flex-direction: column;
    visibility: hidden; clip-path: inset(0 0 100% 0);
    transition: clip-path 0.58s var(--wo-ease), visibility 0.58s var(--wo-ease);
    overflow-y: auto;
  }

  .wo-mobile-menu.is-open { visibility: visible; clip-path: inset(0 0 0% 0); }

  .wo-mobile-menu__inner {
    display: flex; flex-direction: column;
    min-height: 100%;
    padding: calc(var(--wo-h-mob) + 36px) var(--wo-pad-mob) 52px;
  }

  .wo-mob-nav { list-style: none; padding: 0; margin: 0 0 44px; flex: 1; }
  .wo-mob-nav__item { border-bottom: 1px solid rgba(255,255,255,0.055); overflow: hidden; }
  .wo-mob-nav__item:first-child { border-top: 1px solid rgba(255,255,255,0.055); }

  .wo-mob-nav__link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 22px 0;
    font-family: var(--wo-nav-font);
    font-size: clamp(26px, 5.5vw, 46px);
    font-weight: 300;
    color: rgba(255,255,255,0.88);
    text-decoration: none;
    transform: translateY(26px); opacity: 0;
    transition: color 0.3s ease, transform 0.62s var(--wo-ease), opacity 0.62s var(--wo-ease);
  }

  .wo-mobile-menu.is-open .wo-mob-nav__link { transform: translateY(0); opacity: 1; }

  .wo-mob-footer {
    margin-top: auto; padding-top: 32px;
    display: flex; flex-direction: column; gap: 20px;
    transform: translateY(18px); opacity: 0;
    transition: transform 0.56s var(--wo-ease) 0.36s, opacity 0.56s var(--wo-ease) 0.36s;
  }

  .wo-mobile-menu.is-open .wo-mob-footer { transform: translateY(0); opacity: 1; }

  .wo-mob-social { display: flex; gap: 24px; flex-wrap: wrap; align-items: center; }
  .wo-mob-social__link {
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: rgba(255,255,255,0.28);
    text-decoration: none; transition: color 0.25s ease;
  }

  .wo-mob-social__link:hover { color: rgba(255,255,255,0.75); }

  /* Overlay & Drawer */
  .wo-overlay {
    position: fixed; inset: 0; z-index: 9994;
    background: rgba(0,0,0,var(--wo-overlay-op));
    opacity: 0; visibility: hidden; cursor: pointer;
    transition: opacity 0.4s var(--wo-ease), visibility 0.4s var(--wo-ease);
  }

  .wo-overlay.is-open { opacity: 1; visibility: visible; }

  .wo-cart-drawer {
    position: fixed; top: 0; right: 0; bottom: 0; z-index: 9995;
    width: min(430px, 96vw);
    background: var(--wo-drawer-bg);
    transform: translateX(102%);
    transition: transform 0.54s var(--wo-ease);
    box-shadow: -24px 0 80px rgba(0,0,0,0.5);
    display: flex; flex-direction: column;
  }

  .wo-cart-drawer.is-open { transform: translateX(0); }

  .wo-drawer__bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 26px; height: 64px;
    border-bottom: 1px solid rgba(255,255,255,0.055);
  }

  .wo-drawer__title { font-size: 11.5px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.9); }
  .wo-drawer__x {
    width: 34px; height: 34px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
  }

  .wo-drawer__body { flex: 1; overflow-y: auto; padding: 18px 26px; }

  .wo-checkout {
    display: flex; align-items: center; justify-content: center; gap: 9px;
    width: 100%; height: 50px;
    background: rgba(255,255,255,0.94); color: #0a0b0e;
    border-radius: 10px; font-size: 11px; font-weight: 800; text-transform: uppercase; text-decoration: none;
    transition: background 0.28s ease, transform 0.3s var(--wo-spring);
  }

  .wo-checkout:hover { background: #ffffff; transform: translateY(-2px); }

  body.wo-locked { overflow: hidden; touch-action: none; }

  @media (max-width: 1024px) {
    .wo-nav-wrap { display: none; }
    .wo-actions > .wo-cart-btn { display: none; }
    .wo-actions > .wo-cta { display: none; }
    .wo-hamburger { display: flex; }
    .wo-mobile-cluster { display: flex; align-items: center; gap: 5px; }
  }

  @media (max-width: 768px) {
    .wo-header { height: var(--wo-h-mob); }
    .wo-logo__img { width: var(--wo-logo-w-mob); height: var(--wo-logo-h-mob); }
  }
</style>

<header class="wo-header" id="wo-header" role="banner">
  <div class="wo-header__inner">

    <!-- LOGO -->
    <a href="{{ routes.root_url }}" class="wo-logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 800 | image_tag: class: 'wo-logo__img', loading: 'eager', fetchpriority: 'high', alt: shop.name }}
      {%- else -%}
        <div class="wo-logo__text-wrap">
          {%- if section.settings.show_logo_icon -%}
            <span class="wo-logo__icon-mark" aria-hidden="true">
              <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="28" height="28" rx="5" fill="{{ section.settings.logo_icon_bg }}"/>
                <path d="M7 8L11 20L14 12L17 20L21 8" stroke="{{ section.settings.logo_icon_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          {%- endif -%}
          <span class="wo-logo__name">{{ section.settings.logo_text | default: shop.name }}</span>
        </div>
      {%- endif -%}
    </a>

    <!-- NAV -->
    {%- if menu != blank -%}
      <nav class="wo-nav-wrap" role="navigation" aria-label="Primary">
        <ul class="wo-nav">
          {%- for link in linklists[menu].links -%}
            <li class="wo-nav__item">
              <a href="{{ link.url }}" class="wo-nav__link{% if link.active %} wo-active{% endif %}">{{ link.title }}</a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <!-- ACTIONS -->
    <div class="wo-actions">
      <button class="wo-cart-btn" id="wo-cart-desk" aria-label="Open cart">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        {%- if show_cart_count -%}
          <span class="wo-badge{% if cart.item_count > 0 %} is-visible{% endif %}" id="wo-badge-desk">{{ cart.item_count }}</span>
        {%- endif -%}
      </button>

      {%- if show_cta and cta_text != blank -%}
        <a href="{{ cta_url | default: '#' }}" class="wo-cta">{{ cta_text }}</a>
      {%- endif -%}

      <div class="wo-mobile-cluster">
        <button class="wo-cart-btn" id="wo-cart-mob" aria-label="Open cart">
          <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          {%- if show_cart_count -%}
            <span class="wo-badge{% if cart.item_count > 0 %} is-visible{% endif %}" id="wo-badge-mob">{{ cart.item_count }}</span>
          {%- endif -%}
        </button>
        <button class="wo-hamburger" id="wo-hamburger" aria-label="Open menu">
          <span class="wo-hamburger__bar"></span>
          <span class="wo-hamburger__bar"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<div class="wo-mobile-menu" id="wo-mobile-menu">
  <div class="wo-mobile-menu__inner">
    {%- if menu != blank -%}
      <ul class="wo-mob-nav">
        {%- for link in linklists[menu].links -%}
          <li class="wo-mob-nav__item">
            <a href="{{ link.url }}" class="wo-mob-nav__link">{{ link.title }} <span class="wo-mob-nav__arrow">↗</span></a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
    <div class="wo-mob-footer">
      {%- if show_cta and cta_text != blank -%}
        <a href="{{ cta_url | default: '#' }}" class="wo-mob-cta">{{ cta_text }}</a>
      {%- endif -%}
      <div class="wo-mob-social">
        {%- for block in section.blocks -%}
          {%- if block.type == 'social_link' -%}
            <a href="{{ block.settings.url }}" class="wo-mob-social__link" target="_blank">{{ block.settings.label }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<div class="wo-overlay" id="wo-overlay"></div>

<div class="wo-cart-drawer" id="wo-cart-drawer">
  <div class="wo-drawer__bar">
    <span class="wo-drawer__title">Cart</span>
    <button class="wo-drawer__x" id="wo-drawer-x">✕</button>
  </div>
  <div class="wo-drawer__body" id="wo-drawer-body"></div>
  <div class="wo-drawer__foot" id="wo-drawer-foot">
    <div class="wo-drawer__total">
      <span>Subtotal</span>
      <span id="wo-subtotal"></span>
    </div>
    <a href="/checkout" class="wo-checkout">Checkout</a>
  </div>
</div>

<script>
(function () {
  'use strict';
  
  function initHeader() {
    const sid = '{{ section_id }}';
    const hamburger = document.getElementById('wo-hamburger');
    const mobileMenu = document.getElementById('wo-mobile-menu');
    const overlay = document.getElementById('wo-overlay');
    const cartDrawer = document.getElementById('wo-cart-drawer');
    const drawerX = document.getElementById('wo-drawer-x');
    const cartDesk = document.getElementById('wo-cart-desk');
    const cartMob = document.getElementById('wo-cart-mob');
    const drawerBody = document.getElementById('wo-drawer-body');
    const subtotalEl = document.getElementById('wo-subtotal');
    const badges = [document.getElementById('wo-badge-desk'), document.getElementById('wo-badge-mob')];

    let menuOpen = false, drawerOpen = false, busy = false;

    const lock = () => document.body.classList.add('wo-locked');
    const unlock = () => document.body.classList.remove('wo-locked');

    function fmt(cents, currency) {
      return new Intl.NumberFormat(document.documentElement.lang || 'en-US', {
        style: 'currency',
        currency: currency || (window.Shopify && Shopify.currency && Shopify.currency.active) || '{{ cart.currency.iso_code }}'
      }).format(cents / 100);
    }

    function renderCart(cart) {
      badges.forEach(b => { if(b) { b.textContent = cart.item_count; b.classList.toggle('is-visible', cart.item_count > 0); } });
      if (cart.item_count === 0) {
        drawerBody.innerHTML = '<p>Your cart is empty</p>';
        document.getElementById('wo-drawer-foot').style.display = 'none';
        return;
      }
      document.getElementById('wo-drawer-foot').style.display = 'block';
      subtotalEl.textContent = fmt(cart.total_price, cart.currency);
      drawerBody.innerHTML = cart.items.map(item => `
        <div style="margin-bottom:15px; display:flex; gap:10px;">
          <img src="${item.image}" width="60">
          <div>
            <p style="font-size:13px; color:#fff;">${item.product_title}</p>
            <p style="font-size:12px; color:#ccc;">${fmt(item.price, cart.currency)} x ${item.quantity}</p>
          </div>
        </div>
      `).join('');
    }

    async function fetchCart() {
      const res = await fetch('/cart.js');
      renderCart(await res.json());
    }

    hamburger?.addEventListener('click', () => {
      menuOpen = !menuOpen;
      hamburger.classList.toggle('is-open', menuOpen);
      mobileMenu.classList.toggle('is-open', menuOpen);
      menuOpen ? lock() : unlock();
    });

    const openDrawer = () => { drawerOpen = true; cartDrawer.classList.add('is-open'); overlay.classList.add('is-open'); lock(); fetchCart(); };
    const closeDrawer = () => { drawerOpen = false; cartDrawer.classList.remove('is-open'); overlay.classList.remove('is-open'); unlock(); };

    window.WOCartDrawer = { open: openDrawer, close: closeDrawer, refresh: fetchCart };
    document.addEventListener('wo:cart:open', openDrawer);
    window.addEventListener('wo:cart:open', openDrawer);
    document.addEventListener('cart:refresh', fetchCart);

    cartDesk?.addEventListener('click', openDrawer);
    cartMob?.addEventListener('click', openDrawer);
    drawerX?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', () => { if(drawerOpen) closeDrawer(); if(menuOpen) { menuOpen=false; mobileMenu.classList.remove('is-open'); hamburger.classList.remove('is-open'); unlock(); } });

    fetchCart();
  }

  document.addEventListener('shopify:section:load', e => { if(e.detail.sectionId === '{{ section_id }}') initHeader(); });
  initHeader();
})();
</script>

