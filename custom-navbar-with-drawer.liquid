    opacity: 0.55;
  }

  .nb-search-loading-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 24px;
    font-size: 13px;
    color: var(--search-result-text);
    opacity: 0.5;
  }

  .nb-search-spinner-{{ section.id }} {
    width: 18px;
    height: 18px;
    border: 2px solid var(--search-border);
