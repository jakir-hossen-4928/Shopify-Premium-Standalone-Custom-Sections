  }

  @keyframes nbSearchSpin-{{ section.id }} {
    to { transform: rotate(360deg); }
  }

  /* View all results link */
  .nb-search-view-all-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 12px 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--menu-hover-color);
    text-decoration: none;
    border-top: 1px solid rgba(0,0,0,0.06);
    transition: background 0.15s;
    background: rgba(0,0,0,0.01);
  }

  .nb-search-view-all-{{ section.id }}:hover {
    background: rgba(0,0,0,0.04);
    text-decoration: underline;
  }

  /* =====================
     CART DRAWER — FIXED RIGHT SIDE
  ===================== */
  .nb-drawer-overlay-{{ section.id }} {
    position: fixed;
    inset: 0;
    background: var(--overlay-color);
    z-index: 9000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    pointer-events: none;
  }

  .nb-drawer-overlay-{{ section.id }}.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .nb-drawer-{{ section.id }} {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: auto;
    width: min({{ section.settings.drawer_width_mobile }}vw, {{ section.settings.drawer_width_desktop }}px);
    height: 100vh;
    height: 100dvh;
    min-height: 100vh;
    min-height: 100dvh;
