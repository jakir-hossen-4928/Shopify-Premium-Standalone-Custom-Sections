    align-items: center;
    justify-content: center;
  }

  .nb-search-result-info-{{ section.id }} {
    flex: 1;
    min-width: 0;
  }

  .nb-search-result-title-{{ section.id }} {
    font-size: var(--search-result-font-size);
    font-weight: 500;
    color: var(--search-result-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
