  }

  .nb-drawer-subtotal-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 15px;
  }

  .nb-subtotal-label-{{ section.id }} {
    font-weight: 500;
    color: var(--drawer-text);
    opacity: 0.75;
  }

  .nb-subtotal-price-{{ section.id }} {
    font-size: var(--drawer-price-size);
    font-weight: var(--drawer-price-weight);
    color: var(--drawer-price-color);
  }

  .nb-checkout-btn-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    height: var(--checkout-btn-height);
    background: var(--checkout-btn-bg);
    color: var(--checkout-btn-text);
    border: none;
    border-radius: var(--checkout-btn-radius);
    font-size: var(--checkout-btn-font-size);
    font-weight: var(--checkout-btn-font-weight);
    letter-spacing: var(--checkout-btn-letter-spacing);
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .nb-checkout-btn-{{ section.id }}:hover { opacity: 0.88; }

  .nb-continue-btn-{{ section.id }} {
    display: block;
    text-align: center;
    font-size: 13px;
    color: var(--drawer-text);
    opacity: 0.6;
    text-decoration: underline;
    cursor: pointer;
    background: none;
    border: none;
    font-family: inherit;
    width: 100%;
    padding: 0;
  }

  .nb-continue-btn-{{ section.id }}:hover { opacity: 1; }

  /* Loading overlay for drawer */
  .nb-drawer-loading-{{ section.id }} {
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.6);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .nb-drawer-loading-{{ section.id }}.is-active { display: flex; }

  .nb-spinner-{{ section.id }} {
    width: 28px;
    height: 28px;
    border: 3px solid var(--drawer-border);
    border-top-color: var(--checkout-btn-bg);
    border-radius: 50%;
    animation: nbSpin-{{ section.id }} 0.7s linear infinite;
  }

  @keyframes nbSpin-{{ section.id }} { to { transform: rotate(360deg); } }

  /* =====================
     MOBILE MENU DRAWER
  ===================== */
  .nb-mobile-overlay-{{ section.id }} {
    position: fixed;
    inset: 0;
    background: var(--overlay-color);
    z-index: 8000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    pointer-events: none;
  }

  .nb-mobile-overlay-{{ section.id }}.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .nb-mobile-menu-{{ section.id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: min({{ section.settings.mobile_menu_width }}vw, 320px);
    height: 100%;
    height: 100dvh;
    background: var(--mobile-menu-bg);
    color: var(--mobile-menu-text);
    z-index: 8001;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.32, 0, 0.15, 1);
    display: flex;
    flex-direction: column;
    box-shadow: 4px 0 30px rgba(0,0,0,0.12);
    overflow-y: auto;
  }

  .nb-mobile-menu-{{ section.id }}.is-open { transform: translateX(0); }

  .nb-mobile-head-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 20px 16px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    position: sticky;
    top: 0;
    background: var(--mobile-menu-bg);
    z-index: 1;
    flex-shrink: 0;
  }

  .nb-mobile-head-title-{{ section.id }} {
    font-size: 16px;
    font-weight: 700;
    color: var(--mobile-menu-text);
  }

  .nb-mobile-close-{{ section.id }} {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 6px;
    cursor: pointer;
    color: var(--mobile-menu-text);
    transition: all 0.2s;
  }

  .nb-mobile-close-{{ section.id }}:hover { background: rgba(0,0,0,0.06); }

  .nb-mobile-nav-{{ section.id }} {
    flex: 1;
    padding: 8px 0;
    list-style: none;
    margin: 0;
  }

  .nb-mobile-link-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    height: var(--mobile-item-height);
    font-size: var(--mobile-menu-font-size);
    font-weight: var(--mobile-menu-font-weight);
    color: var(--mobile-menu-text);
    text-decoration: none;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    cursor: pointer;
    transition: background 0.15s;
    background: none;
    border-left: none;
    border-right: none;
    border-top: none;
    width: 100%;
    text-align: left;
    font-family: inherit;
  }

  .nb-mobile-link-{{ section.id }}:hover {
    background: rgba(0,0,0,0.04);
    color: var(--menu-hover-color);
  }

  .nb-mobile-arrow-{{ section.id }} { transition: transform 0.25s; flex-shrink: 0; }
  .nb-mobile-link-{{ section.id }}.is-open .nb-mobile-arrow-{{ section.id }} { transform: rotate(90deg); }

  .nb-mobile-sub-{{ section.id }} {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    background: rgba(0,0,0,0.025);
  }

  .nb-mobile-sub-{{ section.id }}.is-open { max-height: 500px; }

  .nb-mobile-sub-link-{{ section.id }} {
    display: block;
    padding: 0 20px 0 36px;
    height: calc(var(--mobile-item-height) - 6px);
    line-height: calc(var(--mobile-item-height) - 6px);
    font-size: var(--mobile-submenu-font-size);
    color: var(--mobile-menu-text);
    opacity: 0.8;
    text-decoration: none;
    border-bottom: 1px solid rgba(0,0,0,0.04);
    transition: all 0.15s;
  }

  .nb-mobile-sub-link-{{ section.id }}:hover {
    opacity: 1;
    color: var(--menu-hover-color);
    padding-left: 42px;
  }

  .nb-mobile-foot-{{ section.id }} {
    padding: 16px 20px 8px;
    border-top: 1px solid rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-shrink: 0;
  }

  .nb-mobile-account-{{ section.id }},
  .nb-mobile-cart-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--mobile-menu-text);
    text-decoration: none;
    transition: background 0.15s;
    border: 1px solid rgba(0,0,0,0.1);
  }

  .nb-mobile-account-{{ section.id }}:hover,
  .nb-mobile-cart-{{ section.id }}:hover { background: rgba(0,0,0,0.04); }

  /* =====================
     RESPONSIVE — DESKTOP
  ===================== */
  @media (min-width: 1024px) {
    .nb-inner-{{ section.id }} {
      padding: 0;
      height: var(--nav-height-desktop);
    }

    .nb-hamburger-{{ section.id }} { display: none; }
    .nb-center-{{ section.id }} { display: flex; }

    .nb-logo-img-{{ section.id }} { width: var(--logo-img-width-desktop); }
    .nb-logo-text-{{ section.id }} { font-size: var(--logo-font-size-desktop); }

    .nb-icon-btn-{{ section.id }} svg {
      width: var(--icon-size-desktop);
      height: var(--icon-size-desktop);
    }

    .nb-search-modal-{{ section.id }} {
      padding: 20px var(--nav-padding-desktop);
    }

    .nb-search-modal-top-{{ section.id }} {
      gap: 12px;
    }

    .nb-search-modal-form-{{ section.id }} {
      padding: 0 16px;
      gap: 10px;
    }
  }

  /* Mobile search responsive fixes */
  @media (max-width: 480px) {
    .nb-search-modal-{{ section.id }} {
      padding: 12px 10px;
    }

    .nb-search-modal-close-{{ section.id }} {
