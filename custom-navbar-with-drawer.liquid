  .nb-qty-btn-{{ section.id }}:hover {
    background: var(--checkout-btn-bg);
    color: var(--checkout-btn-text);
    border-color: var(--checkout-btn-bg);
  }

  .nb-qty-btn-{{ section.id }}.is-loading { opacity: 0.5; pointer-events: none; }

  .nb-qty-num-{{ section.id }} {
    font-size: var(--qty-font-size);
    font-weight: 600;
    color: var(--drawer-text);
