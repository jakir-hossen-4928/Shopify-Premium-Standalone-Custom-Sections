 {% comment %}
 navbar-drawer.liquid
  Place in: sections/navbar-drawer.liquid
{% endcomment %}

{%- liquid
  assign nav_bg = section.settings.nav_bg
  assign nav_text = section.settings.nav_text
  assign nav_border = section.settings.nav_border
  assign logo_color = section.settings.logo_color
  assign menu_color = section.settings.menu_color
  assign menu_hover_color = section.settings.menu_hover_color
  assign dropdown_bg = section.settings.dropdown_bg
  assign dropdown_text = section.settings.dropdown_text
  assign dropdown_border = section.settings.dropdown_border
  assign icon_color = section.settings.icon_color
  assign icon_hover_color = section.settings.icon_hover_color
  assign cart_bubble_bg = section.settings.cart_bubble_bg
  assign cart_bubble_text = section.settings.cart_bubble_text
  assign drawer_bg = section.settings.drawer_bg
  assign drawer_text = section.settings.drawer_text
  assign drawer_border = section.settings.drawer_border
  assign drawer_header_bg = section.settings.drawer_header_bg
  assign drawer_header_text = section.settings.drawer_header_text
  assign button_bg = section.settings.checkout_btn_bg
  assign button_text = section.settings.checkout_btn_text
  assign search_bg = section.settings.search_bg
  assign search_text = section.settings.search_text
  assign search_border = section.settings.search_border
  assign search_result_bg = section.settings.search_result_bg
  assign search_result_text = section.settings.search_result_text
  assign mobile_menu_bg = section.settings.mobile_menu_bg
  assign mobile_menu_text = section.settings.mobile_menu_text
  assign overlay_color = section.settings.overlay_color
  assign main_menu = section.settings.main_menu
-%}

<style>
  /* =====================
     CSS VARIABLES
  ===================== */
  #shopify-section-{{ section.id }} {
    --nav-bg: {{ nav_bg }};
    --nav-text: {{ nav_text }};
    --nav-border: {{ nav_border }};
    --logo-color: {{ logo_color }};
    --menu-color: {{ menu_color }};
    --menu-hover-color: {{ menu_hover_color }};
    --dropdown-bg: {{ dropdown_bg }};
    --dropdown-text: {{ dropdown_text }};
    --dropdown-border: {{ dropdown_border }};
    --icon-color: {{ icon_color }};
    --icon-hover-color: {{ icon_hover_color }};
    --cart-bubble-bg: {{ cart_bubble_bg }};
    --cart-bubble-text: {{ cart_bubble_text }};
    --drawer-bg: {{ drawer_bg }};
    --drawer-text: {{ drawer_text }};
    --drawer-border: {{ drawer_border }};
    --drawer-header-bg: {{ drawer_header_bg }};
    --drawer-header-text: {{ drawer_header_text }};
    --checkout-btn-bg: {{ button_bg }};
    --checkout-btn-text: {{ button_text }};
    --search-bg: {{ search_bg }};
    --search-text: {{ search_text }};
    --search-border: {{ search_border }};
    --search-result-bg: {{ search_result_bg }};
    --search-result-text: {{ search_result_text }};
    --mobile-menu-bg: {{ mobile_menu_bg }};
    --mobile-menu-text: {{ mobile_menu_text }};
    --overlay-color: {{ overlay_color }};
    --nav-height-desktop: {{ section.settings.nav_height_desktop }}px;
    --nav-height-mobile: {{ section.settings.nav_height_mobile }}px;
    --nav-border-width: {{ section.settings.nav_border_width }}px;
    --nav-border-style: {{ section.settings.nav_border_style }};
    --nav-border-radius: {{ section.settings.nav_border_radius }}px;
    --container-max-width: {{ section.settings.container_max_width }}px;
    --nav-padding-desktop: {{ section.settings.nav_padding_desktop }}px;
    --nav-padding-mobile: {{ section.settings.nav_padding_mobile }}px;
    --nav-shadow: {{ section.settings.nav_shadow }};
    --nav-position: {{ section.settings.nav_position }};
    --nav-top-offset: {{ section.settings.nav_top_offset }}px;
    --nav-z-index: {{ section.settings.nav_z_index }};
    --logo-font-size-desktop: {{ section.settings.logo_font_size_desktop }}px;
    --logo-font-size-mobile: {{ section.settings.logo_font_size_mobile }}px;
    --logo-font-weight: {{ section.settings.logo_font_weight }};
    --logo-letter-spacing: {{ section.settings.logo_letter_spacing }}px;
    --logo-text-transform: {{ section.settings.logo_text_transform }};
    --logo-img-width-desktop: {{ section.settings.logo_img_width_desktop }}px;
    --logo-img-width-mobile: {{ section.settings.logo_img_width_mobile }}px;
    --logo-img-height: {{ section.settings.logo_img_height }}px;
    --menu-font-size: {{ section.settings.menu_font_size }}px;
    --menu-font-weight: {{ section.settings.menu_font_weight }};
    --menu-letter-spacing: {{ section.settings.menu_letter_spacing }}px;
    --menu-text-transform: {{ section.settings.menu_text_transform }};
    --menu-gap: {{ section.settings.menu_gap }}px;
    --menu-item-padding: {{ section.settings.menu_item_padding }}px;
    --menu-underline-height: {{ section.settings.menu_underline_height }}px;
    --dropdown-font-size: {{ section.settings.dropdown_font_size }}px;
    --dropdown-font-weight: {{ section.settings.dropdown_font_weight }};
    --dropdown-border-radius: {{ section.settings.dropdown_border_radius }}px;
    --dropdown-padding: {{ section.settings.dropdown_padding }}px;
    --dropdown-item-padding: {{ section.settings.dropdown_item_padding }}px;
    --dropdown-min-width: {{ section.settings.dropdown_min_width }}px;
    --dropdown-shadow: {{ section.settings.dropdown_shadow }};
    --icon-size-desktop: {{ section.settings.icon_size_desktop }}px;
    --icon-size-mobile: {{ section.settings.icon_size_mobile }}px;
    --icon-gap: {{ section.settings.icon_gap }}px;
    --icon-btn-size: {{ section.settings.icon_btn_size }}px;
    --icon-btn-radius: {{ section.settings.icon_btn_radius }}px;
    --icon-btn-bg: {{ section.settings.icon_btn_bg }};
    --bubble-size: {{ section.settings.bubble_size }}px;
    --bubble-font-size: {{ section.settings.bubble_font_size }}px;
    --bubble-offset-top: {{ section.settings.bubble_offset_top }}px;
    --bubble-offset-right: {{ section.settings.bubble_offset_right }}px;
    --drawer-width-desktop: {{ section.settings.drawer_width_desktop }}px;
    --drawer-width-mobile: {{ section.settings.drawer_width_mobile }};
    --drawer-header-height: {{ section.settings.drawer_header_height }}px;
    --drawer-footer-height: {{ section.settings.drawer_footer_height }}px;
    --drawer-padding: {{ section.settings.drawer_padding }}px;
    --drawer-border-radius: {{ section.settings.drawer_border_radius }}px;
    --drawer-item-img-size: {{ section.settings.drawer_item_img_size }}px;
    --drawer-item-radius: {{ section.settings.drawer_item_radius }}px;
    --drawer-title-size: {{ section.settings.drawer_title_size }}px;
    --drawer-title-weight: {{ section.settings.drawer_title_weight }};
    --drawer-price-size: {{ section.settings.drawer_price_size }}px;
    --drawer-price-weight: {{ section.settings.drawer_price_weight }};
    --drawer-price-color: {{ section.settings.drawer_price_color }};
    --drawer-vendor-size: {{ section.settings.drawer_vendor_size }}px;
    --drawer-vendor-color: {{ section.settings.drawer_vendor_color }};
    --qty-btn-size: {{ section.settings.qty_btn_size }}px;
    --qty-btn-bg: {{ section.settings.qty_btn_bg }};
    --qty-btn-color: {{ section.settings.qty_btn_color }};
    --qty-btn-border: {{ section.settings.qty_btn_border }};
    --qty-btn-radius: {{ section.settings.qty_btn_radius }}px;
    --qty-font-size: {{ section.settings.qty_font_size }}px;
    --checkout-btn-radius: {{ section.settings.checkout_btn_radius }}px;
    --checkout-btn-height: {{ section.settings.checkout_btn_height }}px;
    --checkout-btn-font-size: {{ section.settings.checkout_btn_font_size }}px;
    --checkout-btn-font-weight: {{ section.settings.checkout_btn_font_weight }};
    --checkout-btn-letter-spacing: {{ section.settings.checkout_btn_letter_spacing }}px;
    --search-bar-height: {{ section.settings.search_bar_height }}px;
    --search-bar-radius: {{ section.settings.search_bar_radius }}px;
    --search-font-size: {{ section.settings.search_font_size }}px;
    --search-result-radius: {{ section.settings.search_result_radius }}px;
    --search-result-img-size: {{ section.settings.search_result_img_size }}px;
    --search-result-font-size: {{ section.settings.search_result_font_size }}px;
    --search-result-price-size: {{ section.settings.search_result_price_size }}px;
    --search-result-price-color: {{ section.settings.search_result_price_color }};
    --mobile-menu-width: {{ section.settings.mobile_menu_width }};
    --mobile-menu-font-size: {{ section.settings.mobile_menu_font_size }}px;
    --mobile-menu-font-weight: {{ section.settings.mobile_menu_font_weight }};
    --mobile-submenu-font-size: {{ section.settings.mobile_submenu_font_size }}px;
    --mobile-item-height: {{ section.settings.mobile_item_height }}px;
  }

  /* =====================
     RESET & BASE
  ===================== */
  .nb-{{ section.id }} *,
  .nb-{{ section.id }} *::before,
  .nb-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  /* =====================
     SECTION WRAPPER FIX
  ===================== */
  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: var(--nav-z-index);
  }

  /* =====================
     NAVBAR WRAPPER
  ===================== */
  .nb-{{ section.id }} {
    background: var(--nav-bg);
    border-bottom: var(--nav-border-width) var(--nav-border-style) var(--nav-border);
    border-radius: var(--nav-border-radius);
    box-shadow: var(--nav-shadow);
    position: sticky;
    top: var(--nav-top-offset);
    left: 0;
    right: 0;
    z-index: var(--nav-z-index);
    width: 100%;
    overflow: visible;
  }

  /* JS-applied fixed fallback when sticky fails */
  .nb-{{ section.id }}.nb-is-fixed {
    position: fixed;
    top: var(--nav-top-offset);
    left: 0;
    right: 0;
    width: 100%;
  }

  /* Spacer to prevent content jump when navbar is fixed */
  .nb-sticky-spacer-{{ section.id }} {
    display: none;
    width: 100%;
    pointer-events: none;
  }

  .nb-sticky-spacer-{{ section.id }}.nb-spacer-active {
    display: block;
  }

  .nb-inner-{{ section.id }} {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0;
    height: var(--nav-height-mobile);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    position: relative;
    overflow: visible;
  }

  /* =====================
     LEFT
  ===================== */
  .nb-left-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .nb-hamburger-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: var(--icon-btn-size);
    height: var(--icon-btn-size);
    background: var(--icon-btn-bg);
    border: none;
    border-radius: var(--icon-btn-radius);
    cursor: pointer;
    padding: 0;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .nb-hamburger-{{ section.id }} span {
    display: block;
    width: var(--icon-size-mobile);
    height: 2px;
    background: var(--icon-color);
    border-radius: 2px;
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .nb-hamburger-{{ section.id }}.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nb-hamburger-{{ section.id }}.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nb-hamburger-{{ section.id }}.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nb-logo-{{ section.id }} {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nb-logo-img-{{ section.id }} {
    width: var(--logo-img-width-mobile);
    height: var(--logo-img-height);
    object-fit: contain;
    display: block;
  }

  .nb-logo-text-{{ section.id }} {
    font-size: var(--logo-font-size-mobile);
    font-weight: var(--logo-font-weight);
    color: var(--logo-color);
    letter-spacing: var(--logo-letter-spacing);
    text-transform: var(--logo-text-transform);
    line-height: 1;
    white-space: nowrap;
    text-decoration: none;
  }

  /* =====================
     CENTER — DESKTOP MENU
  ===================== */
  .nb-center-{{ section.id }} {
    display: none;
    align-items: center;
    justify-content: center;
    flex: 1;
    overflow: visible;
  }

  .nb-menu-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: var(--menu-gap);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nb-menu-item-{{ section.id }} { position: relative; }

  .nb-menu-link-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--menu-font-size);
    font-weight: var(--menu-font-weight);
    letter-spacing: var(--menu-letter-spacing);
    text-transform: var(--menu-text-transform);
    color: var(--menu-color);
    text-decoration: none;
    padding: var(--menu-item-padding) 0;
    position: relative;
    transition: color 0.2s ease;
    white-space: nowrap;
    cursor: pointer;
    background: none;
    border: none;
    font-family: inherit;
  }

  .nb-menu-link-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: var(--menu-underline-height);
    background: var(--menu-hover-color);
    transition: width 0.25s ease;
    border-radius: 2px;
  }

  .nb-menu-link-{{ section.id }}:hover,
  .nb-menu-link-{{ section.id }}.is-active { color: var(--menu-hover-color); }

  .nb-menu-link-{{ section.id }}:hover::after,
  .nb-menu-link-{{ section.id }}.is-active::after { width: 100%; }

  .nb-menu-arrow-{{ section.id }} {
    width: 12px;
    height: 12px;
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .nb-menu-item-{{ section.id }}:hover .nb-menu-arrow-{{ section.id }},
  .nb-menu-item-{{ section.id }}.is-open .nb-menu-arrow-{{ section.id }} { transform: rotate(180deg); }

  /* =====================
     DROPDOWN
  ===================== */
  .nb-dropdown-{{ section.id }} {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    min-width: var(--dropdown-min-width);
    background: var(--dropdown-bg);
    border: 1px solid var(--dropdown-border);
    border-radius: var(--dropdown-border-radius);
    box-shadow: var(--dropdown-shadow);
    padding: var(--dropdown-padding) 0;
    list-style: none;
    margin: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: all 0.22s ease;
    z-index: 9999;
  }

  .nb-menu-item-{{ section.id }}:hover .nb-dropdown-{{ section.id }},
  .nb-menu-item-{{ section.id }}.is-open .nb-dropdown-{{ section.id }} {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .nb-dropdown-item-{{ section.id }} { display: block; }

  .nb-dropdown-link-{{ section.id }} {
    display: block;
    padding: var(--dropdown-item-padding) calc(var(--dropdown-padding) + 8px);
    font-size: var(--dropdown-font-size);
    font-weight: var(--dropdown-font-weight);
    color: var(--dropdown-text);
    text-decoration: none;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .nb-dropdown-link-{{ section.id }}:hover {
    background: rgba(0,0,0,0.04);
    color: var(--menu-hover-color);
    padding-left: calc(var(--dropdown-padding) + 14px);
  }

  /* =====================
     RIGHT — ICONS
  ===================== */
  .nb-right-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: var(--icon-gap);
    flex-shrink: 0;
  }

  .nb-icon-btn-{{ section.id }} {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--icon-btn-size);
    height: var(--icon-btn-size);
    background: var(--icon-btn-bg);
    border: none;
    border-radius: var(--icon-btn-radius);
    cursor: pointer;
    color: var(--icon-color);
    transition: all 0.2s ease;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nb-icon-btn-{{ section.id }}:hover {
    color: var(--icon-hover-color);
    background: rgba(0,0,0,0.05);
  }

  .nb-icon-btn-{{ section.id }} svg {
    width: var(--icon-size-mobile);
    height: var(--icon-size-mobile);
    display: block;
    flex-shrink: 0;
  }

  /* Cart Bubble */
  .nb-cart-bubble-{{ section.id }} {
    position: absolute;
    top: var(--bubble-offset-top);
    right: var(--bubble-offset-right);
    width: var(--bubble-size);
    height: var(--bubble-size);
    background: var(--cart-bubble-bg);
    color: var(--cart-bubble-text);
    font-size: var(--bubble-font-size);
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    pointer-events: none;
    transition: transform 0.2s ease;
  }

  .nb-cart-bubble-{{ section.id }}.is-hidden { display: none; }

  .nb-cart-bubble-{{ section.id }}.bump {
    animation: nbBubbleBump-{{ section.id }} 0.35s ease;
  }

  @keyframes nbBubbleBump-{{ section.id }} {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.4); }
    100% { transform: scale(1); }
  }

  /* =====================
     SEARCH MODAL OVERLAY
  ===================== */
  .nb-search-modal-overlay-{{ section.id }} {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  .nb-search-modal-overlay-{{ section.id }}.is-open {
    opacity: 1;
    visibility: visible;
  }

  /* Search Modal Panel */
  .nb-search-modal-{{ section.id }} {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10000;
    background: var(--search-bg);
    padding: 16px;
    transform: translateY(-100%);
    transition: transform 0.32s cubic-bezier(0.32, 0, 0.15, 1);
    box-shadow: 0 8px 40px rgba(0,0,0,0.18);
  }

  .nb-search-modal-{{ section.id }}.is-open {
    transform: translateY(0);
  }

  .nb-search-modal-inner-{{ section.id }} {
    max-width: var(--container-max-width);
    margin: 0 auto;
    position: relative;
    width: 100%;
  }

  .nb-search-modal-top-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 0;
    width: 100%;
  }

  .nb-search-modal-form-{{ section.id }} {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--nav-bg);
    border: 2px solid var(--search-border);
    border-radius: var(--search-bar-radius);
    padding: 0 12px;
    height: var(--search-bar-height);
    transition: border-color 0.2s;
  }

  .nb-search-modal-form-{{ section.id }}:focus-within {
    border-color: var(--menu-hover-color);
  }

  .nb-search-modal-input-{{ section.id }} {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent !important;
    background-color: transparent !important;
    font-size: var(--search-font-size);
    color: var(--search-text);
    outline: none;
    font-family: inherit;
    padding: 0;
    margin: 0;
    width: 100%;
    height: 100%;
    box-shadow: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    border-radius: 0;
  }

  /* Hide native browser clear button */
  .nb-search-modal-input-{{ section.id }}::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
    display: none;
    width: 0;
    height: 0;
  }

  .nb-search-modal-input-{{ section.id }}::-webkit-search-decoration {
    -webkit-appearance: none;
    display: none;
  }

  .nb-search-modal-input-{{ section.id }}::-webkit-search-results-decoration {
    -webkit-appearance: none;
    display: none;
  }

  .nb-search-modal-input-{{ section.id }}::-webkit-search-results-button {
    -webkit-appearance: none;
    display: none;
  }

  .nb-search-modal-input-{{ section.id }}::-ms-clear {
    display: none;
    width: 0;
    height: 0;
  }

  .nb-search-modal-input-{{ section.id }}::-ms-reveal {
    display: none;
    width: 0;
    height: 0;
  }

  .nb-search-modal-input-{{ section.id }}::placeholder {
    color: var(--search-text);
    opacity: 0.4;
    font-weight: 400;
  }

  .nb-search-modal-clear-{{ section.id }} {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--search-text);
    opacity: 0.5;
    padding: 4px;
    display: none;
    align-items: center;
    justify-content: center;
    transition: opacity 0.15s;
    flex-shrink: 0;
    border-radius: 50%;
  }

  .nb-search-modal-clear-{{ section.id }}.is-visible {
    display: inline-flex;
  }

  .nb-search-modal-clear-{{ section.id }}:hover {
    opacity: 1;
    background: rgba(0,0,0,0.06);
  }

  .nb-search-modal-close-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--search-bar-height);
    background: rgba(0,0,0,0.06);
    border: none;
    border-radius: var(--search-bar-radius);
    cursor: pointer;
    color: var(--search-text);
    flex-shrink: 0;
    transition: background 0.2s;
    font-size: 13px;
    font-weight: 600;
    font-family: inherit;
    white-space: nowrap;
    padding: 0 14px;
    min-width: auto;
  }

  .nb-search-modal-close-{{ section.id }}:hover {
    background: rgba(0,0,0,0.12);
  }

  /* Search Results Panel inside modal */
  .nb-search-modal-results-{{ section.id }} {
    margin-top: 10px;
    background: var(--search-result-bg);
    border: 1px solid var(--search-border);
    border-radius: var(--search-result-radius);
    max-height: min(420px, 55vh);
    overflow-y: auto;
    display: none;
  }

  .nb-search-modal-results-{{ section.id }}.is-visible {
    display: block;
  }

  .nb-search-modal-results-{{ section.id }}::-webkit-scrollbar { width: 4px; }
  .nb-search-modal-results-{{ section.id }}::-webkit-scrollbar-thumb {
    background: var(--search-border);
    border-radius: 4px;
  }

