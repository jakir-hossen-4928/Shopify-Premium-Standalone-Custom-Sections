  }

  .nb-cart-item-{{ section.id }}:last-child { border-bottom: none; }

  .nb-item-img-wrap-{{ section.id }} { flex-shrink: 0; }

  .nb-item-img-{{ section.id }} {
    width: var(--drawer-item-img-size);
    height: var(--drawer-item-img-size);
    object-fit: cover;
    border-radius: var(--drawer-item-radius);
    display: block;
    background: rgba(0,0,0,0.04);
  }

  .nb-item-info-{{ section.id }} {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nb-item-vendor-{{ section.id }} {
    font-size: var(--drawer-vendor-size);
    color: var(--drawer-vendor-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
