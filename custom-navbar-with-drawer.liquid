</style>

{%- comment -%} ===== NAVBAR HTML ===== {%- endcomment -%}

<div class="nb-sticky-spacer-{{ section.id }}" id="nbStickySpacer-{{ section.id }}"></div>
<div class="nb-{{ section.id }}" id="nb-{{ section.id }}" role="navigation" aria-label="Main navigation">
  <div class="nb-inner-{{ section.id }}">

    {%- comment -%} LEFT {%- endcomment -%}
    <div class="nb-left-{{ section.id }}">
      <button
        class="nb-hamburger-{{ section.id }}"
        id="nbHamburger-{{ section.id }}"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nbMobileMenu-{{ section.id }}">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <a href="{{ routes.root_url }}" class="nb-logo-{{ section.id }}" aria-label="{{ shop.name }}">
        {% if section.settings.logo_image %}
          <img
            class="nb-logo-img-{{ section.id }}"
            src="{{ section.settings.logo_image | image_url: width: section.settings.logo_img_width_desktop }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_img_width_desktop }}"
            height="{{ section.settings.logo_img_height }}"
            loading="eager">
        {% else %}
          <span class="nb-logo-text-{{ section.id }}">
            {{ section.settings.logo_text | default: shop.name }}
          </span>
        {% endif %}
      </a>
    </div>

    {%- comment -%} CENTER — Desktop Menu {%- endcomment -%}
    <nav class="nb-center-{{ section.id }}" aria-label="Desktop navigation">
      {% if main_menu != blank %}
        <ul class="nb-menu-{{ section.id }}" role="menubar">
          {% for link in linklists[main_menu].links %}
            <li class="nb-menu-item-{{ section.id }}" role="none">
              {% if link.links.size > 0 %}
                <button
                  class="nb-menu-link-{{ section.id }}"
                  role="menuitem"
                  aria-haspopup="true"
                  aria-expanded="false"
                  data-nb-menu-toggle>
                  {{ link.title }}
                  <svg class="nb-menu-arrow-{{ section.id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 9l6 6 6-6"/>
                  </svg>
                </button>
                <ul class="nb-dropdown-{{ section.id }}" role="menu">
                  {% for child in link.links %}
                    <li class="nb-dropdown-item-{{ section.id }}" role="none">
                      <a class="nb-dropdown-link-{{ section.id }}" href="{{ child.url }}" role="menuitem">
                        {{ child.title }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              {% else %}
                <a
                  class="nb-menu-link-{{ section.id }}{% if link.active %} is-active{% endif %}"
                  href="{{ link.url }}"
                  role="menuitem"
                  {% if link.active %}aria-current="page"{% endif %}>
                  {{ link.title }}
                </a>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </nav>

    {%- comment -%} RIGHT — Icons {%- endcomment -%}
    <div class="nb-right-{{ section.id }}">

      {% if section.settings.show_search %}
      <button
        class="nb-icon-btn-{{ section.id }}"
        id="nbSearchToggle-{{ section.id }}"
        aria-label="Open search"
        aria-expanded="false"
        aria-controls="nbSearchModal-{{ section.id }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      {% endif %}

      {% if section.settings.show_account %}
      <a class="nb-icon-btn-{{ section.id }}" href="{{ routes.account_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </a>
      {% endif %}

      {% if section.settings.show_cart %}
      <button
        class="nb-icon-btn-{{ section.id }}"
        id="nbCartToggle-{{ section.id }}"
        aria-label="Open cart"
        aria-expanded="false"
        aria-controls="nbDrawer-{{ section.id }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span
          class="nb-cart-bubble-{{ section.id }} is-hidden"
          id="nbCartBubble-{{ section.id }}"
          aria-live="polite"
          aria-label="Cart item count">0</span>
      </button>
      {% endif %}

    </div>
  </div>
</div>

{%- comment -%} ===== SEARCH MODAL ===== {%- endcomment -%}
<div
  class="nb-search-modal-overlay-{{ section.id }}"
  id="nbSearchModalOverlay-{{ section.id }}"
  aria-hidden="true">
</div>

<div
  class="nb-search-modal-{{ section.id }}"
  id="nbSearchModal-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Search"
  aria-hidden="true">
  <div class="nb-search-modal-inner-{{ section.id }}">
    <div class="nb-search-modal-top-{{ section.id }}">
      <div class="nb-search-modal-form-{{ section.id }}">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.4;flex-shrink:0">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          type="search"
          class="nb-search-modal-input-{{ section.id }}"
          id="nbSearchModalInput-{{ section.id }}"
          placeholder="{{ section.settings.search_placeholder | default: 'Search products, collections...' }}"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          aria-label="Search"
          aria-autocomplete="list"
          aria-controls="nbSearchModalResults-{{ section.id }}">
        <button
          class="nb-search-modal-clear-{{ section.id }}"
          id="nbSearchModalClear-{{ section.id }}"
          aria-label="Clear search"
          type="button">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <button
        class="nb-search-modal-close-{{ section.id }}"
        id="nbSearchModalClose-{{ section.id }}"
        aria-label="Close search"
        type="button">
        Cancel
      </button>
    </div>
    <div
      class="nb-search-modal-results-{{ section.id }}"
      id="nbSearchModalResults-{{ section.id }}"
      role="listbox"
      aria-label="Search results">
    </div>
  </div>
</div>

{%- comment -%} ===== CART DRAWER ===== {%- endcomment -%}
<div
  class="nb-drawer-overlay-{{ section.id }}"
  id="nbDrawerOverlay-{{ section.id }}"
  aria-hidden="true">
</div>

<div
  class="nb-drawer-{{ section.id }}"
  id="nbDrawer-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping cart"
  aria-hidden="true">

  <div class="nb-drawer-loading-{{ section.id }}" id="nbDrawerLoading-{{ section.id }}" aria-hidden="true">
    <div class="nb-spinner-{{ section.id }}"></div>
  </div>

  <div class="nb-drawer-head-{{ section.id }}">
    <h2 class="nb-drawer-title-{{ section.id }}">
      {{ section.settings.drawer_title | default: 'Your Cart' }}
      <span class="nb-drawer-count-badge-{{ section.id }}" id="nbDrawerCountBadge-{{ section.id }}">0</span>
    </h2>
    <button
      class="nb-drawer-close-{{ section.id }}"
      id="nbDrawerClose-{{ section.id }}"
      aria-label="Close cart"
      type="button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="nb-drawer-body-{{ section.id }}" id="nbDrawerBody-{{ section.id }}">
    <div class="nb-drawer-empty-{{ section.id }}" id="nbDrawerEmpty-{{ section.id }}">
      <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      <p class="nb-drawer-empty-title-{{ section.id }}">{{ section.settings.empty_cart_title | default: 'Your cart is empty' }}</p>
      <p class="nb-drawer-empty-desc-{{ section.id }}">{{ section.settings.empty_cart_desc | default: 'Add some products to get started' }}</p>
    </div>
    <div id="nbCartItems-{{ section.id }}"></div>
  </div>

  <div class="nb-drawer-foot-{{ section.id }}" id="nbDrawerFoot-{{ section.id }}" style="display:none">
    <div class="nb-drawer-subtotal-{{ section.id }}">
      <span class="nb-subtotal-label-{{ section.id }}">{{ section.settings.subtotal_label | default: 'Subtotal' }}</span>
      <span class="nb-subtotal-price-{{ section.id }}" id="nbSubtotal-{{ section.id }}">$0.00</span>
    </div>
    <a href="/checkout" class="nb-checkout-btn-{{ section.id }}" id="nbCheckoutBtn-{{ section.id }}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
      {{ section.settings.checkout_btn_label | default: 'Checkout' }}
    </a>
    <button class="nb-continue-btn-{{ section.id }}" id="nbContinue-{{ section.id }}" type="button">
      {{ section.settings.continue_label | default: 'Continue Shopping' }}
    </button>
  </div>

</div>

{%- comment -%} ===== MOBILE MENU ===== {%- endcomment -%}
<div
  class="nb-mobile-overlay-{{ section.id }}"
  id="nbMobileOverlay-{{ section.id }}"
  aria-hidden="true">
</div>

<div
  class="nb-mobile-menu-{{ section.id }}"
  id="nbMobileMenu-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
  aria-hidden="true">
  <div class="nb-mobile-head-{{ section.id }}">
    <span class="nb-mobile-head-title-{{ section.id }}">{{ section.settings.mobile_menu_title | default: 'Menu' }}</span>
    <button
      class="nb-mobile-close-{{ section.id }}"
      id="nbMobileClose-{{ section.id }}"
      aria-label="Close menu"
      type="button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  {% if main_menu != blank %}
  <ul class="nb-mobile-nav-{{ section.id }}" role="menu">
    {% for link in linklists[main_menu].links %}
      <li role="none">
        {% if link.links.size > 0 %}
          <button
            class="nb-mobile-link-{{ section.id }}"
            role="menuitem"
            aria-expanded="false"
            aria-haspopup="true"
            data-nb-mobile-toggle
            type="button">
            {{ link.title }}
            <svg class="nb-mobile-arrow-{{ section.id }}" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 6l6 6-6 6"/>
            </svg>
          </button>
          <ul class="nb-mobile-sub-{{ section.id }}" role="menu">
            {% for child in link.links %}
              <li role="none">
                <a class="nb-mobile-sub-link-{{ section.id }}" href="{{ child.url }}" role="menuitem">
                  {{ child.title }}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% else %}
          <a
            class="nb-mobile-link-{{ section.id }}"
            href="{{ link.url }}"
            role="menuitem"
            {% if link.active %}aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
  {% endif %}

  <div class="nb-mobile-foot-{{ section.id }}">
    {% if section.settings.show_account %}
    <a href="{{ routes.account_url }}" class="nb-mobile-account-{{ section.id }}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      {{ section.settings.account_label | default: 'My Account' }}
    </a>
    {% endif %}
    {% if section.settings.show_cart %}
    <button
      class="nb-mobile-cart-{{ section.id }}"
      id="nbMobileCartBtn-{{ section.id }}"
      type="button"
      style="cursor:pointer;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      {{ section.settings.drawer_title | default: 'Cart' }}
    </button>
    {% endif %}
  </div>
</div>

<script>
(function () {
  'use strict';

  var SID = '{{ section.id }}';

  /* ===================== DOM REFS ===================== */
  var $drawer           = document.getElementById('nbDrawer-' + SID);
  var $drawerOverlay    = document.getElementById('nbDrawerOverlay-' + SID);
  var $drawerClose      = document.getElementById('nbDrawerClose-' + SID);
  var $drawerFoot       = document.getElementById('nbDrawerFoot-' + SID);
  var $drawerEmpty      = document.getElementById('nbDrawerEmpty-' + SID);
  var $cartItems        = document.getElementById('nbCartItems-' + SID);
  var $cartBubble       = document.getElementById('nbCartBubble-' + SID);
  var $drawerCountBadge = document.getElementById('nbDrawerCountBadge-' + SID);
  var $subtotal         = document.getElementById('nbSubtotal-' + SID);
  var $cartToggle       = document.getElementById('nbCartToggle-' + SID);
  var $continue         = document.getElementById('nbContinue-' + SID);
  var $drawerLoading    = document.getElementById('nbDrawerLoading-' + SID);
  var $mobileCartBtn    = document.getElementById('nbMobileCartBtn-' + SID);

  var $searchToggle     = document.getElementById('nbSearchToggle-' + SID);
  var $searchModal      = document.getElementById('nbSearchModal-' + SID);
  var $searchModalOverlay = document.getElementById('nbSearchModalOverlay-' + SID);
  var $searchModalInput = document.getElementById('nbSearchModalInput-' + SID);
  var $searchModalResults = document.getElementById('nbSearchModalResults-' + SID);
  var $searchModalClear = document.getElementById('nbSearchModalClear-' + SID);
  var $searchModalClose = document.getElementById('nbSearchModalClose-' + SID);

  var $hamburger        = document.getElementById('nbHamburger-' + SID);
  var $mobileMenu       = document.getElementById('nbMobileMenu-' + SID);
  var $mobileOverlay    = document.getElementById('nbMobileOverlay-' + SID);
  var $mobileClose      = document.getElementById('nbMobileClose-' + SID);

  /* ===================== STATE ===================== */
  var cartDrawerOpen   = false;
  var searchModalOpen  = false;
  var mobileMenuOpen   = false;
  var searchDebounce   = null;
  var lastSearchQuery  = '';
  var isUpdatingCart   = false;

  /* ===================== MONEY FORMAT ===================== */
  function formatMoney(cents) {
    if (typeof cents !== 'number') cents = parseInt(cents) || 0;
    return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  /* =====================
     CART DRAWER
  ===================== */
  function openCartDrawer() {
    if (cartDrawerOpen) return;
    cartDrawerOpen = true;

    if ($drawer) {
      $drawer.classList.add('is-open');
      $drawer.setAttribute('aria-hidden', 'false');
    }
    if ($drawerOverlay) {
      $drawerOverlay.classList.add('is-open');
      $drawerOverlay.setAttribute('aria-hidden', 'false');
    }
    if ($cartToggle) $cartToggle.setAttribute('aria-expanded', 'true');

    document.body.style.overflow = 'hidden';
    loadCart();
  }

  function closeCartDrawer() {
    if (!cartDrawerOpen) return;
    cartDrawerOpen = false;

    if ($drawer) {
      $drawer.classList.remove('is-open');
      $drawer.setAttribute('aria-hidden', 'true');
    }
    if ($drawerOverlay) {
      $drawerOverlay.classList.remove('is-open');
      $drawerOverlay.setAttribute('aria-hidden', 'true');
    }
    if ($cartToggle) $cartToggle.setAttribute('aria-expanded', 'false');

    if (!mobileMenuOpen && !searchModalOpen) {
      document.body.style.overflow = '';
    }
  }

  /* Cart toggle button */
  if ($cartToggle) {
    $cartToggle.addEventListener('click', function (e) {
      e.stopPropagation();
      cartDrawerOpen ? closeCartDrawer() : openCartDrawer();
    });
  }

  /* Close button inside drawer */
  if ($drawerClose) {
    $drawerClose.addEventListener('click', function (e) {
      e.stopPropagation();
      closeCartDrawer();
    });
  }

  /* Overlay click */
  if ($drawerOverlay) {
    $drawerOverlay.addEventListener('click', function () {
      closeCartDrawer();
    });
  }

  /* Continue shopping */
  if ($continue) {
    $continue.addEventListener('click', function () {
      closeCartDrawer();
    });
  }

  /* Mobile cart button */
  if ($mobileCartBtn) {
    $mobileCartBtn.addEventListener('click', function () {
      closeMobileMenu();
      setTimeout(function () { openCartDrawer(); }, 100);
    });
  }

  /* =====================
     LOAD CART
  ===================== */
  function loadCart(showLoading) {
    if (showLoading && $drawerLoading) $drawerLoading.classList.add('is-active');

    var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';

    fetch(root + 'cart.js')
      .then(function (res) { return res.json(); })
      .then(function (cart) { renderCart(cart); })
      .catch(function (err) { console.error('[NavDrawer] Cart load error:', err); })
      .finally(function () {
        if ($drawerLoading) $drawerLoading.classList.remove('is-active');
      });
  }

  /* =====================
     RENDER CART
  ===================== */
  function renderCart(cart) {
    var count = cart.item_count || 0;
    var total = cart.total_price || 0;
    var items = cart.items || [];

    updateBubble(count);
    if ($drawerCountBadge) $drawerCountBadge.textContent = count;
    if ($subtotal) $subtotal.textContent = formatMoney(total);

    if (count === 0) {
      if ($drawerEmpty)  { $drawerEmpty.style.display  = 'flex'; }
      if ($cartItems)    { $cartItems.innerHTML = ''; }
      if ($drawerFoot)   { $drawerFoot.style.display = 'none'; }
    } else {
      if ($drawerEmpty)  { $drawerEmpty.style.display  = 'none'; }
      if ($drawerFoot)   { $drawerFoot.style.display = 'flex'; }
      if ($cartItems) {
        $cartItems.innerHTML = items.map(renderCartItem).join('');
        attachCartItemEvents();
      }
    }
  }

  /* =====================
     RENDER SINGLE ITEM
  ===================== */
  function renderCartItem(item) {
    var imgHTML = (item.featured_image && item.featured_image.url)
      ? '<img class="nb-item-img-' + SID + '" src="' + item.featured_image.url + '" alt="' + (item.title || '') + '" loading="lazy">'
      : '<div class="nb-item-img-' + SID + '" style="background:rgba(0,0,0,0.06)"></div>';

    var variantText = (item.variant_title && item.variant_title !== 'Default Title')
      ? '<span class="nb-item-variant-' + SID + '">' + item.variant_title + '</span>' : '';

    var vendorHTML = item.vendor
      ? '<span class="nb-item-vendor-' + SID + '">' + item.vendor + '</span>' : '';

    return '<div class="nb-cart-item-' + SID + '" data-key="' + item.key + '">' +
      '<div class="nb-item-img-wrap-' + SID + '">' +
        '<a href="' + item.url + '">' + imgHTML + '</a>' +
      '</div>' +
      '<div class="nb-item-info-' + SID + '">' +
        vendorHTML +
        '<a class="nb-item-title-' + SID + '" href="' + item.url + '">' + (item.product_title || item.title) + '</a>' +
        variantText +
        '<div class="nb-item-bottom-' + SID + '">' +
          '<span class="nb-item-price-' + SID + '">' + formatMoney(item.final_line_price) + '</span>' +
          '<div class="nb-qty-' + SID + '">' +
            '<button class="nb-qty-btn-' + SID + '" data-action="decrease" aria-label="Decrease quantity" type="button">' +
              '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>' +
            '</button>' +
            '<span class="nb-qty-num-' + SID + '">' + item.quantity + '</span>' +
            '<button class="nb-qty-btn-' + SID + '" data-action="increase" aria-label="Increase quantity" type="button">' +
              '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>' +
            '</button>' +
          '</div>' +
          '<button class="nb-item-remove-' + SID + '" aria-label="Remove item" type="button">' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
              '<polyline points="3 6 5 6 21 6"/>' +
              '<path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>' +
              '<path d="M10 11v6M14 11v6"/>' +
              '<path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/>' +
            '</svg>' +
          '</button>' +
        '</div>' +
      '</div>' +
    '</div>';
  }

  /* =====================
     CART ITEM EVENTS
  ===================== */
  function attachCartItemEvents() {
    if (!$cartItems) return;

    $cartItems.querySelectorAll('.nb-qty-btn-' + SID).forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (isUpdatingCart) return;
        var item    = this.closest('.nb-cart-item-' + SID);
        var key     = item ? item.dataset.key : null;
        var numEl   = item ? item.querySelector('.nb-qty-num-' + SID) : null;
        var action  = this.dataset.action;
        var current = numEl ? parseInt(numEl.textContent) || 1 : 1;
        var newQty  = action === 'increase' ? current + 1 : Math.max(0, current - 1);

        if (numEl) numEl.textContent = newQty;
        updateCartItem(key, newQty);
      });
    });

    $cartItems.querySelectorAll('.nb-item-remove-' + SID).forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (isUpdatingCart) return;
        var item = this.closest('.nb-cart-item-' + SID);
        var key  = item ? item.dataset.key : null;

        if (item) {
          item.style.opacity   = '0';
          item.style.transform = 'translateX(24px)';
          setTimeout(function () {
            if (item.parentNode) item.parentNode.removeChild(item);
          }, 220);
        }

        updateCartItem(key, 0);
      });
    });
  }

  /* =====================
     UPDATE CART ITEM
  ===================== */
  function updateCartItem(key, quantity) {
    if (!key) return;
    isUpdatingCart = true;
    if ($drawerLoading) $drawerLoading.classList.add('is-active');

    var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';

    fetch(root + 'cart/change.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ id: key, quantity: quantity })
    })
      .then(function (res) { return res.json(); })
      .then(function (cart) { renderCart(cart); })
      .catch(function (err) {
        console.error('[NavDrawer] Cart update error:', err);
        loadCart(false);
      })
      .finally(function () {
        isUpdatingCart = false;
        if ($drawerLoading) $drawerLoading.classList.remove('is-active');
      });
  }

  /* =====================
     BUBBLE
  ===================== */
  function updateBubble(count) {
    if (!$cartBubble) return;
    if (count > 0) {
      $cartBubble.textContent = count > 99 ? '99+' : String(count);
      $cartBubble.classList.remove('is-hidden');
      $cartBubble.classList.remove('bump');
      /* Force reflow for animation */
      void $cartBubble.offsetWidth;
      $cartBubble.classList.add('bump');
      setTimeout(function () { $cartBubble.classList.remove('bump'); }, 400);
    } else {
      $cartBubble.classList.add('is-hidden');
    }
  }

  /* =====================
     CART EVENT LISTENERS
     (ATC from other sections)
  ===================== */
  function setupCartListeners() {
    /* Horizon / standard events */
    document.addEventListener('cart:update', function (e) {
      var count = 0;
      if (e.detail) {
        count = e.detail.itemCount || (e.detail.data && e.detail.data.itemCount) || (e.detail.resource && e.detail.resource.item_count) || 0;
      }
      updateBubble(count);
      if (cartDrawerOpen) loadCart(false);
      else openCartDrawer();
    });

    window.addEventListener('cart:updated', function () {
      if (cartDrawerOpen) loadCart(false);
      else openCartDrawer();
    });

    window.addEventListener('cart:open', function () { openCartDrawer(); });
    window.addEventListener('cart-drawer:open', function () { openCartDrawer(); });

    document.addEventListener('ajaxProduct:added', function () {
      loadCart(false);
      if (!cartDrawerOpen) openCartDrawer();
    });
  }

  /* =====================
     SEARCH MODAL — OPEN / CLOSE
  ===================== */
  function openSearchModal() {
    if (searchModalOpen) return;
    searchModalOpen = true;

    if ($searchModal) {
      $searchModal.classList.add('is-open');
      $searchModal.setAttribute('aria-hidden', 'false');
    }
    if ($searchModalOverlay) {
      $searchModalOverlay.classList.add('is-open');
      $searchModalOverlay.setAttribute('aria-hidden', 'false');
    }
    if ($searchToggle) $searchToggle.setAttribute('aria-expanded', 'true');

    document.body.style.overflow = 'hidden';

    /* Focus input after transition */
    setTimeout(function () {
      if ($searchModalInput) $searchModalInput.focus();
    }, 180);
  }

  function closeSearchModal() {
    if (!searchModalOpen) return;
    searchModalOpen = false;

    if ($searchModal) {
      $searchModal.classList.remove('is-open');
      $searchModal.setAttribute('aria-hidden', 'true');
    }
    if ($searchModalOverlay) {
      $searchModalOverlay.classList.remove('is-open');
      $searchModalOverlay.setAttribute('aria-hidden', 'true');
    }
    if ($searchToggle) $searchToggle.setAttribute('aria-expanded', 'false');

    /* Reset */
    if ($searchModalInput) $searchModalInput.value = '';
    if ($searchModalClear) $searchModalClear.classList.remove('is-visible');
    clearSearchModalResults();
    lastSearchQuery = '';

    if (!cartDrawerOpen && !mobileMenuOpen) {
      document.body.style.overflow = '';
    }
  }

  function clearSearchModalResults() {
    if ($searchModalResults) {
      $searchModalResults.innerHTML = '';
      $searchModalResults.classList.remove('is-visible');
    }
  }

  if ($searchToggle) {
    $searchToggle.addEventListener('click', function (e) {
      e.stopPropagation();
      searchModalOpen ? closeSearchModal() : openSearchModal();
    });
  }

  if ($searchModalClose) {
    $searchModalClose.addEventListener('click', function () {
      closeSearchModal();
    });
  }

  if ($searchModalOverlay) {
    $searchModalOverlay.addEventListener('click', function () {
      closeSearchModal();
    });
  }

  if ($searchModalClear) {
    $searchModalClear.addEventListener('click', function () {
      if ($searchModalInput) {
        $searchModalInput.value = '';
        $searchModalInput.focus();
      }
      $searchModalClear.classList.remove('is-visible');
      clearSearchModalResults();
      lastSearchQuery = '';
    });
  }

  /* =====================
     SEARCH — REAL TIME (Predictive API)
  ===================== */
  if ($searchModalInput) {
    $searchModalInput.addEventListener('input', function () {
      var query = this.value.trim();

      if ($searchModalClear) {
        query.length > 0
          ? $searchModalClear.classList.add('is-visible')
          : $searchModalClear.classList.remove('is-visible');
      }

      clearTimeout(searchDebounce);

      if (query.length < 2) {
        clearSearchModalResults();
        lastSearchQuery = '';
        return;
      }

      if (query === lastSearchQuery) return;

      /* Show loading state */
      if ($searchModalResults) {
        $searchModalResults.innerHTML =
          '<div class="nb-search-loading-' + SID + '">' +
            '<div class="nb-search-spinner-' + SID + '"></div>' +
            'Searching...' +
          '</div>';
        $searchModalResults.classList.add('is-visible');
      }

      searchDebounce = setTimeout(function () {
        performSearch(query);
      }, 280);
    });

    /* Handle Enter key → go to search results page */
    $searchModalInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        var query = this.value.trim();
        if (query.length > 0) {
          window.location.href = '/search?q=' + encodeURIComponent(query) + '&type=product';
        }
      }
    });
  }

  /* =====================
     PERFORM SEARCH (Predictive Search API)
  ===================== */
  function performSearch(query) {
    lastSearchQuery = query;

    var url = '/search/suggest.json' +
      '?q=' + encodeURIComponent(query) +
      '&resources[type]=product,collection,article' +
      '&resources[limit]=6' +
      '&resources[options][unavailable_products]=last' +
      '&resources[options][fields]=title,product_type,variants.title,vendor,tag';

    fetch(url)
      .then(function (res) {
        if (!res.ok) throw new Error('Search API error: ' + res.status);
        return res.json();
      })
      .then(function (data) {
        /* Only render if query still matches */
        if (query !== lastSearchQuery) return;
        renderSearchResults(data, query);
      })
      .catch(function (err) {
        console.error('[NavDrawer] Search error:', err);
        if ($searchModalResults) {
          $searchModalResults.innerHTML =
            '<div class="nb-search-empty-' + SID + '">Something went wrong. Please try again.</div>';
        }
      });
  }

  /* =====================
     RENDER SEARCH RESULTS
  ===================== */
  function renderSearchResults(data, query) {
    if (!$searchModalResults) return;

    var resources = (data && data.resources && data.resources.results) ? data.resources.results : {};
    var products    = resources.products    || [];
    var collections = resources.collections || [];
    var articles    = resources.articles    || [];

    var totalResults = products.length + collections.length + articles.length;

    if (totalResults === 0) {
      $searchModalResults.innerHTML =
        '<div class="nb-search-empty-' + SID + '">' +
          'No results found for "<strong>' + escapeHtml(query) + '</strong>"' +
        '</div>';
      $searchModalResults.classList.add('is-visible');
      return;
    }

    var html = '';

    /* Products */
    if (products.length > 0) {
      if (collections.length > 0 || articles.length > 0) {
        html += '<div class="nb-search-section-label-' + SID + '">Products</div>';
      }
      products.forEach(function (product) {
        var imgHTML = (product.featured_image && product.featured_image.url)
          ? '<img class="nb-search-result-img-' + SID + '" src="' + product.featured_image.url + '" alt="' + escapeHtml(product.title) + '" loading="lazy">'
          : '<div class="nb-search-result-img-placeholder-' + SID + '">' +
              '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>' +
            '</div>';

        var priceHTML = '';
        if (product.price) {
          priceHTML = '<span class="nb-search-result-price-' + SID + '">' + formatMoney(product.price) + '</span>';
        }

        var vendorHTML = product.vendor
          ? '<p class="nb-search-result-vendor-' + SID + '">' + escapeHtml(product.vendor) + '</p>' : '';

        html += '<a class="nb-search-result-item-' + SID + '" href="' + product.url + '">' +
          imgHTML +
          '<div class="nb-search-result-info-' + SID + '">' +
            vendorHTML +
            '<p class="nb-search-result-title-' + SID + '">' + escapeHtml(product.title) + '</p>' +
            priceHTML +
          '</div>' +
        '</a>';
      });
    }

    /* Collections */
    if (collections.length > 0) {
      html += '<div class="nb-search-section-label-' + SID + '">Collections</div>';
      collections.forEach(function (col) {
        var imgHTML = (col.featured_image && col.featured_image.url)
          ? '<img class="nb-search-result-img-' + SID + '" src="' + col.featured_image.url + '" alt="' + escapeHtml(col.title) + '" loading="lazy">'
          : '<div class="nb-search-result-img-placeholder-' + SID + '">' +
              '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>' +
            '</div>';

        html += '<a class="nb-search-result-item-' + SID + '" href="' + col.url + '">' +
          imgHTML +
          '<div class="nb-search-result-info-' + SID + '">' +
            '<p class="nb-search-result-title-' + SID + '">' + escapeHtml(col.title) + '</p>' +
          '</div>' +
        '</a>';
      });
    }

    /* Articles */
    if (articles.length > 0) {
      html += '<div class="nb-search-section-label-' + SID + '">Articles</div>';
      articles.forEach(function (article) {
        var imgHTML = (article.image && article.image.url)
          ? '<img class="nb-search-result-img-' + SID + '" src="' + article.image.url + '" alt="' + escapeHtml(article.title) + '" loading="lazy">'
          : '<div class="nb-search-result-img-placeholder-' + SID + '">' +
              '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>' +
            '</div>';

        html += '<a class="nb-search-result-item-' + SID + '" href="' + article.url + '">' +
          imgHTML +
          '<div class="nb-search-result-info-' + SID + '">' +
            '<p class="nb-search-result-title-' + SID + '">' + escapeHtml(article.title) + '</p>' +
          '</div>' +
        '</a>';
      });
    }

    /* View all link */
    html += '<a class="nb-search-view-all-' + SID + '" href="/search?q=' + encodeURIComponent(query) + '&type=product">' +
      'View all results for "' + escapeHtml(query) + '"' +
      '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>' +
    '</a>';

    $searchModalResults.innerHTML = html;
    $searchModalResults.classList.add('is-visible');
  }

  /* =====================
     ESCAPE HTML HELPER
  ===================== */
  function escapeHtml(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  /* =====================
     DESKTOP MENU DROPDOWNS
  ===================== */
  var $navbar = document.getElementById('nb-' + SID);

  if ($navbar) {
    $navbar.querySelectorAll('[data-nb-menu-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var item   = this.closest('.nb-menu-item-' + SID);
        var isOpen = item ? item.classList.contains('is-open') : false;

        /* Close all */
        $navbar.querySelectorAll('.nb-menu-item-' + SID).forEach(function (i) {
          i.classList.remove('is-open');
          var t = i.querySelector('[data-nb-menu-toggle]');
          if (t) t.setAttribute('aria-expanded', 'false');
        });

        if (!isOpen && item) {
          item.classList.add('is-open');
          this.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  /* Close dropdown on outside click */
  document.addEventListener('click', function (e) {
    if ($navbar && !e.target.closest('.nb-menu-item-' + SID)) {
      $navbar.querySelectorAll('.nb-menu-item-' + SID).forEach(function (i) {
        i.classList.remove('is-open');
        var t = i.querySelector('[data-nb-menu-toggle]');
        if (t) t.setAttribute('aria-expanded', 'false');
      });
    }
  });

  /* =====================
     MOBILE MENU
  ===================== */
  function openMobileMenu() {
    if (mobileMenuOpen) return;
    mobileMenuOpen = true;
    if ($mobileMenu) {
      $mobileMenu.classList.add('is-open');
      $mobileMenu.setAttribute('aria-hidden', 'false');
    }
    if ($mobileOverlay) {
      $mobileOverlay.classList.add('is-open');
      $mobileOverlay.setAttribute('aria-hidden', 'false');
    }
    if ($hamburger) {
      $hamburger.classList.add('is-open');
      $hamburger.setAttribute('aria-expanded', 'true');
    }
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    if (!mobileMenuOpen) return;
    mobileMenuOpen = false;
    if ($mobileMenu) {
      $mobileMenu.classList.remove('is-open');
      $mobileMenu.setAttribute('aria-hidden', 'true');
    }
    if ($mobileOverlay) {
      $mobileOverlay.classList.remove('is-open');
      $mobileOverlay.setAttribute('aria-hidden', 'true');
    }
    if ($hamburger) {
      $hamburger.classList.remove('is-open');
      $hamburger.setAttribute('aria-expanded', 'false');
    }
    if (!cartDrawerOpen && !searchModalOpen) {
      document.body.style.overflow = '';
    }
  }

  if ($hamburger) {
    $hamburger.addEventListener('click', function (e) {
      e.stopPropagation();
      mobileMenuOpen ? closeMobileMenu() : openMobileMenu();
    });
  }

  if ($mobileClose)   { $mobileClose.addEventListener('click',   function () { closeMobileMenu(); }); }
  if ($mobileOverlay) { $mobileOverlay.addEventListener('click', function () { closeMobileMenu(); }); }

  /* Mobile submenu toggles */
  if ($mobileMenu) {
    $mobileMenu.querySelectorAll('[data-nb-mobile-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var sub    = this.nextElementSibling;
        var isOpen = sub && sub.classList.contains('is-open');

        /* Close all submenus */
        if ($mobileMenu) {
          $mobileMenu.querySelectorAll('.nb-mobile-sub-' + SID).forEach(function (s) {
            s.classList.remove('is-open');
          });
          $mobileMenu.querySelectorAll('[data-nb-mobile-toggle]').forEach(function (b) {
            b.classList.remove('is-open');
            b.setAttribute('aria-expanded', 'false');
          });
        }

        if (!isOpen && sub) {
          sub.classList.add('is-open');
          this.classList.add('is-open');
          this.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  /* =====================
     ESC KEY — close everything
  ===================== */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      if (searchModalOpen) { closeSearchModal(); return; }
      if (cartDrawerOpen)  { closeCartDrawer();  return; }
      if (mobileMenuOpen)  { closeMobileMenu();  return; }
    }
  });

  /* =====================
     INIT — LOAD CART COUNT (NO DRAWER OPEN)
  ===================== */
  function initCartCount() {
    var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    fetch(root + 'cart.js')
      .then(function (res) { return res.json(); })
      .then(function (cart) { updateBubble(cart.item_count || 0); })
      .catch(function (err) { console.error('[NavDrawer] Init cart count error:', err); });
  }

  /* =====================
     STICKY NAVBAR (JS SCROLL HANDLER)
  ===================== */
  function initStickyNavbar() {
    var navPosition = '{{ section.settings.nav_position }}';
    if (navPosition === 'static') return;

    var $nav = document.getElementById('nb-' + SID);
    var $spacer = document.getElementById('nbStickySpacer-' + SID);
    if (!$nav) return;

    var navHeight = $nav.offsetHeight;
    var isFixed = false;
    var ticking = false;

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () {
        var scrollY = window.pageYOffset || document.documentElement.scrollTop;
        if (scrollY > navHeight && !isFixed) {
          isFixed = true;
          $nav.classList.add('nb-is-fixed');
          if ($spacer) {
            $spacer.style.height = navHeight + 'px';
            $spacer.classList.add('nb-spacer-active');
          }
        } else if (scrollY <= navHeight && isFixed) {
          isFixed = false;
          $nav.classList.remove('nb-is-fixed');
          if ($spacer) {
            $spacer.classList.remove('nb-spacer-active');
          }
        }
        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', function () {
      navHeight = $nav.offsetHeight;
    }, { passive: true });
  }

  /* =====================
     STARTUP
  ===================== */
  setupCartListeners();
  initCartCount();
  initStickyNavbar();

})();
</script>

