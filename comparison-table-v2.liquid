{%- style -%}
  /* Desktop Styles */
  #shopify-section-{{ section.id }} .nb-comp {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_sides_desktop }}px;
    padding-right: {{ section.settings.padding_sides_desktop }}px;
  }
  #shopify-section-{{ section.id }} .nb-comp-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .nb-comp-head {
    text-align: {{ section.settings.head_alignment_desktop }};
    margin-bottom: {{ section.settings.head_margin_bottom_desktop }}px;
  }
  #shopify-section-{{ section.id }} .nb-comp-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border: {{ section.settings.badge_border_width }}px {{ section.settings.badge_border_style }} {{ section.settings.badge_border_color }};
    background-color: {{ section.settings.badge_bg_color }};
    border-radius: {{ section.settings.badge_border_radius }}px;
    padding: {{ section.settings.badge_padding_top_bottom }}px {{ section.settings.badge_padding_left_right }}px;
    margin-bottom: {{ section.settings.badge_margin_bottom }}px;
  }
  #shopify-section-{{ section.id }} .nb-comp-badge span:first-child {
    width: {{ section.settings.badge_dot_size }}px;
    height: {{ section.settings.badge_dot_size }}px;
    border-radius: 50%;
    background-color: {{ section.settings.badge_text_color }};
    {% unless section.settings.show_badge_dot %}display: none;{% endunless %}
  }
  #shopify-section-{{ section.id }} .nb-comp-badge span:last-child {
    font-size: {{ section.settings.badge_font_size_desktop | divided_by: 100.0 }}rem;
    letter-spacing: {{ section.settings.badge_letter_spacing }}em;
    text-transform: {{ section.settings.badge_text_transform }};
    color: {{ section.settings.badge_text_color }};
  }
  #shopify-section-{{ section.id }} .nb-comp-title {
    font-size: {{ section.settings.title_font_size_desktop | divided_by: 10.0 }}rem;
    line-height: {{ section.settings.title_line_height }};
    margin: 0;
    color: {{ section.settings.title_color }};
  }
  #shopify-section-{{ section.id }} .nb-comp-title .accent {
    background: linear-gradient(to right, {{ section.settings.accent_gradient_start }}, {{ section.settings.accent_gradient_end }});
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  #shopify-section-{{ section.id }} .nb-comp-table {
    background-color: {{ section.settings.table_bg_color }};
    border: {{ section.settings.table_border_width }}px {{ section.settings.table_border_style }} {{ section.settings.table_border_color }};
    border-radius: {{ section.settings.table_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 20px 25px rgba(0,0,0,{{ section.settings.table_shadow_opacity }});
  }
  #shopify-section-{{ section.id }} .nb-comp-row {
    display: grid;
    grid-template-columns: {{ section.settings.col_1_width_desktop }}fr {{ section.settings.col_2_width_desktop }}fr {{ section.settings.col_3_width_desktop }}fr;
    align-items: center;
    padding: {{ section.settings.row_padding_vertical_desktop }}px {{ section.settings.row_padding_horizontal_desktop }}px;
    border-bottom: {{ section.settings.row_border_width }}px {{ section.settings.row_border_style }} {{ section.settings.row_border_color }};
    font-size: {{ section.settings.row_font_size_desktop | divided_by: 100.0 }}rem;
  }
  #shopify-section-{{ section.id }} .nb-comp-row:last-child {
    border-bottom: none;
  }
  #shopify-section-{{ section.id }} .nb-comp-header {
    background: linear-gradient(to right, {{ section.settings.header_gradient_start }}, {{ section.settings.header_gradient_end }});
    padding-top: {{ section.settings.header_padding_vertical_desktop }}px;
    padding-bottom: {{ section.settings.header_padding_vertical_desktop }}px;
    font-weight: 600;
  }
  #shopify-section-{{ section.id }} .nb-comp-header .ninja {
    color: {{ section.settings.brand_column_color }};
    font-size: {{ section.settings.header_brand_font_size_desktop | divided_by: 100.0 }}rem;
  }
  #shopify-section-{{ section.id }} .nb-comp-header .others {
    color: {{ section.settings.competitor_column_color }};
    font-size: {{ section.settings.header_competitor_font_size_desktop | divided_by: 100.0 }}rem;
  }
  #shopify-section-{{ section.id }} .nb-comp-feature {
    font-weight: {{ section.settings.feature_font_weight }};
    color: {{ section.settings.feature_text_color }};
  }
  #shopify-section-{{ section.id }} .nb-comp-cell {
    text-align: center;
  }
  #shopify-section-{{ section.id }} .nb-yes {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.icon_size_desktop }}px;
    height: {{ section.settings.icon_size_desktop }}px;
    border-radius: {{ section.settings.icon_border_radius }}%;
    background: linear-gradient(135deg, {{ section.settings.yes_bg_gradient_start }}, {{ section.settings.yes_bg_gradient_end }});
    color: {{ section.settings.yes_icon_color }};
    font-weight: 700;
    box-shadow: 0 4px 14px rgba(0,82,255,0.25);
  }
  #shopify-section-{{ section.id }} .nb-no {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.icon_size_desktop }}px;
    height: {{ section.settings.icon_size_desktop }}px;
    border-radius: {{ section.settings.icon_border_radius }}%;
    background-color: {{ section.settings.no_bg_color }};
    color: {{ section.settings.no_icon_color }};
    font-weight: 700;
  }
  #shopify-section-{{ section.id }} .nb-comp-value-good {
    color: {{ section.settings.value_good_color }};
    font-weight: 600;
    font-size: {{ section.settings.values_font_size_desktop | divided_by: 100.0 }}rem;
  }
  #shopify-section-{{ section.id }} .nb-comp-value-bad {
    color: {{ section.settings.value_bad_color }};
    font-size: {{ section.settings.values_font_size_desktop | divided_by: 100.0 }}rem;
  }
  #shopify-section-{{ section.id }} .nb-comp-img {
    width: {{ section.settings.row_img_width_desktop }}px;
    height: {{ section.settings.row_img_height_desktop }}px;
    object-fit: {{ section.settings.row_img_object_fit }};
    border-radius: {{ section.settings.row_img_radius }}px;
  }

  /* Mobile Breakpoint Modifications */
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .nb-comp {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_sides_mobile }}px;
      padding-right: {{ section.settings.padding_sides_mobile }}px;
    }
    #shopify-section-{{ section.id }} .nb-comp-head {
      text-align: {{ section.settings.head_alignment_mobile }};
      margin-bottom: {{ section.settings.head_margin_bottom_mobile }}px;
    }
    #shopify-section-{{ section.id }} .nb-comp-badge span:last-child {
      font-size: {{ section.settings.badge_font_size_mobile | divided_by: 100.0 }}rem;
    }
    #shopify-section-{{ section.id }} .nb-comp-title {
      font-size: {{ section.settings.title_font_size_mobile | divided_by: 10.0 }}rem;
    }
    #shopify-section-{{ section.id }} .nb-comp-row {
      grid-template-columns: {{ section.settings.col_1_width_mobile }}fr {{ section.settings.col_2_width_mobile }}fr {{ section.settings.col_3_width_mobile }}fr;
      padding: {{ section.settings.row_padding_vertical_mobile }}px {{ section.settings.row_padding_horizontal_mobile }}px;
      font-size: {{ section.settings.row_font_size_mobile | divided_by: 100.0 }}rem;
    }
    #shopify-section-{{ section.id }} .nb-comp-header {
      padding-top: {{ section.settings.header_padding_vertical_mobile }}px;
      padding-bottom: {{ section.settings.header_padding_vertical_mobile }}px;
    }
    #shopify-section-{{ section.id }} .nb-comp-header .ninja {
      font-size: {{ section.settings.header_brand_font_size_mobile | divided_by: 100.0 }}rem;
    }
    #shopify-section-{{ section.id }} .nb-comp-header .others {
      font-size: {{ section.settings.header_competitor_font_size_mobile | divided_by: 100.0 }}rem;
    }
    #shopify-section-{{ section.id }} .nb-yes, #shopify-section-{{ section.id }} .nb-no {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
    }
    #shopify-section-{{ section.id }} .nb-comp-value-good, #shopify-section-{{ section.id }} .nb-comp-value-bad {
      font-size: {{ section.settings.values_font_size_mobile | divided_by: 100.0 }}rem;
    }
    #shopify-section-{{ section.id }} .nb-comp-img {
      width: {{ section.settings.row_img_width_mobile }}px;
      height: {{ section.settings.row_img_height_mobile }}px;
    }
  }
{%- endstyle -%}

<section class="nb-comp">
  <div class="nb-comp-inner">
    <div class="nb-comp-head">
      {%- if section.settings.badge_text != blank -%}
        <div class="nb-comp-badge">
          <span></span>
          <span>{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="nb-comp-title">
          {{ section.settings.title | replace: '[', '<span class="accent">' | replace: ']', '</span>' }}
        </h2>
      {%- endif -%}
    </div>

    <div class="nb-comp-table">
      <!-- Table Header Row -->
      <div class="nb-comp-row nb-comp-header">
        <div class="nb-comp-feature">{{ section.settings.header_feature_label }}</div>
        <div class="nb-comp-cell ninja">{{ section.settings.header_brand_label }}</div>
        <div class="nb-comp-cell others">{{ section.settings.header_competitor_label }}</div>
      </div>

      <!-- Content Rows -->
      {%- for block in section.blocks -%}
        <div class="nb-comp-row" {{ block.shopify_attributes }}>
          <!-- Feature Name / Optional Image -->
          <div class="nb-comp-feature">
            {%- if block.settings.feature_image != blank -%}
              <img
                src="{{ block.settings.feature_image | image_url: width: 300 }}"
                alt="{{ block.settings.feature_image.alt | escape }}"
                class="nb-comp-img"
                loading="lazy"
                width="{{ block.settings.feature_image.width }}"
                height="{{ block.settings.feature_image.height }}"
              >
            {%- endif -%}
            <div>{{ block.settings.feature_title }}</div>
          </div>

          <!-- Brand Value Cell -->
          <div class="nb-comp-cell">
            {%- if block.settings.brand_type == 'boolean' -%}
              {%- if block.settings.brand_bool == true -%}
                <span class="nb-yes">✓</span>
              {%- else -%}
                <span class="nb-no">✕</span>
              {%- endif -%}
            {%- else -%}
              <span class="nb-comp-value-good">{{ block.settings.brand_text }}</span>
            {%- endif -%}
          </div>

          <!-- Competitor Value Cell -->
          <div class="nb-comp-cell">
            {%- if block.settings.comp_type == 'boolean' -%}
              {%- if block.settings.comp_bool == true -%}
                <span class="nb-yes">✓</span>
              {%- else -%}
                <span class="nb-no">✕</span>
              {%- endif -%}
            {%- else -%}
              <span class="nb-comp-value-bad">{{ block.settings.comp_text }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

