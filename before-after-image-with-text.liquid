{%- style -%}
  #section-{{ section.id }} {
    background-color: {{ section.settings.color_bg }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_right }}px {{ section.settings.padding_bottom }}px {{ section.settings.padding_left }}px;
    overflow: hidden;
  }

  .showcase-container {
    margin: 0 auto;
    {% if section.settings.max_width == 'theme' %}
      max-width: 1570px;
    {% elsif section.settings.max_width == 'full' %}
      max-width: 100%;
    {% else %}
      max-width: {{ section.settings.custom_width }}px;
    {% endif %}
    padding: 0 20px;
  }

  .showcase-wrap {
    display: flex;
    flex-direction: row;
    /* FIX: Force equal height for text and slider blocks */
    align-items: stretch; 
    justify-content: space-between;
    gap: 60px;
  }

  /* --- SCROLL REVEAL ANIMATIONS --- */
  .reveal-item {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s ease, transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* --- LEFT CONTENT BLOCK --- */
  .showcase-text {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .section-label {
    color: {{ section.settings.color_accent }};
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 18px;
    margin-bottom: 12px;
    display: block;
  }

  #section-{{ section.id }} .section-title  {
    color: {{ section.settings.color_heading }};
    font-family: var(--font-heading-family);
    font-size: 40px;
    line-height: 1.1;
    margin: 0 !important;
  }

  #section-{{ section.id }} .section-title em {
    font-style: italic;
    color: {{ section.settings.color_accent }};
  }

  .divider {
    width: 45px;
    height: 1px;
    background: {{ section.settings.color_accent }};
    margin: 20px 0;
  }

  .section-sub {
    color: {{ section.settings.color_body }};
    font-size: {{ section.settings.subheading_size }}px;
    line-height: 1.6;
    margin-bottom: 35px;
    opacity: 0.85;
  }

  /* --- FEATURE CARDS --- */
  .showcase-features {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .sf-item {
    background: {{ section.settings.color_box_bg }};
    padding: {{ section.settings.box_padding }}px;
    display: flex;
    align-items: center;
    gap: 20px;
    border: 1px solid transparent;
    transition: all 0.4s ease;
    cursor: pointer;
  }

  .sf-item:hover {
    transform: translateX(10px);
    border-color: {{ section.settings.color_accent }};
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .sf-num {
    color: {{ section.settings.color_accent }};
    font-family: serif;
    font-size: 14px;
    font-weight: bold;
    opacity: 0.6;
  }

  .sf-text h4 {
    color: {{ section.settings.color_box_title }};
    font-size: {{ section.settings.body_title_size }}px;
    margin: 0;
    font-weight: 600;
  }

  .sf-text p {
    color: {{ section.settings.color_body }};
    font-size: {{ section.settings.body_text_size }}px;
    margin: 4px 0 0 0;
    opacity: 0.7;
  }

  /* --- SLIDER BLOCK (RIGHT) --- */
  .showcase-slider-column {
    flex: 0 0 50%;
    display: flex; /* Allows ba-container to fill the height of the column */
  }

  .ba-container {
    position: relative;
    width: 100%;
    height: 100%; /* Matches the height of the left block */
    min-height: 500px;
    overflow: hidden;
    border-radius: 4px;
    cursor: ew-resize;
    user-select: none;
    /* background: #f1f1f1;
    box-shadow: 0 20px 60px rgba(0,0,0,0.1); */
  }

  .ba-image-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .ba-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba-before {
    z-index: 2;
    width: 50%;
    overflow: hidden;
    will-change: width;
    border-right: 1.5px solid {{ section.settings.color_accent }};
  }

  .ba-before-img {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    max-width: none;
    object-fit: cover;
  }

  /* --- UPDATED GOLD SLIDER HANDLE WITH SVG --- */
  .ba-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    background: {{ section.settings.color_accent }};
    z-index: 3;
    pointer-events: none;
    will-change: left;
  }

  .ba-handle-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    background: {{ section.settings.color_accent }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.25);
    border: 2px solid rgba(255,255,255,0.2);
  }

  .ba-handle-circle svg {
    width: 24px;
    height: 24px;
    fill: #1a1a1a; /* Dark arrows for high contrast on gold */
  }

  .ba-labels {
    position: absolute;
    bottom: 25px;
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 25px;
    z-index: 4;
    pointer-events: none;
  }

  .ba-label {
    background: rgba(0,0,0,0.65);
    color: white;
    padding: 6px 14px;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    backdrop-filter: blur(5px);
    border-radius: 2px;
  }

  @media (max-width: 990px) {
    .showcase-wrap {
      flex-direction: column;
      height: auto;
      gap: 5px;
    }
    .showcase-text, .showcase-slider-column {
      flex: 0 0 100%;
      width: 100%;
    }
    .ba-container {
       min-height: 400px;
       height: auto;
       aspect-ratio: 1 / 1;
    }
    .section-title { font-size: 30px !important; }
    .section-label { font-size: 16px; line-height: 1.6;}
  }
{%- endstyle -%}

<section id="section-{{ section.id }}">
  <div class="showcase-container">
    <div class="showcase-wrap">
      
      <div class="showcase-text reveal-item">
        <span class="section-label">{{ section.settings.label }}</span>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <span class="divider"></span>
        <div class="section-sub">{{ section.settings.subheading }}</div>
        
        <div class="showcase-features">
          {% for block in section.blocks %}
            <div class="sf-item reveal-item" style="transition-delay: {{ forloop.index | times: 100 }}ms;">
              <div class="sf-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
              <div class="sf-text">
                <h4>{{ block.settings.title }}</h4>
                <p>{{ block.settings.text }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="showcase-slider-column reveal-item">
        <div class="ba-container" id="ba-cnt-{{ section.id }}">
          <div class="ba-image-layer">
            {% if section.settings.image_after %}
              <img src="{{ section.settings.image_after | image_url: width: 1400 }}" class="ba-image" alt="After">
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'ba-image' }}
            {% endif %}
          </div>
          
          <div class="ba-image-layer ba-before" id="ba-before-{{ section.id }}">
             {% if section.settings.image_before %}
                <img src="{{ section.settings.image_before | image_url: width: 1400 }}" class="ba-image ba-before-img" id="ba-img-{{ section.id }}" alt="Before">
             {% else %}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'ba-image ba-before-img' }}
             {% endif %}
          </div>

          <div class="ba-handle" id="ba-handle-{{ section.id }}">
            <div class="ba-handle-circle">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 8L4 12L8 16V8Z" />
                <path d="M16 8L20 12L16 16V8Z" />
              </svg>
            </div>
          </div>

          <div class="ba-labels">
            <div class="ba-label">{{ section.settings.label_before }}</div>
            <div class="ba-label">{{ section.settings.label_after }}</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const container = document.getElementById('ba-cnt-{{ section.id }}');
  const beforeLayer = document.getElementById('ba-before-{{ section.id }}');
  const beforeImg = document.getElementById('ba-img-{{ section.id }}');
  const handle = document.getElementById('ba-handle-{{ section.id }}');
  
  let isDragging = false;
  let targetPercent = 50;
  let currentPercent = 50;

  // --- Scroll Animation Trigger ---
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal-item').forEach(item => observer.observe(item));

  // --- Slider Logic ---
  function syncImageSize() {
    if(beforeImg && container) {
      beforeImg.style.width = container.offsetWidth + 'px';
      beforeImg.style.height = container.offsetHeight + 'px';
    }
  }

  function lerp() {
    currentPercent += (targetPercent - currentPercent) * 0.1;
    beforeLayer.style.width = currentPercent + '%';
    handle.style.left = currentPercent + '%';
    if (Math.abs(targetPercent - currentPercent) > 0.001) requestAnimationFrame(lerp);
  }

  function handleInput(e) {
    if (!isDragging) return;
    const rect = container.getBoundingClientRect();
    const x = (e.clientX || (e.touches && e.touches[0].clientX)) - rect.left;
    targetPercent = Math.max(0, Math.min(100, (x / rect.width) * 100));
    requestAnimationFrame(lerp);
  }

  container.addEventListener('mousedown', () => isDragging = true);
  window.addEventListener('mouseup', () => isDragging = false);
  window.addEventListener('mousemove', handleInput);
  container.addEventListener('touchstart', () => isDragging = true, {passive: true});
  window.addEventListener('touchend', () => isDragging = false);
  window.addEventListener('touchmove', handleInput, {passive: true});

  window.addEventListener('resize', syncImageSize);
  window.onload = syncImageSize;
  syncImageSize();
  requestAnimationFrame(lerp);
});
</script>

{% schema %}
{
  "name": "Before/After Slider",
  "settings": [
    { "type": "image_picker", "id": "image_before", "label": "Before Image" },
    { "type": "image_picker", "id": "image_after", "label": "After Image" },
    { "type": "text", "id": "label_before", "label": "Left Label", "default": "Plain Board" },
    { "type": "text", "id": "label_after", "label": "Right Label", "default": "Engraved" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "color_bg", "label": "Background", "default": "#f4ede4" },
    { "type": "color", "id": "color_heading", "label": "Heading", "default": "#1a1a1a" },
    { "type": "color", "id": "color_body", "label": "Body Text", "default": "#4a4a4a" },
    { "type": "color", "id": "color_accent", "label": "Gold Accent", "default": "#c5a059" },
    { "type": "color", "id": "color_box_bg", "label": "Card Background", "default": "#fcfaf7" },
    { "type": "color", "id": "color_box_title", "label": "Card Title", "default": "#1a1a1a" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "max_width", "label": "Width", "options": [
        { "value": "theme", "label": "Theme Default" },
        { "value": "full", "label": "Full" },
        { "value": "custom", "label": "Custom" }
      ], "default": "theme" 
    },
    { "type": "range", "id": "custom_width", "label": "Custom Max Width", "min": 1000, "max": 2000, "step": 10, "default": 1400 },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 200, "step": 5, "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 200, "step": 5, "default": 100 },
    { "type": "range", "id": "padding_left", "label": "Left Padding", "min": 0, "max": 100, "step": 5, "default": 0 },
    { "type": "range", "id": "padding_right", "label": "Right Padding", "min": 0, "max": 100, "step": 5, "default": 0 },
    { "type": "range", "id": "box_padding", "label": "Card Padding", "min": 10, "max": 60, "step": 2, "default": 26 },
    { "type": "header", "content": "Typography" },
    { "type": "text", "id": "label", "label": "Section Label", "default": "Customization Showcase" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "From Raw Wood <br>to <em>Heirloom Gift</em>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Drag the slider to see the transformation." },
    { "type": "range", "id": "heading_size", "label": "Heading Size", "min": 24, "max": 80, "step": 2, "default": 48 },
    { "type": "range", "id": "subheading_size", "label": "Sub Size", "min": 14, "max": 30, "step": 1, "default": 18 },
    { "type": "range", "id": "body_title_size", "label": "Card Title Size", "min": 14, "max": 30, "step": 1, "default": 18 },
    { "type": "range", "id": "body_text_size", "label": "Card Text Size", "min": 12, "max": 20, "step": 1, "default": 14 },
    { "type": "range", "id": "heading_size_mobile", "label": "Mobile Heading Size", "min": 20, "max": 60, "step": 2, "default": 36 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Family Name Engraving" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Elegant serif typography, laser-precision depth" }
      ]
    }
  ],
  "presets": [
    { "name": "Before/After Slider" }
  ]
}
{% endschema %}