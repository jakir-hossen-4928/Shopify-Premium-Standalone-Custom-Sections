{%- style -%}
  :root {
    /* Layout */
    --pts-max-width: {{ section.settings.max_width }}px;
    --pts-section-bg: {{ section.settings.section_bg_color }};
    --pts-container-bg: {{ section.settings.container_bg_color }};
    --pts-section-radius: {{ section.settings.section_border_radius }}px;
    --pts-primary: {{ section.settings.primary_color }};

    /* Section Padding - Desktop */
    --pts-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --pts-pad-bot-d: {{ section.settings.padding_bottom_desktop }}px;

    /* Section Padding - Tablet */
    --pts-pad-top-t: {{ section.settings.padding_top_tablet }}px;
    --pts-pad-bot-t: {{ section.settings.padding_bottom_tablet }}px;

    /* Section Padding - Mobile */
    --pts-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --pts-pad-bot-m: {{ section.settings.padding_bottom_mobile }}px;

    /* Header Block */
    --pts-header-mb: {{ section.settings.header_margin_bottom }}px;
    --pts-header-align: {{ section.settings.header_alignment }};

    /* Heading */
    --pts-h-size-d: {{ section.settings.heading_size_desktop }}px;
    --pts-h-size-m: {{ section.settings.heading_size_mobile }}px;
    --pts-h-weight: {{ section.settings.heading_weight }};
    --pts-h-color: {{ section.settings.heading_color }};
    --pts-h-ls: {{ section.settings.heading_letter_spacing }}em;
    --pts-h-lh: {{ section.settings.heading_line_height }};
    --pts-h-mb: {{ section.settings.heading_margin_bottom }}px;
    --pts-h-transform: {{ section.settings.heading_transform }};

    /* Description */
    --pts-d-size-d: {{ section.settings.desc_size_desktop }}px;
    --pts-d-size-m: {{ section.settings.desc_size_mobile }}px;
    --pts-d-color: {{ section.settings.desc_color }};
    --pts-d-lh: {{ section.settings.desc_line_height }};
    --pts-d-mw: {{ section.settings.desc_max_width }}%;
    --pts-d-align: {{ section.settings.desc_alignment }};
    --pts-d-mb: {{ section.settings.desc_margin_bottom }}px;

    /* Left Image */
    --pts-img-w-d: {{ section.settings.image_width_desktop }}px;
    --pts-img-w-m: {{ section.settings.image_width_mobile }}px;
    --pts-img-h-d: {{ section.settings.image_height_desktop }}px;
    --pts-img-h-m: {{ section.settings.image_height_mobile }}px;
    --pts-img-aspect: {{ section.settings.image_aspect_ratio }};
    --pts-img-fit: {{ section.settings.image_object_fit }};
    --pts-img-radius: {{ section.settings.image_border_radius }}px;
    --pts-img-shadow: {{ section.settings.image_shadow }};
    --pts-img-overlay: {{ section.settings.image_overlay_color }};
    --pts-img-overlay-opacity: {{ section.settings.image_overlay_opacity }};

    /* Grid */
    --pts-grid-gap-d: {{ section.settings.grid_gap_desktop }}px;
    --pts-grid-gap-t: {{ section.settings.grid_gap_tablet }}px;
    --pts-grid-gap-m: {{ section.settings.grid_gap_mobile }}px;

    /* Carousel */
    --pts-car-height-d: {{ section.settings.carousel_height_desktop }}px;
    --pts-car-height-t: {{ section.settings.carousel_height_tablet }}px;
    --pts-car-height-m: {{ section.settings.carousel_height_mobile }}px;
    --pts-car-gap: {{ section.settings.card_gap }}px;
    --pts-car-pad: {{ section.settings.carousel_padding }}px;

    /* Review Card */
    --pts-card-bg: {{ section.settings.card_bg_color }};
    --pts-card-bw: {{ section.settings.card_border_width }}px;
    --pts-card-bs: {{ section.settings.card_border_style }};
    --pts-card-bc: {{ section.settings.card_border_color }};
    --pts-card-radius: {{ section.settings.card_border_radius }}px;
    --pts-card-pad-d: {{ section.settings.card_padding_desktop }}px;
    --pts-card-pad-m: {{ section.settings.card_padding_mobile }}px;
    --pts-card-shadow: {{ section.settings.card_shadow }};
    --pts-card-hover-shadow: {{ section.settings.card_hover_shadow }};
    --pts-card-hover-scale: {{ section.settings.card_hover_scale }};
    --pts-card-transition: {{ section.settings.card_transition }}ms;
    --pts-card-active-border: {{ section.settings.card_active_border_color }};

    /* Review Title */
    --pts-rt-size-d: {{ section.settings.review_title_size_desktop }}px;
    --pts-rt-size-m: {{ section.settings.review_title_size_mobile }}px;
    --pts-rt-color: {{ section.settings.review_title_color }};
    --pts-rt-weight: {{ section.settings.review_title_weight }};
    --pts-rt-transform: {{ section.settings.review_title_transform }};
    --pts-rt-mb: {{ section.settings.review_title_margin_bottom }}px;

    /* Review Text */
    --pts-rtx-size-d: {{ section.settings.review_text_size_desktop }}px;
    --pts-rtx-size-m: {{ section.settings.review_text_size_mobile }}px;
    --pts-rtx-color: {{ section.settings.review_text_color }};
    --pts-rtx-lh: {{ section.settings.review_text_line_height }};
    --pts-rtx-weight: {{ section.settings.review_text_weight }};
    --pts-rtx-mb: {{ section.settings.review_text_margin_bottom }}px;

    /* Customer Name */
    --pts-name-size-d: {{ section.settings.name_size_desktop }}px;
    --pts-name-size-m: {{ section.settings.name_size_mobile }}px;
    --pts-name-color: {{ section.settings.name_color }};
    --pts-name-weight: {{ section.settings.name_weight }};
    --pts-name-transform: {{ section.settings.name_transform }};

    /* Stars */
    --pts-star-size-d: {{ section.settings.star_size_desktop }}px;
    --pts-star-size-m: {{ section.settings.star_size_mobile }}px;
    --pts-star-active: {{ section.settings.star_active_color }};
    --pts-star-inactive: {{ section.settings.star_inactive_color }};
    --pts-star-gap: {{ section.settings.star_gap }}px;
    --pts-star-mb: {{ section.settings.star_margin_bottom }}px;

    /* Avatar */
    --pts-avatar-size: {{ section.settings.avatar_size }}px;
    --pts-avatar-radius: {{ section.settings.avatar_border_radius }}%;
    --pts-avatar-bw: {{ section.settings.avatar_border_width }}px;
    --pts-avatar-bc: {{ section.settings.avatar_border_color }};

    /* Dots Navigation */
    --pts-dot-size: {{ section.settings.dot_size }}px;
    --pts-dot-active-size: {{ section.settings.dot_active_size }}px;
    --pts-dot-bg: {{ section.settings.dot_color }};
    --pts-dot-active-bg: {{ section.settings.dot_active_color }};
    --pts-dot-gap: {{ section.settings.dot_gap }}px;
    --pts-dot-offset: {{ section.settings.dot_offset }}px;

    /* Mobile Dots Navigation */
    --pts-mobile-dot-size: {{ section.settings.mobile_dot_size }}px;
    --pts-mobile-dot-active-size: {{ section.settings.mobile_dot_active_size }}px;
    --pts-mobile-dot-bg: {{ section.settings.mobile_dot_color }};
    --pts-mobile-dot-active-bg: {{ section.settings.mobile_dot_active_color }};
    --pts-mobile-dot-gap: {{ section.settings.mobile_dot_gap }}px;
    --pts-mobile-dot-mt: {{ section.settings.mobile_dot_margin_top }}px;
  }

  /* ─── Base Section ─────────────────────────────────────────── */
  .pts-section {
    background-color: var(--pts-section-bg);
    padding: var(--pts-pad-top-m) 0 var(--pts-pad-bot-m);
    width: 100%;
    box-sizing: border-box;
  }

  .pts-container {
    max-width: var(--pts-max-width);
    margin: 0 auto;
    background-color: var(--pts-container-bg);
    border-radius: var(--pts-section-radius);
  }

  /* ─── Header ───────────────────────────────────────────────── */
  .pts-header {
    text-align: var(--pts-header-align);
    margin-bottom: var(--pts-header-mb);
  }

  .pts-heading {
    font-size: var(--pts-h-size-m);
    font-weight: var(--pts-h-weight);
    color: var(--pts-h-color);
    letter-spacing: var(--pts-h-ls);
    line-height: var(--pts-h-lh);
    margin: 0 0 var(--pts-h-mb) 0;
    text-transform: var(--pts-h-transform);
  }

  .pts-description {
    font-size: var(--pts-d-size-m);
    color: var(--pts-d-color);
    line-height: var(--pts-d-lh);
    max-width: var(--pts-d-mw);
    margin: 0 auto var(--pts-d-mb);
    text-align: var(--pts-d-align);
  }

  /* ─── Grid ─────────────────────────────────────────────────── */
  .pts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--pts-grid-gap-m);
    min-width: 0;
  }

  /* ─── Left Image ────────────────────────────────────────────── */
  .pts-image-block {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    min-width: 0;
  }

  .pts-image-wrapper {
    position: relative;
    width: 100%;
    height: var(--pts-img-h-m);
    aspect-ratio: var(--pts-img-aspect);
    overflow: hidden;
    border-radius: var(--pts-img-radius);
    box-shadow: var(--pts-img-shadow);
  }

  .pts-image {
    width: 100%;
    height: 100%;
    object-fit: var(--pts-img-fit);
    display: block;
  }

  .pts-image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background-color: var(--pts-img-overlay);
    opacity: var(--pts-img-overlay-opacity);
    pointer-events: none;
    border-radius: inherit;
  }

  /* ─── Carousel Column ───────────────────────────────────────── */
  .pts-carousel-block {
    width: 100%;
    box-sizing: border-box;
    position: relative;
    min-width: 0;
  }

  .pts-carousel-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  /* Desktop: Row layout with dots on right */
  @media (min-width: 1024px) {
    .pts-carousel-wrapper {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .pts-carousel {
    display: grid;
    grid-auto-flow: row;
    grid-auto-rows: auto;
    height: var(--pts-car-height-m);
    min-height: 0;
    overflow-y: auto;
    overflow-x: visible;
    scroll-snap-type: y mandatory;
    scroll-padding-top: var(--pts-car-pad);
    gap: var(--pts-car-gap);
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: var(--pts-car-pad) 4px var(--pts-car-pad) 4px;
    width: 100%;
  }

  .pts-carousel::-webkit-scrollbar { display: none; }

  /* ─── Card ──────────────────────────────────────────────────── */
  .pts-card {
    scroll-snap-align: start;
    background: var(--pts-card-bg);
    border: var(--pts-card-bw) var(--pts-card-bs) var(--pts-card-bc);
    border-radius: var(--pts-card-radius);
    padding: var(--pts-card-pad-m);
    box-shadow: var(--pts-card-shadow);
    transition: transform var(--pts-card-transition) cubic-bezier(0.2, 0, 0, 1),
                box-shadow var(--pts-card-transition) cubic-bezier(0.2, 0, 0, 1),
                border-color var(--pts-card-transition) ease;
    cursor: pointer;
    margin: 0;
    position: relative;
  }

  .pts-card:hover {
    transform: scale(var(--pts-card-hover-scale));
    box-shadow: var(--pts-card-hover-shadow);
    z-index: 2;
  }

  /* Active card: uses dashed border style from schema + active color */
  .pts-card.active {
    border-color: var(--pts-card-active-border);
    border-style: var(--pts-card-active-border-style);
    box-shadow: 0 0 0 2px var(--pts-card-active-border);
  }

  /* ─── Card Inner ────────────────────────────────────────────── */
  .pts-card-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }

  .pts-avatar {
    width: var(--pts-avatar-size);
    height: var(--pts-avatar-size);
    border-radius: var(--pts-avatar-radius);
    border: var(--pts-avatar-bw) solid var(--pts-avatar-bc);
    object-fit: cover;
    flex-shrink: 0;
  }

  .pts-avatar-placeholder {
    width: var(--pts-avatar-size);
    height: var(--pts-avatar-size);
    border-radius: var(--pts-avatar-radius);
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    flex-shrink: 0;
  }

  .pts-card-info { flex: 1; }

  .pts-stars {
    display: flex;
    gap: var(--pts-star-gap);
    margin-bottom: var(--pts-star-mb);
  }

  .pts-star {
    width: var(--pts-star-size-m);
    height: var(--pts-star-size-m);
    fill: var(--pts-star-inactive);
  }

  .pts-star.active { fill: var(--pts-star-active); }

  .pts-review-title {
    font-size: var(--pts-rt-size-m);
    font-weight: var(--pts-rt-weight);
    color: var(--pts-rt-color);
    margin: 0 0 var(--pts-rt-mb) 0;
    line-height: 1.3;
    text-transform: var(--pts-rt-transform);
  }

  .pts-review-text {
    font-size: var(--pts-rtx-size-m);
    font-weight: var(--pts-rtx-weight);
    color: var(--pts-rtx-color);
    line-height: var(--pts-rtx-lh);
    margin: 0 0 var(--pts-rtx-mb) 0;
  }

  .pts-customer-name {
    font-size: var(--pts-name-size-m);
    font-weight: var(--pts-name-weight);
    color: var(--pts-name-color);
    margin: 0;
    text-transform: var(--pts-name-transform);
  }

  /* ─── Dots Navigation (Desktop - Vertical on right) ─────────── */
  .pts-carousel-dots {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: var(--pts-dot-gap);
    position: sticky;
    top: 50%;
    transform: translateY(-50%);
    align-self: center;
    padding-left: var(--pts-dot-offset);
    flex-shrink: 0;
  }

  .pts-dot {
    width: var(--pts-dot-size);
    height: var(--pts-dot-size);
    border-radius: 50%;
    background-color: var(--pts-dot-bg);
    cursor: pointer;
    transition: all 0.25s ease;
    flex-shrink: 0;
    border: none;
    padding: 0;
  }

  .pts-dot.active {
    background-color: var(--pts-dot-active-bg);
    width: var(--pts-dot-active-size);
    height: var(--pts-dot-active-size);
  }

  .pts-dot:hover { opacity: 0.7; }

  /* ─── Mobile Dots Navigation (Horizontal below cards) ───────── */
  .pts-mobile-dots {
    display: none;
    justify-content: center;
    align-items: center;
    gap: var(--pts-mobile-dot-gap);
    margin-top: var(--pts-mobile-dot-mt);
    padding: 12px 0 4px;
    width: 100%;
  }

  .pts-mobile-dot {
    width: var(--pts-mobile-dot-size);
    height: var(--pts-mobile-dot-size);
    border-radius: 50%;
    background-color: var(--pts-mobile-dot-bg);
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
    padding: 0;
    flex-shrink: 0;
  }

  .pts-mobile-dot.active {
    background-color: var(--pts-mobile-dot-active-bg);
    width: var(--pts-mobile-dot-active-size);
    height: var(--pts-mobile-dot-active-size);
  }

  .pts-mobile-dot:hover { opacity: 0.7; }

  /* ─── Tablet Styles ─────────────────────────────────────────── */
  @media (min-width: 768px) and (max-width: 1023px) {
    .pts-section {
      padding: var(--pts-pad-top-t) 0 var(--pts-pad-bot-t);
    }
    .pts-grid {
      gap: var(--pts-grid-gap-t);
    }
    .pts-carousel {
      height: var(--pts-car-height-t);
    }
  }

  /* ─── Desktop Styles ────────────────────────────────────────── */
  @media (min-width: 1024px) {
    .pts-section {
      padding: var(--pts-pad-top-d) 0 var(--pts-pad-bot-d);
    }
    .pts-heading { font-size: var(--pts-h-size-d); }
    .pts-description { font-size: var(--pts-d-size-d); }

    .pts-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--pts-grid-gap-d);
    }

    .pts-image-wrapper {
      width: 100%;
      height: var(--pts-img-h-d);
    }

    .pts-carousel {
      height: var(--pts-car-height-d);
      max-height: var(--pts-car-height-d);
      overflow-y: auto;
      overflow-x: hidden;
    }

    .pts-carousel-dots {
      display: flex;
    }

    .pts-card { padding: var(--pts-card-pad-d); }

    .pts-star {
      width: var(--pts-star-size-d);
      height: var(--pts-star-size-d);
    }
    .pts-review-title { font-size: var(--pts-rt-size-d); }
    .pts-review-text { font-size: var(--pts-rtx-size-d); }
    .pts-customer-name { font-size: var(--pts-name-size-d); }

    /* Hide mobile dots on desktop */
    .pts-mobile-dots {
      display: none !important;
    }
  }

  /* ─── Mobile Only Styles (Horizontal slider + bottom dots) ──── */
  @media (max-width: 767px) {
    /* Hide desktop vertical dots on mobile */
    .pts-carousel-dots {
      display: none !important;
    }

    /* When horizontal reviews is enabled */
    .pts-carousel.pts-mobile-horizontal {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      overflow-y: hidden;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      height: auto;
      min-height: auto;
      scroll-snap-type: x mandatory;
      scroll-padding: 0 var(--pts-car-pad);
      gap: var(--pts-car-gap);
      padding: var(--pts-car-pad) var(--pts-car-pad);
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .pts-carousel.pts-mobile-horizontal::-webkit-scrollbar {
      display: none;
    }

    .pts-carousel.pts-mobile-horizontal .pts-card {
      flex: 0 0 min(85vw, 360px);
      min-width: min(85vw, 360px);
      max-width: min(85vw, 360px);
      scroll-snap-align: start;
    }

    /* Show mobile dots */
    .pts-mobile-dots {
      display: flex;
    }
  }

  /* ─── Reduced Motion ────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .pts-carousel { scroll-behavior: auto; }
    .pts-card { transition: none; }
    .pts-card:hover { transform: none; }
  }
{%- endstyle -%}

<section class="pts-section" aria-label="{{ section.settings.heading | escape }}">
  <div class="pts-container">

    <div class="pts-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="pts-heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="pts-description">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="pts-grid">

      <!-- Left: Image -->
      <div class="pts-image-block">
        <div class="pts-image-wrapper">
          {%- if section.settings.image != blank -%}
            <img class="pts-image"
                 src="{{ section.settings.image | image_url: width: 800 }}"
                 alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
                 loading="lazy"
                 width="{{ section.settings.image.width }}"
                 height="{{ section.settings.image.height }}">
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'pts-image' }}
          {%- endif -%}
        </div>
      </div>

      <!-- Right: Carousel + Dots -->
      <div class="pts-carousel-block">
        <div class="pts-carousel-wrapper">

          <div class="pts-carousel{% if section.settings.mobile_horizontal_reviews %} pts-mobile-horizontal{% endif %}"
               id="pts-carousel-{{ section.id }}"
               data-autoplay="{{ section.settings.autoplay_enable }}"
               data-speed="{{ section.settings.autoplay_speed }}"
               data-loop="{{ section.settings.loop_enable }}"
               data-pause-hover="{{ section.settings.pause_on_hover }}"
               data-pause-touch="{{ section.settings.pause_on_touch }}"
               data-active-border-style="{{ section.settings.card_active_border_style }}"
               role="list"
               tabindex="0"
               aria-label="Testimonials">

            {%- assign testimonial_count = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'testimonial' -%}
                {%- assign testimonial_count = testimonial_count | plus: 1 -%}
                <article class="pts-card"
                         data-index="{{ testimonial_count | minus: 1 }}"
                         data-block-id="{{ block.id }}"
                         role="listitem"
                         {{ block.shopify_attributes }}>

                  <div class="pts-card-meta">
                    {%- if block.settings.customer_avatar != blank -%}
                      <img class="pts-avatar"
                           src="{{ block.settings.customer_avatar | image_url: width: 150 }}"
                           alt="{{ block.settings.customer_name | escape }}"
                           loading="lazy"
                           width="{{ section.settings.avatar_size }}"
                           height="{{ section.settings.avatar_size }}">
                    {%- else -%}
                      <div class="pts-avatar-placeholder" aria-hidden="true">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                          <circle cx="12" cy="7" r="4"/>
                        </svg>
                      </div>
                    {%- endif -%}

                    <div class="pts-card-info">
                      <div class="pts-stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                        {%- for i in (1..5) -%}
                          <svg class="pts-star{% if i <= block.settings.rating %} active{% endif %}" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                          </svg>
                        {%- endfor -%}
                      </div>
                      <p class="pts-customer-name">{{ block.settings.customer_name | escape }}</p>
                    </div>
                  </div>

                  {%- if block.settings.review_title != blank -%}
                    <h3 class="pts-review-title">{{ block.settings.review_title | escape }}</h3>
                  {%- endif -%}

                  {%- if block.settings.review_text != blank -%}
                    <p class="pts-review-text">"{{ block.settings.review_text | escape }}"</p>
                  {%- endif -%}

                </article>
              {%- endif -%}
            {%- endfor -%}
          </div>

          <!-- Mobile Dots (visible only on mobile when horizontal slider is active) -->
          <div class="pts-mobile-dots" id="pts-mobile-dots-{{ section.id }}" aria-label="Testimonial navigation" role="tablist">
            {%- assign dot_index = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'testimonial' -%}
                <button class="pts-mobile-dot"
                        data-mobile-dot-index="{{ dot_index }}"
                        role="tab"
                        aria-label="Go to testimonial {{ dot_index | plus: 1 }}"
                        aria-selected="false">
                </button>
                {%- assign dot_index = dot_index | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

          <!-- Desktop Dots (vertical on the right side) -->
          <div class="pts-carousel-dots" id="pts-dots-{{ section.id }}" aria-label="Testimonial navigation" role="tablist">
            {%- assign dot_index = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'testimonial' -%}
                <button class="pts-dot"
                        data-dot-index="{{ dot_index }}"
                        role="tab"
                        aria-label="Go to testimonial {{ dot_index | plus: 1 }}"
                        aria-selected="false">
                </button>
                {%- assign dot_index = dot_index | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function() {
  'use strict';

  var carousel = document.getElementById('pts-carousel-{{ section.id }}');
  var desktopDotsContainer = document.getElementById('pts-dots-{{ section.id }}');
  var mobileDotsContainer = document.getElementById('pts-mobile-dots-{{ section.id }}');

  if (!carousel) return;

  var cards = Array.prototype.slice.call(carousel.querySelectorAll('.pts-card'));
  if (cards.length <= 1) {
    // Still highlight the only card
    if (cards.length === 1) cards[0].classList.add('active');
    return;
  }

  var desktopDots = desktopDotsContainer
    ? Array.prototype.slice.call(desktopDotsContainer.querySelectorAll('.pts-dot'))
    : [];
  var mobileDots = mobileDotsContainer
    ? Array.prototype.slice.call(mobileDotsContainer.querySelectorAll('.pts-mobile-dot'))
    : [];

  var autoplay     = carousel.dataset.autoplay === 'true';
  var speed        = parseInt(carousel.dataset.speed, 10) || 5000;
  var loop         = carousel.dataset.loop === 'true';
  var pauseHover   = carousel.dataset.pauseHover === 'true';
  var pauseTouch   = carousel.dataset.pauseTouch === 'true';

  /* ── active border style from data attr (set via Liquid) ─── */
  var activeBorderStyle = carousel.dataset.activeBorderStyle || 'dashed';

  var currentIndex  = 0;
  var autoplayTimer = null;
  var isPaused      = false;
  var userScrolling = false;
  var scrollTimeout = null;

  /* ── helpers ──────────────────────────────────────────────── */

  /**
   * Detect whether we are in the horizontal-mobile layout.
   * Re-evaluated on every call so resize / orientation changes
   * are handled correctly.
   */
  function isMobileHorizontal() {
    return window.innerWidth <= 767 &&
           carousel.classList.contains('pts-mobile-horizontal');
  }

  /**
   * Find the index of the card whose centre is closest to the
   * visible centre of the scrolling carousel element.
   *
   * On desktop (vertical scroll) we compare vertical centres
   * against the carousel element's own viewport, NOT the window.
   * On mobile-horizontal we compare horizontal centres.
   */
  function getMostVisibleCardIndex() {
    var carouselRect = carousel.getBoundingClientRect();

    if (isMobileHorizontal()) {
      /* ── horizontal (mobile) ── */
      var viewCentreX = carouselRect.left + carouselRect.width / 2;
      var best = 0, bestDist = Infinity;
      cards.forEach(function(card, idx) {
        var r = card.getBoundingClientRect();
        var dist = Math.abs((r.left + r.right) / 2 - viewCentreX);
        if (dist < bestDist) { bestDist = dist; best = idx; }
      });
      return best;
    } else {
      /* ── vertical (desktop + tablet + mobile-stack) ──
         Key fix: measure card centres relative to the carousel
         element's own bounding rect, accounting for its scroll
         offset so the comparison is in document space.          */
      var scrollTop   = carousel.scrollTop;
      var visibleTop  = scrollTop;
      var visibleBot  = scrollTop + carousel.clientHeight;
      var viewCentreY = visibleTop + carousel.clientHeight / 2;

      var best = 0, bestDist = Infinity;
      cards.forEach(function(card, idx) {
        /* offsetTop is relative to the carousel (scroll parent) */
        var cardTop    = card.offsetTop;
        var cardBot    = cardTop + card.offsetHeight;
        var cardCentre = (cardTop + cardBot) / 2;
        var dist       = Math.abs(cardCentre - viewCentreY);
        if (dist < bestDist) { bestDist = dist; best = idx; }
      });
      return best;
    }
  }

  function setActiveCard(index) {
    if (index < 0) index = 0;
    if (index >= cards.length) index = cards.length - 1;

    cards.forEach(function(card, i) {
      if (i === index) {
        card.classList.add('active');
        /* Apply the schema-controlled active border style */
        card.style.borderStyle = activeBorderStyle;
      } else {
        card.classList.remove('active');
        /* Restore the base border style from the CSS variable */
        card.style.borderStyle = '';
      }
    });

    desktopDots.forEach(function(dot, i) {
      var on = i === index;
      dot.classList.toggle('active', on);
      dot.setAttribute('aria-selected', on ? 'true' : 'false');
    });

    mobileDots.forEach(function(dot, i) {
      var on = i === index;
      dot.classList.toggle('active', on);
      dot.setAttribute('aria-selected', on ? 'true' : 'false');
    });

    currentIndex = index;
  }

  function updateActiveFromScroll() {
    var idx = getMostVisibleCardIndex();
    if (idx !== currentIndex) setActiveCard(idx);
  }

  function scrollToCard(index) {
    if (index < 0) index = 0;
    if (index >= cards.length) index = cards.length - 1;

    var target = cards[index];
    if (!target) return;

    if (isMobileHorizontal()) {
      target.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    } else {
      /* Scroll the carousel element itself, not the window */
      var targetTop = target.offsetTop - parseInt(
        getComputedStyle(carousel).scrollPaddingTop || '0', 10
      );
      carousel.scrollTo({ top: targetTop, behavior: 'smooth' });
    }

    setActiveCard(index);
  }

  /* ── autoplay ──────────────────────────────────────────────── */

  function startAutoplay() {
    if (!autoplay || cards.length <= 1) return;
    stopAutoplay();
    autoplayTimer = setInterval(function() {
      if (userScrolling || isPaused) return;
      var next = currentIndex + 1;
      if (next >= cards.length) {
        if (loop) { next = 0; } else { return; }
      }
      scrollToCard(next);
    }, speed);
  }

  function stopAutoplay() {
    if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; }
  }

  /* ── scroll listener ───────────────────────────────────────── */

  carousel.addEventListener('scroll', function() {
    userScrolling = true;

    /* Update active card & dots in real-time during scroll */
    updateActiveFromScroll();

    if (autoplay) stopAutoplay();

    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(function() {
      userScrolling = false;
      /* Final snap position check after scroll settles */
      updateActiveFromScroll();
      if (autoplay && !isPaused) startAutoplay();
    }, 200);
  }, { passive: true });

  /* ── hover / touch pause ───────────────────────────────────── */

  if (pauseHover) {
    carousel.addEventListener('mouseenter', function() {
      isPaused = true; stopAutoplay();
    });
    carousel.addEventListener('mouseleave', function() {
      isPaused = false;
      if (autoplay && !userScrolling) startAutoplay();
    });
  }

  if (pauseTouch) {
    carousel.addEventListener('touchstart', function() {
      isPaused = true; stopAutoplay();
    }, { passive: true });
    carousel.addEventListener('touchend', function() {
      setTimeout(function() {
        isPaused = false;
        if (autoplay && !userScrolling) startAutoplay();
      }, 400);
    }, { passive: true });
  }

  /* ── dot click handlers ────────────────────────────────────── */

  function dotClickHandler(idx) {
    return function(e) {
      e.preventDefault();
      scrollToCard(idx);
      if (autoplay) {
        stopAutoplay();
        setTimeout(function() {
          if (!isPaused && !userScrolling) startAutoplay();
        }, 3000);
      }
    };
  }

  desktopDots.forEach(function(dot, idx) {
    dot.addEventListener('click', dotClickHandler(idx));
  });
  mobileDots.forEach(function(dot, idx) {
    dot.addEventListener('click', dotClickHandler(idx));
  });

  /* ── keyboard navigation ───────────────────────────────────── */

  carousel.addEventListener('keydown', function(e) {
    if (isMobileHorizontal()) {
      if (e.key === 'ArrowRight') { e.preventDefault(); scrollToCard(currentIndex + 1); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); scrollToCard(currentIndex - 1); }
    } else {
      if (e.key === 'ArrowDown') { e.preventDefault(); scrollToCard(currentIndex + 1); }
      if (e.key === 'ArrowUp')   { e.preventDefault(); scrollToCard(currentIndex - 1); }
    }
  });

  /* ── init ──────────────────────────────────────────────────── */

  /* Wait one frame for layout, then set the first card active */
  requestAnimationFrame(function() {
    setTimeout(function() {
      setActiveCard(getMostVisibleCardIndex());
      if (autoplay) startAutoplay();
    }, 100);
  });

  /* Re-check active card on resize / orientation change */
  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      setActiveCard(getMostVisibleCardIndex());
    }, 150);
  });

})();
</script>

