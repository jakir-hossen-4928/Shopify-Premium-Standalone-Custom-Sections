{%- style -%}
  /* Dynamic Spacing & Colors */
  .sk-features-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .sk-features-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Custom Scoped Classes */
  .sk-premium-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .sk-premium-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .sk-premium-image-wrapper { 
    position: relative; 
  }

  .sk-premium-main-img {
    width: 100%;
    height: auto;
    min-height: {{ section.settings.image_height }}px;
    object-fit: cover;
    border-radius: 40px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
    display: block;
  }

  .sk-premium-text-gradient {
    background: {{ section.settings.accent_color }};
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }

  .sk-premium-feature-card {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-bottom: 16px;
    padding: 15px;
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.08 }};
    transition: transform 0.3s ease;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 20px;
  }

  .sk-premium-feature-card:hover {
    transform: translateX(10px);
  }

  .sk-premium-icon-wrap {
    width: 36px;
    height: 36px;
    background: {{ section.settings.accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    flex-shrink: 0;
  }

  .sk-premium-icon-wrap svg {
     display: inline-block;
     vertical-align: middle;
     fill: none;
     stroke: currentColor;
     width: 2rem;
     height: 2rem;
     transition: var(--anchor-transition);
  }

  .sk-premium-floating-card {
    position: absolute; 
    bottom: 30px; 
    right: -20px;
    background: white; 
    padding: 20px; 
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1); 
    width: 180px;
    animation: sk-float 6s ease-in-out infinite; 
    z-index: 3;
  }

  @keyframes sk-float { 
    0%, 100% { transform: translateY(0); } 
    50% { transform: translateY(-10px); } 
  }

  @media (max-width: 1024px) {
    .sk-premium-grid { grid-template-columns: 1fr; gap: 40px; }
    .sk-premium-floating-card { right: 10px; bottom: 10px; width: 150px; }
    .sk-premium-main-img { min-height: 350px; }
  }
{%- endstyle -%}

<section class="sk-features-{{ section.id }}">
  <div class="sk-premium-container">
    <div class="sk-premium-grid">
      
      <div class="sk-premium-image-wrapper">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" 
               alt="{{ section.settings.image.alt }}" 
               class="sk-premium-main-img"
               loading="lazy">
        {% else %}
          {%- assign placeholder_class = 'sk-premium-main-img' -%}
          {{ 'product-1' | placeholder_svg_tag: placeholder_class }}
        {% endif %}
          
        {% if section.settings.show_testimonial %}
          <div class="sk-premium-floating-card">
            <div style="color:#fbbf24; margin-bottom:8px; font-size: 12px;">★★★★★</div>
            <p style="font-size:13px; font-weight:600; margin:0; line-height: 1.3;">{{ section.settings.testimonial_text }}</p>
            <small style="color:#64748b; display: block; margin-top: 5px;">{{ section.settings.testimonial_author }}</small>
          </div>
        {% endif %}
      </div>

      <div class="sk-premium-content">
        <span class="sk-premium-badge" style="
          color: {{ section.settings.accent_color }}; 
          border: 1px solid {{ section.settings.accent_color }}; 
          padding: 5px 15px; 
          border-radius: 20px; 
          font-size: 12px; 
          font-weight: 700; 
          text-transform: uppercase;">
          {{ section.settings.badge_text }}
        </span>

        <h2 style="font-size: clamp(32px, 5vw, 48px); font-weight: 800; margin: 20px 0 30px 0; line-height: 1.1; color: #1a1a1a;">
          {{ section.settings.title_part_1 }}<br>
          <span class="sk-premium-text-gradient">{{ section.settings.title_part_2 }}</span>
        </h2>

        <div class="sk-premium-feature-stack">
          {% for block in section.blocks %}
            <div class="sk-premium-feature-card" {{ block.shopify_attributes }}>
              <div class="sk-premium-icon-wrap">
                <svg width="18" height="18" viewBox="0 0 24 24"  stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div class="sk-premium-text-content">
                <h3 style="margin:0; font-size:18px; font-weight: 400; color: #1a1a1a;">{{ block.settings.heading }}</h3>
                <p style="margin:4px 0 0 0; color:#64748b; font-size:15px; line-height: 1.4;">{{ block.settings.text }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Custom Features",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Feature Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#2d6c4f"
    },
    {
      "type": "range",
      "id": "image_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "default": 550,
      "unit": "px",
      "label": "Min Image Height"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Why it works"
    },
    {
      "type": "text",
      "id": "title_part_1",
      "label": "Title Line 1",
      "default": "Effortless skincare."
    },
    {
      "type": "text",
      "id": "title_part_2",
      "label": "Title Line 2 (Colored)",
      "default": "Zero thinking."
    },
    {
      "type": "header",
      "content": "Floating Testimonial"
    },
    {
      "type": "checkbox",
      "id": "show_testimonial",
      "label": "Show Floating Card",
      "default": true
    },
    {
      "type": "text",
      "id": "testimonial_text",
      "label": "Quote",
      "default": "The best travel hack I've found."
    },
    {
      "type": "text",
      "id": "testimonial_author",
      "label": "Author Name",
      "default": "— Sarah J."
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Describe the benefit or feature here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Custom Features",
      "blocks": [
        { "type": "feature", "settings": { "heading": "Post-workout ready" } },
        { "type": "feature", "settings": { "heading": "Travel-friendly" } },
        { "type": "feature", "settings": { "heading": "Eco-conscious" } }
      ]
    }
  ]
}
{% endschema %}