{% comment %}
  ============================================================
  WORK OFFSHORE — HOW IT WORKS (Timeline with Icons)
  Light theme · Dashed connector line · Circular icon badges
  Numbered gold step labels · Icon per step via image picker
  ============================================================
{% endcomment %}

<style>
/* ============================================================
   CSS VARIABLES
============================================================ */
#shopify-section-{{ section.id }} {
  --wo-bg:           {{ section.settings.bg_color }};
  --wo-accent:       {{ section.settings.accent_color }};
  --wo-badge-bg:     {{ section.settings.badge_bg_color }};
  --wo-text:         {{ section.settings.text_color_main }};
  --wo-sub:          {{ section.settings.text_color_sub }};
  --wo-eyebrow:      {{ section.settings.eyebrow_color }};
  --wo-line:         {{ section.settings.line_color }};

  --wo-title-d:      {{ section.settings.title_size_desktop }}px;
  --wo-sub-d:        {{ section.settings.subtitle_size_desktop }}px;
  --wo-stitle-d:     {{ section.settings.step_title_size_desktop }}px;
  --wo-stext-d:      {{ section.settings.step_text_size_desktop }}px;

  --wo-title-m:      {{ section.settings.title_size_mobile }}px;
  --wo-sub-m:        {{ section.settings.subtitle_size_mobile }}px;
  --wo-stitle-m:     {{ section.settings.step_title_size_mobile }}px;
  --wo-stext-m:      {{ section.settings.step_text_size_mobile }}px;

  --wo-pt-d: {{ section.settings.pad_top_desktop }}px;
  --wo-pb-d: {{ section.settings.pad_bot_desktop }}px;
  --wo-px-d: {{ section.settings.pad_x_desktop }}px;
  --wo-pt-m: {{ section.settings.pad_top_mobile }}px;
  --wo-pb-m: {{ section.settings.pad_bot_mobile }}px;
  --wo-px-m: {{ section.settings.pad_x_mobile }}px;
}

/* ============================================================
   SECTION
============================================================ */
.wo-hiw {
  background: var(--wo-bg);
  padding: var(--wo-pt-d) var(--wo-px-d) var(--wo-pb-d);
  font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Helvetica Neue', sans-serif;
  color: var(--wo-text);
  overflow: hidden;
}

.wo-hiw__inner {
  max-width: 1200px;
  margin: 0 auto;
}

/* ============================================================
   HEADER
============================================================ */
.wo-hiw__header {
  text-align: center;
  margin-bottom: 64px;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.wo-hiw__header.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.wo-hiw__eyebrow {
  display: block;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--wo-eyebrow);
  margin-bottom: 12px;
}

.wo-hiw__title {
  font-size: var(--wo-title-d);
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.025em;
  color: var(--wo-text);
  margin: 0 0 14px;
}

.wo-hiw__subtitle {
  font-size: var(--wo-sub-d);
  color: var(--wo-sub);
  margin: 0;
  line-height: 1.5;
}

/* ============================================================
   TIMELINE WRAPPER
============================================================ */
.wo-hiw__timeline {
  position: relative;
}

/* ============================================================
   DASHED CONNECTOR LINE
   Sits horizontally between the icon circles on desktop.
   left/right offsets = half of one column width so the line
   starts/ends at the centre of the first/last icon.
============================================================ */
.wo-hiw__line {
  display: none;
  position: absolute;
  top: 46px;
  left: calc(100% / ({{ section.blocks.size }} * 2));
  right: calc(100% / ({{ section.blocks.size }} * 2));
  height: 2px;
  z-index: 0;
  background-image: repeating-linear-gradient(
    90deg,
    var(--wo-line) 0,
    var(--wo-line) 10px,
    transparent 10px,
    transparent 22px
  );
}

/* ============================================================
   STEPS GRID
============================================================ */
.wo-hiw__grid {
  display: grid;
  grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
  gap: 20px;
  position: relative;
}

/* ============================================================
   SINGLE STEP
============================================================ */
.wo-hiw__step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  z-index: 1;
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}

.wo-hiw__step.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ============================================================
   ICON CIRCLE
============================================================ */
.wo-hiw__icon-wrap {
  width: 92px;
  height: 92px;
  border-radius: 50%;
  background: var(--wo-badge-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
  flex-shrink: 0;
  transition:
    transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
    box-shadow 0.4s ease;
}

.wo-hiw__step:hover .wo-hiw__icon-wrap,
.wo-hiw__step.is-active .wo-hiw__icon-wrap {
  transform: translateY(-5px) scale(1.06);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.20);
}

.wo-hiw__icon-img {
  width: 44px;
  height: 44px;
  object-fit: contain;
  filter: brightness(0) invert(1);
}

/* Inline SVG fallback placeholders */
.wo-hiw__icon-svg {
  width: 40px;
  height: 40px;
  display: block;
}

/* ============================================================
   STEP LABEL — numbered gold badge + title
============================================================ */
.wo-hiw__label {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-bottom: 10px;
}

.wo-hiw__num {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--wo-accent);
  color: #fff;
  font-size: 12px;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-family: 'Space Mono', 'Courier New', monospace;
}

.wo-hiw__step-title {
  font-size: var(--wo-stitle-d);
  font-weight: 700;
  color: var(--wo-text);
  margin: 0;
  letter-spacing: -0.01em;
  transition: color 0.3s ease;
}

.wo-hiw__step.is-active .wo-hiw__step-title {
  color: var(--wo-accent);
}

.wo-hiw__step-desc {
  font-size: var(--wo-stext-d);
  color: var(--wo-sub);
  line-height: 1.65;
  margin: 0;
  max-width: 280px;
}

/* ============================================================
   TABLET — 2-column
============================================================ */
@media (max-width: 992px) and (min-width: 769px) {
  .wo-hiw__line { display: none !important; }
  .wo-hiw__grid {
    grid-template-columns: repeat(2, 1fr);
    row-gap: 52px;
  }
}

/* ============================================================
   MOBILE — vertical stacked cards (no scroll)
============================================================ */
@media (max-width: 768px) {
  .wo-hiw {
    padding: var(--wo-pt-m) var(--wo-px-m) var(--wo-pb-m);
  }

  .wo-hiw__header { margin-bottom: 40px; }
  .wo-hiw__title    { font-size: var(--wo-title-m); }
  .wo-hiw__subtitle { font-size: var(--wo-sub-m); }

  .wo-hiw__line { display: none !important; }

  /* Vertical stack */
  .wo-hiw__grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    grid-template-columns: unset;
  }

  /* Horizontal card row */
  .wo-hiw__step {
    flex-direction: row;
    align-items: flex-start;
    text-align: left;
    gap: 18px;
    padding: 22px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    opacity: 1 !important;
    transform: none !important;
  }

  .wo-hiw__step:last-child { border-bottom: none; }

  /* Smaller icon on mobile */
  .wo-hiw__icon-wrap {
    width: 72px;
    height: 72px;
    flex-shrink: 0;
    margin-bottom: 0;
  }

  .wo-hiw__icon-img { width: 34px; height: 34px; }
  .wo-hiw__icon-svg { width: 34px; height: 34px; }

  .wo-hiw__step:hover .wo-hiw__icon-wrap,
  .wo-hiw__step.is-active .wo-hiw__icon-wrap {
    transform: none;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  /* Text block */
  .wo-hiw__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 2px;
    min-width: 0;
  }

  .wo-hiw__label {
    justify-content: flex-start;
    margin-bottom: 6px;
  }

  .wo-hiw__step-title { font-size: var(--wo-stitle-m); }
  .wo-hiw__step-desc  { font-size: var(--wo-stext-m); max-width: none; }
}

/* ============================================================
   DESKTOP — show dashed line
============================================================ */
@media (min-width: 993px) {
  .wo-hiw__line { display: block; }
}
</style>

<section class="wo-hiw" id="wo-hiw-{{ section.id }}">
  <div class="wo-hiw__inner">

    <div class="wo-hiw__header" id="wo-hiw-header-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="wo-hiw__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="wo-hiw__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="wo-hiw__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="wo-hiw__timeline">
      <div class="wo-hiw__line" aria-hidden="true"></div>

      <div class="wo-hiw__grid" id="wo-hiw-grid-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="wo-hiw__step" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>

            <!-- Icon circle -->
            <div class="wo-hiw__icon-wrap">
              {%- if block.settings.icon != blank -%}
                <img
                  class="wo-hiw__icon-img"
                  src="{{ block.settings.icon | image_url: width: 88 }}"
                  alt="{{ block.settings.title | escape }}"
                  width="44" height="44"
                  loading="lazy"
                >
              {%- else -%}
                {%- case forloop.index -%}
                  {%- when 1 -%}
                    <svg class="wo-hiw__icon-svg" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M8 6h10a2 2 0 0 1 2 2v18a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2z" stroke="white" stroke-width="2" stroke-linejoin="round"/>
                      <path d="M22 6h10a2 2 0 0 1 2 2v18a2 2 0 0 1-2 2H22a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2z" stroke="white" stroke-width="2" stroke-linejoin="round"/>
                      <path d="M10 12h6M10 16h6M10 20h4M24 12h6M24 16h6M24 20h4" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  {%- when 2 -%}
                    <svg class="wo-hiw__icon-svg" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <rect x="8" y="5" width="24" height="30" rx="3" stroke="white" stroke-width="2"/>
                      <path d="M14 2v6M26 2v6" stroke="white" stroke-width="2" stroke-linecap="round"/>
                      <path d="M13 18h14M13 24h10" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                      <circle cx="27" cy="27" r="6" fill="#1a1a2e" stroke="white" stroke-width="1.5"/>
                      <path d="M25 27l1.5 1.5L29 25" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {%- when 3 -%}
                    <svg class="wo-hiw__icon-svg" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M34 6L6 18l10 4 4 10 14-26z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M16 22l6-6" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  {%- when 4 -%}
                    <svg class="wo-hiw__icon-svg" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <rect x="5" y="16" width="30" height="19" rx="3" stroke="white" stroke-width="2"/>
                      <path d="M13 16V12a7 7 0 0 1 14 0v4" stroke="white" stroke-width="2" stroke-linecap="round"/>
                      <circle cx="20" cy="25" r="3" fill="white"/>
                      <path d="M20 28v3" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  {%- when 5 -%}
                    <svg class="wo-hiw__icon-svg" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <circle cx="20" cy="20" r="13" stroke="white" stroke-width="2"/>
                      <path d="M20 13v7l4 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {%- else -%}
                    <svg class="wo-hiw__icon-svg" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <circle cx="20" cy="20" r="13" stroke="white" stroke-width="2"/>
                      <path d="M20 14v12M14 20h12" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                {%- endcase -%}
              {%- endif -%}
            </div>

            <!-- Text body (wrapper needed for mobile row layout) -->
            <div class="wo-hiw__body">
              <div class="wo-hiw__label">
                <span class="wo-hiw__num">{{ forloop.index }}</span>
                {%- if block.settings.title != blank -%}
                  <h3 class="wo-hiw__step-title">{{ block.settings.title }}</h3>
                {%- endif -%}
              </div>
              {%- if block.settings.text != blank -%}
                <p class="wo-hiw__step-desc">{{ block.settings.text }}</p>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

<script>
(function () {
  'use strict';

  var SID   = '{{ section.id }}';
  var TOTAL = {{ section.blocks.size }};

  var sec    = document.getElementById('wo-hiw-' + SID);
  var header = document.getElementById('wo-hiw-header-' + SID);
  var grid   = document.getElementById('wo-hiw-grid-' + SID);

  if (!sec || !grid) return;

  var items = Array.from(grid.querySelectorAll('.wo-hiw__step'));

  function isMobile()   { return window.innerWidth <= 768; }
  function clearActive(){ items.forEach(function (el) { el.classList.remove('is-active'); }); }
  function setActive(i) { items.forEach(function (el, j) { el.classList.toggle('is-active', j === i); }); }

  /* ── Desktop: scroll-driven progress + active step ── */
  var scrollHandler = null;

  function onDesktopScroll() {
    var rect  = sec.getBoundingClientRect();
    var winH  = window.innerHeight;
    if (rect.top > winH || rect.bottom < 0) { clearActive(); return; }
    var progress = Math.min(Math.max(-(rect.top - winH / 2) / rect.height, 0), 1);
    var active = -1;
    for (var i = 0; i < TOTAL; i++) {
      if (progress >= (i === 0 ? 0 : (i / TOTAL) * 0.85)) active = i;
    }
    if (active < 0) clearActive(); else setActive(active);
  }

  function initDesktop() {
    if (header) {
      new IntersectionObserver(function (entries, obs) {
        if (entries[0].isIntersecting) { header.classList.add('is-visible'); obs.disconnect(); }
      }, { threshold: 0.4 }).observe(header);
    }

    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        var i = parseInt(e.target.getAttribute('data-index'), 10);
        setTimeout(function () { e.target.classList.add('is-visible'); }, i * 130);
        io.unobserve(e.target);
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    items.forEach(function (el) { io.observe(el); });
    scrollHandler = onDesktopScroll;
    window.addEventListener('scroll', scrollHandler, { passive: true });
    onDesktopScroll();
  }

  /* ── Mobile: highlight most visible card via IntersectionObserver ── */
  function initMobile() {
    if (header) {
      new IntersectionObserver(function (entries, obs) {
        if (entries[0].isIntersecting) { header.classList.add('is-visible'); obs.disconnect(); }
      }, { threshold: 0.2 }).observe(header);
    }

    clearActive();
    var ratios = new Array(TOTAL).fill(0);

    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        ratios[parseInt(e.target.getAttribute('data-index'), 10)] = e.intersectionRatio;
      });
      var best = -1, bestR = 0;
      ratios.forEach(function (r, i) { if (r > bestR) { bestR = r; best = i; } });
      if (best >= 0 && bestR > 0.15) setActive(best); else clearActive();
    }, { threshold: [0, 0.25, 0.5, 0.75, 1] });

    items.forEach(function (el) { io.observe(el); });
  }

  /* ── Boot / resize ── */
  var mode = null;

  function boot() {
    var next = isMobile() ? 'mobile' : 'desktop';
    if (next === mode) return;
    mode = next;
    if (scrollHandler) { window.removeEventListener('scroll', scrollHandler); scrollHandler = null; }
    clearActive();
    if (next === 'mobile') {
      items.forEach(function (el) { el.classList.add('is-visible'); });
      initMobile();
    } else {
      items.forEach(function (el) { el.classList.remove('is-visible'); });
      initDesktop();
    }
  }

  var resizeTimer;
  window.addEventListener('resize', function () { clearTimeout(resizeTimer); resizeTimer = setTimeout(boot, 200); });
  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', boot); } else { boot(); }
}());
</script>

{% schema %}
{
  "name": "WO How It Works",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "━━ Content ━━"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "SIMPLE STEPS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Your journey to an offshore career made simple."
    },
    {
      "type": "header",
      "content": "━━ Colors ━━"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Icon Circle Background",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / Number Badge",
      "default": "#e8a020"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#e8a020"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Connector Line Color",
      "default": "#e8a020"
    },
    {
      "type": "color",
      "id": "text_color_main",
      "label": "Main Text",
      "default": "#0f0f1a"
    },
    {
      "type": "color",
      "id": "text_color_sub",
      "label": "Sub / Description Text",
      "default": "#6b7280"
    },
    {
      "type": "header",
      "content": "━━ Typography Desktop ━━"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 24, "max": 64, "step": 2, "unit": "px",
      "label": "Title Size",
      "default": 42
    },
    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "min": 12, "max": 22, "step": 1, "unit": "px",
      "label": "Subtitle Size",
      "default": 15
    },
    {
      "type": "range",
      "id": "step_title_size_desktop",
      "min": 14, "max": 28, "step": 1, "unit": "px",
      "label": "Step Title Size",
      "default": 18
    },
    {
      "type": "range",
      "id": "step_text_size_desktop",
      "min": 12, "max": 18, "step": 1, "unit": "px",
      "label": "Step Text Size",
      "default": 14
    },
    {
      "type": "header",
      "content": "━━ Typography Mobile ━━"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 20, "max": 48, "step": 1, "unit": "px",
      "label": "Title Size",
      "default": 32
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "min": 12, "max": 18, "step": 1, "unit": "px",
      "label": "Subtitle Size",
      "default": 14
    },
    {
      "type": "range",
      "id": "step_title_size_mobile",
      "min": 14, "max": 24, "step": 1, "unit": "px",
      "label": "Step Title Size",
      "default": 17
    },
    {
      "type": "range",
      "id": "step_text_size_mobile",
      "min": 12, "max": 16, "step": 1, "unit": "px",
      "label": "Step Text Size",
      "default": 13
    },
    {
      "type": "header",
      "content": "━━ Padding Desktop ━━"
    },
    {
      "type": "range",
      "id": "pad_top_desktop",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_desktop",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_x_desktop",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Horizontal",
      "default": 40
    },
    {
      "type": "header",
      "content": "━━ Padding Mobile ━━"
    },
    {
      "type": "range",
      "id": "pad_top_mobile",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Top",
      "default": 48
    },
    {
      "type": "range",
      "id": "pad_bot_mobile",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Bottom",
      "default": 48
    },
    {
      "type": "range",
      "id": "pad_x_mobile",
      "min": 0, "max": 60, "step": 2, "unit": "px",
      "label": "Horizontal",
      "default": 20
    }
  ],
  "blocks": [
    {
