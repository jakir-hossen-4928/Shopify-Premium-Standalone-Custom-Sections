{% comment %}
  ============================================================
  PRO PATH TIMELINE SECTION
  Refactored for full customization from Theme Editor
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign title_font = section.settings.title_font
  assign body_font = section.settings.body_font
  assign meta_font = section.settings.meta_font

  assign title_font_bold = title_font | font_modify: 'weight', 'bold'
  assign title_font_italic = title_font | font_modify: 'style', 'italic'
  assign title_font_bold_italic = title_font_bold | font_modify: 'style', 'italic'

  assign body_font_bold = body_font | font_modify: 'weight', 'bold'
  assign body_font_italic = body_font | font_modify: 'style', 'italic'
  assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
-%}

<style>
  {{ title_font | font_face: font_display: 'swap' }}
  {{ title_font_bold | font_face: font_display: 'swap' }}
  {{ title_font_italic | font_face: font_display: 'swap' }}
  {{ title_font_bold_italic | font_face: font_display: 'swap' }}

  {{ body_font | font_face: font_display: 'swap' }}
  {{ body_font_bold | font_face: font_display: 'swap' }}
  {{ body_font_italic | font_face: font_display: 'swap' }}
  {{ body_font_bold_italic | font_face: font_display: 'swap' }}

  {{ meta_font | font_face: font_display: 'swap' }}

  #shopify-section-{{ section_id }} {
    /* Colors */
    --wo-bg: {{ section.settings.bg_color }};
    --wo-accent: {{ section.settings.accent_color }};
    --wo-badge-bg: {{ section.settings.badge_bg_color }};
    --wo-text-main: {{ section.settings.text_color_main }};
    --wo-text-sub: {{ section.settings.text_color_sub }};
    --wo-eyebrow-color: {{ section.settings.eyebrow_color }};
    --wo-line-color: {{ section.settings.line_color }};

    /* Typography - Header */
    --wo-title-font: {{ title_font.family }}, {{ title_font.fallback_families }};
    --wo-title-weight: {{ section.settings.title_weight | default: title_font.weight }};
    --wo-title-ls: {{ section.settings.title_ls }}em;
    --wo-title-lh: {{ section.settings.title_lh }};
    --wo-title-transform: {{ section.settings.title_transform }};

    --wo-sub-font: {{ body_font.family }}, {{ body_font.fallback_families }};
    --wo-sub-size: {{ section.settings.subtitle_size_desktop }}px;
    --wo-sub-weight: {{ section.settings.subtitle_weight }};
    --wo-sub-ls: {{ section.settings.subtitle_ls }}em;
    --wo-sub-transform: {{ section.settings.subtitle_transform }};

    --wo-eyebrow-font: {{ meta_font.family }}, {{ meta_font.fallback_families }};
    --wo-eyebrow-size: {{ section.settings.eyebrow_size }}px;
    --wo-eyebrow-weight: {{ section.settings.eyebrow_weight }};
    --wo-eyebrow-ls: {{ section.settings.eyebrow_ls }}em;
    --wo-eyebrow-transform: {{ section.settings.eyebrow_transform }};

    /* Typography - Step */
    --wo-stitle-font: {{ title_font.family }}, {{ title_font.fallback_families }};
    --wo-stitle-size: {{ section.settings.step_title_size_desktop }}px;
    --wo-stitle-weight: {{ section.settings.step_title_weight }};
    --wo-stitle-ls: {{ section.settings.step_title_ls }}em;
    --wo-stitle-transform: {{ section.settings.step_title_transform }};

    --wo-stext-font: {{ body_font.family }}, {{ body_font.fallback_families }};
    --wo-stext-size: {{ section.settings.step_text_size_desktop }}px;
    --wo-stext-weight: {{ section.settings.step_text_weight }};
    --wo-stext-lh: {{ section.settings.step_text_lh }};

    --wo-num-font: {{ meta_font.family }}, {{ meta_font.fallback_families }};
    --wo-num-size: {{ section.settings.num_size }}px;
    --wo-num-weight: {{ section.settings.num_weight }};

    /* Layout & Sizes */
    --wo-max-w: {{ section.settings.container_width }}px;
    --wo-icon-wrap-size: {{ section.settings.icon_wrap_size }}px;
    --wo-icon-img-size: {{ section.settings.icon_img_size }}px;
    --wo-icon-radius: {{ section.settings.icon_radius }}%;
    --wo-line-h: {{ section.settings.line_thickness }}px;
    --wo-line-dash: {{ section.settings.line_dash_length }}px;
    --wo-line-gap: {{ section.settings.line_dash_gap }}px;

    /* Spacing */
    --wo-pt-d: {{ section.settings.pad_top_desktop }}px;
    --wo-pb-d: {{ section.settings.pad_bot_desktop }}px;
    --wo-pt-m: {{ section.settings.pad_top_mobile }}px;
    --wo-pb-m: {{ section.settings.pad_bot_mobile }}px;
  }

  .wo-hiw {
    background: var(--wo-bg);
    padding: var(--wo-pt-d) 20px var(--wo-pb-d);
    color: var(--wo-text-main);
    overflow: hidden;
  }

  .wo-hiw__inner {
    max-width: var(--wo-max-w);
    margin: 0 auto;
  }

  /* ── Header ── */
  .wo-hiw__header {
    text-align: {{ section.settings.header_align }};
    margin-bottom: {{ section.settings.header_margin_bottom }}px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .wo-hiw__header.is-visible { opacity: 1; transform: translateY(0); }

  .wo-hiw__eyebrow {
    display: block;
    font-family: var(--wo-eyebrow-font);
    font-size: var(--wo-eyebrow-size);
    font-weight: var(--wo-eyebrow-weight);
    letter-spacing: var(--wo-eyebrow-ls);
    text-transform: var(--wo-eyebrow-transform);
    color: var(--wo-eyebrow-color);
    margin-bottom: 12px;
  }

  .wo-hiw__title {
    font-family: var(--wo-title-font);
    font-size: {{ section.settings.title_size_desktop }}px;
    font-weight: var(--wo-title-weight);
    line-height: var(--wo-title-lh);
    letter-spacing: var(--wo-title-ls);
    text-transform: var(--wo-title-transform);
    color: var(--wo-text-main);
    margin: 0 0 16px;
  }

  .wo-hiw__subtitle {
    font-family: var(--wo-sub-font);
    font-size: var(--wo-sub-size);
    font-weight: var(--wo-sub-weight);
    letter-spacing: var(--wo-sub-ls);
    text-transform: var(--wo-sub-transform);
    color: var(--wo-text-sub);
    line-height: 1.5;
    margin: 0 auto;
    max-width: 600px;
  }

  /* ── Timeline ── */
  .wo-hiw__timeline { position: relative; }

  .wo-hiw__line {
    display: none;
    position: absolute;
    top: calc(var(--wo-icon-wrap-size) / 2);
    left: calc(100% / ({{ section.blocks.size }} * 2));
    right: calc(100% / ({{ section.blocks.size }} * 2));
    height: var(--wo-line-h);
    z-index: 0;
    background-image: repeating-linear-gradient(
      90deg,
      var(--wo-line-color) 0,
      var(--wo-line-color) var(--wo-line-dash),
      transparent var(--wo-line-dash),
      transparent calc(var(--wo-line-dash) + var(--wo-line-gap))
    );
  }

  .wo-hiw__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: 24px;
    position: relative;
  }

  .wo-hiw__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .wo-hiw__step.is-visible { opacity: 1; transform: translateY(0); }

  .wo-hiw__icon-wrap {
    width: var(--wo-icon-wrap-size);
    height: var(--wo-icon-wrap-size);
    border-radius: var(--wo-icon-radius);
    background: var(--wo-badge-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s ease;
  }

  .wo-hiw__step:hover .wo-hiw__icon-wrap,
  .wo-hiw__step.is-active .wo-hiw__icon-wrap {
    transform: translateY(-8px) scale(1.05);
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
  }

  .wo-hiw__icon-img {
    width: var(--wo-icon-img-size);
    height: var(--wo-icon-img-size);
    object-fit: contain;
    {% if section.settings.icon_invert %}filter: brightness(0) invert(1);{% endif %}
  }

  .wo-hiw__icon-svg {
    width: var(--wo-icon-img-size);
    height: var(--wo-icon-img-size);
    display: block;
  }

  .wo-hiw__label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .wo-hiw__num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--wo-accent);
    color: #fff;
    font-family: var(--wo-num-font);
    font-size: var(--wo-num-size);
    font-weight: var(--wo-num-weight);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .wo-hiw__step-title {
    font-family: var(--wo-stitle-font);
    font-size: var(--wo-stitle-size);
    font-weight: var(--wo-stitle-weight);
    letter-spacing: var(--wo-stitle-ls);
    text-transform: var(--wo-stitle-transform);
    color: var(--wo-text-main);
    margin: 0;
    transition: color 0.3s ease;
  }

  .wo-hiw__step.is-active .wo-hiw__step-title { color: var(--wo-accent); }

  .wo-hiw__step-desc {
    font-family: var(--wo-stext-font);
    font-size: var(--wo-stext-size);
    font-weight: var(--wo-stext-weight);
    color: var(--wo-text-sub);
    line-height: var(--wo-stext-lh);
    margin: 0 auto;
    max-width: 300px;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .wo-hiw__grid { grid-template-columns: repeat(2, 1fr); row-gap: 48px; }
    .wo-hiw__line { display: none !important; }
  }

  @media (max-width: 767px) {
    .wo-hiw { padding: var(--wo-pt-m) 20px var(--wo-pb-m); }
    .wo-hiw__title { font-size: {{ section.settings.title_size_mobile }}px; }
    .wo-hiw__grid { display: flex; flex-direction: column; gap: 0; }
    .wo-hiw__step {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      gap: 20px;
      padding: 24px 0;
      border-bottom: 1px solid rgba(0,0,0,0.06);
      opacity: 1 !important; transform: none !important;
    }
    .wo-hiw__step:last-child { border-bottom: none; }
    .wo-hiw__icon-wrap { width: 72px; height: 72px; margin-bottom: 0; }
    .wo-hiw__icon-img, .wo-hiw__icon-svg { width: 34px; height: 34px; }
    .wo-hiw__body { display: flex; flex-direction: column; padding-top: 4px; }
    .wo-hiw__label { justify-content: flex-start; margin-bottom: 8px; }
    .wo-hiw__step-title { font-size: {{ section.settings.step_title_size_mobile }}px; }
    .wo-hiw__step-desc { font-size: {{ section.settings.step_text_size_mobile }}px; max-width: none; }
  }

  @media (min-width: 1025px) {
    .wo-hiw__line { display: block; }
  }
</style>

<section class="wo-hiw" id="wo-hiw-{{ section_id }}">
  <div class="wo-hiw__inner">

    <div class="wo-hiw__header" id="wo-header-{{ section_id }}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="wo-hiw__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="wo-hiw__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="wo-hiw__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="wo-hiw__timeline">
      <div class="wo-hiw__line" aria-hidden="true"></div>

      <div class="wo-hiw__grid" id="wo-grid-{{ section_id }}">
        {%- for block in section.blocks -%}
          <div class="wo-hiw__step" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <div class="wo-hiw__icon-wrap">
              {%- if block.settings.icon != blank -%}
                <img class="wo-hiw__icon-img" src="{{ block.settings.icon | image_url: width: 120 }}" alt="{{ block.settings.title | escape }}" width="60" height="60" loading="lazy">
              {%- else -%}
                <svg class="wo-hiw__icon-svg" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="20" cy="20" r="13" stroke="white" stroke-width="2"/>
                  <path d="M20 14v12M14 20h12" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
              {%- endif -%}
            </div>

            <div class="wo-hiw__body">
              <div class="wo-hiw__label">
                <span class="wo-hiw__num">{{ forloop.index }}</span>
                {%- if block.settings.title != blank -%}
                  <h3 class="wo-hiw__step-title">{{ block.settings.title }}</h3>
                {%- endif -%}
              </div>
              {%- if block.settings.text != blank -%}
                <p class="wo-hiw__step-desc">{{ block.settings.text }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

<script>
(function () {
  'use strict';
  
  function initSection() {
    const sid = '{{ section_id }}';
    const sec = document.getElementById('wo-hiw-' + sid);
    const header = document.getElementById('wo-header-' + sid);
    const grid = document.getElementById('wo-grid-' + sid);
    if (!sec || !grid) return;

    const items = Array.from(grid.querySelectorAll('.wo-hiw__step'));
    const total = items.length;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          if (e.target.id.includes('wo-header')) {
            e.target.classList.add('is-visible');
          } else {
            const i = parseInt(e.target.getAttribute('data-index'), 10);
            setTimeout(() => e.target.classList.add('is-visible'), i * 150);
            observer.unobserve(e.target);
          }
        }
      });
    }, { threshold: 0.2 });

    if (header) observer.observe(header);
    items.forEach(el => observer.observe(el));

    // Scroll progress active states
    window.addEventListener('scroll', () => {
      const rect = sec.getBoundingClientRect();
      const winH = window.innerHeight;
      if (rect.top > winH || rect.bottom < 0) return;
      
      const progress = Math.min(Math.max(-(rect.top - winH / 2) / rect.height, 0), 1);
      let active = -1;
      for (let i = 0; i < total; i++) {
        if (progress >= (i / total) * 0.8) active = i;
      }
      items.forEach((el, j) => el.classList.toggle('is-active', j === active));
    }, { passive: true });
  }

  document.addEventListener('shopify:section:load', e => { if (e.detail.sectionId === '{{ section_id }}') initSection(); });
  initSection();
})();
</script>

{% schema %}
{
  "name": "PRO Path Timeline",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "━━ Content ━━"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "SIMPLE STEPS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Your journey to an offshore career made simple."
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "━━ Layout ━━"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "━━ Icon Style ━━"
    },
    {
      "type": "range",
      "id": "icon_wrap_size",
      "min": 40,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Icon Wrap Size",
      "default": 92
    },
    {
      "type": "range",
      "id": "icon_img_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Icon Image Size",
      "default": 44
    },
    {
      "type": "range",
      "id": "icon_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "%",
      "label": "Icon Border Radius",
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "icon_invert",
      "label": "Invert Icon Color (White)",
      "default": true
    },
    {
      "type": "header",
      "content": "━━ Connector Line ━━"
    },
    {
      "type": "range",
      "id": "line_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Line Thickness",
      "default": 2
    },
    {
      "type": "range",
      "id": "line_dash_length",
      "min": 2,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Dash Length",
      "default": 10
    },
    {
      "type": "range",
      "id": "line_dash_gap",
      "min": 2,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Dash Gap",
      "default": 12
    },
    {
      "type": "header",
      "content": "━━ Colors ━━"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Icon Circle BG",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / Number BG",
      "default": "#e8a020"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#e8a020"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Connector Line",
      "default": "#e8a020"
    },
    {
      "type": "color",
      "id": "text_color_main",
      "label": "Main Text",
      "default": "#0f0f1a"
    },
    {
      "type": "color",
      "id": "text_color_sub",
      "label": "Description Text",
      "default": "#6b7280"
    },
    {
      "type": "header",
      "content": "━━ Typography Header ━━"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Heading Font",
      "default": "assistant_n8"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading Size Desktop",
      "default": 42
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 18,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Heading Size Mobile",
      "default": 32
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Heading Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-Bold" }
      ],
      "default": "800"
    },
    {
      "type": "range",
      "id": "title_lh",
      "min": 0.8,
      "max": 2.0,
      "step": 0.1,
      "label": "Heading Line Height",
      "default": 1.2
    },
    {
      "type": "range",
      "id": "title_ls",
      "min": -0.05,
      "max": 0.2,
      "step": 0.01,
      "unit": "em",
      "label": "Heading Letter Spacing",
      "default": -0.02
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Heading Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "━━ Typography Subtitle ━━"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Subtitle Size Desktop",
      "default": 15
    },
    {
      "type": "select",
      "id": "subtitle_weight",
      "label": "Subtitle Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-Bold" }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "subtitle_ls",
      "min": 0,
      "max": 0.5,
      "step": 0.05,
      "unit": "em",
      "label": "Subtitle Letter Spacing",
      "default": 0
    },
    {
      "type": "select",
      "id": "subtitle_transform",
      "label": "Subtitle Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "━━ Typography Eyebrow ━━"
    },
    {
      "type": "font_picker",
      "id": "meta_font",
      "label": "Meta Font (Eyebrow/Numbers)",
      "default": "assistant_n7"
    },
    {
      "type": "range",
